<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NABD - نبض</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/patient-style.css" asp-append-version="true" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    @await RenderSectionAsync("Head", required: false)
    @await RenderSectionAsync("Styles", required: false)
</head>
@{
    var layoutPatientId = ViewData["PatientId"] as int? ?? 0;
    var layoutUserName = ViewData["UserName"] as string
        ?? User?.Identity?.Name
        ?? "Patient";
}

<body data-patient-id="@layoutPatientId">
<div class="container">

    @await Html.PartialAsync("_PatientSidebar")

    <!-- Sidebar Toggle Button -->
    <button class="sidebar-toggle"><i class="fas fa-chevron-left"></i></button>

    <!-- Sidebar Overlay (for mobile) -->
    <div class="sidebar-overlay"></div>

    <!-- Main Content -->
    <main class="main-content">
        <header class="pp-topbar">
            <div class="pp-topbar-inner">
                <div class="pp-topbar-actions">
                    <div class="db-date-chip">
                        <i class="fas fa-calendar-alt"></i>
                        <span id="ppTopbarDateLabel"></span>
                    </div>
                    <button class="pp-notif-toggle" id="patientNotificationToggle" type="button" aria-label="Open notifications" title="Notifications">
                        <i class="fas fa-bell"></i>
                        <span class="pp-notif-badge" id="patientNotificationBadge" hidden>0</span>
                    </button>
                    <div class="db-profile-chip" title="@layoutUserName">
                        <div class="db-avatar"><i class="fas fa-user"></i></div>
                        <span id="ppTopbarUserName">@layoutUserName</span>
                    </div>
                </div>
            </div>
        </header>
        <div class="page-content">
            @RenderBody()
        </div>
    </main>

</div>

<div class="pp-notif-overlay" id="patientNotificationOverlay"></div>

<aside class="pp-notif-panel" id="patientNotificationPanel" aria-hidden="true">
    <div class="pp-notif-header">
        <h3><i class="fas fa-bell"></i> Notifications</h3>
        <button class="pp-notif-close" id="patientNotificationClose" type="button" aria-label="Close notifications">
            <i class="fas fa-times"></i>
        </button>
    </div>
    <div class="pp-notif-list" id="patientNotificationList">
        <div class="pp-notif-empty">No alerts found.</div>
    </div>
</aside>

<div style="display:none;">
    @Html.AntiForgeryToken()
</div>

<script src="~/js/shared.js" asp-append-version="true"></script>
<script src="~/js/patient-notifications.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
