    position: relative;
    overflow: hidden;
    transition: transform .2s, box-shadow .2s;
}
.rx-wrap .rx-kpi:hover { transform: translateY(-2px); box-shadow: var(--shadow); }
.rx-wrap .rx-kpi-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
}
.rx-wrap .rx-kpi-ico {
    width: 40px;
    height: 40px;
    border-radius: 10px;
