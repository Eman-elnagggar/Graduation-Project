@model Graduation_Project.ViewModels.PrescriptionsViewModel
@{
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    ViewData["Title"] = "My Prescriptions";
    ViewData["PatientId"]  = Model.Patient.PatientID;
    ViewData["ActivePage"] = "Prescriptions";
}

<div class="rx-wrap">

    <!-- HERO BANNER -->
    <div class="rx-hero">
        <div class="rx-hero-left">
            <span class="rx-hero-eyebrow"><i class="fas fa-prescription-bottle-alt"></i> My Prescriptions</span>
            <h2 class="rx-hero-title">Prescriptions <span>Overview</span></h2>
            <p class="rx-hero-sub">
                <i class="fas fa-circle"></i>
                <span>View all prescriptions issued by your doctors</span>
            </p>
        </div>
        <div class="rx-hero-right">
            <div class="rx-hero-stat">
                <div class="rx-hero-stat-ico"><i class="fas fa-file-prescription"></i></div>
                <div class="rx-hero-stat-body">
                    <span class="rx-hero-stat-val">@Model.TotalCount</span>
                    <span class="rx-hero-stat-lbl">Total Prescriptions</span>
                </div>
            </div>
            <div class="rx-hero-stat">
                <div class="rx-hero-stat-ico"><i class="fas fa-calendar-alt"></i></div>
                <div class="rx-hero-stat-body">
                    <span class="rx-hero-stat-val rx-hero-stat-val-md">
                        @(Model.LatestDate.HasValue ? Model.LatestDate.Value.ToString("MMM dd") : "—")
                    </span>
                    <span class="rx-hero-stat-lbl">Latest Prescription</span>
                </div>
            </div>
        </div>
    </div>

    <!-- KPI GRID -->
    <div class="rx-kpi-grid">

        <!-- Total Prescriptions -->
        <div class="rx-kpi">
            <div class="rx-kpi-top">
                <div class="rx-kpi-ico teal"><i class="fas fa-file-prescription"></i></div>
                <span class="rx-kpi-trend neu"><i class="fas fa-list"></i> All Time</span>
            </div>
            <div class="rx-kpi-mid">
                <div class="rx-kpi-val">@Model.TotalCount</div>
                <div class="rx-kpi-label">Total Prescriptions</div>
            </div>
            <div class="rx-kpi-foot"><i class="fas fa-info-circle"></i> All issued prescriptions</div>
            <div class="rx-kpi-glow teal"></div>
        </div>

        <!-- Latest Date -->
        <div class="rx-kpi">
            <div class="rx-kpi-top">
                <div class="rx-kpi-ico amber"><i class="fas fa-calendar-alt"></i></div>
                <span class="rx-kpi-trend up"><i class="fas fa-clock"></i> Latest</span>
            </div>
            <div class="rx-kpi-mid">
                <div class="rx-kpi-val rx-kpi-val-md">
                    @(Model.LatestDate.HasValue ? Model.LatestDate.Value.ToString("MMM dd") : "—")
                </div>
                <div class="rx-kpi-label">Latest Prescription</div>
            </div>
            <div class="rx-kpi-foot">
                <i class="fas fa-calendar"></i>
                @(Model.LatestDate.HasValue ? Model.LatestDate.Value.ToString("yyyy") : "No prescriptions yet")
            </div>
            <div class="rx-kpi-glow amber"></div>
        </div>

        <!-- Recent (last 30 days) -->
        <div class="rx-kpi">
            <div class="rx-kpi-top">
                <div class="rx-kpi-ico blue"><i class="fas fa-star"></i></div>
                <span class="rx-kpi-trend up"><i class="fas fa-check-circle"></i> Active</span>
            </div>
            <div class="rx-kpi-mid">
                <div class="rx-kpi-val">
                    @(Model.Prescriptions.Count(r => (DateTime.Today - r.PrescriptionDate.Date).TotalDays <= 30))
                </div>
                <div class="rx-kpi-label">Last 30 Days</div>
            </div>
            <div class="rx-kpi-foot"><i class="fas fa-history"></i> Recent prescriptions</div>
            <div class="rx-kpi-glow blue"></div>
        </div>

        <!-- Unique Doctors -->
        <div class="rx-kpi">
            <div class="rx-kpi-top">
                <div class="rx-kpi-ico purple"><i class="fas fa-user-md"></i></div>
                <span class="rx-kpi-trend neu"><i class="fas fa-minus"></i> Doctors</span>
            </div>
            <div class="rx-kpi-mid">
                <div class="rx-kpi-val">
                    @(Model.Prescriptions.Select(r => r.Doctor?.DoctorID).Distinct().Count())
                </div>
                <div class="rx-kpi-label">Unique Doctors</div>
            </div>
            <div class="rx-kpi-foot"><i class="fas fa-stethoscope"></i> Prescribing physicians</div>
            <div class="rx-kpi-glow purple"></div>
        </div>

    </div>

    <!-- FILTER / SEARCH CARD -->
    <div class="rx-card rx-filter-card">
        <div class="rx-filter-body">
            <div class="rx-search-wrap">
                <i class="fas fa-search rx-search-icon"></i>
                <input type="text" id="rxSearch" class="rx-search-input"
                       placeholder="Search by medicine, doctor or date…" />
                <button class="rx-clear-btn" id="clearSearch" style="display:none;">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="rx-filter-controls">
                <div class="rx-filter-tabs">
                    <button class="rx-tab active" data-filter="all">
                        <i class="fas fa-list"></i> All
                        <span class="rx-tab-count">@Model.TotalCount</span>
                    </button>
                    <button class="rx-tab" data-filter="recent">
                        <i class="fas fa-clock"></i> Last 30 Days
                    </button>
                </div>
                <div class="rx-expand-controls">
                    <button class="rx-control-btn" id="expandAll">
                        <i class="fas fa-chevron-down"></i> Expand All
                    </button>
                    <button class="rx-control-btn" id="collapseAll">
                        <i class="fas fa-chevron-up"></i> Collapse All
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- PRESCRIPTIONS LIST -->
    <div class="rx-prescriptions-container">

        @if (!Model.Prescriptions.Any())
        {
            <div class="rx-empty-state">
                <div class="rx-empty-icon"><i class="fas fa-prescription-bottle"></i></div>
                <h3>No prescriptions yet</h3>
                <p>Your doctor-issued prescriptions will appear here.</p>
            </div>
        }
        else
        {
            @foreach (var rx in Model.Prescriptions)
            {
                var doctorName = rx.Doctor?.User != null
                    ? $"Dr. {rx.Doctor.User.FirstName} {rx.Doctor.User.LastName}"
                    : "Unknown Doctor";
                var specialization = rx.Doctor?.Specialization ?? "";
                var itemCount = rx.Items?.Count ?? 0;
                var isRecent = (DateTime.Today - rx.PrescriptionDate.Date).TotalDays <= 30;

                <div class="rx-card rx-prescription-card prescription-card"
                     data-date="@rx.PrescriptionDate.ToString("yyyy-MM-dd")"
                     data-doctor="@doctorName.ToLower()"
                     data-medicines="@string.Join(" ", rx.Items?.Select(i => i.MedicineName?.ToLower() ?? "") ?? Enumerable.Empty<string>())"
                     data-recent="@isRecent.ToString().ToLower()">

                    <!-- Card Header -->
                    <div class="rx-pcard-header" data-target="rx-body-@rx.PrescriptionID">
                        <div class="rx-pcard-main">
                            <div class="rx-pcard-title-row">
                                <h3 class="rx-pcard-title">
                                    <i class="fas fa-file-prescription"></i>
                                    Prescription #@rx.PrescriptionID
                                </h3>
                                @if (isRecent)
                                {
                                    <span class="rx-badge-recent">
                                        <i class="fas fa-star"></i> Recent
                                    </span>
                                }
                            </div>
                            <div class="rx-pcard-meta">
                                <span class="rx-meta-item">
                                    <i class="fas fa-calendar-alt"></i>
                                    @rx.PrescriptionDate.ToString("MMMM dd, yyyy")
                                </span>
                                <span class="rx-meta-divider">•</span>
                                <span class="rx-meta-item">
                                    <i class="fas fa-pills"></i>
                                    @itemCount medication@(itemCount != 1 ? "s" : "")
                                </span>
                            </div>
                        </div>
                        <button class="rx-expand-btn" data-target="rx-body-@rx.PrescriptionID"
                                aria-expanded="false" title="Toggle details">
                            <i class="fas fa-chevron-down"></i>
                        </button>
                    </div>

                    <!-- Doctor Info -->
                    <div class="rx-doctor-info">
                        <div class="rx-doctor-avatar">
                            <i class="fas fa-user-md"></i>
                        </div>
                        <div class="rx-doctor-details">
                            <span class="rx-doctor-name">@doctorName</span>
                            @if (!string.IsNullOrWhiteSpace(specialization))
                            {
                                <span class="rx-doctor-spec">@specialization</span>
                            }
                        </div>
                        <div class="rx-doctor-actions">
                            <a class="rx-print-btn"
                               href="@Url.Action("Print", "Prescription", new { id = Model.Patient.PatientID, prescriptionId = rx.PrescriptionID })"
                               target="_blank"
                               rel="noopener noreferrer">
                                <i class="fas fa-print"></i> Print
                            </a>
                        </div>
                    </div>

                    <!-- Collapsible Body -->
                    <div class="rx-pcard-body" id="rx-body-@rx.PrescriptionID">

                        @if (!string.IsNullOrWhiteSpace(rx.Notes))
                        {
                            <div class="rx-notes-section">
                                <div class="rx-section-label">
                                    <i class="fas fa-sticky-note"></i> Doctor's Notes
                                </div>
                                <p class="rx-notes-text">@rx.Notes</p>
                            </div>
                        }

                        @if (rx.Items != null && rx.Items.Any())
                        {
                            <div class="rx-meds-section">
                                <div class="rx-section-label">
                                    <i class="fas fa-pills"></i> Medications (@itemCount)
                                </div>
                                <div class="rx-meds-list">
                                    @foreach (var item in rx.Items)
                                    {
                                        <div class="rx-med-row">
                                            <div class="rx-med-icon">
                                                <i class="fas fa-capsules"></i>
                                            </div>
                                            <div class="rx-med-content">
                                                <div class="rx-med-name">@item.MedicineName</div>
                                                <div class="rx-med-details">
                                                    @if (!string.IsNullOrWhiteSpace(item.Dosage))
                                                    {
                                                        <span class="rx-detail-item">
                                                            <i class="fas fa-weight"></i> @item.Dosage
                                                        </span>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(item.Frequency))
                                                    {
                                                        <span class="rx-detail-item">
                                                            <i class="fas fa-redo"></i> @item.Frequency
                                                        </span>
                                                    }
                                                    @if (item.DurationDays > 0)
                                                    {
                                                        <span class="rx-detail-item">
                                                            <i class="fas fa-hourglass-half"></i> @item.DurationDays day@(item.DurationDays != 1 ? "s" : "")
                                                        </span>
                                                    }
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(item.Instructions))
                                                {
                                                    <div class="rx-med-instructions">
                                                        <i class="fas fa-info-circle"></i>
                                                        <span>@item.Instructions</span>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <p class="rx-no-items">
                                <i class="fas fa-info-circle"></i> No medication items recorded for this prescription.
                            </p>
                        }

                    </div><!-- /rx-pcard-body -->
                </div><!-- /rx-prescription-card -->
            }
        }
    </div>

</div><!-- /rx-wrap -->

@section Scripts {
<script>
document.addEventListener("DOMContentLoaded", function () {

    // Expand / Collapse cards
    function toggleCard(btn) {
        const targetId = btn.dataset.target;
        const body = document.getElementById(targetId);
        if (!body) return;
        
        const expanded = btn.getAttribute("aria-expanded") === "true";
        
        if (expanded) {
            body.style.maxHeight = body.scrollHeight + "px";
            requestAnimationFrame(() => { body.style.maxHeight = "0"; });
            btn.setAttribute("aria-expanded", "false");
            btn.querySelector("i").style.transform = "rotate(0deg)";
        } else {
            body.style.maxHeight = body.scrollHeight + "px";
            btn.setAttribute("aria-expanded", "true");
            btn.querySelector("i").style.transform = "rotate(180deg)";
        }
    }

    document.querySelectorAll(".rx-expand-btn").forEach(btn => {
        btn.addEventListener("click", function(e) {
            e.stopPropagation();
            toggleCard(this);
        });
    });

    // Click header to expand/collapse
    document.querySelectorAll(".rx-pcard-header").forEach(header => {
        header.addEventListener("click", function() {
            const btn = this.querySelector(".rx-expand-btn");
            if (btn) toggleCard(btn);
        });
    });

    // Expand All / Collapse All
    document.getElementById("expandAll")?.addEventListener("click", function() {
        document.querySelectorAll(".rx-expand-btn").forEach(btn => {
            if (btn.getAttribute("aria-expanded") !== "true") {
                toggleCard(btn);
            }
        });
    });

    document.getElementById("collapseAll")?.addEventListener("click", function() {
        document.querySelectorAll(".rx-expand-btn").forEach(btn => {
            if (btn.getAttribute("aria-expanded") === "true") {
                toggleCard(btn);
            }
        });
    });

    // Filter tabs
    document.querySelectorAll(".rx-tab").forEach(tab => {
        tab.addEventListener("click", function () {
            document.querySelectorAll(".rx-tab").forEach(t => t.classList.remove("active"));
            this.classList.add("active");
            applyFilters();
        });
    });

    // Search
    const searchInput = document.getElementById("rxSearch");
    const clearBtn = document.getElementById("clearSearch");

    searchInput.addEventListener("input", function() {
        clearBtn.style.display = this.value ? "flex" : "none";
        applyFilters();
    });

    clearBtn?.addEventListener("click", function() {
        searchInput.value = "";
        this.style.display = "none";
        applyFilters();
    });

    function applyFilters() {
        const query = searchInput.value.toLowerCase().trim();
        const filter = document.querySelector(".rx-tab.active")?.dataset.filter ?? "all";

        document.querySelectorAll(".prescription-card").forEach(card => {
            const doctor = card.dataset.doctor ?? "";
            const medicines = card.dataset.medicines ?? "";
            const date = card.dataset.date ?? "";
            const isRecent = card.dataset.recent === "true";

            const matchesSearch = !query ||
                doctor.includes(query) ||
                medicines.includes(query) ||
                date.includes(query);

            const matchesFilter = filter === "all" ||
                (filter === "recent" && isRecent);

            card.style.display = (matchesSearch && matchesFilter) ? "block" : "none";
        });
    }
});
</script>

<style>
/* ???????????????????????????????????????????????????????????????
   PRESCRIPTIONS PAGE — Clean, Modern, Professional Design
??????????????????????????????????????????????????????????????? */

.rx-wrap {
    --p:       #1BAEBE;
    --p-dk:    #138fa0;
    --p-mid:   #22c9db;
    --p-lt:    #e0f7fa;
    --p-xlt:   #f0fdfe;

    --pink:    #e91e63;
    --pink-lt: #fce4ec;
    --purple:  #9c27b0;
    --purp-lt: #f3e5f5;
    --green:   #4caf50;
    --grn-lt:  #e8f5e9;
    --amber:   #ff9800;
    --amb-lt:  #fff8e1;
    --blue:    #2196f3;
    --blue-lt: #e3f2fd;

    --navy:      #0b1f35;
    --navy-mid:  #152d47;
    --text:      #1e293b;
    --text-2:    #4a5568;
    --text-3:    #8896ab;
    --border:    #e4eaf2;
    --border-2:  #cdd6e3;
    --bg:        #f3f6fb;
    --white:     #fff;
    --danger:    #ef4444;
    --warning:   #f59e0b;
    --success:   #22c55e;
    --info:      #3b82f6;

    --r:         10px;
    --r-lg:      16px;
    --r-xl:      22px;
    --shadow-sm: 0 1px 4px rgba(15,28,46,.06);
    --shadow:    0 4px 16px rgba(15,28,46,.08);
    --shadow-md: 0 8px 28px rgba(15,28,46,.11);

    display: flex;
    flex-direction: column;
    gap: 20px;
}

/* ?? HERO ?? */
.rx-wrap .rx-hero {
    background: linear-gradient(130deg, var(--navy) 0%, var(--navy-mid) 50%, #0d3d5c 100%);
    border-radius: var(--r-xl);
    padding: 28px 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
}
.rx-wrap .rx-hero-left {
    display: flex;
    flex-direction: column;
    gap: 8px;
}
.rx-wrap .rx-hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: .68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--p-mid);
    background: rgba(27,174,190,.18);
    padding: 4px 10px;
    border-radius: 20px;
    border: 1px solid rgba(27,174,190,.25);
    width: fit-content;
}
.rx-wrap .rx-hero-title {
    font-size: 1.85rem;
    font-weight: 700;
    color: #f1f5f9;
    line-height: 1.25;
    margin: 0;
}
.rx-wrap .rx-hero-title span { color: var(--p-mid); }
.rx-wrap .rx-hero-sub {
    font-size: .95rem;
    color: #94a3b8;
    display: flex;
    align-items: center;
    gap: 7px;
    margin: 0;
}
.rx-wrap .rx-hero-sub i { font-size: .45rem; color: var(--p-mid); }
.rx-wrap .rx-hero-right {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
}
.rx-wrap .rx-hero-stat {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255,255,255,.07);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: var(--r-lg);
    padding: 12px 18px;
    min-width: 140px;
}
.rx-wrap .rx-hero-stat-ico {
    width: 38px;
    height: 38px;
    border-radius: 9px;
    background: rgba(27,174,190,.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--p-mid);
    flex-shrink: 0;
}
.rx-wrap .rx-hero-stat-body {
    display: flex;
    flex-direction: column;
}
.rx-wrap .rx-hero-stat-val {
    font-size: 1.6rem;
    font-weight: 800;
    color: #fff;
    line-height: 1;
}
.rx-wrap .rx-hero-stat-val-md { font-size: 1.15rem; }
.rx-wrap .rx-hero-stat-lbl {
    font-size: .72rem;
    color: #94a3b8;
