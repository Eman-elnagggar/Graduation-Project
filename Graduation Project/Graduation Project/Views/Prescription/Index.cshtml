}
.rx-wrap .rx-kpi-ico.teal   { background: var(--p-lt);    color: var(--p); }
.rx-wrap .rx-kpi-ico.amber  { background: var(--amb-lt);  color: var(--amber); }
.rx-wrap .rx-kpi-ico.blue   { background: var(--blue-lt); color: var(--blue); }
