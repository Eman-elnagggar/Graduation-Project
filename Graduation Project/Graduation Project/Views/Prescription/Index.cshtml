}

.rx-wrap .rx-print-btn:hover {
    border-color: var(--p);
    color: var(--p-dk);
    background: var(--p-xlt);
}

/* ?? CARD BASE ?? */
.rx-wrap .rx-card {
    background: var(--white);
    border-radius: var(--r-lg);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
}

/* ?? FILTER CARD ?? */
.rx-wrap .rx-filter-card {
    padding: 16px 20px;
}
.rx-wrap .rx-filter-body {
    display: flex;
    flex-direction: column;
    gap: 14px;
}
.rx-wrap .rx-search-wrap {
    position: relative;
    width: 100%;
}
.rx-wrap .rx-search-icon {
    position: absolute;
    left: .9rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-3);
    font-size: .85rem;
    pointer-events: none;
}
.rx-wrap .rx-search-input {
    width: 100%;
    padding: 10px 42px 10px 2.6rem;
    border: 1.5px solid var(--border);
    border-radius: var(--r);
    font-size: .88rem;
    color: var(--text);
    background: var(--bg);
    outline: none;
    transition: border-color .2s, box-shadow .2s;
