}
.rx-wrap .rx-kpi-glow {
    position: absolute;
    bottom: -20px;
    right: -20px;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    opacity: .06;
    pointer-events: none;
}
.rx-wrap .rx-kpi-glow.teal   { background: var(--p); }
.rx-wrap .rx-kpi-glow.amber  { background: var(--amber); }
.rx-wrap .rx-kpi-glow.blue   { background: var(--blue); }
.rx-wrap .rx-kpi-glow.purple { background: var(--purple); }

.rx-wrap .rx-doctor-actions {
    margin-left: auto;
}

.rx-wrap .rx-print-btn {
    display: inline-flex;
    align-items: center;
