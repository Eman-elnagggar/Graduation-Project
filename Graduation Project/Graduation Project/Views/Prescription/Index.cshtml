.rx-wrap .rx-kpi-trend.up  { background: #f0fdf4; color: #15803d; }
.rx-wrap .rx-kpi-trend.neu { background: #f8fafc; color: #64748b; }
.rx-wrap .rx-kpi-mid { display: flex; flex-direction: column; gap: 4px; }
.rx-wrap .rx-kpi-val {
    font-size: 2rem;
    font-weight: 800;
    color: var(--text);
