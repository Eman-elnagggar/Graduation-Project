@model Graduation_Project.ViewModels.PatientProfileViewModel
@{
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    ViewData["Title"] = "My Profile";
    ViewData["PatientId"]  = Model.Patient.PatientID;
    ViewData["ActivePage"] = "Profile";
}

@section Head {
    <meta name="patient-id" content="@Model.Patient.PatientID" />
    @Html.AntiForgeryToken()
}

<!-- ══════════════════ HERO HEADER ══════════════════ -->
<header class="pf-hero">
    <div class="pf-hero-left">
        <div class="pf-hero-avatar">
          <i class="fas fa-user-circle"></i>
        </div>
        <div class="pf-hero-info">
      <h1 class="pf-hero-name">@Model.FullName</h1>
      <p class="pf-hero-sub"><i class="fas fa-envelope"></i> @Model.Email</p>
    <div class="pf-hero-badges">
        <span class="pf-hbadge pf-hbadge-week"><i class="fas fa-baby"></i> Week @Model.PregnancyWeek</span>
                <span class="pf-hbadge pf-hbadge-trim"><i class="fas fa-calendar"></i> @Model.Trimester</span>
     @if (Model.DueDate != "N/A")
     {
        <span class="pf-hbadge pf-hbadge-due"><i class="fas fa-clock"></i> Due @Model.DueDate</span>
     }
   </div>
      </div>
    </div>
</header>

@if (TempData["PregnancyStatusMessage"] is string pregnancyStatusMessage && !string.IsNullOrWhiteSpace(pregnancyStatusMessage))
{
    <div class="alert alert-info" style="margin-bottom:1rem; border-radius:10px;">
        @pregnancyStatusMessage
    </div>
}

<!-- ══════════════════ STATS BAR ══════════════════ -->
<div class="pf-stats-bar">
    <div class="pf-stat">
  <div class="pf-stat-icon pf-stat-week"><i class="fas fa-baby-carriage"></i></div>
        <div class="pf-stat-body">
            <span class="pf-stat-num">@Model.PregnancyWeek</span>
            <span class="pf-stat-lbl">Week</span>
      </div>
    </div>
    <div class="pf-stat">
        <div class="pf-stat-icon pf-stat-days"><i class="fas fa-clock"></i></div>
    <div class="pf-stat-body">
          <span class="pf-stat-num">@Model.DaysRemaining</span>
            <span class="pf-stat-lbl">Days Left</span>
     </div>
    </div>
    <div class="pf-stat">
        <div class="pf-stat-icon pf-stat-bmi"><i class="fas fa-weight"></i></div>
        <div class="pf-stat-body">
            <span class="pf-stat-num">@(Model.Bmi > 0 ? Model.Bmi.ToString("F1") : "—")</span>
            <span class="pf-stat-lbl">BMI</span>
        </div>
    </div>
    <div class="pf-stat">
        <div class="pf-stat-icon pf-stat-age"><i class="fas fa-birthday-cake"></i></div>
        <div class="pf-stat-body">
            <span class="pf-stat-num">@Model.Age</span>
            <span class="pf-stat-lbl">Age</span>
        </div>
    </div>
    <div class="pf-stat">
        <div class="pf-stat-icon pf-stat-meds"><i class="fas fa-pills"></i></div>
        <div class="pf-stat-body">
            <span class="pf-stat-num">@(Model.Medications?.Count ?? 0)</span>
      <span class="pf-stat-lbl">Medications</span>
        </div>
    </div>
</div>

<!-- ══════════════════ TABS ══════════════════ -->
<div class="pf-tabs-wrap">
    <button class="pf-tab active" data-tab="personal"><i class="fas fa-user"></i> Personal</button>
    <button class="pf-tab" data-tab="pregnancy"><i class="fas fa-baby-carriage"></i> Pregnancy</button>
    <button class="pf-tab" data-tab="medical"><i class="fas fa-notes-medical"></i> Medical</button>
    <button class="pf-tab" data-tab="lifestyle"><i class="fas fa-heart"></i> Lifestyle</button>
    <button class="pf-tab" data-tab="security"><i class="fas fa-lock"></i> Security</button>
</div>

<!-- ══════════════════ TAB: PERSONAL ══════════════════ -->
<div class="pf-tab-content active" id="personal-tab">

    <!-- Personal Information -->
    <div class="pf-card">
        <div class="pf-card-header">
          <div class="pf-card-title">
           <div class="pf-card-icon pf-icon-teal"><i class="fas fa-user"></i></div>
         <div>
   <h3>Personal Information</h3>
<p>Your basic contact and identity details</p>
       </div>
            </div>
   <button class="pf-edit-btn" id="editPersonalBtn"><i class="fas fa-pen"></i> Edit</button>
        </div>
        <form class="pf-form" id="personalForm">
            <div class="pf-form-row">
                <div class="pf-form-group">
       <label>First Name</label>
            <input type="text" id="firstName" class="pf-input" value="@Model.User?.FirstName" disabled />
           </div>
     <div class="pf-form-group">
<label>Last Name</label>
         <input type="text" id="lastName" class="pf-input" value="@Model.User?.LastName" disabled />
    </div>
       </div>
            <div class="pf-form-row">
        <div class="pf-form-group">
       <label>Email Address</label>
     <input type="email" id="email" class="pf-input" value="@Model.Email" disabled readonly />
        </div>
     <div class="pf-form-group">
    <label>Phone Number</label>
        <input type="tel" id="phone" class="pf-input" value="@Model.Phone" disabled />
    </div>
            </div>
      <div class="pf-form-row">
          <div class="pf-form-group">
        <label>Date of Birth</label>
   <input type="date" id="dateOfBirth" class="pf-input" value="@(Model.User?.DateOfBirth.ToString("yyyy-MM-dd"))" disabled />
     </div>
          <div class="pf-form-group">
 <label>Age (calculated)</label>
                 <input type="text" id="ageDisplay" class="pf-input" value="@Model.Age years" disabled readonly />
       </div>
   </div>
            <div class="pf-form-row">
       <div class="pf-form-group pf-col-full">
    <label>Address</label>
<input type="text" id="address" class="pf-input" value="@Model.Patient.Address" disabled />
             </div>
            </div>
         <div class="pf-form-actions" id="personalActions" style="display:none">
 <button type="button" class="pf-btn-ghost" id="cancelPersonal"><i class="fas fa-times"></i> Cancel</button>
  <button type="submit" class="pf-btn-primary"><i class="fas fa-save"></i> Save Changes</button>
        </div>
        </form>
    </div>

    <!-- Body Measurements -->
    <div class="pf-card">
 <div class="pf-card-header">
          <div class="pf-card-title">
    <div class="pf-card-icon pf-icon-purple"><i class="fas fa-ruler-combined"></i></div>
          <div>
 <h3>Body Measurements</h3>
          <p>Weight, height and BMI tracking</p>
         </div>
            </div>
       <button class="pf-edit-btn" id="editMeasurementsBtn"><i class="fas fa-pen"></i> Edit</button>
        </div>
        <form class="pf-form" id="measurementsForm">
            <div class="pf-form-row pf-three-col">
            <div class="pf-form-group">
      <label>Weight</label>
            <div class="pf-input-unit">
      <input type="number" id="weightKg" class="pf-input" step="0.1" value="@Model.Patient.WeightKg" disabled />
               <span class="pf-unit-badge">kg</span>
  </div>
    </div>
   <div class="pf-form-group">
     <label>Height</label>
 <div class="pf-input-unit">
              <input type="number" id="heightCm" class="pf-input" value="@Model.Patient.HeightCm" disabled />
   <span class="pf-unit-badge">cm</span>
              </div>
      </div>
        <div class="pf-form-group">
       <label>BMI (calculated)</label>
         <div class="pf-input-unit">
      <input type="text" id="bmiDisplay" class="pf-input" value="@Model.Bmi" disabled readonly />
      <span class="pf-unit-badge pf-bmi-badge @Model.BmiStatus.ToLower()" id="bmiStatus">@Model.BmiStatus</span>
     </div>
         </div>
  </div>
            <div class="pf-form-actions" id="measurementsActions" style="display:none">
      <button type="button" class="pf-btn-ghost" id="cancelMeasurements"><i class="fas fa-times"></i> Cancel</button>
       <button type="submit" class="pf-btn-primary"><i class="fas fa-save"></i> Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- ══════════════════ TAB: PREGNANCY ══════════════════ -->
<div class="pf-tab-content" id="pregnancy-tab">

    <!-- Pregnancy progress visual -->
    <div class="pf-card pf-preg-progress-card">
 <div class="pf-preg-bar-wrap">
            <div class="pf-preg-labels">
                <span>1st Trimester</span><span>2nd Trimester</span><span>3rd Trimester</span>
            </div>
            <div class="pf-preg-track">
  <div class="pf-preg-fill" style="width:@Model.PregnancyProgressPercent%"></div>
        <div class="pf-preg-thumb" style="left:calc(@Model.PregnancyProgressPercent% - 10px)">
      <i class="fas fa-baby"></i>
      </div>
        </div>
       <div class="pf-preg-info-row">
     <span class="pf-preg-pill"><i class="fas fa-baby-carriage"></i> Week @Model.PregnancyWeek + @Model.PregnancyDays days</span>
   <span class="pf-preg-pill pf-preg-pill-trim">@Model.Trimester</span>
  @if (Model.DaysRemaining > 0)
     {
           <span class="pf-preg-pill pf-preg-pill-due"><i class="fas fa-clock"></i> @Model.DaysRemaining days remaining</span>
    }
     </div>
        </div>
    </div>

    <!-- Current Pregnancy -->
    <div class="pf-card">
  <div class="pf-card-header">
  <div class="pf-card-title">
   <div class="pf-card-icon pf-icon-pink"><i class="fas fa-baby-carriage"></i></div>
      <div>
<h3>Current Pregnancy</h3>
    <p>Gestational age and estimated due date</p>
     </div>
            </div>
            <div style="display:flex; gap:.5rem; align-items:center;">
                @if (Model.HasActivePregnancy)
                {
                    <form asp-action="EndCurrentPregnancy" asp-controller="Patient" method="post" onsubmit="return confirm('Are you sure you want to end the current pregnancy? This will reset active pregnancy progress.');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Patient.PatientID" />
                        <input type="hidden" name="returnUrl" value="@($"/PatientProfile/Index/{Model.Patient.PatientID}")" />
                        <button type="submit" class="pf-btn-danger-outline" style="padding:.55rem .9rem;">
                            <i class="fas fa-stop-circle"></i> End Pregnancy
                        </button>
                    </form>
                }
                else
                {
                    <button type="button" class="pf-btn-primary" id="startPregnancyBtn" style="padding:.55rem .9rem;">
                        <i class="fas fa-play-circle"></i> Start New Pregnancy
                    </button>
                }
                <button class="pf-edit-btn" id="editPregnancyBtn"><i class="fas fa-pen"></i> Edit</button>
            </div>
        </div>
        @if (!Model.HasActivePregnancy)
        {
            <div class="pf-tip pf-tip-info" style="margin-bottom:1rem;">
                <div class="pf-tip-icon"><i class="fas fa-info-circle"></i></div>
                <div>
                    <h4>No active pregnancy</h4>
                    <p>Set a pregnancy date and save to start tracking a new pregnancy journey.</p>
                </div>
            </div>
        }
        <form class="pf-form" id="pregnancyForm">
            <div class="pf-form-row">
                <div class="pf-form-group">
   <label>Date of Last Menstrual Period</label>
        <input type="date" id="pregnancyDate" class="pf-input"
       value="@(Model.ActivePregnancyStartDate?.ToString("yyyy-MM-dd"))" disabled />
        <span class="pf-hint"><i class="fas fa-info-circle"></i> Used to calculate gestational age</span>
    </div>
              <div class="pf-form-group">
<label>Gestational Age (calculated)</label>
     <div class="pf-calc-display">
        <span class="pf-calc-main" id="gestWeeks">@Model.PregnancyWeek weeks</span>
      <span class="pf-calc-sub">+ @Model.PregnancyDays days · @Model.Trimester</span>
       </div>
       </div>
            </div>
    <div class="pf-form-row">
<div class="pf-form-group">
          <label>Estimated Due Date</label>
     <div class="pf-calc-display">
               <span class="pf-calc-main">@Model.DueDate</span>
       @if (Model.DaysRemaining > 0)
    {
         <span class="pf-calc-sub">@Model.DaysRemaining days remaining</span>
                }
          </div>
     </div>
   </div>

    <div class="pf-form-row">
        <div class="pf-form-group">
            <label>Baby Gender</label>
            <select id="babyGender" class="pf-input" disabled>
                @if (string.IsNullOrWhiteSpace(Model.BabyGender))
                {
                    <option value="" selected>Unknown / Not sure yet</option>
                }
                else
                {
                    <option value="">Unknown / Not sure yet</option>
                }

                @if (Model.BabyGender == "Male")
                {
                    <option value="Male" selected>Male</option>
                }
                else
                {
                    <option value="Male">Male</option>
                }

                @if (Model.BabyGender == "Female")
                {
                    <option value="Female" selected>Female</option>
                }
                else
                {
                    <option value="Female">Female</option>
                }
            </select>
        </div>
    </div>

        <!-- Pregnancy History (merged into same form/save) -->
    <div class="pf-section-divider"><span>Pregnancy History</span></div>

            <div class="pf-form-group" style="margin-bottom:.85rem">
      <label>Is this your first pregnancy?</label>
     <div class="pf-radio-row">
              <label class="pf-radio-opt">
         <input type="radio" name="firstPregnancy" value="yes" disabled
      @(Model.Patient.IsFirstPregnancy ? "checked" : "") />
        <span class="pf-radio-box"><i class="fas fa-check"></i></span>
    <span>Yes</span>
              </label>
      <label class="pf-radio-opt">
     <input type="radio" name="firstPregnancy" value="no" disabled
    @(!Model.Patient.IsFirstPregnancy ? "checked" : "") />
         <span class="pf-radio-box"><i class="fas fa-check"></i></span>
      <span>No</span>
   </label>
     </div>
 </div>

   <div id="previousPregnancySection" class="pf-conditional"
      style="@(Model.Patient.IsFirstPregnancy ? "display:none" : "")">
     <div class="pf-form-row pf-three-col">
          <div class="pf-form-group">
       <label>Previous Pregnancies</label>
               <input type="number" id="previousPregnancies" class="pf-input" min="0"
                     value="@Model.Patient.PreviousPregnancies" disabled />
           </div>
     <div class="pf-form-group">
    <label>Abortions / Miscarriages</label>
    <input type="number" id="abortions" class="pf-input" min="0"
   value="@Model.Patient.Abortions" disabled />
         </div>
     <div class="pf-form-group">
         <label>Live Births</label>
     <input type="number" id="births" class="pf-input" min="0"
  value="@Model.Patient.Births" disabled />
              </div>
        </div>
            </div>

       <div class="pf-form-actions" id="pregnancyActions" style="display:none">
            <button type="button" class="pf-btn-ghost" id="cancelPregnancy"><i class="fas fa-times"></i> Cancel</button>
    <button type="submit" class="pf-btn-primary"><i class="fas fa-save"></i> Save Changes</button>
 </div>
     </form>
    </div>
</div>

<!-- ══════════════════ TAB: MEDICAL ══════════════════ -->
<div class="pf-tab-content" id="medical-tab">

    <!-- Blood Pressure -->
    <div class="pf-card">
        <div class="pf-card-header">
            <div class="pf-card-title">
  <div class="pf-card-icon pf-icon-red"><i class="fas fa-heartbeat"></i></div>
       <div>
    <h3>Blood Pressure Status</h3>
           <p>Monitor your cardiovascular health</p>
            </div>
            </div>
            <button class="pf-edit-btn" id="editBPBtn"><i class="fas fa-pen"></i> Edit</button>
     </div>
        <form class="pf-form" id="bpForm">
            <div class="pf-form-group">
 <label>Do you have blood pressure issues?</label>
                <div class="pf-radio-row">
      <label class="pf-radio-opt">
 <input type="radio" name="bloodPressure" value="yes" disabled
     @(Model.Patient.BloodPressureIssue ? "checked" : "") />
         <span class="pf-radio-box"><i class="fas fa-check"></i></span>
           <span>Yes</span>
      </label>
        <label class="pf-radio-opt">
    <input type="radio" name="bloodPressure" value="no" disabled
      @(!Model.Patient.BloodPressureIssue ? "checked" : "") />
     <span class="pf-radio-box"><i class="fas fa-check"></i></span>
             <span>No</span>
     </label>
 </div>
      </div>
            <div class="pf-bp-status-chip @(Model.Patient.BloodPressureIssue ? "pf-chip-risk" : "pf-chip-ok")" id="bpStatusChip">
       <i class="fas @(Model.Patient.BloodPressureIssue ? "fa-exclamation-circle" : "fa-check-circle")"></i>
                <span>@(Model.Patient.BloodPressureIssue ? "Risk — blood pressure issues reported" : "Normal — no blood pressure issues")</span>
  </div>
   <div class="pf-form-actions" id="bpActions" style="display:none">
     <button type="button" class="pf-btn-ghost" id="cancelBP"><i class="fas fa-times"></i> Cancel</button>
      <button type="submit" class="pf-btn-primary"><i class="fas fa-save"></i> Save Changes</button>
            </div>
        </form>
    </div>

    <!-- Medications -->
    <div class="pf-card">
     <div class="pf-card-header">
     <div class="pf-card-title">
 <div class="pf-card-icon pf-icon-teal"><i class="fas fa-pills"></i></div>
    <div>
      <h3>Chronic &amp; Mental Health Medications</h3>
        <p>Track your ongoing prescriptions</p>
     </div>
            </div>
      <button class="pf-edit-btn" id="editMedsBtn"><i class="fas fa-pen"></i> Edit</button>
        </div>

        <div class="pf-med-list" id="medicationList">
          @if (Model.Medications != null && Model.Medications.Any())
   {
     @foreach (var med in Model.Medications)
          {
          <div class="pf-med-row" data-drug-id="@med.DrugID">
     <div class="pf-med-pill-icon"><i class="fas fa-capsules"></i></div>
                 <div class="pf-med-details">
     <span class="pf-med-name">@med.DrugName</span>
              <div class="pf-med-chips">
         <span class="pf-med-chip pf-chip-reason"><i class="fas fa-tag"></i> @med.Reason</span>
        <span class="pf-med-chip pf-chip-dose"><i class="fas fa-syringe"></i> @med.DoseMgPerDay mg/day</span>
        <span class="pf-med-chip pf-chip-dur"><i class="fas fa-calendar-alt"></i> @med.DurationMonths months</span>
                   </div>
              </div>
             <button type="button" class="pf-med-remove" data-drug-id="@med.DrugID"
   title="Remove medication" style="display:none">
          <i class="fas fa-trash-alt"></i>
            </button>
          </div>
            }
            }
            else
    {
      <div class="pf-med-empty" id="noMedsMsg">
 <div class="pf-med-empty-icon"><i class="fas fa-pills"></i></div>
              <p>No medications recorded yet.</p>
     </div>
          }
        </div>

        <button type="button" class="pf-add-med-btn" id="showAddMedBtn" style="display:none">
         <i class="fas fa-plus"></i> Add Medication
        </button>
    </div>
</div>

<!-- ══════════════════ TAB: LIFESTYLE ══════════════════ -->
<div class="pf-tab-content" id="lifestyle-tab">
    <div class="pf-card">
        <div class="pf-card-header">
    <div class="pf-card-title">
    <div class="pf-card-icon pf-icon-orange"><i class="fas fa-leaf"></i></div>
                <div>
       <h3>Lifestyle &amp; Habits</h3>
 <p>Track habits that affect your pregnancy</p>
                </div>
</div>
    <button class="pf-edit-btn" id="editLifestyleBtn"><i class="fas fa-pen"></i> Edit</button>
        </div>
        <form class="pf-form" id="lifestyleForm">
            <!-- Smoking -->
          <div class="pf-lifestyle-row">
  <div class="pf-ls-icon pf-ls-smoke"><i class="fas fa-smoking"></i></div>
           <div class="pf-ls-body">
        <h4>Smoking</h4>
      <p>Do you smoke cigarettes or use tobacco products?</p>
          <div class="pf-radio-row">
          <label class="pf-radio-opt">
      <input type="radio" name="smoking" value="yes" disabled
                   @(Model.Patient.Smoking ? "checked" : "") />
              <span class="pf-radio-box"><i class="fas fa-check"></i></span>
        <span>Yes</span>
             </label>
          <label class="pf-radio-opt">
         <input type="radio" name="smoking" value="no" disabled
  @(!Model.Patient.Smoking ? "checked" : "") />
       <span class="pf-radio-box"><i class="fas fa-check"></i></span>
            <span>No</span>
         </label>
    </div>
                </div>
     <div class="pf-ls-status @(Model.Patient.Smoking ? "pf-ls-risk" : "pf-ls-safe")" id="smokingStatus">
     <i class="fas @(Model.Patient.Smoking ? "fa-times-circle" : "fa-check-circle")"></i>
          <span>@(Model.Patient.Smoking ? "Risk" : "Safe")</span>
      </div>
          </div>

            <!-- Alcohol -->
       <div class="pf-lifestyle-row">
        <div class="pf-ls-icon pf-ls-alcohol"><i class="fas fa-wine-glass-alt"></i></div>
    <div class="pf-ls-body">
  <h4>Alcohol Consumption</h4>
          <p>Do you consume alcoholic beverages?</p>
        <div class="pf-radio-row">
      <label class="pf-radio-opt">
         <input type="radio" name="alcohol" value="yes" disabled
       @(Model.Patient.AlcoholUse ? "checked" : "") />
     <span class="pf-radio-box"><i class="fas fa-check"></i></span>
            <span>Yes</span>
      </label>
            <label class="pf-radio-opt">
                   <input type="radio" name="alcohol" value="no" disabled
  @(!Model.Patient.AlcoholUse ? "checked" : "") />
<span class="pf-radio-box"><i class="fas fa-check"></i></span>
     <span>No</span>
  </label>
           </div>
      </div>
       <div class="pf-ls-status @(Model.Patient.AlcoholUse ? "pf-ls-risk" : "pf-ls-safe")" id="alcoholStatus">
             <i class="fas @(Model.Patient.AlcoholUse ? "fa-times-circle" : "fa-check-circle")"></i>
          <span>@(Model.Patient.AlcoholUse ? "Risk" : "Safe")</span>
              </div>
    </div>

 <div class="pf-form-actions" id="lifestyleActions" style="display:none">
           <button type="button" class="pf-btn-ghost" id="cancelLifestyle"><i class="fas fa-times"></i> Cancel</button>
         <button type="submit" class="pf-btn-primary"><i class="fas fa-save"></i> Save Changes</button>
            </div>
        </form>
    </div>

    <!-- Health Tips -->
    <div class="pf-card">
        <div class="pf-card-header">
            <div class="pf-card-title">
        <div class="pf-card-icon pf-icon-green"><i class="fas fa-lightbulb"></i></div>
     <div>
           <h3>Personalized Health Tips</h3>
        <p>Recommendations based on your profile</p>
         </div>
   </div>
        </div>
        <div class="pf-tips">
            @if (!Model.Patient.Smoking && !Model.Patient.AlcoholUse)
  {
      <div class="pf-tip pf-tip-success">
       <div class="pf-tip-icon"><i class="fas fa-check-circle"></i></div>
    <div>
           <h4>Great lifestyle choices!</h4>
    <p>You're smoke-free and alcohol-free — excellent for your baby's development.</p>
          </div>
             </div>
            }
            <div class="pf-tip pf-tip-info">
           <div class="pf-tip-icon"><i class="fas fa-apple-alt"></i></div>
   <div>
           <h4>Nutrition Reminder</h4>
         <p>Take your prenatal vitamins daily and maintain a balanced diet rich in iron and folic acid.</p>
  </div>
   </div>
   <div class="pf-tip pf-tip-info">
         <div class="pf-tip-icon"><i class="fas fa-walking"></i></div>
           <div>
           <h4>Stay Active</h4>
        <p>Light exercise like walking or prenatal yoga for 30 minutes daily helps maintain a healthy pregnancy.</p>
    </div>
   </div>
        </div>
    </div>
</div>

<!-- ══════════════════ TAB: SECURITY ══════════════════ -->
<div class="pf-tab-content" id="security-tab">
    <!-- Change Password -->
    <div class="pf-card">
        <div class="pf-card-header">
<div class="pf-card-title">
   <div class="pf-card-icon pf-icon-red"><i class="fas fa-lock"></i></div>
         <div>
      <h3>Change Password</h3>
            <p>Keep your account secure</p>
       </div>
 </div>
        </div>
        <form class="pf-form" id="passwordForm">
  <div class="pf-form-group" style="margin-bottom:.85rem">
         <label>Current Password</label>
      <div class="pf-pw-wrap">
     <input type="password" id="currentPassword" class="pf-input" placeholder="Enter current password" />
       <button type="button" class="pf-pw-eye"><i class="fas fa-eye"></i></button>
            </div>
  </div>
      <div class="pf-form-row">
                <div class="pf-form-group">
        <label>New Password</label>
            <div class="pf-pw-wrap">
                  <input type="password" id="newPassword" class="pf-input" placeholder="Enter new password" />
    <button type="button" class="pf-pw-eye"><i class="fas fa-eye"></i></button>
                </div>
              <div class="pf-pw-strength">
           <div class="pf-pw-track"><div class="pf-pw-fill" id="pwFill" style="width:0%"></div></div>
             <span class="pf-pw-label" id="pwLabel">Password strength</span>
     </div>
       </div>
           <div class="pf-form-group">
      <label>Confirm New Password</label>
     <div class="pf-pw-wrap">
       <input type="password" id="confirmPassword" class="pf-input" placeholder="Confirm new password" />
       <button type="button" class="pf-pw-eye"><i class="fas fa-eye"></i></button>
  </div>
     </div>
  </div>
         <div class="pf-pw-reqs">
          <h4>Requirements</h4>
     <ul>
        <li id="req-length"><i class="fas fa-circle"></i> At least 8 characters</li>
           <li id="req-upper"><i class="fas fa-circle"></i> One uppercase letter</li>
      <li id="req-lower"><i class="fas fa-circle"></i> One lowercase letter</li>
              <li id="req-number"><i class="fas fa-circle"></i> One number</li>
        <li id="req-special"><i class="fas fa-circle"></i> One special character (!@@#$%^&amp;*)</li>
          </ul>
            </div>
       <div class="pf-form-actions" style="display:flex">
     <button type="submit" class="pf-btn-primary"><i class="fas fa-lock"></i> Update Password</button>
     </div>
    </form>
    </div>

    <!-- Account Settings -->
    <div class="pf-card">
     <div class="pf-card-header">
            <div class="pf-card-title">
            <div class="pf-card-icon pf-icon-teal"><i class="fas fa-sliders-h"></i></div>
      <div>
           <h3>Account Settings</h3>
          <p>Notifications and privacy preferences</p>
     </div>
            </div>
   </div>
        <div class="pf-settings-list">
       <div class="pf-setting-item">
 <div>
    <h4>Email Notifications</h4>
           <p>Receive email updates about appointments and test results</p>
   </div>
             <label class="pf-toggle"><input type="checkbox" checked /><span class="pf-toggle-track"></span></label>
     </div>
     <div class="pf-setting-item">
      <div>
       <h4>SMS Notifications</h4>
         <p>Receive text messages for appointment reminders</p>
         </div>
        <label class="pf-toggle"><input type="checkbox" checked /><span class="pf-toggle-track"></span></label>
      </div>
            <div class="pf-setting-item">
           <div>
   <h4>Two-Factor Authentication</h4>
        <p>Add an extra layer of security to your account</p>
        </div>
     <label class="pf-toggle"><input type="checkbox" /><span class="pf-toggle-track"></span></label>
   </div>
      <div class="pf-setting-item">
              <div>
      <h4>Data Sharing with Doctors</h4>
    <p>Allow approved doctors to view your medical data</p>
 </div>
            <label class="pf-toggle"><input type="checkbox" checked /><span class="pf-toggle-track"></span></label>
