        <div class="pf-card-icon pf-icon-danger"><i class="fas fa-exclamation-triangle"></i></div>
     <div>
    <h3>Danger Zone</h3>
 <p>Irreversible account actions</p>
          </div>
      </div>
        </div>
        <div class="pf-danger-list">
     <div class="pf-danger-item">
                <div>
             <h4>Download My Data</h4>
      <p>Download a copy of all your personal and medical data</p>
   </div>
        <button type="button" class="pf-btn-outline" id="downloadDataBtn"><i class="fas fa-download"></i> Download</button>
            </div>
            <div class="pf-danger-item">
   <div>
              <h4>Delete Account</h4>
                    <p>Permanently delete your account and all associated data</p>
     </div>
  <button type="button" class="pf-btn-danger-outline" id="deleteAccountBtn"><i class="fas fa-trash"></i> Delete Account</button>
