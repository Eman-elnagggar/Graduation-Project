@section Scripts {
<script>
(function () {
    const PATIENT_ID = parseInt(document.querySelector('meta[name="patient-id"]').content, 10);
    const TOKEN      = document.querySelector('input[name="__RequestVerificationToken"]').value;

    // ── Toast notification ────────────────────────────────────────────
    function toast(msg, type = 'success') {
        document.querySelector('.pf-toast')?.remove();
        const icons = { success: 'fa-check-circle', error: 'fa-times-circle', warning: 'fa-exclamation-triangle', info: 'fa-info-circle' };
  const n = document.createElement('div');
        n.className = `pf-toast pf-toast-${type}`;
        n.innerHTML = `<i class="fas ${icons[type] ?? icons.info}"></i><span>${msg}</span><button class="pf-toast-close"><i class="fas fa-times"></i></button>`;
   document.body.appendChild(n);
   n.querySelector('.pf-toast-close').addEventListener('click', () => n.remove());
        setTimeout(() => n?.remove(), 4500);
    }

    // Keep backward-compat with any window.showNotification calls
    window.showNotification = (msg, type) => toast(msg, type);

    // ── Tab switching ─────────────────────────────────────────────────
    document.querySelectorAll('.pf-tab').forEach(btn => {
        btn.addEventListener('click', function () {
  document.querySelectorAll('.pf-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.pf-tab-content').forEach(c => c.classList.remove('active'));
       this.classList.add('active');
            document.getElementById(this.dataset.tab + '-tab').classList.add('active');
        });
    });

    // ── Generic edit section ──────────────────────────────────────────
    function setupEdit(editBtnId, formId, actionsId, cancelBtnId) {
        const editBtn   = document.getElementById(editBtnId);
  const form      = document.getElementById(formId);
        const actions   = document.getElementById(actionsId);
        const cancelBtn = document.getElementById(cancelBtnId);
   if (!editBtn) return;

        editBtn.addEventListener('click', function () {
    const inputs = form ? form.querySelectorAll('input:not([readonly]), select, textarea') : [];
     const isDisabled = inputs[0]?.disabled ?? true;
            if (isDisabled) {
              inputs.forEach(i => i.disabled = false);
         if (actions) actions.style.display = 'flex';
       editBtn.innerHTML = '<i class="fas fa-times"></i> Cancel';
    // show med remove + add buttons
      document.querySelectorAll('.pf-med-remove').forEach(b => b.style.display = 'inline-flex');
       const addBtn = document.getElementById('showAddMedBtn');
     if (addBtn) addBtn.style.display = 'inline-flex';
          } else {
     cancelSection(form, actions, editBtn);
            }
        });

        cancelBtn?.addEventListener('click', () => cancelSection(form, actions, editBtn));
    }

    function cancelSection(form, actions, editBtn) {
  form?.querySelectorAll('input:not([readonly]), select, textarea').forEach(i => i.disabled = true);
        if (actions) actions.style.display = 'none';
        if (editBtn) editBtn.innerHTML = '<i class="fas fa-pen"></i> Edit';
   document.querySelectorAll('.pf-med-remove').forEach(b => b.style.display = 'none');
        const addBtn = document.getElementById('showAddMedBtn');
    if (addBtn) addBtn.style.display = 'none';
  }

    setupEdit('editPersonalBtn',     'personalForm',     'personalActions',     'cancelPersonal');
    setupEdit('editMeasurementsBtn', 'measurementsForm', 'measurementsActions', 'cancelMeasurements');
    setupEdit('editPregnancyBtn',    'pregnancyForm',    'pregnancyActions', 'cancelPregnancy');
    setupEdit('editBPBtn',           'bpForm',           'bpActions',           'cancelBP');
    setupEdit('editMedsBtn',         null,         null,    null);
    setupEdit('editLifestyleBtn',    'lifestyleForm',    'lifestyleActions',    'cancelLifestyle');

    document.getElementById('startPregnancyBtn')?.addEventListener('click', function () {
        const editBtn = document.getElementById('editPregnancyBtn');
        if (!editBtn) return;

        const pregnancyDateInput = document.getElementById('pregnancyDate');
        if (pregnancyDateInput?.disabled) {
            editBtn.click();
        }

        setTimeout(() => {
            pregnancyDateInput?.focus();
        }, 0);
    });

    // ── Save Personal ─────────────────────────────────────────────────
    document.getElementById('personalForm')?.addEventListener('submit', async function (e) {
 e.preventDefault();
        const fd = new FormData();
        fd.append('patientId',   PATIENT_ID);
    fd.append('firstName',   document.getElementById('firstName').value);
     fd.append('lastName',    document.getElementById('lastName').value);
        fd.append('phone',       document.getElementById('phone').value);
        fd.append('address',     document.getElementById('address').value);
        fd.append('dateOfBirth', document.getElementById('dateOfBirth').value);
        fd.append('__RequestVerificationToken', TOKEN);
        try {
            const d = await (await fetch('/PatientProfile/SavePersonal', { method: 'POST', body: fd })).json();
            if (d.success) { toast('Personal information saved!'); cancelSection(this, document.getElementById('personalActions'), document.getElementById('editPersonalBtn')); }
            else toast(d.message || 'Save failed.', 'error');
        } catch { toast('Could not save. Please try again.', 'error'); }
  });

  // ── Save Measurements + live BMI ──────────────────────────────────
    function calcBmi() {
        const w = parseFloat(document.getElementById('weightKg').value);
      const h = parseFloat(document.getElementById('heightCm').value) / 100;
        if (w > 0 && h > 0) {
            const bmi    = (w / (h * h)).toFixed(1);
            const status = bmi < 18.5 ? 'Underweight' : bmi < 25 ? 'Normal' : bmi < 30 ? 'Overweight' : 'Obese';
const disp   = document.getElementById('bmiDisplay');
            const badge  = document.getElementById('bmiStatus');
    if (disp)  disp.value = bmi;
       if (badge) { badge.textContent = status; badge.className = 'pf-unit-badge pf-bmi-badge ' + status.toLowerCase(); }
        }
    }
    document.getElementById('weightKg')?.addEventListener('input', calcBmi);
    document.getElementById('heightCm')?.addEventListener('input', calcBmi);

    document.getElementById('measurementsForm')?.addEventListener('submit', async function (e) {
        e.preventDefault();
        const fd = new FormData();
        fd.append('patientId', PATIENT_ID);
 fd.append('weightKg',  document.getElementById('weightKg').value);
  fd.append('heightCm',  document.getElementById('heightCm').value);
        fd.append('__RequestVerificationToken', TOKEN);
    try {
  const d = await (await fetch('/PatientProfile/SaveMeasurements', { method: 'POST', body: fd })).json();
            if (d.success) { toast('Measurements saved!'); cancelSection(this, document.getElementById('measurementsActions'), document.getElementById('editMeasurementsBtn')); }
            else toast(d.message || 'Save failed.', 'error');
        } catch { toast('Could not save. Please try again.', 'error'); }
    });

  // ── Save Pregnancy ─────────────────────────────────────────────────
    document.getElementById('pregnancyForm')?.addEventListener('submit', async function (e) {
        e.preventDefault();
        const fp = document.querySelector('input[name="firstPregnancy"]:checked')?.value === 'yes';
        const fd = new FormData();
        fd.append('patientId',           PATIENT_ID);
  fd.append('pregnancyDate',       document.getElementById('pregnancyDate').value);
        fd.append('isFirstPregnancy',    fp);
        fd.append('previousPregnancies', document.getElementById('previousPregnancies')?.value || 0);
        fd.append('abortions',           document.getElementById('abortions')?.value || 0);
        fd.append('babyGender',          document.getElementById('babyGender')?.value || '');
        fd.append('births',    document.getElementById('births')?.value || 0);
        fd.append('__RequestVerificationToken', TOKEN);
        try {
            const d = await (await fetch('/PatientProfile/SavePregnancy', { method: 'POST', body: fd })).json();
    if (d.success) { toast('Pregnancy info saved!'); cancelSection(this, document.getElementById('pregnancyActions'), document.getElementById('editPregnancyBtn')); }
  else toast(d.message || 'Save failed.', 'error');
        } catch { toast('Could not save. Please try again.', 'error'); }
    });

    // Show/hide previous pregnancy section
    document.querySelectorAll('input[name="firstPregnancy"]').forEach(r => {
        r.addEventListener('change', function () {
            const sec = document.getElementById('previousPregnancySection');
  if (sec) sec.style.display = this.value === 'no' ? '' : 'none';
        });
 });

    // ── Save Medical (BP) ─────────────────────────────────────────────
    async function saveMedical(successMsg, cancelForm, cancelActionsId, cancelBtnId) {
    const bp = document.querySelector('input[name="bloodPressure"]:checked')?.value === 'yes';
        const sm = document.querySelector('input[name="smoking"]:checked')?.value === 'yes';
        const al = document.querySelector('input[name="alcohol"]:checked')?.value === 'yes';
        const fd = new FormData();
 fd.append('patientId',     PATIENT_ID);
 fd.append('bloodPressureIssue', bp);
        fd.append('smoking',            sm);
        fd.append('alcoholUse',         al);
        fd.append('__RequestVerificationToken', TOKEN);
      try {
            const d = await (await fetch('/PatientProfile/SaveMedical', { method: 'POST', body: fd })).json();
         if (d.success) {
                toast(successMsg);
       cancelSection(cancelForm, document.getElementById(cancelActionsId), document.getElementById(cancelBtnId));
            // update BP chip
  const chip = document.getElementById('bpStatusChip');
 if (chip) {
        chip.className = 'pf-bp-status-chip ' + (bp ? 'pf-chip-risk' : 'pf-chip-ok');
  chip.innerHTML = `<i class="fas ${bp ? 'fa-exclamation-circle' : 'fa-check-circle'}"></i><span>${bp ? 'Risk - blood pressure issues reported' : 'Normal - no blood pressure issues'}</span>`;
      }
    } else toast(d.message || 'Save failed.', 'error');
        } catch { toast('Could not save. Please try again.', 'error'); }
    }

    document.getElementById('bpForm')?.addEventListener('submit', async function (e) {
        e.preventDefault();
        await saveMedical('Blood pressure status saved!', this, 'bpActions', 'editBPBtn');
    });

    document.getElementById('lifestyleForm')?.addEventListener('submit', async function (e) {
        e.preventDefault();
    await saveMedical('Lifestyle info saved!', this, 'lifestyleActions', 'editLifestyleBtn');
        // update lifestyle status chips
    ['smoking', 'alcohol'].forEach(name => {
  const isYes = document.querySelector(`input[name="${name}"]:checked`)?.value === 'yes';
  const statusEl = document.getElementById(name + 'Status');
       if (!statusEl) return;
          statusEl.className = 'pf-ls-status ' + (isYes ? 'pf-ls-risk' : 'pf-ls-safe');
            statusEl.innerHTML = `<i class="fas ${isYes ? 'fa-times-circle' : 'fa-check-circle'}"></i><span>${isYes ? 'Risk' : 'Safe'}</span>`;
 });
    });

    // ── Medication modal ──────────────────────────────────────────────
    document.getElementById('showAddMedBtn')?.addEventListener('click', () => {
    document.getElementById('addMedModal').style.display = 'flex';
document.body.style.overflow = 'hidden';
    });

    function closeMedModal() {
     document.getElementById('addMedModal').style.display = 'none';
     document.body.style.overflow = '';
        ['medName','medReason','medDose','medDuration'].forEach(id => {
            const el = document.getElementById(id);
     if (el) el.value = '';
     });
    }
    document.getElementById('closeMedModal')?.addEventListener('click', closeMedModal);
    document.getElementById('cancelAddMed')?.addEventListener('click', closeMedModal);
    document.getElementById('addMedModal')?.addEventListener('click', e => { if (e.target === e.currentTarget) closeMedModal(); });

    document.getElementById('saveNewMed')?.addEventListener('click', async function () {
        const name     = document.getElementById('medName').value.trim();
    const reason   = document.getElementById('medReason').value.trim();
        const dose     = parseFloat(document.getElementById('medDose').value);
      const duration = parseInt(document.getElementById('medDuration').value) || 0;
        if (!name || !reason || !dose) { toast('Please fill in Name, Reason and Dosage.', 'warning'); return; }

        const fd = new FormData();
        fd.append('patientId',      PATIENT_ID);
        fd.append('drugName',       name);
        fd.append('reason',         reason);
      fd.append('doseMgPerDay',   dose);
        fd.append('durationMonths', duration);
        fd.append('__RequestVerificationToken', TOKEN);

    const btn = this;
     btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving…';
        btn.disabled = true;
        try {
      const d = await (await fetch('/PatientProfile/AddMedication', { method: 'POST', body: fd })).json();
            if (d.success) {
  appendMedRow(d.id, d.name, d.reason, d.dose, d.duration);
        closeMedModal();
         document.getElementById('noMedsMsg')?.remove();
   toast('Medication added!');
            } else toast(d.message || 'Could not add medication.', 'error');
        } catch { toast('Could not save. Please try again.', 'error'); }
finally { btn.innerHTML = '<i class="fas fa-plus"></i> Add Medication'; btn.disabled = false; }
    });

    function appendMedRow(id, name, reason, dose, duration) {
        const list = document.getElementById('medicationList');
    if (!list) return;
        const row = document.createElement('div');
        row.className = 'pf-med-row';
     row.dataset.drugId = id;
        row.innerHTML = `
            <div class="pf-med-pill-icon"><i class="fas fa-capsules"></i></div>
    <div class="pf-med-details">
                <span class="pf-med-name">${esc(name)}</span>
                <div class="pf-med-chips">
     <span class="pf-med-chip pf-chip-reason"><i class="fas fa-tag"></i> ${esc(reason)}</span>
         <span class="pf-med-chip pf-chip-dose"><i class="fas fa-syringe"></i> ${dose} mg/day</span>
     <span class="pf-med-chip pf-chip-dur"><i class="fas fa-calendar-alt"></i> ${duration} months</span>
            </div>
            </div>
            <button type="button" class="pf-med-remove" data-drug-id="${id}" title="Remove" style="display:inline-flex">
            <i class="fas fa-trash-alt"></i>
 </button>`;
    list.insertBefore(row, list.firstChild);
      row.querySelector('.pf-med-remove').addEventListener('click', removeHandler);
    }

    // ── Remove Medication ─────────────────────────────────────────────
 async function removeHandler() {
 const drugId = parseInt(this.dataset.drugId, 10);
 if (!confirm('Remove this medication?')) return;
        const fd = new FormData();
   fd.append('drugId', drugId);
      fd.append('patientId', PATIENT_ID);
        fd.append('__RequestVerificationToken', TOKEN);
        try {
      const d = await (await fetch('/PatientProfile/DeleteMedication', { method: 'POST', body: fd })).json();
    if (d.success) {
      const row = this.closest('.pf-med-row');
             row.style.animation = 'pfFadeOut .3s ease forwards';
    setTimeout(() => { row.remove(); toast('Medication removed.', 'info'); }, 300);
       } else toast('Could not remove medication.', 'error');
        } catch { toast('Could not remove. Please try again.', 'error'); }
    }
    document.querySelectorAll('.pf-med-remove').forEach(btn => btn.addEventListener('click', removeHandler));

    // ── Password toggle ───────────────────────────────────────────────
    document.querySelectorAll('.pf-pw-eye').forEach(btn => {
      btn.addEventListener('click', function () {
   const inp  = this.previousElementSibling;
      const icon = this.querySelector('i');
        if (inp.type === 'password') { inp.type = 'text';     icon.className = 'fas fa-eye-slash'; }
 else          { inp.type = 'password'; icon.className = 'fas fa-eye'; }
        });
    });

// ── Password strength ─────────────────────────────────────────────
    document.getElementById('newPassword')?.addEventListener('input', function () {
        const pw = this.value;
    const checks = { length: pw.length >= 8, upper: /[A-Z]/.test(pw), lower: /[a-z]/.test(pw), number: /[0-9]/.test(pw), special: /[!@@#$%^&*]/.test(pw) };
        let score = Object.values(checks).filter(Boolean).length;
   Object.entries(checks).forEach(([k, v]) => {
     const el = document.getElementById('req-' + k);
       if (!el) return;
            el.classList.toggle('pf-req-ok', v);
      el.querySelector('i').className = v ? 'fas fa-check-circle' : 'fas fa-circle';
        });
        const map = [[0,'0%','',''],[1,'20%','Very Weak','#ef4444'],[2,'40%','Weak','#f59e0b'],[3,'60%','Fair','#f59e0b'],[4,'80%','Good','#22c55e'],[5,'100%','Strong','#16a34a']];
        const [,w,text,color] = map[score] ?? map[0];
 const fill = document.getElementById('pwFill'); const label = document.getElementById('pwLabel');
      if (fill)  { fill.style.width = w; fill.style.background = color || '#e2e8f0'; }
        if (label) label.textContent = text || 'Password strength';
    });

    document.getElementById('passwordForm')?.addEventListener('submit', async function (e) {
        e.preventDefault();
        const cur = document.getElementById('currentPassword').value;
   const nw  = document.getElementById('newPassword').value;
 const cf  = document.getElementById('confirmPassword').value;
      if (!cur || !nw || !cf) { toast('Please fill in all password fields.', 'warning'); return; }
        if (nw !== cf)           { toast('New passwords do not match.', 'error'); return; }
        if (nw.length < 8)       { toast('Password must be at least 8 characters.', 'error'); return; }

        const fd = new FormData();
        fd.append('currentPassword', cur);
        fd.append('newPassword', nw);
        fd.append('confirmPassword', cf);
        fd.append('__RequestVerificationToken', TOKEN);

        try {
            const d = await (await fetch('/Account/ChangePassword', { method: 'POST', body: fd })).json();
            if (d.success) {
                toast('Password updated successfully!');
                this.reset();
                const fill = document.getElementById('pwFill');
                const label = document.getElementById('pwLabel');
                if (fill) { fill.style.width = '0%'; fill.style.background = '#e2e8f0'; }
                if (label) label.textContent = 'Password strength';
            } else {
                toast(d.message || 'Could not update password.', 'error');
            }
        } catch {
            toast('Could not update password. Please try again.', 'error');
        }
    });

    // ── Download My Data ─────────────────────────────────────────────
    document.getElementById('downloadDataBtn')?.addEventListener('click', async function () {
        const fd = new FormData();
        fd.append('__RequestVerificationToken', TOKEN);

        const btn = this;
        const oldHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Preparing...';

        try {
            const response = await fetch('/Account/DownloadMyData', { method: 'POST', body: fd });
            if (!response.ok) {
                toast('Could not download data. Please try again.', 'error');
                return;
            }

            const blob = await response.blob();
            const url = window.URL.createObjectURL(blob);
            const link = document.createElement('a');
            const cd = response.headers.get('Content-Disposition') || '';
            const match = cd.match(/filename="?([^";]+)"?/i);
            link.href = url;
            link.download = match?.[1] || 'my-data.csv';
            document.body.appendChild(link);
            link.click();
            link.remove();
            window.URL.revokeObjectURL(url);
            toast('Data downloaded successfully!');
        } catch {
            toast('Could not download data. Please try again.', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = oldHtml;
        }
    });

    // ── Delete Account ────────────────────────────────────────────────
    document.getElementById('deleteAccountBtn')?.addEventListener('click', async function () {
        const confirmed = confirm('Are you sure you want to delete your account? This action cannot be undone.');
        if (!confirmed) return;

        const fd = new FormData();
        fd.append('__RequestVerificationToken', TOKEN);

        const btn = this;
        const oldHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Deleting...';

        try {
            const response = await fetch('/Account/DeleteAccount', { method: 'POST', body: fd });
            const data = await response.json();
            if (data.success) {
                toast('Your account has been deleted.', 'info');
                setTimeout(() => {
                    window.location.href = data.redirectUrl || '/Account/Login';
                }, 700);
                return;
            }

            toast(data.message || 'Could not delete account.', 'error');
        } catch {
            toast('Could not delete account. Please try again.', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = oldHtml;
        }
    });

    // ── Util ──────────────────────────────────────────────────────────
    function esc(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
})();
</script>

