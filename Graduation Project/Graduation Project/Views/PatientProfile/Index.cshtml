<!-- ══════════════════ ADD MEDICATION MODAL ══════════════════ -->
<div id="addMedModal" class="pf-modal-backdrop" style="display:none">
    <div class="pf-modal">
        <div class="pf-modal-header">
            <div class="pf-modal-title">
      <div class="pf-modal-icon"><i class="fas fa-pills"></i></div>
    <span>Add New Medication</span>
          </div>
            <button class="pf-modal-close" id="closeMedModal"><i class="fas fa-times"></i></button>
    </div>
      <div class="pf-modal-body">
    <div class="pf-form-row">
                <div class="pf-form-group">
   <label>Medication Name <span class="pf-required">*</span></label>
        <input type="text" id="medName" class="pf-input" placeholder="e.g., Metformin" />
         </div>
           <div class="pf-form-group">
 <label>Reason for Taking <span class="pf-required">*</span></label>
        <input type="text" id="medReason" class="pf-input" placeholder="e.g., Type 2 Diabetes" />
 </div>
            </div>
   <div class="pf-form-row">
                <div class="pf-form-group">
        <label>Dosage (mg/day) <span class="pf-required">*</span></label>
      <div class="pf-input-unit">
              <input type="number" id="medDose" class="pf-input" placeholder="500" min="0" step="0.1" />
      <span class="pf-unit-badge">mg/day</span>
            </div>
            </div>
        <div class="pf-form-group">
    <label>Duration (months)</label>
         <div class="pf-input-unit">
      <input type="number" id="medDuration" class="pf-input" placeholder="6" min="0" />
         <span class="pf-unit-badge">months</span>
         </div>
          </div>
            </div>
        </div>
      <div class="pf-modal-footer">
   <button class="pf-btn-ghost" id="cancelAddMed"><i class="fas fa-times"></i> Cancel</button>
      <button class="pf-btn-primary" id="saveNewMed"><i class="fas fa-plus"></i> Add Medication</button>
