@model DoctorClinicsViewModel
@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Clinics";
    ViewData["ActivePage"] = "Clinics";
    ViewData["DoctorId"] = Model.Doctor.DoctorID;
    ViewData["DoctorName"] = Model.DoctorName;
    ViewData["PageTitle"] = "Clinics";
    ViewData["PageSubtitle"] = "Create clinics and manage your linked locations";

    var clinicList = Model.Clinics.ToList();
    var totalClinics = clinicList.Count;
    var linkedClinics = Model.LinkedClinicIds.Count;
    var unlinkedClinics = totalClinics - linkedClinics;
    var totalDoctorsInClinics = clinicList.Sum(c => c.ClinicDoctors?.Count ?? 0);
    var hasError = TempData["ClinicError"] != null;
}

<section class="doctor-hero card">
    <div class="doctor-hero-content">
        <div class="doctor-hero-icon"><i class="fas fa-clinic-medical"></i></div>
        <div>
            <h2>Clinic Management Hub</h2>
            <p>Create new clinics and review all registered clinics in one place.</p>
        </div>
    </div>
    <span class="doctor-hero-chip"><i class="fas fa-shield-heart"></i> Doctor Portal</span>
</section>

<section class="cl-stats-row" id="statsRow">
    <article class="cl-stat-card">
        <div class="cl-stat-icon"><i class="fas fa-hospital"></i></div>
        <div style="flex:1">
            <h3><span class="count-num" data-target="@totalClinics">0</span></h3>
            <p>Total Clinics</p>
            <div class="cl-stat-progress"><div class="cl-stat-progress-fill" data-w="100%"></div></div>
        </div>
    </article>

    <article class="cl-stat-card">
        <div class="cl-stat-icon linked"><i class="fas fa-link"></i></div>
        <div style="flex:1">
            <h3><span class="count-num" data-target="@linkedClinics">0</span></h3>
            <p>Linked to You</p>
            <div class="cl-stat-progress"><div class="cl-stat-progress-fill is-linked" data-w="@(totalClinics == 0 ? 0 : Math.Round((double)linkedClinics / totalClinics * 100))%"></div></div>
        </div>
    </article>

    <article class="cl-stat-card">
        <div class="cl-stat-icon muted"><i class="fas fa-map-marker-alt"></i></div>
        <div style="flex:1">
            <h3><span class="count-num" data-target="@unlinkedClinics">0</span></h3>
            <p>Available Clinics</p>
            <div class="cl-stat-progress"><div class="cl-stat-progress-fill is-muted" data-w="@(totalClinics == 0 ? 0 : Math.Round((double)unlinkedClinics / totalClinics * 100))%"></div></div>
        </div>
    </article>

    <article class="cl-stat-card">
        <div class="cl-stat-icon accent"><i class="fas fa-user-md"></i></div>
        <div style="flex:1">
            <h3><span class="count-num" data-target="@totalDoctorsInClinics">0</span></h3>
            <p>Total Doctor Links</p>
            <div class="cl-stat-progress"><div class="cl-stat-progress-fill" data-w="80%"></div></div>
        </div>
    </article>
</section>

<section class="card">
    <div class="card-header cl-create-toggle" id="createToggle" role="button" tabindex="0" aria-expanded="false" aria-controls="createBody">
        <h3><i class="fas fa-plus-circle" id="createToggleIcon"></i> Create New Clinic</h3>
        <span class="cl-head-sub">Click to open / collapse form</span>
    </div>

    @if (TempData["ClinicSuccess"] != null)
    {
        <div class="privacy-notice cl-msg cl-msg-success">
            <i class="fas fa-check-circle"></i>
            <p>@TempData["ClinicSuccess"]</p>
        </div>
    }

    @if (TempData["ClinicError"] != null)
    {
        <div class="privacy-notice cl-msg cl-msg-error">
            <i class="fas fa-exclamation-triangle"></i>
            <p>@TempData["ClinicError"]</p>
        </div>
    }

    <div class="cl-create-body" id="createBody">
        @using (Html.BeginForm("CreateClinic", "Doctor", FormMethod.Post, new { @class = "clinic-form" }))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="doctorId" value="@Model.Doctor.DoctorID" />

            <div class="cl-form-grid">
                <div class="form-group">
                    <label for="clinicName"><i class="fas fa-signature"></i> Clinic Name</label>
                    <input id="clinicName" name="clinicName" class="form-input" maxlength="120" placeholder="e.g. Care Women Clinic" required />
                </div>

                <div class="form-group">
                    <label for="clinicLocation"><i class="fas fa-map-marker-alt"></i> Clinic Location</label>
                    <input id="clinicLocation" name="clinicLocation" class="form-input" maxlength="200" placeholder="e.g. 22 Nasr City, Cairo" required />
                </div>
            </div>

            <div class="cl-form-actions">
                <button type="reset" class="btn btn-outline btn-pill"><i class="fas fa-rotate-right"></i> Reset</button>
                <button type="submit" class="btn btn-primary btn-pill"><i class="fas fa-save"></i> Save Changes</button>
            </div>
        }
    </div>
</section>

<section class="card">
    <div class="card-header">
        <h3><i class="fas fa-hospital"></i> Existing Clinics</h3>
        <span class="cl-count-chip" id="countChip">@totalClinics total · @linkedClinics linked to you</span>
    </div>

    <div class="cl-toolbar">
        <div class="cl-search-wrap">
            <i class="fas fa-search"></i>
            <input type="text" class="cl-search-input" id="searchInput" placeholder="Search clinics by name or location…" />
        </div>
        <button class="cl-filter-btn active" data-filter="all" type="button"><i class="fas fa-th-large"></i> All</button>
        <button class="cl-filter-btn" data-filter="linked" type="button"><i class="fas fa-link"></i> Linked</button>
        <button class="cl-filter-btn" data-filter="available" type="button"><i class="fas fa-map-marker-alt"></i> Available</button>
    </div>

    @if (!clinicList.Any())
    {
        <div class="empty-state" style="padding:2rem;">
            <i class="fas fa-clinic-medical"></i>
            <h3>No clinics yet</h3>
            <p>Create your first clinic using the form above.</p>
        </div>
    }
    else
    {
        <div class="cl-grid" id="clinicGrid">
            @for (int i = 0; i < clinicList.Count; i++)
            {
                var clinic = clinicList[i];
                var doctorsCount = clinic.ClinicDoctors?.Count ?? 0;
                var assistantsCount = clinic.Assistants?.Count ?? 0;
                var isMine = Model.LinkedClinicIds.Contains(clinic.ClinicID);
                var doctorNames = clinic.ClinicDoctors?
                    .Where(cd => cd.Doctor?.User != null)
                    .Take(2)
                    .Select(cd => $"Dr. {cd.Doctor!.User!.FirstName} {cd.Doctor.User.LastName}")
                    .ToList() ?? new List<string>();

                <article class="cl-card" data-name="@clinic.Name" data-location="@clinic.Location" data-linked="@(isMine ? "true" : "false")" style="animation-delay:@(i * 0.06)s">
                    <div class="cl-card-top">
                        <div class="cl-icon"><i class="fas fa-clinic-medical"></i></div>
                        @if (isMine)
                        {
                            <span class="cl-badge"><i class="fas fa-check-circle"></i> Linked to you</span>
                        }
                    </div>

                    <h4>@clinic.Name</h4>
                    <p class="cl-location"><i class="fas fa-map-marker-alt"></i> @clinic.Location</p>

                    @if (doctorNames.Any())
                    {
                        <p class="cl-doctors-preview">
                            <i class="fas fa-user-md"></i>
                            @string.Join(" • ", doctorNames)
                            @if (doctorsCount > doctorNames.Count)
                            {
                                <span>+@(doctorsCount - doctorNames.Count) more</span>
                            }
                        </p>
                    }

                    <div class="cl-stats">
                        <span><i class="fas fa-user-md"></i> @doctorsCount doctor@(doctorsCount != 1 ? "s" : "")</span>
                        <span><i class="fas fa-user-nurse"></i> @assistantsCount assistant@(assistantsCount != 1 ? "s" : "")</span>
                    </div>
                </article>
            }
        </div>

        <div class="cl-no-results" id="noResults" style="display:none;">
            <i class="fas fa-search-minus"></i>
            <p>No clinics match your search.</p>
        </div>
    }
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const keepOpen = @hasError.ToString().ToLowerInvariant();
            const createToggle = document.getElementById('createToggle');
            const createBody = document.getElementById('createBody');
            const createIcon = document.getElementById('createToggleIcon');

            let open = keepOpen;

            function syncCreatePanel() {
                createToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
                createIcon.className = open ? 'fas fa-minus-circle' : 'fas fa-plus-circle';
                createBody.style.maxHeight = open ? createBody.scrollHeight + 'px' : '0px';
                createBody.style.opacity = open ? '1' : '0';
                createBody.style.marginTop = open ? '.4rem' : '0';
            }

            function toggleCreatePanel() {
                open = !open;
                syncCreatePanel();
            }

            createToggle?.addEventListener('click', toggleCreatePanel);
            createToggle?.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    toggleCreatePanel();
                }
            });

            syncCreatePanel();

            const counters = document.querySelectorAll('.count-num');
            counters.forEach((el) => {
                const target = parseInt(el.dataset.target || '0', 10);
                let current = 0;
                const step = Math.max(1, Math.ceil(target / 28));
                const timer = setInterval(() => {
                    current = Math.min(current + step, target);
                    el.textContent = current;
                    if (current >= target) clearInterval(timer);
                }, 30);
            });

            document.querySelectorAll('.cl-stat-progress-fill').forEach((bar, i) => {
                setTimeout(() => { bar.style.width = bar.dataset.w || '0%'; }, 160 + (i * 120));
            });

            const searchInput = document.getElementById('searchInput');
            const filterBtns = document.querySelectorAll('.cl-filter-btn');
            const cards = Array.from(document.querySelectorAll('.cl-card'));
            const noResults = document.getElementById('noResults');
            let activeFilter = 'all';

            function applyFilters() {
                if (!cards.length) return;
                const q = (searchInput?.value || '').trim().toLowerCase();
                let visibleCount = 0;

                cards.forEach((card) => {
                    const name = (card.dataset.name || '').toLowerCase();
                    const location = (card.dataset.location || '').toLowerCase();
                    const linked = (card.dataset.linked || 'false') === 'true';

                    const matchesSearch = !q || name.includes(q) || location.includes(q);
                    const matchesFilter = activeFilter === 'all'
                        || (activeFilter === 'linked' && linked)
                        || (activeFilter === 'available' && !linked);

                    const show = matchesSearch && matchesFilter;
                    card.style.display = show ? '' : 'none';
                    if (show) visibleCount++;
                });

                if (noResults) noResults.style.display = visibleCount === 0 ? 'block' : 'none';
            }

            searchInput?.addEventListener('input', applyFilters);
            filterBtns.forEach((btn) => {
                btn.addEventListener('click', function () {
                    activeFilter = this.dataset.filter || 'all';
                    filterBtns.forEach((b) => b.classList.remove('active'));
                    this.classList.add('active');
                    applyFilters();
                });
            });
        });
    </script>
}

@section Styles {
    <style>
        .card {
            animation: sectionFadeUp .45s ease;
        }

        .doctor-hero {
            background: linear-gradient(135deg, var(--doctor-primary-dark) 0%, var(--doctor-primary) 55%, var(--doctor-accent) 100%);
            border: none;
            padding: 1.5rem 1.8rem;
            color: #fff;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            overflow: hidden;
            position: relative;
            margin-bottom: 1.2rem;
            box-shadow: 0 8px 28px rgba(20,150,127,.35);
        }

        .doctor-hero::before {
            content: "";
            position: absolute;
            width: 220px;
            height: 220px;
            border-radius: 50%;
            right: -60px;
            top: -70px;
            background: rgba(255,255,255,.10);
        }

        .doctor-hero::after {
            content: "";
            position: absolute;
            width: 120px;
            height: 120px;
            border-radius: 50%;
            right: 80px;
            bottom: -50px;
            background: rgba(255,255,255,.08);
        }

        .doctor-hero-content {
            display: flex;
            align-items: center;
            gap: 1rem;
            z-index: 1;
        }

        .doctor-hero-icon {
            width: 54px;
            height: 54px;
            border-radius: 14px;
            display: grid;
            place-items: center;
            background: rgba(255,255,255,.18);
            border: 1.5px solid rgba(255,255,255,.3);
            font-size: 1.4rem;
            flex-shrink: 0;
            animation: iconPulse 3s ease-in-out infinite;
        }

        .doctor-hero h2 {
            margin: 0;
            font-size: 1.25rem;
            font-weight: 700;
            letter-spacing: -.3px;
        }

        .doctor-hero p {
            margin: .28rem 0 0;
            font-size: .87rem;
            color: rgba(255,255,255,.88);
        }

        .doctor-hero-chip {
            z-index: 1;
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            padding: .48rem .95rem;
            border-radius: 999px;
            font-size: .78rem;
            font-weight: 700;
            border: 1.5px solid rgba(255,255,255,.3);
            background: rgba(255,255,255,.15);
            backdrop-filter: blur(4px);
            white-space: nowrap;
            letter-spacing: .3px;
        }

        .cl-stats-row {
            display: grid;
            grid-template-columns: repeat(4, minmax(0,1fr));
            gap: 14px;
            margin-bottom: 1.2rem;
        }

        .cl-stat-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-lg);
            padding: 1.1rem 1rem;
            display: flex;
            align-items: center;
            gap: .9rem;
            box-shadow: var(--shadow-sm);
            position: relative;
            overflow: hidden;
            transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
        }

        .cl-stat-card::after {
            content: "";
            position: absolute;
            right: -18px;
            bottom: -18px;
            width: 70px;
            height: 70px;
            border-radius: 50%;
            background: rgba(20,150,127,.06);
            transition: transform .35s ease;
        }

        .cl-stat-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-md);
            border-color: rgba(20,150,127,.3);
        }

        .cl-stat-card:hover::after {
            transform: scale(1.6);
        }

        .cl-stat-icon {
            width: 46px;
            height: 46px;
            border-radius: 12px;
            display: grid;
            place-items: center;
            background: rgba(20,150,127,.12);
            color: var(--doctor-primary);
            font-size: 1.05rem;
            flex-shrink: 0;
            transition: background .25s;
        }

        .cl-stat-icon.linked {
            background: rgba(40,167,69,.12);
            color: var(--success);
        }

        .cl-stat-icon.muted {
            background: rgba(107,114,128,.12);
            color: #6b7280;
        }

        .cl-stat-icon.accent {
            background: rgba(15,191,160,.12);
            color: var(--doctor-accent);
        }

        .cl-stat-card h3 {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 800;
            line-height: 1;
            color: var(--text-primary);
        }

        .cl-stat-card p {
            margin: .25rem 0 0;
            font-size: .79rem;
            color: var(--text-secondary);
            font-weight: 500;
        }

        .count-num {
            display: inline-block;
        }

        .cl-stat-progress {
            height: 3px;
            border-radius: 999px;
            background: var(--border-color);
            margin-top: .5rem;
            overflow: hidden;
        }

        .cl-stat-progress-fill {
            width: 0;
            height: 100%;
            border-radius: 999px;
            background: linear-gradient(90deg, var(--doctor-primary), var(--doctor-accent));
            transition: width 1s ease;
        }

        .cl-stat-progress-fill.is-linked {
            background: linear-gradient(90deg,#28a745,#4ade80);
        }

        .cl-stat-progress-fill.is-muted {
            background: linear-gradient(90deg,#6b7280,#9ca3af);
        }

        .cl-create-toggle {
            cursor: pointer;
            user-select: none;
            transition: background .2s ease;
            border-radius: var(--radius-md);
            padding: .2rem .35rem;
            margin: -.2rem -.35rem 0;
        }

        .cl-create-toggle:hover {
            background: var(--bg-secondary);
        }

        .cl-head-sub {
            font-size: .8rem;
            color: var(--text-secondary);
            font-weight: 500;
        }

        .cl-create-body {
            max-height: 0;
            overflow: hidden;
            opacity: 0;
            transition: max-height .45s ease, opacity .28s ease, margin-top .25s ease;
        }

        .privacy-notice {
            display: flex;
            align-items: center;
            gap: .7rem;
            padding: .85rem 1rem;
            border-radius: var(--radius-md);
            border-left: 4px solid;
            font-size: .88rem;
            animation: slideDown .35s ease;
        }

        .cl-msg {
            margin-bottom: 1rem;
        }

        .cl-msg-success {
            border-left-color: var(--success);
            background: #f0fdf4;
            color: #15803d;
        }

        .cl-msg-error {
            border-left-color: var(--danger);
            background: #fef2f2;
            color: #b91c1c;
        }

        .cl-form-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0,1fr));
            gap: 18px;
            margin-bottom: 12px;
        }

        .form-group label {
            display: flex;
            align-items: center;
            gap: .4rem;
            margin-bottom: .5rem;
            font-size: .86rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .form-group label i {
            color: var(--doctor-primary);
        }

        .form-input {
            width: 100%;
            padding: 11px 14px;
            border: 1.5px solid var(--border-color);
            border-radius: var(--radius-md);
            background: var(--bg-secondary);
            color: var(--text-primary);
            font-family: inherit;
            font-size: .93rem;
            transition: border-color .2s, box-shadow .2s, background .2s;
        }

        .form-input::placeholder {
            color: #aab4be;
        }

        .form-input:focus {
            outline: none;
            border-color: var(--doctor-primary);
            box-shadow: 0 0 0 3.5px rgba(20,150,127,.15);
            background: #fff;
        }

        .cl-form-actions {
            margin-top: .8rem;
            display: flex;
            justify-content: flex-end;
            gap: .65rem;
        }

        .btn-pill {
            border-radius: 999px;
            padding: .62rem 1.35rem;
            font-weight: 700;
            letter-spacing: .1px;
        }

        .btn-pill i {
            transition: transform .2s ease;
        }

        .btn-pill:hover i {
            transform: translateX(1px);
        }

        .cl-toolbar {
            display: flex;
            align-items: center;
            gap: .7rem;
            flex-wrap: wrap;
            margin-bottom: 1.2rem;
        }

        .cl-search-wrap {
            position: relative;
            flex: 1;
            min-width: 200px;
        }

        .cl-search-wrap i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-secondary);
            font-size: .88rem;
        }

        .cl-search-input {
            width: 100%;
            padding: 9px 14px 9px 36px;
            border: 1.5px solid var(--border-color);
            border-radius: var(--radius-md);
            background: var(--bg-secondary);
            color: var(--text-primary);
            font-family: inherit;
            font-size: .88rem;
            transition: border-color .2s, box-shadow .2s;
        }

        .cl-search-input:focus {
            outline: none;
            border-color: var(--doctor-primary);
            box-shadow: 0 0 0 3px rgba(20,150,127,.12);
            background: #fff;
        }

        .cl-filter-btn {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: 9px 14px;
            border-radius: var(--radius-md);
            font-size: .82rem;
            font-weight: 600;
            cursor: pointer;
            border: 1.5px solid var(--border-color);
            background: var(--bg-secondary);
            color: var(--text-secondary);
            transition: all .2s;
            font-family: inherit;
        }

        .cl-filter-btn.active,
        .cl-filter-btn:hover {
            border-color: var(--doctor-primary);
            color: var(--doctor-primary);
            background: var(--doctor-primary-light);
        }

        .cl-count-chip {
            font-size: .79rem;
            color: var(--text-secondary);
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            border-radius: 999px;
            padding: 5px 12px;
            font-weight: 500;
        }

        .cl-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 16px;
        }

        .cl-card {
            border: 1.5px solid var(--border-color);
            border-radius: var(--radius-lg);
            padding: 18px;
            background: var(--bg-card);
            box-shadow: var(--shadow-sm);
            transition: all .25s ease;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            animation: fadeUp .4s ease both;
        }

        .cl-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--doctor-primary), var(--doctor-accent));
            transform: scaleX(0);
            transform-origin: left;
            transition: transform .3s ease;
        }

        .cl-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-lg);
            border-color: rgba(20,150,127,.3);
        }

        .cl-card:hover::before {
            transform: scaleX(1);
        }

        .cl-card-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }

        .cl-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, rgba(20,150,127,.15), rgba(15,191,160,.2));
            color: var(--doctor-primary);
            font-size: 1.1rem;
            transition: background .25s, transform .25s;
        }

        .cl-card:hover .cl-icon {
            background: linear-gradient(135deg, rgba(20,150,127,.25), rgba(15,191,160,.3));
            transform: rotate(-5deg) scale(1.08);
        }

        .cl-badge {
            font-size: .72rem;
            font-weight: 700;
            color: #0f7a67;
            background: linear-gradient(135deg, #d0f5ee, #e6f7f4);
            border: 1px solid rgba(20,150,127,.3);
            border-radius: 999px;
            padding: 4px 11px;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .cl-badge i {
            font-size: .65rem;
        }

        .cl-card h4 {
            margin: 0 0 7px;
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1.3;
        }

        .cl-location,
        .cl-doctors-preview {
