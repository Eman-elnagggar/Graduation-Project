@model DoctorPatientDetailsViewModel
@{
  Layout = "~/Views/Shared/_DoctorLayout.cshtml";
  ViewData["Title"] = "Patient Details";
  ViewData["ActivePage"] = "Patients";
  ViewData["DoctorId"] = Model.Doctor.DoctorID;
  ViewData["DoctorName"] = Model.DoctorName;
  ViewData["PageTitle"] = "Patient Details";
  ViewData["PageSubtitle"] = "Detailed patient profile and clinical history";

  var p = Model.Patient;
  var name = ((p?.User?.FirstName ?? "") + " " + (p?.User?.LastName ?? "")).Trim();
  var risk = (Model.RiskLevel ?? "low").ToLower();
  var weeks = p?.GestationalWeeks ?? 0;
  var trim = weeks <= 12 ? "1st" : weeks <= 26 ? "2nd" : "3rd";
}

<div class="patient-header-card">
  <div class="patient-header-main">
    <div class="patient-avatar-large">
      <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(name)&background=14967f&color=fff&size=100"
           alt="@name" />
      <span class="risk-indicator @risk"></span>
    </div>
    <div class="patient-header-info">
      <h1>@name</h1>
      <div class="patient-meta">
        <span><i class="fas fa-baby"></i> @weeks weeks pregnant</span>
        <span><i class="fas fa-layer-group"></i> @trim Trimester</span>
        @if (Model.ExpectedDeliveryDate.HasValue)
        {
          <span><i class="fas fa-calendar-day"></i> EDD: @Model.ExpectedDeliveryDate.Value.ToString("MMM dd, yyyy")</span>
        }
      </div>
      <div class="patient-tags">
        <span class="tag">@(char.ToUpper(risk[0]) + risk[1..]) Risk</span>
      </div>
    </div>
  </div>
  <div class="patient-header-actions">
    <a href="/Doctor/Messages/@Model.Doctor.DoctorID?patient=@p.PatientID" class="btn btn-primary">
      <i class="fas fa-comment-medical"></i> Send Message
    </a>
    <button class="btn btn-outline" id="addNoteBtn"><i class="fas fa-sticky-note"></i> Add Note</button>
  </div>
</div>

<div class="patient-quick-stats">
  <div class="stat-card">
    <div class="stat-icon bp"><i class="fas fa-heartbeat"></i></div>
    <div class="stat-info">
      <span class="stat-value">@(Model.LastBloodPressure ?? "-")</span>
      <span class="stat-label">Last Blood Pressure</span>
      <span class="stat-date">@(Model.LastBPDate?.ToString("MMM dd") ?? "No readings")</span>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon sugar"><i class="fas fa-tint"></i></div>
    <div class="stat-info">
      <span class="stat-value">@(Model.LastBloodSugar > 0 ? Model.LastBloodSugar + " mg/dL" : "-")</span>
      <span class="stat-label">Last Blood Sugar</span>
      <span class="stat-date">@(Model.LastBSDate?.ToString("MMM dd") ?? "No readings")</span>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon weight"><i class="fas fa-weight"></i></div>
    <div class="stat-info">
      <span class="stat-value">@(p?.WeightKg > 0 ? p.WeightKg + " kg" : "-")</span>
      <span class="stat-label">Current Weight</span>
      <span class="stat-date">Last recorded</span>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon appointment"><i class="fas fa-calendar-check"></i></div>
    <div class="stat-info">
      <span class="stat-value">@(Model.NextAppointment?.Date.ToString("MMM dd") ?? "-")</span>
      <span class="stat-label">Next Appointment</span>
      <span class="stat-date">@(Model.NextAppointment != null ? DateTime.Today.Add(Model.NextAppointment.Time).ToString("h:mm tt") : "None scheduled")</span>
    </div>
  </div>
</div>

<div class="detail-tabs">
  <button class="detail-tab active" data-tab="overview"><i class="fas fa-chart-pie"></i> Overview</button>
  <button class="detail-tab" data-tab="vitals"><i class="fas fa-heartbeat"></i> Vitals History</button>
  <button class="detail-tab" data-tab="tests"><i class="fas fa-flask"></i> Tests</button>
  <button class="detail-tab" data-tab="appointments"><i class="fas fa-calendar-alt"></i> Appointments</button>
  <button class="detail-tab" data-tab="notes"><i class="fas fa-sticky-note"></i> Notes</button>
  <button class="detail-tab" data-tab="prescriptions"><i class="fas fa-prescription"></i> Prescriptions</button>
</div>

<div class="tab-content active" id="tab-overview">
  <div class="card">
    <div class="card-header"><h3><i class="fas fa-notes-medical"></i> Medical Overview</h3></div>
    <div class="card-body" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:.8rem;">
      <div class="info-group"><label>Address</label><span>@(p?.Address ?? "-")</span></div>
      <div class="info-group"><label>Height</label><span>@(p?.HeightCm > 0 ? p.HeightCm + " cm" : "-")</span></div>
      <div class="info-group"><label>First Pregnancy</label><span>@(p?.IsFirstPregnancy == true ? "Yes" : "No")</span></div>
      <div class="info-group"><label>Blood Pressure Issues</label><span>@(p?.BloodPressureIssue == true ? "Yes" : "No")</span></div>
      <div class="info-group"><label>Smoking</label><span>@(p?.Smoking == true ? "Yes" : "No")</span></div>
      <div class="info-group"><label>Alcohol</label><span>@(p?.AlcoholUse == true ? "Yes" : "No")</span></div>
    </div>
  </div>
</div>

<div class="tab-content" id="tab-vitals">
  <div class="card">
    <div class="card-header"><h3><i class="fas fa-heartbeat"></i> Blood Pressure History</h3></div>
    <div style="overflow-x:auto;">
      <table style="width:100%;border-collapse:collapse;font-size:.84rem;">
        <thead>
          <tr style="border-bottom:1px solid var(--dr-border);text-align:left;">
            <th style="padding:.7rem;">Date</th>
            <th style="padding:.7rem;">Reading</th>
            <th style="padding:.7rem;">Measurement Time</th>
          </tr>
        </thead>
        <tbody>
          @if (Model.BloodPressureHistory.Any())
          {
            @foreach (var bp in Model.BloodPressureHistory)
            {
              <tr style="border-bottom:1px solid var(--dr-border);">
                <td style="padding:.7rem;">@bp.DateTime.ToString("MMM dd, yyyy h:mm tt")</td>
                <td style="padding:.7rem;">@bp.BloodPressure</td>
                <td style="padding:.7rem;">@(bp.MeasurementTime ?? "-")</td>
              </tr>
            }
          }
          else
          {
            <tr><td colspan="3" style="padding:1rem;color:var(--dr-muted);">No blood pressure records.</td></tr>
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="tab-content" id="tab-tests">
  <div class="card">
    <div class="card-header"><h3><i class="fas fa-flask"></i> Lab Test Results</h3></div>
    <div style="display:flex;flex-direction:column;gap:.7rem;">
      @if (Model.LabTests.Any())
      {
        @foreach (var test in Model.LabTests)
        {
          <div class="schedule-item" style="border-left-color:var(--dr-primary);">
            <div class="schedule-content">
              <h4>@test.TestType</h4>
              <p>@test.UploadDate.ToString("MMM dd, yyyy")</p>
            </div>
          </div>
        }
      }
      else
      {
        <div class="no-appointments" style="padding:1.5rem;"><p>No lab tests found.</p></div>
      }
    </div>
  </div>
</div>

<div class="tab-content" id="tab-appointments">
  <div class="card">
    <div class="card-header"><h3><i class="fas fa-calendar-alt"></i> Appointment History</h3></div>
    <div class="schedule-timeline">
      @if (Model.AppointmentHistory.Any())
      {
        @foreach (var appt in Model.AppointmentHistory)
        {
          var statusCls = (appt.Booking?.Status ?? (appt.isBooked ? "confirmed" : "pending")).ToLower();
          <div class="schedule-item @statusCls">
            <div class="schedule-time">
              <span class="time">@appt.Date.ToString("MMM dd")</span>
              <span class="duration">@DateTime.Today.Add(appt.Time).ToString("h:mm tt")</span>
            </div>
            <div class="schedule-content">
              <h4>@(appt.Booking?.Reason ?? "Consultation")</h4>
              <p>@statusCls</p>
            </div>
          </div>
        }
      }
      else
      {
        <div class="no-appointments" style="padding:1.5rem;"><p>No appointments found.</p></div>
      }
    </div>
  </div>
</div>

<div class="tab-content" id="tab-notes">
  <div class="card">
    <div class="card-header">
      <h3><i class="fas fa-sticky-note"></i> Clinical Notes</h3>
      <button class="btn btn-sm btn-primary" id="addNoteBtn2"><i class="fas fa-plus"></i> Add Note</button>
    </div>
    <div id="addNoteForm" style="display:none;padding:1rem;border-bottom:1px solid var(--dr-border);background:var(--dr-light);">
      @using (Html.BeginForm("AddNote", "Doctor", FormMethod.Post))
      {
        @Html.AntiForgeryToken()
        <input type="hidden" name="patientId" value="@p.PatientID" />
        <input type="hidden" name="doctorId" value="@Model.Doctor.DoctorID" />
        <div class="form-group" style="margin-bottom:.6rem;">
          <textarea id="noteText" name="content" class="form-input" rows="4" placeholder="Write your clinical note here..." required></textarea>
        </div>
        <div style="display:flex;gap:.6rem;">
          <button type="submit" class="btn btn-primary">Save Note</button>
          <button type="button" class="btn btn-outline" id="cancelNote">Cancel</button>
        </div>
      }
    </div>
    <div style="display:flex;flex-direction:column;gap:.7rem;margin-top:.5rem;">
      @if (Model.ClinicalNotes.Any())
      {
        @foreach (var note in Model.ClinicalNotes)
        {
          <div class="schedule-item">
            <div class="schedule-content">
              <h4>@note.CreatedDate.ToString("MMM dd, yyyy h:mm tt")</h4>
              <p>@note.Content</p>
            </div>
          </div>
        }
      }
      else
      {
        <div class="no-appointments" style="padding:1.5rem;"><p>No clinical notes yet.</p></div>
      }
    </div>
  </div>
</div>

<div class="tab-content" id="tab-prescriptions">
  <div class="card">
    <div class="card-header">
      <h3><i class="fas fa-prescription"></i> Prescriptions</h3>
    </div>
    <div style="display:flex;flex-direction:column;gap:.7rem;margin-top:.5rem;">
      @if (Model.Prescriptions.Any())
      {
        @foreach (var rx in Model.Prescriptions)
        {
          <div class="schedule-item">
            <div class="schedule-content">
              <h4>@rx.PrescriptionDate.ToString("MMM dd, yyyy")</h4>
              <p>@(string.IsNullOrWhiteSpace(rx.Notes) ? "No notes" : rx.Notes)</p>
            </div>
          </div>
        }
      }
      else
      {
        <div class="no-appointments" style="padding:1.5rem;"><p>No prescriptions found.</p></div>
      }
    </div>
  </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('.detail-tab').forEach(tab => {
  tab.addEventListener('click', function () {
    document.querySelectorAll('.detail-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
    this.classList.add('active');
    document.getElementById('tab-' + this.dataset.tab).classList.add('active');
  });
});

['addNoteBtn','addNoteBtn2'].forEach(id => {
  document.getElementById(id)?.addEventListener('click', () => {
    const f = document.getElementById('addNoteForm');
    f.style.display = f.style.display === 'none' ? 'block' : 'none';
    if (f.style.display === 'block') {
      document.querySelectorAll('.detail-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      document.querySelector('.detail-tab[data-tab="notes"]').classList.add('active');
      document.getElementById('tab-notes').classList.add('active');
      document.getElementById('noteText')?.focus();
    }
  });
});

document.getElementById('cancelNote')?.addEventListener('click', () => {
  document.getElementById('addNoteForm').style.display = 'none';
});
</script>
}
