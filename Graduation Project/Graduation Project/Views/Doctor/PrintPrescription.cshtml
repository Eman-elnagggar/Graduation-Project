@model Graduation_Project.ViewModels.DoctorPrescriptionPrintViewModel
@{
    Layout = null;

    var doctor = Model.Doctor;
    var patient = Model.Patient;
    var user = patient.User;
    var rx = Model.Prescription;

    var patientName = ((user?.FirstName ?? string.Empty) + " " + (user?.LastName ?? string.Empty)).Trim();
    if (string.IsNullOrWhiteSpace(patientName)) patientName = "Patient";

    var doctorName = string.IsNullOrWhiteSpace(Model.DoctorName) ? "Doctor" : Model.DoctorName;
    var specialization = string.IsNullOrWhiteSpace(doctor.Specialization) ? "General Practice" : doctor.Specialization;
    var licenseNo = string.IsNullOrWhiteSpace(doctor.LicenseNumber) ? "Not specified" : doctor.LicenseNumber;

    var age = user != null && user.DateOfBirth > DateTime.MinValue
        ? DateTime.Today.Year - user.DateOfBirth.Year - (user.DateOfBirth.Date > DateTime.Today.AddYears(-(DateTime.Today.Year - user.DateOfBirth.Year)) ? 1 : 0)
        : 0;

    var patientIdText = $"PT-{patient.PatientID:D6}";
    var issueDate = rx.PrescriptionDate;
    var followUpDate = Model.FollowUpDate;

    var items = (rx.Items ?? new List<Graduation_Project.Models.PrescriptionItem>()).ToList();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Prescription - @patientName</title>
    <link rel="icon" type="image/png" href="~/images/logo.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/prescription-print.css" asp-append-version="true" />
</head>
<body>
    <button class="print-btn" onclick="window.print()">
        <span>🖨</span>
        <span>Print Prescription</span>
    </button>

    <div class="prescription-page">
        <table class="print-table">
            <thead>
                <tr>
                    <th>
                        <div class="header">
                            <div class="header-content">
                                <div class="doctor-info">
                                    <div class="doctor-name">Dr. @doctorName</div>
                                    <div class="specialization">@specialization</div>
                                    <div class="credentials">
                                        License No: @licenseNo
                                    </div>
                                </div>
                                <div class="logo-placeholder">℞</div>
                                <div class="clinic-info">
                                    <div class="clinic-name">@(string.IsNullOrWhiteSpace(Model.ClinicName) ? "Clinic" : Model.ClinicName)</div>
                                    <div>📍 @(string.IsNullOrWhiteSpace(Model.ClinicAddress) ? "Address not specified" : Model.ClinicAddress)</div>
                                    <div>📞 @(string.IsNullOrWhiteSpace(Model.ClinicPhone) ? "Phone not specified" : Model.ClinicPhone)</div>
                                </div>
                            </div>
                        </div>
                    </th>
                </tr>
            </thead>
            <tfoot>
                <tr>
                    <td>
                        <div class="footer">
                            <div class="footer-content">
                                <div class="signature-section">
                                    <div class="signature-line"></div>
                                    <div class="signature-label">Doctor's Signature</div>
                                </div>
                                <div class="followup-section">
                                    <div class="followup-label">Follow-up Date</div>
                                    <div class="followup-date">@(followUpDate.HasValue ? followUpDate.Value.ToString("dd MMM yyyy") : "Not scheduled")</div>
                                </div>
                            </div>
                            <div class="disclaimer">This prescription is generated by the system and should be presented during pharmacy dispensing.</div>
                            @if (Model.IsPrintedByPatient)
                            {
                                <div class="disclaimer">Note: This prescription copy was printed by the patient user.</div>
                            }
                        </div>
                    </td>
                </tr>
            </tfoot>
            <tbody>
                <tr>
                    <td>
                        <div class="content">
                            <div class="patient-section">
                                <div class="patient-field full-width">
                                    <span class="field-label">Patient Name</span>
                                    <span class="field-value">@patientName</span>
                                </div>
                                <div class="patient-field">
                                    <span class="field-label">Patient ID</span>
                                    <span class="field-value">@patientIdText</span>
                                </div>
                                <div class="patient-field">
                                    <span class="field-label">Date</span>
                                    <span class="field-value">@issueDate.ToString("dd MMM yyyy")</span>
                                </div>
                                <div class="patient-field">
                                    <span class="field-label">Age</span>
                                    <span class="field-value">@(age > 0 ? age + " years" : "-")</span>
                                </div>
                                <div class="patient-field">
                                    <span class="field-label">Phone</span>
                                    <span class="field-value">@(string.IsNullOrWhiteSpace(user?.PhoneNumber) ? "-" : user.PhoneNumber)</span>
                                </div>
                                <div class="patient-field">
                                    <span class="field-label">Blood Group</span>
                                    <span class="field-value">-</span>
                                </div>
                            </div>

                            <div class="rx-section">
                                <div class="rx-header">
                                    <span class="rx-symbol">℞</span>
                                    <span class="rx-title">PRESCRIPTION</span>
                                </div>

                                <table class="medicine-table">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Medicine Name</th>
                                            <th>Dosage</th>
                                            <th>Frequency</th>
                                            <th>Duration</th>
                                            <th>Instructions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (items.Any())
                                        {
                                            var idx = 1;
                                            foreach (var item in items)
                                            {
                                                <tr>
                                                    <td class="med-number">@idx</td>
                                                    <td class="med-name">@(string.IsNullOrWhiteSpace(item.MedicineName) ? "-" : item.MedicineName)</td>
                                                    <td>@(string.IsNullOrWhiteSpace(item.Dosage) ? "-" : item.Dosage)</td>
                                                    <td>@(string.IsNullOrWhiteSpace(item.Frequency) ? "-" : item.Frequency)</td>
                                                    <td>@(item.DurationDays > 0 ? item.DurationDays + " days" : "-")</td>
                                                    <td class="med-details">@(string.IsNullOrWhiteSpace(item.Instructions) ? "-" : item.Instructions)</td>
                                                </tr>
                                                idx++;
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td class="med-number">1</td>
                                                <td class="med-name">No medicine items found</td>
                                                <td>-</td>
                                                <td>-</td>
                                                <td>-</td>
                                                <td class="med-details">-</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <div class="notes-section">
                                <div class="notes-title">📋 Additional Instructions</div>
                                <div class="notes-content">@(string.IsNullOrWhiteSpace(rx.Notes) ? "No additional notes provided." : rx.Notes)</div>
                            </div>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</body>
</html>