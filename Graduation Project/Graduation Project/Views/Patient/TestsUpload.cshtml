@{
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    ViewData["Title"] = "Tests Upload";
    ViewData["ActivePage"] = "Tests";
}

@Html.AntiForgeryToken()

<!-- ══════════════════════════════════════════
     PAGE HEADER
══════════════════════════════════════════ -->
<header class="tu-hero">
    <div class="tu-hero-left">
        <div class="tu-hero-icon">
            <i class="fas fa-flask"></i>
        </div>
        <div>
            <h1 class="tu-hero-title">Upload Lab Tests</h1>
            <p class="tu-hero-sub">Upload test images · AI extracts values · Review &amp; get a full report</p>
        </div>
    </div>
    <div class="tu-hero-right">
        <div class="tu-hero-chip"><i class="fas fa-brain"></i><span>AI Extraction</span></div>
        <div class="tu-hero-chip tu-chip-review"><i class="fas fa-check-double"></i><span>Review &amp; Approve</span></div>
        <div class="tu-hero-chip tu-chip-report"><i class="fas fa-file-medical-alt"></i><span>Full Report</span></div>
    </div>
</header>

<!-- ══════════════════════════════════════════
     PROGRESS STEPS
══════════════════════════════════════════ -->
<div class="tu-progress-bar">
    <div class="tu-progress-step active" id="step1">
        <div class="tu-step-circle"><span class="tu-step-num">1</span></div>
        <div class="tu-step-label">Upload Tests</div>
    </div>
    <div class="tu-step-connector"><span class="tu-connector-line" id="conn1"></span></div>
    <div class="tu-progress-step" id="step2">
        <div class="tu-step-circle"><span class="tu-step-num">2</span></div>
        <div class="tu-step-label">Review &amp; Approve</div>
    </div>
    <div class="tu-step-connector"><span class="tu-connector-line" id="conn2"></span></div>
    <div class="tu-progress-step" id="step3">
        <div class="tu-step-circle"><span class="tu-step-num">3</span></div>
        <div class="tu-step-label">View Report</div>
    </div>
</div>

<!-- ══════════════════════════════════════════
     STEP 1 — UPLOAD
══════════════════════════════════════════ -->
<section class="tu-section" id="section-upload">
    <div class="tu-card">
        <div class="tu-card-header">
            <div class="tu-card-title">
                <div class="tu-card-icon-wrap"><i class="fas fa-cloud-upload-alt"></i></div>
                <div>
                    <h3>Upload Test Images</h3>
                    <p>Select a test type, then upload one or more lab test photos</p>
                </div>
            </div>
            <span class="tu-step-badge">Step 1</span>
        </div>

        <div class="tu-upload-row">

            <!-- Left col: selector + queue -->
            <div class="tu-form-group">
                <label for="testType"><i class="fas fa-vials"></i> Test Type</label>
                <div class="tu-select-container">
                    <select id="testType" class="tu-select">
                        <option value="">— Select Test Type —</option>
                        <option value="cbc">CBC (Complete Blood Count)</option>
                        <option value="urinalysis">Urinalysis</option>
                        <option value="tsh">TSH (Thyroid)</option>
                        <option value="ferritin">Ferritin</option>
                        <option value="fbg">Fasting Blood Glucose</option>
                        <option value="hba1c">HbA1c (Sugar Test)</option>
                        <option value="hcv">HCV (Hepatitis C)</option>
                        <option value="hbsag">HBsAg (Hepatitis B)</option>
                        <option value="bloodgroup">Blood Group</option>
                    </select>
                    <i class="fas fa-chevron-down tu-select-arrow"></i>
                </div>
                <p class="tu-field-hint"><i class="fas fa-info-circle"></i> Choose the test type before uploading</p>

                <!-- Queued files list -->
                <div id="queuedFilesList" style="display:none; margin-top:1rem;">
                    <p class="tu-queue-label"><i class="fas fa-layer-group"></i> Queued for upload</p>
                    <div id="queuedFilesInner"></div>
                </div>
            </div>

            <!-- Right col: drop zone -->
            <div class="tu-upload-zone" id="uploadZone">
                <div class="tu-upload-icon-wrap"><i class="fas fa-cloud-upload-alt"></i></div>
                <p class="tu-upload-title">Drag &amp; Drop test images here</p>
                <p class="tu-upload-sub">or <span class="tu-upload-link">click to browse files</span></p>
                <div class="tu-upload-hint">
                    <i class="fas fa-info-circle"></i>
                    JPG &nbsp;·&nbsp; PNG &nbsp;·&nbsp; PDF &nbsp;·&nbsp; Max 10 MB &nbsp;·&nbsp; Multiple files allowed
                </div>
                <input type="file" id="fileInput" accept="image/*,.pdf" multiple style="display:none" />
            </div>
        </div>

        <div class="tu-card-footer">
            <button class="tu-btn tu-btn-primary" id="sendToAIBtn" type="button" style="display:none">
                <i class="fas fa-paper-plane"></i> Send to AI for Extraction
                <span class="tu-file-count-badge" id="fileCountBadge">0</span>
            </button>
            <button class="tu-btn tu-btn-outline" id="addMoreTests" type="button">
                <i class="fas fa-plus"></i> Add More Files
            </button>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════
     STEP 2 — REVIEW & APPROVE
══════════════════════════════════════════ -->
<section class="tu-section" id="uploadedTestsSection" style="display:none">
    <div class="tu-card">
        <div class="tu-card-header">
            <div class="tu-card-title">
                <div class="tu-card-icon-wrap tu-icon-review"><i class="fas fa-file-medical"></i></div>
                <div>
                    <h3>Review Extracted Values</h3>
                    <p>AI has read your images — verify each value, edit if needed, then approve</p>
                </div>
            </div>
            <div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;">
                <span class="tu-step-badge tu-badge-2">Step 2</span>
                <button class="tu-btn tu-btn-danger-ghost" id="clearAllTests" type="button">
                    <i class="fas fa-trash"></i> Clear All
                </button>
            </div>
        </div>

        <!-- Extraction progress bar (shown while AI is reading files) -->
        <div id="extractionProgress" style="display:none">
            <div class="tu-ext-bar-wrap">
                <div class="tu-ext-bar-fill" id="extractionBarFill"></div>
            </div>
            <p class="tu-ext-status" id="extractionStatus">Extracting values…</p>
        </div>

        <!-- Test cards injected here -->
        <div id="uploadedTestsList"></div>

        <div class="tu-submit-row" id="submitRow" style="display:none">
            <div class="tu-submit-info">
                <i class="fas fa-info-circle"></i>
                Approve all tests below, then submit for comprehensive AI analysis
            </div>
            <div style="display:flex;gap:.75rem;flex-wrap:wrap;align-items:center;">
                <span class="tu-approval-counter" id="approvalCounter">0 / 0 approved</span>
                <button class="tu-btn tu-btn-primary tu-btn-lg" id="submitAllTests" type="button" disabled>
                    <i class="fas fa-lock"></i> Approve all tests to submit
                </button>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════
     STEP 3 — AI REPORT
══════════════════════════════════════════ -->
<section class="tu-section" id="comprehensiveResults" style="display:none">
    <div class="tu-card tu-card-report">
        <div class="tu-card-header">
            <div class="tu-card-title">
                <div class="tu-card-icon-wrap tu-icon-report"><i class="fas fa-brain"></i></div>
                <div>
                    <h3>Comprehensive AI Analysis Report</h3>
                    <p id="reportSubtitle">AI-generated insights based on your submitted tests</p>
                </div>
            </div>
            <div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;">
                <span class="tu-step-badge tu-badge-3">Step 3</span>
                <span class="tu-confidence-badge" id="overallConfidence" style="display:none">
                    <i class="fas fa-brain"></i> Confidence: —
                </span>
            </div>
        </div>

        <!-- Report loading state -->
        <div id="reportLoading" class="tu-report-loading">
            <div class="tu-report-loading-inner">
                <div class="tu-report-spinner"><i class="fas fa-brain"></i></div>
                <h4>Generating comprehensive report…</h4>
                <p>AI is cross-referencing all test results against pregnancy-safe ranges</p>
                <div class="tu-loading-steps" id="loadingSteps"></div>
                <div class="tu-loading-bar"><div class="tu-loading-bar-fill" id="reportBarFill"></div></div>
            </div>
        </div>

        <!-- Report content (shown after loading) -->
        <div id="reportReady" style="display:none">
            <div class="tu-report-verdict-row" id="reportVerdictRow"></div>
            <div id="comprehensiveReportContent"></div>
            <div class="tu-report-actions">
                <button class="tu-btn tu-btn-primary" type="button">
                    <i class="fas fa-download"></i> Download Report
                </button>
                <button class="tu-btn tu-btn-outline" type="button">
                    <i class="fas fa-share-alt"></i> Share with Doctor
                </button>
                <button class="tu-btn tu-btn-ghost" id="uploadMoreBtn" type="button">
                    <i class="fas fa-plus"></i> Upload More Tests
                </button>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════
     PREVIOUS TESTS — CLEAN TABLE WITH PAGINATION
══════════════════════════════════════════ -->
@{
    var testTypeNames = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        { "cbc",       "CBC" },
        { "urinalysis","Urinalysis" },
        { "tsh",       "TSH" },
        { "ferritin",  "Ferritin" },
        { "fbg",       "FBG" },
        { "hba1c",     "HbA1c" },
        { "hcv",       "HCV" },
        { "hbsag",     "HBsAg" },
        { "bloodgroup","Blood Group" }
    };

    var previousTests = ViewBag.PreviousTests as IEnumerable<Graduation_Project.Models.LabTest>
                        ?? Enumerable.Empty<Graduation_Project.Models.LabTest>();

    string GetStatusClass(string status) =>
        (status ?? "").ToLower() switch
        {
            "reviewed"  => "reviewed",
            "completed" => "reviewed",
            "pending"   => "pending",
            _           => "pending"
        };

    string GetResultClass(string result) =>
        (result ?? "").ToLower() switch
        {
            "normal"                    => "normal",
            "all values normal"         => "normal",
            "abnormal"                  => "high",
            "abnormal values detected"  => "high",
            "attention"                 => "warning",
            "some values below normal"  => "warning",
            "requires attention"        => "warning",
            _                           => "pending"
        };

    string ShortResult(string result) =>
        (result ?? "").ToLower() switch
        {
            "all values normal"         => "Normal",
            "abnormal values detected"  => "Abnormal",
            "some values below normal"  => "Attention",
            _ => string.IsNullOrWhiteSpace(result) ? "—" : result
        };

    string ShortStatus(string status) =>
        (status ?? "").ToLower() switch
        {
            "completed"  => "Reviewed",
            "reviewed"   => "Reviewed",
            "processing" => "Processing",
            "failed"     => "Failed",
            _            => string.IsNullOrWhiteSpace(status) ? "Pending" : status
        };

    string ResolveName(string? testType, string? testName) =>
        testTypeNames.TryGetValue(testType ?? "", out var rn) ? rn
        : (!string.IsNullOrWhiteSpace(testName) ? testName! : testType ?? "Unknown");

    var groupedSessions = previousTests
        .Where(t => t.ReportID.HasValue)
        .GroupBy(t => t.ReportID!.Value)
        .Select(g =>
        {
            var sorted     = g.OrderBy(t => t.UploadDate).ToList();
            var report     = sorted.Select(t => t.TestReport).FirstOrDefault(r => r != null);
            var names      = sorted.Select(t => ResolveName(t.TestType, t.TestName)).ToList();
            var viewTestId = sorted.FirstOrDefault(t => t.TestReport?.OverallStatus != null)?.LabTestID
                             ?? sorted.Last().LabTestID;
            var testImages  = sorted
                .Where(t => !string.IsNullOrWhiteSpace(t.ImagePath))
                .Select(t => new { Name = ResolveName(t.TestType, t.TestName), Path = t.ImagePath! })
                .ToList();
            return new
            {
                Date        = sorted.Max(t => t.UploadDate),
                Names       = names,
                Status      = report?.AnalysisStatus ?? sorted.Last().AnalysisStatus ?? "",
                Overall     = report?.OverallStatus,
                HasReport   = report?.OverallStatus != null,
                ViewTestId  = viewTestId,
                TestImages  = testImages
            };
        })
        .OrderByDescending(g => g.Date)
        .ToList();

    var orphanTests = previousTests
        .Where(t => !t.ReportID.HasValue)
        .OrderByDescending(t => t.UploadDate)
        .ToList();
}

<section class="tu-section">
    <div class="tu-card">
        <div class="tu-card-header" style="padding: 1.25rem 1.5rem;">
            <div class="tu-card-title">
                <div class="tu-card-icon-wrap tu-icon-history">
                    <i class="fas fa-history"></i>
                </div>
                <div>
                    <h3>Test History</h3>
                    <p>View and manage your previous lab tests</p>
                </div>
            </div>
            @if (groupedSessions.Any() || orphanTests.Any())
            {
                <div class="tu-history-meta">
                    <span class="tu-history-count">@((groupedSessions.Count() + orphanTests.Count())) tests</span>
                </div>
            }
        </div>
        
        @if (!groupedSessions.Any() && !orphanTests.Any())
        {
            <div class="tu-empty-state">
                <div class="tu-empty-icon">
                    <i class="fas fa-flask"></i>
                </div>
                <h4>No Test History</h4>
                <p>Your uploaded tests will appear here</p>
            </div>
        }
        else
        {
            <!-- Filter & Search Bar -->
            <div class="tu-history-toolbar">
                <div class="tu-search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" id="historySearch" placeholder="Search tests..." />
                </div>
                <div class="tu-filter-group">
                    <select id="statusFilter" class="tu-filter-select">
                        <option value="">All Status</option>
                        <option value="reviewed">Reviewed</option>
                        <option value="pending">Pending</option>
                    </select>
                    <select id="resultFilter" class="tu-filter-select">
                        <option value="">All Results</option>
                        <option value="normal">Normal</option>
                        <option value="warning">Attention</option>
                        <option value="high">Abnormal</option>
                    </select>
                </div>
            </div>

            <!-- Table -->
            <div class="tu-history-table-wrap">
                <table class="tu-history-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Test Type</th>
                            <th>Status</th>
                            <th>Result</th>
                            <th class="tu-th-actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="historyTableBody">
                        @foreach (var session in groupedSessions)
                        {
                            var statusClass  = GetStatusClass(session.Status);
                            var resultText   = ShortResult(session.Overall);
                            var resultClass  = GetResultClass(session.Overall);
                            var joinedNames  = string.Join(", ", session.Names);
                            var imagesJson   = session.TestImages.Any() ? System.Text.Json.JsonSerializer.Serialize(session.TestImages.Select(i => new { name = i.Name, path = i.Path })) : "";
                            
                            <tr class="tu-history-row" data-status="@statusClass" data-result="@resultClass" data-search="@joinedNames.ToLower() @session.Date.ToString("MMM dd, yyyy").ToLower()">
                                <td>
                                    <span class="tu-history-date">@session.Date.ToString("MMM dd, yyyy")</span>
                                    <span class="tu-history-time">@session.Date.ToString("HH:mm")</span>
                                </td>
                                <td>
                                    <div class="tu-test-type-cell">
                                        @if (session.Names.Count == 1)
                                        {
                                            <span class="tu-test-type-single">@session.Names[0]</span>
                                        }
                                        else
                                        {
                                            <span class="tu-test-type-main">@session.Names[0]</span>
                                            <span class="tu-test-type-extra">+@(session.Names.Count - 1) more</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <span class="tu-status-dot @statusClass"></span>
                                    <span class="tu-status-text">@ShortStatus(session.Status)</span>
                                </td>
                                <td>
                                    @if (session.HasReport)
                                    {
                                        <span class="tu-result-badge @resultClass">@resultText</span>
                                    }
                                    else
                                    {
                                        <span class="tu-result-pending">—</span>
                                    }
                                </td>
                                <td class="tu-actions-cell">
                                    <div class="tu-action-btns">
                                        @if (session.TestImages.Any())
                                        {
                                            <button class="tu-action-btn tu-btn-view-images"
                                                    data-images="@imagesJson"
                                                    data-test-name="@joinedNames"
                                                    data-test-date="@session.Date.ToString("MMM dd, yyyy")"
                                                    type="button"
                                                    title="View Images">
                                                <i class="fas fa-images"></i>
                                            </button>
                                        }
                                        @if (session.HasReport)
                                        {
                                            <button class="tu-action-btn tu-action-primary tu-btn-view-report"
                                                    data-test-id="@session.ViewTestId"
                                                    data-test-name="@joinedNames"
                                                    data-test-date="@session.Date.ToString("MMM dd, yyyy")"
                                                    data-result="@resultText"
                                                    data-result-class="@resultClass"
                                                    type="button"
                                                    title="View Report">
                                                <i class="fas fa-file-medical-alt"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="tu-processing-badge">
                                                <i class="fas fa-clock"></i>
                                            </span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }

                        @foreach (var test in orphanTests)
                        {
                            var displayName = ResolveName(test.TestType, test.TestName);
                            
                            <tr class="tu-history-row" data-status="pending" data-result="pending" data-search="@displayName.ToLower() @test.UploadDate.ToString("MMM dd, yyyy").ToLower()">
                                <td>
                                    <span class="tu-history-date">@test.UploadDate.ToString("MMM dd, yyyy")</span>
                                    <span class="tu-history-time">@test.UploadDate.ToString("HH:mm")</span>
                                </td>
                                <td>
                                    <span class="tu-test-type-single">@displayName</span>
                                </td>
                                <td>
                                    <span class="tu-status-dot pending"></span>
                                    <span class="tu-status-text">@ShortStatus(test.AnalysisStatus)</span>
                                </td>
                                <td>
                                    <span class="tu-result-pending">—</span>
                                </td>
                                <td class="tu-actions-cell">
                                    <div class="tu-action-btns">
                                        <span class="tu-processing-badge">
                                            <i class="fas fa-clock"></i>
                                        </span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="tu-pagination" id="historyPagination">
                <div class="tu-pagination-info">
                    <span id="paginationInfo">Showing 1-10 of @((groupedSessions.Count() + orphanTests.Count()))</span>
                </div>
                <div class="tu-pagination-controls">
                    <button class="tu-page-btn" id="prevPage" disabled>
                        <i class="fas fa-chevron-left"></i>
                    </button>
                    <div class="tu-page-numbers" id="pageNumbers"></div>
                    <button class="tu-page-btn" id="nextPage">
                        <i class="fas fa-chevron-right"></i>
                    </button>
                </div>
                <div class="tu-pagination-size">
                    <select id="pageSize" class="tu-page-size-select">
                        <option value="5">5 / page</option>
                        <option value="10">10 / page</option>
                        <option value="25">25 / page</option>
                    </select>
                </div>
            </div>
        }
    </div>
</section>

<!-- ══════════════════════════════════════════
       IMAGE GALLERY MODAL
  ══════════════════════════════════════════ -->
  <div id="tuImageGallery" class="tu-gallery-overlay" role="dialog" aria-modal="true" aria-label="Test Images" style="display:none">
      <div class="tu-gallery">
          <div class="tu-gallery-hdr">
              <div class="tu-gallery-hdr-left">
                  <div class="tu-card-icon-wrap tu-icon-history"><i class="fas fa-images"></i></div>
                  <div>
                      <h4 id="tuGalleryTitle">Test Images</h4>
                      <p id="tuGallerySubtitle" style="margin:0;font-size:.8rem;color:var(--tu-muted)"></p>
                  </div>
              </div>
              <button id="tuGalleryClose" class="tu-modal-close" type="button" aria-label="Close"><i class="fas fa-times"></i></button>
          </div>
          <div class="tu-gallery-body">
              <div id="tuGalleryGrid" class="tu-gallery-grid"></div>
          </div>
      </div>
  </div>

  <!-- ══════════════════════════════════════════
     REPORT MODAL
══════════════════════════════════════════ -->
<div id="tuReportModal" class="tu-modal-overlay" role="dialog" aria-modal="true" aria-labelledby="tuModalTitle" style="display:none">
    <div class="tu-modal">
        <div class="tu-modal-hdr">
            <div class="tu-modal-hdr-left">
                <div class="tu-card-icon-wrap tu-icon-report"><i class="fas fa-file-medical-alt"></i></div>
                <div>
                    <h3 id="tuModalTitle">Test Report</h3>
                    <p id="tuModalSubtitle">Loading report…</p>
                </div>
            </div>
            <div class="tu-modal-hdr-right">
                <span id="tuModalResultBadge" class="tu-badge-status" style="display:none"></span>
                <button class="tu-modal-close-btn" id="tuModalClose" type="button" aria-label="Close"><i class="fas fa-times"></i></button>
            </div>
        </div>

        <div class="tu-modal-body" id="tuModalBody">
            <!-- Loading state -->
            <div id="tuModalLoading" class="tu-modal-loading-wrap">
                <div class="tu-report-spinner"><i class="fas fa-brain"></i></div>
                <p>Fetching report from database…</p>
            </div>
            <!-- Report content -->
            <div id="tuModalContent" style="display:none">
                <div id="tuModalVerdictRow" class="tu-report-verdict-row" style="padding:1rem 1.5rem 0"></div>
                <div id="tuModalReportContent"></div>
            </div>
            <!-- Error state -->
            <div id="tuModalError" style="display:none;text-align:center;padding:3rem 1.5rem;color:var(--tu-muted)">
                <i class="fas fa-exclamation-circle" style="font-size:2rem;display:block;margin-bottom:.75rem;color:#ef9a9a"></i>
                <p id="tuModalErrorMsg">Could not load the report.</p>
            </div>
        </div>

        <div class="tu-modal-footer">
            <button class="tu-btn tu-btn-ghost" id="tuModalCloseFooter" type="button"><i class="fas fa-times"></i> Close</button>
        </div>
    </div>
</div>


@section Styles {
<style>
/* ════════════════════════════════════════════
   Variables
════════════════════════════════════════════ */
:root {
    --tu-primary:    #1BAEBE;
    --tu-primary-dk: #138fa0;
    --tu-text:       #1e293b;
    --tu-muted:      #64748b;
    --tu-light:      #f8fafc;
    --tu-border:     #e2e8f0;
    --tu-radius:     16px;
    --tu-shadow:     0 4px 24px rgba(0,0,0,.07);
    --tu-shadow-hov: 0 8px 32px rgba(0,0,0,.12);
}

/* ════════════════════════════════════════════
   HERO
════════════════════════════════════════════ */
.tu-hero {
    display: flex; justify-content: space-between; align-items: center;
    background: linear-gradient(135deg, #0f2942 0%, #1a4a6e 50%, #0d3d5c 100%);
    border-radius: 18px; padding: 1.8rem 2rem; margin-bottom: 1.5rem;
    flex-wrap: wrap; gap: 1rem; position: relative; overflow: hidden;
}
.tu-hero::before {
    content: ""; position: absolute; top: -40px; right: -40px;
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(27,174,190,.25) 0%, transparent 70%);
    pointer-events: none;
}
.tu-hero::after {
    content: ""; position: absolute; bottom: -60px; left: 20%;
    width: 260px; height: 260px;
    background: radial-gradient(circle, rgba(0,180,216,.12) 0%, transparent 70%);
    pointer-events: none;
}
.tu-hero-left  { display: flex; align-items: center; gap: 1.1rem; z-index: 1; }
.tu-hero-icon  {
    width: 56px; height: 56px; border-radius: 16px; flex-shrink: 0;
    background: linear-gradient(135deg, var(--tu-primary), var(--tu-primary-dk));
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; color: #fff;
    box-shadow: 0 6px 20px rgba(27,174,190,.45);
}
.tu-hero-title { margin: 0; font-size: 1.7rem; font-weight: 800; color: #f1f5f9; letter-spacing: -.3px; }
.tu-hero-sub   { margin: .2rem 0 0; font-size: .88rem; color: #94a3b8; }
.tu-hero-right { display: flex; align-items: center; gap: .65rem; flex-wrap: wrap; z-index: 1; }
.tu-hero-chip  {
    display: inline-flex; align-items: center; gap: .4rem;
    padding: .38rem .95rem; border-radius: 22px; font-size: .8rem; font-weight: 700;
    background: rgba(255,255,255,.1); border: 1.5px solid rgba(255,255,255,.2);
    color: #e2f8fa; white-space: nowrap; backdrop-filter: blur(4px); transition: background .2s;
}
.tu-hero-chip:hover { background: rgba(255,255,255,.18); }
.tu-chip-review { border-color: rgba(251,191,36,.45); color: #fde68a; }
.tu-chip-report { border-color: rgba(74,222,128,.45);  color: #bbf7d0; }

/* ════════════════════════════════════════════
   PROGRESS BAR
════════════════════════════════════════════ */
.tu-progress-bar {
    display: flex; align-items: center; background: #fff;
    border: 1px solid var(--tu-border); border-radius: var(--tu-radius);
    padding: 1.1rem 1.75rem; margin-bottom: 1.5rem; box-shadow: var(--tu-shadow);
}
.tu-progress-step { display: flex; align-items: center; gap: .65rem; flex: 1; min-width: 0; }
.tu-step-circle {
    width: 38px; height: 38px; border-radius: 50%; flex-shrink: 0;
    background: var(--tu-border); color: var(--tu-muted);
    font-size: .88rem; font-weight: 800;
    display: flex; align-items: center; justify-content: center;
    transition: background .35s, color .35s, box-shadow .35s;
}
.tu-step-num  { display: inline; }
.tu-step-check{ display: none;   }
.tu-progress-step.active .tu-step-circle {
    background: linear-gradient(135deg, var(--tu-primary), var(--tu-primary-dk));
    color: #fff; box-shadow: 0 3px 12px rgba(27,174,190,.35);
}
.tu-progress-step.completed .tu-step-circle { background: #e8f5e9; color: #2e7d32; }
.tu-progress-step.completed .tu-step-num   { display: none; }
.tu-progress-step.completed .tu-step-check { display: inline; font-family: 'Font Awesome 6 Free'; font-weight: 900; font-size: .75rem; }
.tu-step-label {
    font-size: .84rem; font-weight: 600; color: var(--tu-muted);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; transition: color .3s;
}
.tu-progress-step.active .tu-step-label    { color: var(--tu-primary); }
.tu-progress-step.completed .tu-step-label { color: #2e7d32; }
.tu-step-connector { flex: 1; display: flex; align-items: center; padding: 0 .5rem; min-width: 20px; }
.tu-connector-line {
    display: block; height: 2px; width: 100%; background: var(--tu-border);
    border-radius: 2px; transition: background .4s;
}
.tu-connector-line.active { background: linear-gradient(90deg, var(--tu-primary), var(--tu-primary-dk)); }
@@media (max-width: 600px) {
    .tu-step-label     { display: none; }
    .tu-step-connector { min-width: 12px; }
}

/* ════════════════════════════════════════════
   SECTIONS & CARDS
════════════════════════════════════════════ */
.tu-section { margin-bottom: 1.5rem; }
.tu-card {
    background: #fff; border-radius: var(--tu-radius);
    box-shadow: var(--tu-shadow); border: 1px solid var(--tu-border); overflow: hidden;
    transition: box-shadow .2s;
}
.tu-card-report { border-color: rgba(27,174,190,.25); box-shadow: 0 4px 24px rgba(27,174,190,.1); }
.tu-card-header {
    display: flex; justify-content: space-between; align-items: flex-start;
    flex-wrap: wrap; gap: .75rem;
    padding: 1.3rem 1.5rem; border-bottom: 1.5px solid var(--tu-border); background: #fafbfc;
}
.tu-card-title       { display: flex; align-items: flex-start; gap: .75rem; }
.tu-card-title h3    { margin: 0 0 .15rem; font-size: 1rem; font-weight: 700; color: var(--tu-text); }
.tu-card-title p     { margin: 0; font-size: .8rem; color: var(--tu-muted); }
.tu-card-icon-wrap   {
    width: 40px; height: 40px; border-radius: 11px; flex-shrink: 0;
    background: rgba(27,174,190,.12); color: var(--tu-primary);
    display: flex; align-items: center; justify-content: center; font-size: 1rem;
}
.tu-icon-review  { background: rgba(139,92,246,.12); color: #7c3aed; }
.tu-icon-report  { background: rgba(27,174,190,.12);  color: var(--tu-primary); }
.tu-icon-history { background: rgba(245,158,11,.12);  color: #b45309; }
.tu-card-footer {
    display: flex; align-items: center; gap: .75rem; flex-wrap: wrap;
    padding: 1rem 1.5rem; border-top: 1.5px solid var(--tu-border); background: #fafbfc;
}

/* ════════════════════════════════════════════
   STEP BADGES
════════════════════════════════════════════ */
.tu-step-badge {
    display: inline-flex; align-items: center; padding: .3rem .85rem; border-radius: 20px;
    font-size: .75rem; font-weight: 700;
    background: rgba(27,174,190,.1); color: var(--tu-primary);
    border: 1px solid rgba(27,174,190,.25); white-space: nowrap;
}
.tu-badge-2 { background: rgba(139,92,246,.1); color: #7c3aed; border-color: rgba(139,92,246,.25); }
.tu-badge-3 { background: rgba(245,158,11,.1);  color: #b45309; border-color: rgba(245,158,11,.25); }

/* ════════════════════════════════════════════
   UPLOAD AREA
════════════════════════════════════════════ */
.tu-upload-row {
    display: grid; grid-template-columns: 260px 1fr; gap: 1.25rem;
    padding: 1.4rem 1.5rem; align-items: start;
}
@@media (max-width: 768px) { .tu-upload-row { grid-template-columns: 1fr; } }

.tu-form-group { display: flex; flex-direction: column; gap: .4rem; }
.tu-form-group label {
    display: flex; align-items: center; gap: .45rem;
    font-size: .85rem; font-weight: 700; color: var(--tu-text);
}
.tu-form-group label i { color: var(--tu-primary); font-size: .8rem; }
.tu-field-hint { display: flex; align-items: center; gap: .35rem; font-size: .75rem; color: var(--tu-muted); margin-top: .15rem; }
.tu-field-hint i { color: var(--tu-primary); flex-shrink: 0; }

.tu-select-container { position: relative; }
.tu-select {
    width: 100%; padding: .62rem 2.2rem .62rem .95rem;
    border: 1.5px solid var(--tu-border); border-radius: 10px;
    font-size: .9rem; color: var(--tu-text); background: var(--tu-light);
    appearance: none; outline: none; font-family: inherit; cursor: pointer;
    transition: border-color .2s, box-shadow .2s;
}
.tu-select:focus { border-color: var(--tu-primary); box-shadow: 0 0 0 3px rgba(27,174,190,.12); background: #fff; }
.tu-select-arrow { position: absolute; right: .85rem; top: 50%; transform: translateY(-50%); color: var(--tu-muted); font-size: .75rem; pointer-events: none; }

/* Queue list */
.tu-queue-label {
    font-size: .77rem; font-weight: 700; color: var(--tu-muted);
    display: flex; align-items: center; gap: .35rem; margin-bottom: .45rem;
}
.tu-queue-label i { color: var(--tu-primary); }
.tu-queue-item {
    display: flex; align-items: center; gap: .55rem;
    padding: .35rem .65rem; background: var(--tu-light);
    border: 1px solid var(--tu-border); border-radius: 8px; margin-bottom: .35rem;
    font-size: .79rem; color: var(--tu-text); animation: tuFadeIn .2s ease;
}
.tu-queue-item-name { display: flex; align-items: center; gap: .38rem; flex: 1; min-width: 0; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.tu-queue-item-name i { color: var(--tu-primary); flex-shrink: 0; }
.tu-queue-type { font-size: .7rem; font-weight: 700; color: var(--tu-primary); white-space: nowrap; flex-shrink: 0; }
.tu-queue-remove { background: none; border: none; cursor: pointer; color: var(--tu-muted); font-size: .74rem; padding: .18rem .3rem; border-radius: 4px; transition: color .2s; flex-shrink: 0; }
.tu-queue-remove:hover { color: #c62828; }
.tu-file-count-badge {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 20px; height: 20px; border-radius: 10px; padding: 0 .35rem;
    background: rgba(255,255,255,.22); font-size: .71rem; font-weight: 800; margin-left: .1rem;
}

/* Drop zone */
.tu-upload-zone {
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: .6rem;
    padding: 2.5rem 1.5rem; border: 2px dashed #c8d8e4; border-radius: 14px;
    background: #f8fafc; cursor: pointer; text-align: center; min-height: 215px;
    transition: border-color .2s, background .2s, box-shadow .2s;
}
.tu-upload-zone:hover, .tu-upload-zone.drag-over {
    border-color: var(--tu-primary); background: rgba(27,174,190,.04);
    box-shadow: 0 0 0 4px rgba(27,174,190,.08);
}
.tu-upload-icon-wrap {
    width: 64px; height: 64px; border-radius: 16px;
    background: rgba(27,174,190,.12); color: var(--tu-primary);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.7rem; transition: transform .2s;
}
.tu-upload-zone:hover .tu-upload-icon-wrap { transform: scale(1.08); }
.tu-upload-title { margin: 0; font-size: 1rem; font-weight: 700; color: var(--tu-text); }
.tu-upload-sub   { margin: 0; font-size: .85rem; color: var(--tu-muted); }
.tu-upload-link  { color: var(--tu-primary); font-weight: 600; text-decoration: underline; text-decoration-style: dotted; }
.tu-upload-hint  {
    display: inline-flex; align-items: center; gap: .4rem;
    background: var(--tu-light); border: 1px solid var(--tu-border);
    border-radius: 20px; padding: .3rem .85rem; font-size: .74rem; color: var(--tu-muted); margin-top: .1rem;
}

/* ════════════════════════════════════════════
   EXTRACTION PROGRESS
════════════════════════════════════════════ */
.tu-ext-bar-wrap { height: 4px; background: #e2e8f0; margin: 0 1.5rem; border-radius: 4px; overflow: hidden; }
.tu-ext-bar-fill {
    height: 100%; width: 0%; background: linear-gradient(90deg, var(--tu-primary), var(--tu-primary-dk));
    border-radius: 4px; transition: width .35s ease;
}
.tu-ext-status {
    padding: .6rem 1.5rem .85rem; font-size: .82rem; color: var(--tu-primary);
    font-weight: 600; display: flex; align-items: center; gap: .5rem; margin: 0;
}
.tu-ext-status::before {
    content: ''; display: inline-block; width: 8px; height: 8px; border-radius: 50%;
    background: var(--tu-primary); animation: tuPulse 1s infinite; flex-shrink: 0;
}

/* ════════════════════════════════════════════
   TEST REVIEW CARDS
════════════════════════════════════════════ */
.tu-test-card {
    border-top: 1px solid var(--tu-border);
    animation: tuFadeIn .35s ease; transition: background .2s;
}
.tu-test-card:first-child { border-top: none; }
.tu-test-card.approved    { background: rgba(27,174,190,.025); }

.tu-test-card-header {
    display: flex; justify-content: space-between; align-items: flex-start;
    flex-wrap: wrap; gap: .75rem;
    padding: .95rem 1.5rem; background: #fafbfc; border-bottom: 1px solid var(--tu-border);
}
.tu-test-card-header h4 {
    margin: 0 0 .2rem; font-size: .9rem; font-weight: 700; color: var(--tu-text);
    display: flex; align-items: center; gap: .45rem;
}
.tu-test-card-header h4 i { color: var(--tu-primary); }
.tu-test-meta { display: flex; align-items: center; gap: .85rem; flex-wrap: wrap; }
.tu-test-meta span { font-size: .75rem; color: var(--tu-muted); display: flex; align-items: center; gap: .3rem; }
.tu-test-meta span i { color: var(--tu-primary); }
.tu-confidence-pill {
    display: inline-flex; align-items: center; gap: .3rem; padding: .22rem .7rem;
    border-radius: 14px; background: rgba(27,174,190,.1); color: var(--tu-primary);
    font-size: .73rem; font-weight: 700; border: 1px solid rgba(27,174,190,.2);
}
.tu-test-actions { display: flex; align-items: center; gap: .55rem; flex-wrap: wrap; }

.tu-values-table-wrap { padding: .85rem 1.5rem; overflow-x: auto; }
.tu-values-table { width: 100%; border-collapse: collapse; font-size: .84rem; }
.tu-values-table thead th {
    padding: .52rem .85rem; text-align: left; font-size: .74rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .05em; color: var(--tu-muted);
    border-bottom: 1.5px solid var(--tu-border); white-space: nowrap;
}
.tu-values-table tbody tr { border-bottom: 1px solid var(--tu-border); transition: background .15s; }
.tu-values-table tbody tr:last-child { border-bottom: none; }
.tu-values-table tbody tr:hover { background: #f8fafc; }
.tu-values-table tbody td { padding: .58rem .85rem; color: var(--tu-text); vertical-align: middle; }

.tu-value-input {
    padding: .36rem .65rem; border: 1.5px solid var(--tu-border); border-radius: 8px;
    font-size: .84rem; color: var(--tu-text); background: var(--tu-light);
    outline: none; font-family: inherit; width: 110px;
    transition: border-color .2s, box-shadow .2s;
}
.tu-value-input:focus { border-color: var(--tu-primary); box-shadow: 0 0 0 3px rgba(27,174,190,.1); background: #fff; }
.tu-value-input:disabled { background: #f1f5f9; color: var(--tu-muted); cursor: default; }
.tu-value-unit { font-size: .76rem; color: var(--tu-muted); margin-left: .3rem; }

.tu-test-card-footer {
    padding: .8rem 1.5rem; border-top: 1px solid var(--tu-border);
    background: #fafbfc; display: flex; align-items: center; gap: .6rem; flex-wrap: wrap;
}

/* ════════════════════════════════════════════
   SUBMIT ROW
════════════════════════════════════════════ */
.tu-submit-row {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 1rem; padding: 1.1rem 1.5rem;
    border-top: 1.5px solid var(--tu-border); background: #fafbfc;
}
.tu-submit-info { display: flex; align-items: center; gap: .5rem; font-size: .82rem; color: var(--tu-muted); }
.tu-submit-info i { color: var(--tu-primary); flex-shrink: 0; }
.tu-approval-counter {
    font-size: .79rem; font-weight: 700; color: var(--tu-muted);
    padding: .28rem .72rem; background: var(--tu-light); border: 1px solid var(--tu-border); border-radius: 20px;
}

/* ════════════════════════════════════════════
   REPORT — LOADING STATE
════════════════════════════════════════════ */
.tu-report-loading { padding: 3rem 1.5rem; display: flex; justify-content: center; }
.tu-report-loading-inner { text-align: center; max-width: 400px; width: 100%; }
.tu-report-spinner {
    width: 72px; height: 72px; border-radius: 50%; margin: 0 auto 1rem;
    background: rgba(27,174,190,.1); color: var(--tu-primary);
    display: flex; align-items: center; justify-content: center; font-size: 1.8rem;
    animation: tuSpinPulse 2s ease-in-out infinite;
}
.tu-report-loading-inner h4 { margin: 0 0 .35rem; font-size: 1rem; font-weight: 700; color: var(--tu-text); }
.tu-report-loading-inner p  { margin: 0 0 1.25rem; font-size: .84rem; color: var(--tu-muted); }
.tu-loading-steps { display: flex; flex-direction: column; gap: .38rem; margin-bottom: 1.1rem; text-align: left; }
.tu-loading-step {
    display: flex; align-items: center; gap: .5rem; font-size: .8rem; color: var(--tu-muted);
    padding: .33rem .65rem; border-radius: 8px; transition: background .3s, color .3s;
}
.tu-loading-step i     { font-size: .74rem; width: 15px; text-align: center; flex-shrink: 0; }
.tu-loading-step.active{ color: var(--tu-primary); background: rgba(27,174,190,.07); font-weight: 600; }
.tu-loading-step.done  { color: #2e7d32; background: #f0fdf4; }
.tu-loading-bar { height: 5px; background: #e2e8f0; border-radius: 5px; overflow: hidden; }
.tu-loading-bar-fill {
    height: 100%; width: 0; border-radius: 5px;
    background: linear-gradient(90deg, var(--tu-primary), var(--tu-primary-dk));
    transition: width .5s ease;
}

/* ════════════════════════════════════════════
   REPORT — CONTENT
════════════════════════════════════════════ */
.tu-confidence-badge {
    display: inline-flex; align-items: center; gap: .4rem; padding: .32rem .85rem;
    border-radius: 20px; font-size: .75rem; font-weight: 700;
    background: rgba(27,174,190,.1); color: var(--tu-primary);
    border: 1px solid rgba(27,174,190,.2); white-space: nowrap;
}
.tu-report-verdict-row {
    display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
    padding: 1rem 1.5rem; border-bottom: 1px solid var(--tu-border);
}
.tu-verdict-badge {
    display: inline-flex; align-items: center; gap: .45rem; padding: .45rem 1.05rem;
    border-radius: 22px; font-size: .82rem; font-weight: 800; white-space: nowrap;
}
.tu-verdict-badge.safe    { background: #e8f5e9; color: #1b5e20; border: 1.5px solid #a5d6a7; }
.tu-verdict-badge.warning { background: #fff3e0; color: #b84700; border: 1.5px solid #ffcc80; }
.tu-verdict-badge.danger  { background: #ffebee; color: #b71c1c; border: 1.5px solid #ef9a9a; }
.tu-verdict-summary { margin: 0; font-size: .84rem; color: var(--tu-muted); }

.tu-report-summary {
    padding: 1.1rem 1.5rem; background: rgba(27,174,190,.04); border-bottom: 1px solid var(--tu-border);
}
.tu-report-summary h4 {
    margin: 0 0 .4rem; font-size: .92rem; font-weight: 700; color: var(--tu-text);
    display: flex; align-items: center; gap: .45rem;
}
.tu-report-summary h4 i { color: var(--tu-primary); }
.tu-report-summary p  { margin: 0; font-size: .84rem; color: var(--tu-muted); }

.tu-report-section { padding: 1.1rem 1.5rem; border-bottom: 1px solid var(--tu-border); }
.tu-report-section:last-of-type { border-bottom: none; }
.tu-report-section h5 {
    margin: 0 0 .85rem; font-size: .9rem; font-weight: 700; color: var(--tu-text);
    display: flex; align-items: center; gap: .45rem;
}
.tu-report-section h5 i { color: var(--tu-primary); }

/* Insight value cards */
.tu-insight-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: .8rem; }
.tu-insight-card {
    padding: .8rem 1rem; border-radius: 12px; border: 1.5px solid var(--tu-border);
    transition: box-shadow .2s, transform .2s;
}
.tu-insight-card:hover { box-shadow: var(--tu-shadow-hov); transform: translateY(-2px); }
.tu-insight-card.normal  { border-color: #a5d6a7; background: #f6fff8; }
.tu-insight-card.warning { border-color: #fde68a; background: #fffdf5; }
.tu-insight-card.high    { border-color: #ef9a9a; background: #fff8f8; }
.tu-insight-card.low     { border-color: #90caf9; background: #f0f8ff; }
.tu-insight-label { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--tu-muted); margin-bottom: .28rem; }
.tu-insight-value { font-size: 1.18rem; font-weight: 800; line-height: 1; margin-bottom: .2rem; }
.tu-insight-value .tu-insight-unit { font-size: .68em; font-weight: 600; margin-left: .18rem; }
.tu-insight-card.normal  .tu-insight-value { color: #1b5e20; }
.tu-insight-card.warning .tu-insight-value { color: #b84700; }
.tu-insight-card.high    .tu-insight-value { color: #b71c1c; }
.tu-insight-card.low     .tu-insight-value { color: #1565c0; }
.tu-insight-range { font-size: .7rem; color: var(--tu-muted); }
.tu-insight-dot {
    display: inline-block; width: 6px; height: 6px; border-radius: 50%; margin-right: .3rem; vertical-align: middle;
}
.tu-insight-card.normal  .tu-insight-dot { background: #4caf50; }
.tu-insight-card.warning .tu-insight-dot { background: #ff9800; }
.tu-insight-card.high    .tu-insight-dot { background: #f44336; }
.tu-insight-card.low     .tu-insight-dot { background: #2196f3; }

.tu-recommendations {
    padding: 1.1rem 1.5rem; background: #f6fff8; border-top: 1px solid var(--tu-border);
}
.tu-recommendations h4 {
    margin: 0 0 .65rem; font-size: .92rem; font-weight: 700; color: #1b5e20;
    display: flex; align-items: center; gap: .45rem;
}
.tu-rec-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: .42rem; }
.tu-rec-list li { display: flex; align-items: flex-start; gap: .55rem; font-size: .84rem; color: #2e7d32; line-height: 1.55; }
.tu-rec-list li i { color: #4caf50; margin-top: .18rem; flex-shrink: 0; }

.tu-report-actions {
    display: flex; align-items: center; gap: .75rem; flex-wrap: wrap;
    padding: 1.1rem 1.5rem; border-top: 1.5px solid var(--tu-border); background: #fafbfc;
}

/* ════════════════════════════════════════════
   STATUS BADGES
════════════════════════════════════════════ */
.tu-badge-status {
    display: inline-flex; align-items: center; gap: .3rem;
    padding: .28rem .75rem; border-radius: 20px; font-size: .75rem; font-weight: 700;
}
.tu-badge-status.reviewed { background: rgba(27,174,190,.1); color: var(--tu-primary); border: 1px solid rgba(27,174,190,.25); }
.tu-badge-status.normal   { background: #e8f5e9; color: #2e7d32;  border: 1px solid #a5d6a7; }
.tu-badge-status.warning  { background: #fff3e0; color: #e65100;  border: 1px solid #ffcc80; }
.tu-badge-status.low      { background: #e3f2fd; color: #1565c0;  border: 1px solid #90caf9; }
.tu-badge-status.high     { background: #ffebee; color: #c62828;  border: 1px solid #ef9a9a; }
.tu-badge-status.success  { background: #e8f5e9; color: #2e7d32;  border: 1px solid #a5d6a7; }
.tu-badge-status.pending  { background: #fff3e0; color: #e65100;  border: 1px solid #ffcc80; }

/* ════════════════════════════════════════════
   TEST HISTORY — CLEAN TABLE DESIGN
════════════════════════════════════════════ */

/* History Meta */
.tu-history-meta {
    display: flex;
    align-items: center;
    gap: .75rem;
}

.tu-history-count {
    font-size: .82rem;
    font-weight: 600;
    color: var(--tu-muted);
    padding: .3rem .75rem;
    background: var(--tu-light);
    border-radius: 20px;
    border: 1px solid var(--tu-border);
}

/* Empty State */
.tu-empty-state {
    text-align: center;
    padding: 3.5rem 2rem;
    color: var(--tu-muted);
}

.tu-empty-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 1rem;
    border-radius: 50%;
    background: var(--tu-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    color: var(--tu-primary);
}

.tu-empty-state h4 {
    margin: 0 0 .4rem;
    font-size: 1rem;
    font-weight: 700;
    color: var(--tu-text);
}

.tu-empty-state p {
    margin: 0;
    font-size: .85rem;
    color: var(--tu-muted);
}

/* Toolbar */
.tu-history-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--tu-border);
    background: #fafbfc;
    flex-wrap: wrap;
}

.tu-search-box {
    position: relative;
    flex: 1;
    min-width: 200px;
    max-width: 320px;
}

.tu-search-box i {
    position: absolute;
    left: .85rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--tu-muted);
    font-size: .8rem;
}

.tu-search-box input {
    width: 100%;
    padding: .55rem .85rem .55rem 2.5rem;
    border: 1px solid var(--tu-border);
    border-radius: 8px;
    font-size: .85rem;
    color: var(--tu-text);
    background: #fff;
    outline: none;
    transition: border-color .2s, box-shadow .2s;
}

.tu-search-box input:focus {
    border-color: var(--tu-primary);
    box-shadow: 0 0 0 3px rgba(27,174,190,.08);
}

.tu-filter-group {
    display: flex;
    gap: .5rem;
    flex-wrap: wrap;
}

.tu-filter-select {
    padding: .55rem .85rem;
    border: 1px solid var(--tu-border);
    border-radius: 8px;
    font-size: .82rem;
    color: var(--tu-text);
    background: #fff;
    cursor: pointer;
    outline: none;
    transition: border-color .2s;
}

.tu-filter-select:focus {
    border-color: var(--tu-primary);
}

/* Table */
.tu-history-table-wrap {
    overflow-x: auto;
}

.tu-history-table {
    width: 100%;
    border-collapse: collapse;
    font-size: .85rem;
}

.tu-history-table thead th {
    padding: .85rem 1.2rem;
    text-align: center;
    font-size: .75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .05em;
    color: var(--tu-muted);
    background: #fafbfc;
    border-bottom: 2px solid var(--tu-border);
    white-space: nowrap;
}

.tu-th-actions {
    text-align: center;
}

.tu-history-table tbody tr {
    border-bottom: 1px solid var(--tu-border);
    transition: background .15s;
}

.tu-history-table tbody tr:last-child {
    border-bottom: none;
}

.tu-history-table tbody tr:hover {
    background: #fafbfc;
}

.tu-history-table tbody td {
    padding: 1rem 1.2rem;
    color: var(--tu-text);
    vertical-align: middle;
    text-align: center;
}

/* Date Column */
.tu-history-date {
    display: block;
    font-size: .85rem;
    font-weight: 600;
    color: var(--tu-text);
    margin-bottom: .1rem;
}

.tu-history-time {
    display: block;
    font-size: .75rem;
    color: var(--tu-muted);
}

/* Test Type Column */
.tu-test-type-cell {
    display: flex;
    flex-direction: column;
    gap: .2rem;
}

.tu-test-type-single,
.tu-test-type-main {
    font-size: .85rem;
    font-weight: 600;
    color: var(--tu-text);
}

.tu-test-type-extra {
    font-size: .75rem;
    color: var(--tu-muted);
}

/* Status Column */
.tu-status-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: .5rem;
    vertical-align: middle;
}

.tu-status-dot.reviewed {
    background: var(--tu-primary);
}

.tu-status-dot.pending {
    background: #f59e0b;
}

.tu-status-text {
    font-size: .82rem;
    font-weight: 500;
    color: var(--tu-text);
}

/* Result Column */
.tu-result-badge {
    display: inline-block;
    padding: .3rem .7rem;
    border-radius: 6px;
    font-size: .78rem;
    font-weight: 700;
    white-space: nowrap;
}

.tu-result-badge.normal {
    background: #e8f5e9;
    color: #2e7d32;
}

.tu-result-badge.warning {
    background: #fff3e0;
    color: #e65100;
}

.tu-result-badge.high {
    background: #ffebee;
    color: #c62828;
}

.tu-result-pending {
    color: var(--tu-muted);
    font-size: .82rem;
}

/* Actions Column */
.tu-actions-cell {
    text-align: center;
    width: 180px;
}

.tu-action-btns {
    display: inline-flex;
    gap: .4rem;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
}

.tu-action-btn {
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--tu-border);
    border-radius: 6px;
    background: #fff;
    color: var(--tu-muted);
    font-size: .8rem;
    cursor: pointer;
    transition: all .2s;
}

.tu-action-btn:hover {
    background: var(--tu-light);
    border-color: var(--tu-primary);
    color: var(--tu-primary);
}

.tu-action-primary {
    border-color: var(--tu-primary);
    color: var(--tu-primary);
    background: rgba(27,174,190,.05);
}

.tu-action-primary:hover {
    background: var(--tu-primary);
    color: #fff;
}

.tu-processing-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    color: var(--tu-muted);
    font-size: .75rem;
}

/* Pagination */
.tu-pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    border-top: 1px solid var(--tu-border);
    background: #fafbfc;
    gap: 1rem;
    flex-wrap: wrap;
}

.tu-pagination-info {
    font-size: .8rem;
    color: var(--tu-muted);
}

.tu-pagination-controls {
    display: flex;
    align-items: center;
    gap: .5rem;
}

.tu-page-btn {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--tu-border);
    border-radius: 6px;
    background: #fff;
    color: var(--tu-muted);
    font-size: .75rem;
    cursor: pointer;
    transition: all .2s;
}

.tu-page-btn:hover:not(:disabled) {
    background: var(--tu-primary);
    border-color: var(--tu-primary);
    color: #fff;
}

.tu-page-btn:disabled {
    opacity: .4;
    cursor: not-allowed;
}

.tu-page-numbers {
    display: flex;
    gap: .3rem;
}

.tu-page-num {
    min-width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 .5rem;
    border: 1px solid var(--tu-border);
    border-radius: 6px;
    background: #fff;
    color: var(--tu-text);
    font-size: .82rem;
    font-weight: 600;
    cursor: pointer;
    transition: all .2s;
}

.tu-page-num:hover {
    background: var(--tu-light);
    border-color: var(--tu-primary);
}

.tu-page-num.active {
    background: var(--tu-primary);
    border-color: var(--tu-primary);
    color: #fff;
}

.tu-pagination-size {
    margin-left: auto;
}

.tu-page-size-select {
    padding: .45rem .7rem;
    border: 1px solid var(--tu-border);
    border-radius: 6px;
    font-size: .8rem;
    color: var(--tu-text);
    background: #fff;
    cursor: pointer;
    outline: none;
}

/* Responsive */
@@media (max-width: 768px) {
    .tu-history-toolbar {
        flex-direction: column;
        align-items: stretch;
    }
    
    .tu-search-box {
        max-width: none;
    }
    
    .tu-filter-group {
        width: 100%;
    }
    
    .tu-filter-select {
        flex: 1;
    }
    
    .tu-pagination {
        flex-direction: column;
        gap: .75rem;
    }
    
    .tu-pagination-info,
    .tu-pagination-size {
        margin: 0;
        width: 100%;
        text-align: center;
    }
    
    .tu-history-table {
        font-size: .8rem;
    }
    
    .tu-history-table thead th,
    .tu-history-table tbody td {
        padding: .75rem .8rem;
        text-align: center;
    }
}

/* ════════════════════════════════════════════
   BUTTONS
════════════════════════════════════════════ */
.tu-btn {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .6rem 1.3rem; border-radius: 10px;
    font-size: .85rem; font-weight: 700; cursor: pointer; border: none;
    font-family: inherit; transition: all .2s;
}
.tu-btn:hover:not(:disabled) { transform: translateY(-1px); }
.tu-btn:disabled { opacity: .55; cursor: not-allowed; transform: none !important; }
.tu-btn-primary {
    background: linear-gradient(135deg, var(--tu-primary), var(--tu-primary-dk));
    color: #fff; box-shadow: 0 3px 10px rgba(27,174,190,.3);
}
.tu-btn-primary:hover:not(:disabled) { box-shadow: 0 5px 18px rgba(27,174,190,.45); }
.tu-btn-outline { background: transparent; color: var(--tu-primary); border: 1.5px solid var(--tu-primary); }
.tu-btn-outline:hover:not(:disabled) { background: rgba(27,174,190,.06); }
.tu-btn-ghost { background: var(--tu-light); color: var(--tu-muted); border: 1.5px solid var(--tu-border); }
.tu-btn-ghost:hover:not(:disabled) { background: #f1f5f9; border-color: #cbd5e1; }
.tu-btn-danger-ghost { background: transparent; color: #c62828; border: 1.5px solid #ef9a9a; font-size: .8rem; padding: .42rem 1rem; }
.tu-btn-danger-ghost:hover:not(:disabled) { background: #ffebee; }
.tu-btn-sm {
    padding: .38rem .9rem; font-size: .8rem; border-radius: 8px;
    background: var(--tu-light); color: var(--tu-text); border: 1.5px solid var(--tu-border);
}
.tu-btn-sm:hover:not(:disabled) { background: #f1f5f9; border-color: #cbd5e1; }
.tu-btn-sm.approve {
    background: linear-gradient(135deg, var(--tu-primary), var(--tu-primary-dk));
    color: #fff; border-color: transparent; box-shadow: 0 2px 8px rgba(27,174,190,.25);
}
.tu-btn-sm.approve:hover:not(:disabled) { box-shadow: 0 4px 12px rgba(27,174,190,.4); }
.tu-btn-lg { padding: .72rem 1.6rem; font-size: .9rem; }

/* ════════════════════════════════════════════
   PERSONAL INFO GRID
════════════════════════════════════════════ */
.tu-pi-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: .7rem;
}
.tu-pi-card {
    display: flex; align-items: center; gap: .7rem;
    padding: .7rem .9rem; border-radius: 12px;
    background: var(--tu-light); border: 1.5px solid var(--tu-border);
    transition: box-shadow .2s, transform .2s;
}
.tu-pi-card:hover { box-shadow: var(--tu-shadow); transform: translateY(-1px); }
.tu-pi-icon {
    width: 36px; height: 36px; border-radius: 10px; flex-shrink: 0;
    background: rgba(27,174,190,.1); color: var(--tu-primary);
    display: flex; align-items: center; justify-content: center; font-size: .85rem;
}
.tu-pi-info { display: flex; flex-direction: column; min-width: 0; }
.tu-pi-label { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; color: var(--tu-muted); }
.tu-pi-value { font-size: .92rem; font-weight: 700; color: var(--tu-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* ════════════════════════════════════════════
   RISK PREDICTION BANNER
════════════════════════════════════════════ */
.tu-risk-banner {
    display: flex; align-items: center; gap: 1rem;
    padding: 1rem 1.3rem; border-radius: 14px;
    font-size: .95rem; font-weight: 600;
}
.tu-risk-banner i { font-size: 1.5rem; flex-shrink: 0; }
.tu-risk-banner.safe    { background: #e8f5e9; color: #1b5e20; border: 1.5px solid #a5d6a7; }
.tu-risk-banner.warning { background: #fff3e0; color: #b84700; border: 1.5px solid #ffcc80; }
.tu-risk-banner.danger  { background: #ffebee; color: #b71c1c; border: 1.5px solid #ef9a9a; }
.tu-risk-conf { display: block; font-size: .78rem; font-weight: 600; opacity: .8; margin-top: .15rem; }

/* ════════════════════════════════════════════
   AI MEDICAL REPORT TEXT
════════════════════════════════════════════ */
.tu-ai-report-section { background: rgba(27,174,190,.02); }
.tu-ai-report-body { padding: .5rem 0; line-height: 1.7; }
.tu-report-heading {
    margin: 1rem 0 .4rem; font-size: .92rem; font-weight: 800; color: var(--tu-text);
    padding-bottom: .3rem; border-bottom: 2px solid rgba(27,174,190,.2);
}
.tu-report-para { margin: 0 0 .6rem; font-size: .86rem; color: #334155; line-height: 1.7; }
.tu-report-bullet {
    display: flex; align-items: flex-start; gap: .5rem;
    margin: 0 0 .4rem; font-size: .84rem; color: #334155; line-height: 1.6;
    list-style: none; padding-left: .5rem;
}
.tu-report-bullet i { color: var(--tu-primary); margin-top: .22rem; flex-shrink: 0; font-size: .7rem; }

/* ════════════════════════════════════════════
   ANIMATIONS
════════════════════════════════════════════ */
@@keyframes tuFadeIn    { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
@@keyframes tuPulse     { 0%,100% { opacity:1; transform:scale(1); } 50% { opacity:.45; transform:scale(.75); } }
@@keyframes tuSpinPulse { 0%,100% { transform:scale(1); opacity:1; } 50% { transform:scale(1.07); opacity:.65); } }

/* ════════════════════════════════════════════
   REPORT MODAL
════════════════════════════════════════════ */
.tu-modal-overlay {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(15,35,60,.65); backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
    padding: 1rem; animation: tuFadeIn .2s ease;
}
.tu-modal {
    background: #fff; border-radius: 20px;
    width: 100%; max-width: 860px; max-height: 92vh;
    display: flex; flex-direction: column;
    box-shadow: 0 24px 80px rgba(0,0,0,.22);
    overflow: hidden; animation: tuSlideUp .25s ease;
}
@@keyframes tuSlideUp { from { opacity:0; transform: translateY(24px); } to { opacity:1; transform: translateY(0); } }
.tu-modal-hdr {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: .75rem; flex-wrap: wrap;
    padding: 1.3rem 1.5rem; border-bottom: 1.5px solid var(--tu-border);
    background: linear-gradient(135deg,#0f2942 0%,#1a4a6e 50%,#0d3d5c 100%);
    flex-shrink: 0;
}
.tu-modal-hdr-left  { display: flex; align-items: flex-start; gap: .75rem; }
.tu-modal-hdr-left h3 { margin:0 0 .1rem; font-size:1rem; font-weight:800; color:#f1f5f9; }
.tu-modal-hdr-left p  { margin:0; font-size:.78rem; color:#94a3b8; }
.tu-modal-hdr-right { display:flex; align-items:center; gap:.65rem; flex-wrap:wrap; }
.tu-modal-close-btn {
    width:34px; height:34px; border-radius:50%; border:1.5px solid rgba(255,255,255,.25);
    background:rgba(255,255,255,.1); color:#e2e8f0; cursor:pointer;
    display:flex; align-items:center; justify-content:center; font-size:.85rem;
    transition: background .2s;
}
.tu-modal-close-btn:hover { background:rgba(255,255,255,.22); }
.tu-modal-hdr .tu-card-icon-wrap { background:rgba(27,174,190,.25); color:#7de8f4; flex-shrink:0; }

.tu-modal-body {
    overflow-y: auto; flex: 1;
    scrollbar-width: thin; scrollbar-color: var(--tu-border) transparent;
}
.tu-modal-loading-wrap {
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    padding:3.5rem 1.5rem; color:var(--tu-muted); gap:.85rem;
}
.tu-modal-loading-wrap .tu-report-spinner { animation:tuSpinPulse 1.4s ease-in-out infinite; font-size:2.4rem; color:var(--tu-primary); }
.tu-modal-loading-wrap p { margin:0; font-size:.9rem; }
.tu-modal-footer {
    padding:.9rem 1.5rem; border-top:1.5px solid var(--tu-border);
    background:#fafbfc; display:flex; align-items:center; justify-content:flex-end;
    gap:.65rem; flex-shrink:0;
}
.tu-btn-view-report {
    background:rgba(27,174,190,.08); color:var(--tu-primary);
    border:1.5px solid rgba(27,174,190,.3); gap:.35rem;
}
.tu-btn-view-report:hover:not(:disabled) { background:rgba(27,174,190,.16); border-color:var(--tu-primary); }
.tu-pending-label { font-size:.75rem; color:var(--tu-muted); display:inline-flex; align-items:center; gap:.3rem; }
.tu-pending-label i { font-size:.7rem; }
.tu-test-names-cell { display:flex; flex-wrap:wrap; gap:.3rem; align-items:center; }
.tu-test-badge {
    display:inline-flex; align-items:center;
    padding:.18rem .6rem; border-radius:20px;
    background:rgba(27,174,190,.08); border:1px solid rgba(27,174,190,.22);
    color:var(--tu-primary); font-size:.75rem; font-weight:600; white-space:nowrap;
}
.tu-test-badge-js {
    display:inline-flex; align-items:center;
    padding:.18rem .6rem; border-radius:20px;
    background:rgba(27,174,190,.08); border:1px solid rgba(27,174,190,.22);
    color:var(--tu-primary); font-size:.75rem; font-weight:600; white-space:nowrap;
}
  .tu-action-cell { display:flex; flex-direction:row; gap:.45rem; align-items:center; justify-content:center; flex-wrap:wrap; }
  .tu-btn-view-images {
      background:rgba(120,80,200,.08); color:#7850c8;
      border:1.5px solid rgba(120,80,200,.25); gap:.35rem;
  }
  .tu-btn-view-images:hover:not(:disabled) { background:rgba(120,80,200,.15); border-color:#7850c8; }
  .tu-btn-view-images,
  .tu-btn-view-report {
      justify-content: center;
  }
  .tu-gallery-overlay {
      position:fixed; inset:0; background:rgba(10,20,40,.55); backdrop-filter:blur(4px);
      display:flex; align-items:center; justify-content:center; z-index:1100; padding:1rem;
  }
  .tu-gallery {
      background:#fff; border-radius:1.2rem; width:100%; max-width:720px;
      max-height:88vh; display:flex; flex-direction:column; overflow:hidden;
      box-shadow:0 20px 60px rgba(10,20,40,.22);
  }
  .tu-gallery-hdr {
      display:flex; align-items:center; justify-content:space-between;
      padding:1.1rem 1.4rem; border-bottom:1.5px solid var(--tu-border); flex-shrink:0;
  }
  .tu-gallery-hdr-left { display:flex; align-items:center; gap:.8rem; }
  .tu-gallery-hdr-left h4 { margin:0; font-size:1rem; font-weight:700; color:var(--tu-dark); }
  .tu-gallery-body { overflow-y:auto; padding:1.4rem; flex:1; }
  .tu-gallery-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:1rem; }
  .tu-gallery-item {
      border-radius:.75rem; overflow:hidden; border:1.5px solid var(--tu-border);
      background:#f8f9fb; transition:box-shadow .2s,transform .2s; cursor:pointer;
  }
  .tu-gallery-item:hover { box-shadow:0 6px 20px rgba(27,174,190,.18); transform:translateY(-2px); }
  .tu-gallery-item a { display:flex; flex-direction:column; text-decoration:none; color:inherit; }
  .tu-gallery-item img { width:100%; height:160px; object-fit:cover; display:block; }
  .tu-gallery-item-name {
      padding:.5rem .7rem; font-size:.78rem; font-weight:600;
      color:var(--tu-dark); text-align:center; background:#fff;
      border-top:1px solid var(--tu-border); white-space:nowrap;
      overflow:hidden; text-overflow:ellipsis;
  }
  .tu-gallery-pdf {
      display:flex; flex-direction:column; align-items:center; justify-content:center;
      padding:1.5rem 1rem; min-height:160px;
  }
  .tu-gallery-pdf a { display:flex; flex-direction:column; align-items:center; gap:.5rem; text-decoration:none; color:inherit; }
  .tu-gallery-pdf .fa-file-pdf { font-size:3rem; color:#e63946; }
  .tu-gallery-pdf .tu-gallery-item-name { border-top:none; background:transparent; }
  .tu-gallery-hint { text-align:center; margin-top:.8rem; font-size:.78rem; color:var(--tu-muted); }
  .tu-modal-close {
      width:34px; height:34px; border-radius:50%; border:none;
      background:var(--tu-light); color:var(--tu-text); cursor:pointer;
      display:flex; align-items:center; justify-content:center; font-size:.85rem;
      transition: background .2s;
  }
  .tu-modal-close:hover { background:#e2e8f0; }

</style>
}

@section Scripts {
<script>
(function () {
    'use strict';

    const TOKEN = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

    /* ══════════════════════════════════════════════════════
       TEST CONFIGURATIONS
    ══════════════════════════════════════════════════════ */
    const testConfigurations = {
        cbc: {
            name: 'CBC (Complete Blood Count)',
            parameters: [
                { key: 'hb',              name: 'Hemoglobin (HB)', unit: 'g/dL',         normalRange: '12–16'           },
                { key: 'wbc',             name: 'WBC Count',        unit: '/µL',           normalRange: '4000–11000'      },
                { key: 'rbcs_count',      name: 'RBC Count',        unit: 'million/µL',    normalRange: '4.2–5.4'         },
                { key: 'mcv',             name: 'MCV',              unit: 'fL',            normalRange: '80–100'          },
                { key: 'mch',             name: 'MCH',              unit: 'pg',            normalRange: '27–33'           },
                { key: 'mchc',            name: 'MCHC',             unit: 'g/dL',          normalRange: '32–36'           },
                { key: 'lymphocytes',     name: 'Lymphocytes',      unit: '%',             normalRange: '20–40'           },
                { key: 'platelet_count',  name: 'Platelets',        unit: '/µL',           normalRange: '150000–400000'   }
            ]
        },
        urinalysis: {
            name: 'Urinalysis',
            parameters: [
                { key: 'color',            name: 'Color',            unit: '',        normalRange: 'Light Yellow'  },
                { key: 'ph',               name: 'pH',               unit: '',        normalRange: '4.5–8.0'       },
                { key: 'specific_gravity', name: 'Specific Gravity', unit: '',        normalRange: '1.005–1.030'   },
                { key: 'protein',          name: 'Protein',          unit: '',        normalRange: 'Negative'      },
                { key: 'glucose',          name: 'Glucose',          unit: '',        normalRange: 'Negative'      },
                { key: 'ketones',          name: 'Ketones',          unit: '',        normalRange: 'Negative'      },
                { key: 'blood',            name: 'Blood',            unit: '',        normalRange: 'Negative'      },
                { key: 'rbcs',             name: 'RBCs',             unit: '/HPF',    normalRange: '0–5'           },
                { key: 'leukocytes',       name: 'Leukocytes',       unit: '/HPF',    normalRange: '0–5'           },
                { key: 'nitrite',          name: 'Nitrite',          unit: '',        normalRange: 'Negative'      }
            ]
        },
        tsh: {
            name: 'TSH (Thyroid)',
            parameters: [
                { key: 'tsh', name: 'TSH', unit: 'mIU/L', normalRange: '0.4–4.0' }
            ]
        },
        ferritin: {
            name: 'Ferritin',
            parameters: [
                { key: 'ferritin_value', name: 'Ferritin', unit: 'ng/mL', normalRange: '12–150' }
            ]
        },
        fbg: {
            name: 'Fasting Blood Glucose',
            parameters: [
                { key: 'fbg', name: 'FBG', unit: 'mg/dL', normalRange: '70–100' }
            ]
        },
        hba1c: {
            name: 'HbA1c (Sugar Test)',
            parameters: [
                { key: 'hba1c', name: 'HbA1c', unit: '%', normalRange: '4.0–5.6' }
            ]
        },
        hcv: {
            name: 'HCV (Hepatitis C)',
            parameters: [
                { key: 'hcv', name: 'HCV', unit: '', normalRange: 'Non-Reactive' }
            ]
        },
        hbsag: {
            name: 'HBsAg (Hepatitis B)',
            parameters: [
                { key: 'hbsag', name: 'HBsAg', unit: '', normalRange: 'Non-Reactive' }
            ]
        },
        bloodgroup: {
            name: 'Blood Group',
            parameters: [
                { key: 'abo_group', name: 'ABO Group', unit: '', normalRange: 'A/B/AB/O' },
                { key: 'rh_factor', name: 'Rh Factor', unit: '', normalRange: '+/–'       }
            ]
        }
    };

    async function apiExtractValues(testType, file) {
        const formData = new FormData();
        formData.append('patientId', document.body.dataset.patientId || '0');
        formData.append('testType', testType);
        formData.append('image', file);
        formData.append('__RequestVerificationToken', TOKEN);

        const reportId = uploadedTests[0]?.reportId;
        if (reportId) {
            formData.append('reportId', reportId);
        }

        const response = await fetchWithTimeout('/api/analysis', {
            method: 'POST',
            body: formData
        }, 45000);

        if (!response.ok) {
            const error = await safeReadError(response);
            throw new Error(error || 'Failed to extract values from the uploaded image.');
        }

        const data = await response.json();
        return {
            id: data.labTestId,
            reportId: data.reportId,
            testType,
            testTypeName: data.testName || testConfigurations[testType].name,
            fileName: file.name,
            confidence: data.confidence ?? '—',
            extractedValues: data.extractedValues || {}
        };
    }

    async function apiAnalyzeTests(tests) {
        const confirmPromises = tests.map(test => {
            const payload = { values: test.extractedValues };
            return fetchWithTimeout(`/api/analysis/${test.id}/confirm`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': TOKEN
            },
                body: JSON.stringify(payload)
            }, 45000).then(async response => {
                if (!response.ok) {
                    const error = await safeReadError(response);
                    throw new Error(error || 'Failed to confirm test values.');
                }
                return response.json();
            });
        });

        await Promise.all(confirmPromises);
        const lastTest = tests[tests.length - 1];
        return waitForAnalysisResult(lastTest.id);
    }

    async function waitForAnalysisResult(labTestId) {
        const maxAttempts = 20;
        for (let attempt = 0; attempt < maxAttempts; attempt++) {
            const response = await fetchWithTimeout(`/api/analysis/${labTestId}`, {}, 15000);
            if (!response.ok) {
                const error = await safeReadError(response);
                throw new Error(error || 'Failed to fetch analysis status.');
            }
            const data = await response.json();
            if (data.status === 'Completed') {
                return mapAnalysisResponse(data);
            }
            if (data.status === 'Failed') {
                throw new Error('Analysis failed.');
            }
            await delay(2000);
        }
        throw new Error('Analysis is taking too long. Please try again later.');
    }

    async function fetchWithTimeout(url, options, timeoutMs) {
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), timeoutMs);
        try {
            return await fetch(url, { ...options, signal: controller.signal });
        } finally {
            clearTimeout(timeout);
        }
    }

    async function safeReadError(response) {
        try {
            const data = await response.json();
            return data.error || data.message || null;
        } catch {
            return null;
        }
    }

    function mapAnalysisResponse(data) {
        const tests = data.tests || [];
        let hasHigh = false;
        let hasLow = false;
        tests.forEach(test => {
            const config = resolveTestConfig(test.test_name);
            if (!config) return;
            config.parameters.forEach(p => {
                const s = getParamStatus(extractValue(test, p.key), p.normalRange);
                if (s === 'high') hasHigh = true;
                if (s === 'low') hasLow = true;
            });
        });

        const verdict = hasHigh ? 'danger' : hasLow ? 'warning' : 'safe';
        const overall = hasHigh ? 'Abnormal Values Detected'
            : hasLow ? 'Some Values Below Normal'
                : 'All Values Normal';

        // Extract risk from result_3 (can be object or array)
        const riskRaw = data.riskPrediction;
        let riskObj = {};
        if (riskRaw && typeof riskRaw === 'object' && !Array.isArray(riskRaw)) {
            riskObj = riskRaw;
        } else if (Array.isArray(riskRaw)) {
            for (let i = riskRaw.length - 1; i >= 0; i--) {
                if (riskRaw[i] && typeof riskRaw[i] === 'object' && Object.keys(riskRaw[i]).length > 0) { riskObj = riskRaw[i]; break; }
            }
        }

        return {
            verdict,
            overall,
            personalInfo: data.personalInfo || null,
            confidence: riskObj.confidence ?? '—',
            diabetesStatus: riskObj.diabetes_status || null,
            recommendations: data.alerts || [],
            tests,
            riskLevel: riskObj.risk_level || null,
            report: data.report || null
        };
    }

    function resolveTestConfig(testName) {
        if (!testName) return null;
        const normalized = testName.toLowerCase();
        return Object.values(testConfigurations).find(cfg => cfg.name.toLowerCase() === normalized)
            || Object.values(testConfigurations).find(cfg => normalized.includes(cfg.name.toLowerCase()));
    }

    /* ══════════════════════════════════════════════════════
       STATE
    ══════════════════════════════════════════════════════ */
    let queuedFiles  = [];   // { file, testType }
    let uploadedTests = [];  // extracted + { id, approved, reportId }

    /* ══════════════════════════════════════════════════════
       DOM REFS
    ══════════════════════════════════════════════════════ */
    const uploadZone           = document.getElementById('uploadZone');
    const fileInput            = document.getElementById('fileInput');
    const testTypeSelect       = document.getElementById('testType');
    const sendToAIBtn          = document.getElementById('sendToAIBtn');
    const addMoreBtn           = document.getElementById('addMoreTests');
    const fileCountBadge       = document.getElementById('fileCountBadge');
    const queuedFilesList      = document.getElementById('queuedFilesList');
    const queuedFilesInner     = document.getElementById('queuedFilesInner');

    const uploadedTestsSection = document.getElementById('uploadedTestsSection');
    const uploadedTestsList    = document.getElementById('uploadedTestsList');
    const extractionProgress   = document.getElementById('extractionProgress');
    const extractionBarFill    = document.getElementById('extractionBarFill');
    const extractionStatus     = document.getElementById('extractionStatus');
    const submitRow            = document.getElementById('submitRow');
    const submitAllBtn         = document.getElementById('submitAllTests');
    const approvalCounter      = document.getElementById('approvalCounter');
    const clearAllBtn          = document.getElementById('clearAllTests');

    const comprehensiveResults = document.getElementById('comprehensiveResults');
    const reportLoading        = document.getElementById('reportLoading');
    const reportReady          = document.getElementById('reportReady');
    const loadingStepsEl       = document.getElementById('loadingSteps');
    const reportBarFill        = document.getElementById('reportBarFill');
    const overallConfidence    = document.getElementById('overallConfidence');
    const reportVerdictRow     = document.getElementById('reportVerdictRow');
    const reportContent        = document.getElementById('comprehensiveReportContent');
    const uploadMoreBtn        = document.getElementById('uploadMoreBtn');

    /* ══════════════════════════════════════════════════════
       PROGRESS STEPPER
    ══════════════════════════════════════════════════════ */
    function setStep(n) {
        [1, 2, 3].forEach(i => {
            const el = document.getElementById('step' + i);
            if (!el) return;
            el.classList.remove('active', 'completed');
            if (i < n)  el.classList.add('completed');
            if (i === n) el.classList.add('active');
            // Show checkmark vs number
            const num   = el.querySelector('.tu-step-num');
            const check = el.querySelector('.tu-step-check');
            if (num)   num.style.display   = i < n ? 'none' : '';
            if (check) check.style.display = i < n ? 'inline' : 'none';
        });
        const c1 = document.getElementById('conn1');
        const c2 = document.getElementById('conn2');
        if (c1) c1.classList.toggle('active', n >= 2);
        if (c2) c2.classList.toggle('active', n >= 3);
    }

    /* ══════════════════════════════════════════════════════
       UPLOAD ZONE
    ══════════════════════════════════════════════════════ */
    uploadZone.addEventListener('click', () => fileInput.click());
    uploadZone.addEventListener('dragover',  e => { e.preventDefault(); uploadZone.classList.add('drag-over'); });
    uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-over'));
    uploadZone.addEventListener('drop', e => {
        e.preventDefault(); uploadZone.classList.remove('drag-over');
        if (e.dataTransfer.files.length) enqueueFiles(e.dataTransfer.files);
    });
    fileInput.addEventListener('change', () => {
        if (fileInput.files.length) enqueueFiles(fileInput.files);
        fileInput.value = '';
    });
    addMoreBtn.addEventListener('click', () => fileInput.click());

    function enqueueFiles(files) {
        const type = testTypeSelect.value;
        if (!type) { notify('Please select a test type first.', 'warning'); return; }
        Array.from(files).forEach(f => {
            if (f.size > 10 * 1024 * 1024) { notify('"' + f.name + '" exceeds 10 MB.', 'error'); return; }
            queuedFiles.push({ file: f, testType: type });
        });
        renderQueue();
    }

    function renderQueue() {
        if (!queuedFiles.length) {
            queuedFilesList.style.display = 'none';
            sendToAIBtn.style.display     = 'none';
            return;
        }
        queuedFilesList.style.display = 'block';
        sendToAIBtn.style.display     = 'inline-flex';
        fileCountBadge.textContent    = queuedFiles.length;

        queuedFilesInner.innerHTML = '';
        queuedFiles.forEach((item, idx) => {
            const div = document.createElement('div');
            div.className = 'tu-queue-item';
            div.innerHTML =
                '<span class="tu-queue-item-name"><i class="fas fa-file-image"></i>'
                + '<span>' + escHtml(item.file.name) + '</span>'
                + '<span style="font-size:.7rem;color:var(--tu-muted);margin-left:.2rem">' + Math.round(item.file.size / 1024) + ' KB</span>'
                + '</span>'
                + '<span class="tu-queue-type">' + escHtml(testConfigurations[item.testType].name) + '</span>'
                + '<button class="tu-queue-remove" type="button" data-idx="' + idx + '" title="Remove"><i class="fas fa-times"></i></button>';

            div.querySelector('.tu-queue-remove').addEventListener('click', function () {
                queuedFiles.splice(parseInt(this.dataset.idx), 1);
                renderQueue();
            });
            queuedFilesInner.appendChild(div);
        });
    }

    /* ══════════════════════════════════════════════════════
       STEP 1 → 2  :  SEND TO AI (OCR EXTRACTION)
    ══════════════════════════════════════════════════════ */
    sendToAIBtn.addEventListener('click', async () => {
        if (!queuedFiles.length) return;
        if (!document.body.dataset.patientId || document.body.dataset.patientId === '0') {
            notify('Patient profile not found. Please refresh and try again.', 'error');
            return;
        }
        const batch = [...queuedFiles];
        queuedFiles = [];
        renderQueue();

        // Show step 2 section
        uploadedTestsSection.style.display = 'block';
        uploadedTestsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        setStep(2);
        extractionProgress.style.display = 'block';
        submitRow.style.display = 'none';

        sendToAIBtn.disabled = true;
        sendToAIBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Extracting…';

        for (let i = 0; i < batch.length; i++) {
            const pct = Math.round((i / batch.length) * 90);
            extractionBarFill.style.width = pct + '%';
            extractionStatus.textContent  = 'Reading "' + batch[i].file.name + '" (' + (i + 1) + ' of ' + batch.length + ')…';

            try {
                const result = await apiExtractValues(batch[i].testType, batch[i].file);

                result.approved = false;
                uploadedTests.push(result);
                renderTestCard(result);
            } catch (err) {
                notify(err?.message || 'Failed to extract values.', 'error');
            }
        }

        extractionBarFill.style.width = '100%';
        extractionStatus.textContent  = 'Extraction complete — please review the values below.';
        await delay(700);
        extractionProgress.style.display = 'none';
        submitRow.style.display          = 'flex';
        updateApprovalCounter();

        sendToAIBtn.disabled = false;
        sendToAIBtn.innerHTML = '<i class="fas fa-paper-plane"></i> Send to AI for Extraction <span class="tu-file-count-badge" id="fileCountBadge">0</span>';
    });

    /* ══════════════════════════════════════════════════════
       RENDER REVIEW CARD
    ══════════════════════════════════════════════════════ */
    function renderTestCard(testData) {
        document.getElementById('test-' + testData.id)?.remove();
        const cfg  = testConfigurations[testData.testType];
        const card = document.createElement('div');
        card.className = 'tu-test-card' + (testData.approved ? ' approved' : '');
        card.id = 'test-' + testData.id;

        let rows = '';
        cfg.parameters.forEach(param => {
            const val    = extractValue(testData.extractedValues, param.key) ?? '';
            const status = getParamStatus(val, param.normalRange);
            rows += '<tr>'
                + '<td style="font-weight:600">' + escHtml(param.name) + '</td>'
                + '<td><input class="tu-value-input" type="text" data-param="' + escHtml(param.key) + '"'
                + ' value="' + escHtml(String(val)) + '"'
                + (testData.approved ? ' disabled' : '') + '>'
                + '<span class="tu-value-unit">' + escHtml(param.unit) + '</span></td>'
                + '<td style="font-size:.82rem;color:var(--tu-muted)">' + escHtml(param.normalRange) + (param.unit ? ' ' + param.unit : '') + '</td>'
                + '<td><span class="tu-badge-status ' + status + '">' + status + '</span></td>'
                + '</tr>';
        });

        const approvedBadge = testData.approved
            ? '<span class="tu-badge-status success"><i class="fas fa-check-circle"></i> Approved</span>'
            : '<span class="tu-badge-status pending"><i class="fas fa-clock"></i> Pending Review</span>';

        const footerBtns = testData.approved
            ? '<button class="tu-btn tu-btn-sm" data-action="unapprove" type="button"><i class="fas fa-undo"></i> Edit Again</button>'
            : '<button class="tu-btn tu-btn-sm" data-action="edit" type="button"><i class="fas fa-edit"></i> Edit Values</button>'
              + '<button class="tu-btn tu-btn-sm approve" data-action="approve" type="button"><i class="fas fa-check"></i> Approve &amp; Confirm</button>';

        card.innerHTML =
            '<div class="tu-test-card-header">'
            + '<div><h4><i class="fas fa-file-medical"></i> ' + escHtml(testData.testTypeName) + '</h4>'
            + '<div class="tu-test-meta">'
            + '<span><i class="fas fa-image"></i> ' + escHtml(testData.fileName) + '</span>'
            + '<span class="tu-confidence-pill"><i class="fas fa-brain"></i> AI Confidence: ' + testData.confidence + '%</span>'
            + '</div></div>'
            + '<div class="tu-test-actions">' + approvedBadge
            + '<button class="tu-btn tu-btn-sm" data-action="remove" title="Remove" type="button" style="color:#c62828;border-color:#ef9a9a"><i class="fas fa-trash"></i></button>'
            + '</div></div>'
            + '<div class="tu-values-table-wrap"><table class="tu-values-table">'
            + '<thead><tr><th>Parameter</th><th>Extracted Value</th><th>Normal Range</th><th>Status</th></tr></thead>'
            + '<tbody>' + rows + '</tbody></table></div>'
            + '<div class="tu-test-card-footer">' + footerBtns + '</div>';

        card.querySelectorAll('[data-action]').forEach(btn =>
            btn.addEventListener('click', () => handleCardAction(btn.dataset.action, testData.id))
        );

        uploadedTestsList.appendChild(card);
    }

    function handleCardAction(action, testId) {
        const test = uploadedTests.find(t => t.id === testId);
        if (!test) return;

        if (action === 'edit') {
            document.querySelectorAll('#test-' + testId + ' .tu-value-input').forEach(i => i.disabled = false);
            notify('Values unlocked — edit then click "Approve & Confirm".', 'info');
            return;
        }
        if (action === 'approve') {
            document.querySelectorAll('#test-' + testId + ' .tu-value-input').forEach(input => {
                test.extractedValues[input.dataset.param] = input.value;
            });
            test.approved = true;
            renderTestCard(test);
            updateApprovalCounter();
            return;
        }
        if (action === 'unapprove') {
            test.approved = false;
            renderTestCard(test);
            updateApprovalCounter();
            return;
        }
        if (action === 'remove') {
            if (!confirm('Remove this test?')) return;
            uploadedTests = uploadedTests.filter(t => t.id !== testId);
            document.getElementById('test-' + testId)?.remove();
            updateApprovalCounter();
            if (!uploadedTests.length) {
                submitRow.style.display            = 'none';
                uploadedTestsSection.style.display = 'none';
            }
        }
    }

    function updateApprovalCounter() {
        const total    = uploadedTests.length;
        const approved = uploadedTests.filter(t => t.approved).length;
        if (approvalCounter) approvalCounter.textContent = approved + ' / ' + total + ' approved';
        const allReady = total > 0 && approved === total;
        submitAllBtn.disabled  = !allReady;
        submitAllBtn.innerHTML = allReady
            ? '<i class="fas fa-paper-plane"></i> Submit All Tests for Comprehensive Analysis'
            : '<i class="fas fa-lock"></i> Approve all tests to submit';
    }

    /* ══════════════════════════════════════════════════════
       CLEAR ALL
    ══════════════════════════════════════════════════════ */
    clearAllBtn.addEventListener('click', () => {
        if (!confirm('Remove all uploaded tests?')) return;
        uploadedTests = [];
        uploadedTestsList.innerHTML = '';
        submitRow.style.display             = 'none';
        uploadedTestsSection.style.display  = 'none';
        comprehensiveResults.style.display  = 'none';
        setStep(1);
    });

    /* ══════════════════════════════════════════════════════
       STEP 2 → 3  :  SUBMIT FOR ANALYSIS
    ══════════════════════════════════════════════════════ */
    submitAllBtn.addEventListener('click', async () => {
        if (!uploadedTests.every(t => t.approved)) return;

        comprehensiveResults.style.display = 'block';
        reportLoading.style.display        = 'block';
        reportReady.style.display          = 'none';
        overallConfidence.style.display    = 'none';
        comprehensiveResults.scrollIntoView({ behavior: 'smooth', block: 'start' });
        setStep(3);
        submitAllBtn.disabled  = true;
        submitAllBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Analyzing…';

        loadingStepsEl.innerHTML = '';
        reportBarFill.style.width = '0%';

        // ↓ Replace this call with a real API request when ready ↓
        let analysis;
        try {
            analysis = await apiAnalyzeTests(uploadedTests);
        } catch (err) {
            notify(err?.message || 'Failed to analyze tests.', 'error');
            reportLoading.style.display = 'none';
            reportReady.style.display = 'none';
            overallConfidence.style.display = 'none';
            submitAllBtn.disabled = false;
            submitAllBtn.innerHTML = '<i class="fas fa-paper-plane"></i> Submit All Tests for Comprehensive Analysis';
            return;
        }

        generateComprehensiveReport(analysis);
        overallConfidence.innerHTML = '<i class="fas fa-brain"></i> Confidence: ' + analysis.confidence + '%';
        refreshPreviousTests();

        document.getElementById('reportSubtitle').textContent =
            uploadedTests.length + ' test(s) · ' + new Date().toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' });
    });

    /* ══════════════════════════════════════════════════════
       GENERATE REPORT HTML
    ══════════════════════════════════════════════════════ */
    function generateComprehensiveReport(analysis) {
        const iconMap = { safe: 'fa-check-circle', warning: 'fa-exclamation-circle', danger: 'fa-exclamation-triangle' };

        reportVerdictRow.innerHTML =
            '<span class="tu-verdict-badge ' + analysis.verdict + '">'
            + '<i class="fas ' + iconMap[analysis.verdict] + '"></i> ' + escHtml(analysis.overall)
            + '</span>'
            + '<p class="tu-verdict-summary">' + uploadedTests.length + ' test(s) analyzed &mdash; ' + escHtml(analysis.riskLevel || 'see detailed breakdown below') + '</p>';

        let html = '';

        // ── Personal Information (result_1) ──
        if (analysis.personalInfo) {
            const pi = analysis.personalInfo;
            const piFields = [
                { label: 'Name', value: pi.name, icon: 'fa-user' },
                { label: 'Age', value: pi.age, icon: 'fa-birthday-cake', suffix: ' years' },
                { label: 'Trimester', value: pi.trimester, icon: 'fa-baby' },
                { label: 'Week', value: pi.week, icon: 'fa-calendar-week' },
                { label: 'Baby Gender', value: pi.baby_gender, icon: 'fa-venus-mars' },
                { label: 'Height', value: pi.height, icon: 'fa-ruler-vertical', suffix: ' cm' },
                { label: 'Weight', value: pi.weight, icon: 'fa-weight', suffix: ' kg' },
                { label: 'RBS Avg', value: pi.rbs_avg, icon: 'fa-tint', suffix: ' mg/dL' },
                { label: 'BP', value: (pi.avg_systolic && pi.avg_diastolic) ? pi.avg_systolic + '/' + pi.avg_diastolic : null, icon: 'fa-heartbeat', suffix: ' mmHg' },
                { label: 'Parity', value: pi.parity, icon: 'fa-child' },
                { label: 'DG State', value: pi.dg_state, icon: 'fa-notes-medical' },
                { label: 'Risk State', value: pi.risk_state, icon: 'fa-shield-alt' }
            ];
            let piCards = '';
            piFields.forEach(f => {
                if (f.value == null || f.value === '') return;
                piCards += '<div class="tu-pi-card">'
                    + '<div class="tu-pi-icon"><i class="fas ' + f.icon + '"></i></div>'
                    + '<div class="tu-pi-info"><span class="tu-pi-label">' + escHtml(f.label) + '</span>'
                    + '<span class="tu-pi-value">' + escHtml(String(f.value)) + (f.suffix || '') + '</span></div></div>';
            });
            html += '<div class="tu-report-section"><h5><i class="fas fa-id-card"></i> Patient Information</h5>'
                + '<div class="tu-pi-grid">' + piCards + '</div></div>';
        }

        // ── Analysis Summary ──
        html += '<div class="tu-report-summary">'
            + '<h4><i class="fas fa-chart-line"></i> Analysis Summary</h4>'
            + '<p>Based on <strong>' + (analysis.tests?.length || uploadedTests.length) + '</strong> approved test(s). Review each section below.</p></div>';

        // ── Test Results (result_2) ──
        const reportTests = analysis.tests && analysis.tests.length
            ? analysis.tests.map(t => ({ testTypeName: t.test_name, extractedValues: t }))
            : uploadedTests;
        reportTests.forEach(test => {
            const cfg = testConfigurations[test.testType] || resolveTestConfig(test.testTypeName);
            if (!cfg) return;
            const confVal = test.extractedValues?.confidence;
            let cards = '';
            cfg.parameters.forEach(p => {
                const val = extractValue(test.extractedValues, p.key) ?? '—';
                const status = getParamStatus(val, p.normalRange);
                cards += '<div class="tu-insight-card ' + status + '">'
                    + '<div class="tu-insight-label">' + escHtml(p.name) + '</div>'
                    + '<div class="tu-insight-value"><span class="tu-insight-dot"></span>' + escHtml(String(val))
                    + (p.unit ? '<span class="tu-insight-unit">' + escHtml(p.unit) + '</span>' : '') + '</div>'
                    + '<div class="tu-insight-range">Normal: ' + escHtml(p.normalRange) + (p.unit ? ' ' + p.unit : '') + '</div></div>';
            });
            html += '<div class="tu-report-section"><h5><i class="fas fa-vial"></i> ' + escHtml(test.testTypeName || cfg.name)
                + (confVal ? '<span class="tu-confidence-pill" style="margin-left:.75rem"><i class="fas fa-brain"></i> ' + (parseFloat(confVal) * 100).toFixed(0) + '% confidence</span>' : '')
                + '</h5><div class="tu-insight-grid">' + cards + '</div></div>';
        });

        // ── Risk Prediction (result_3) ──
        if (analysis.riskLevel || analysis.diabetesStatus) {
            const rl = (analysis.riskLevel || '').toLowerCase();
            const rc = rl.includes('high') ? 'danger' : rl.includes('moderate') ? 'warning' : 'safe';
            const ri = rc === 'danger' ? 'fa-exclamation-triangle' : rc === 'warning' ? 'fa-exclamation-circle' : 'fa-shield-alt';
            html += '<div class="tu-report-section"><h5><i class="fas fa-chart-pie"></i> Risk Prediction</h5>'
                + '<div class="tu-risk-banner ' + rc + '"><i class="fas ' + ri + '"></i>'
                + '<div><strong>' + escHtml(analysis.riskLevel || 'N/A') + '</strong>'
                + (analysis.confidence !== '—' ? '<span class="tu-risk-conf">' + analysis.confidence + '% confidence</span>' : '')
                + (analysis.diabetesStatus ? '<span class="tu-risk-conf">Diabetes: ' + escHtml(analysis.diabetesStatus) + '</span>' : '')
                + '</div></div></div>';
        }

        // ── AI Medical Report (result_4) ──
        if (analysis.report) {
            html += '<div class="tu-report-section tu-ai-report-section"><h5><i class="fas fa-file-medical-alt"></i> AI Medical Report</h5>'
                + '<div class="tu-ai-report-body">' + formatReportText(analysis.report) + '</div></div>';
        }

        // ── Clinical Recommendations (result_5) ──
        if (analysis.recommendations && analysis.recommendations.length) {
            html += '<div class="tu-recommendations"><h4><i class="fas fa-lightbulb"></i> Clinical Recommendations</h4>'
                + '<ul class="tu-rec-list">' + analysis.recommendations.map(r => '<li><i class="fas fa-check-circle"></i> ' + escHtml(r) + '</li>').join('') + '</ul></div>';
        }

        reportContent.innerHTML = html;
        reportLoading.style.display = 'none';
        reportReady.style.display = 'block';
        overallConfidence.style.display = 'inline-flex';
    }

    function formatReportText(text) {
        if (!text) return '';
        return text.split('\n').map(line => {
            line = line.trim();
            if (!line) return '';
            if (line.startsWith('*')) return '<li class="tu-report-bullet"><i class="fas fa-angle-right"></i>' + escHtml(line.replace(/^\*\s*/, '')) + '</li>';
            if (line.endsWith(':') && line.length < 120) return '<h6 class="tu-report-heading">' + escHtml(line) + '</h6>';
            return '<p class="tu-report-para">' + escHtml(line) + '</p>';
        }).join('');
    }

