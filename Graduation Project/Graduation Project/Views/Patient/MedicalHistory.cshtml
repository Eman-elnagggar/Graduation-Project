@model Graduation_Project.ViewModels.MedicalHistoryViewModel
@{
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    ViewData["Title"] = "Medical History";
    ViewData["PatientId"]  = Model.Patient.PatientID;
    ViewData["ActivePage"] = "MedicalHistory";
    var groups = Model.TimelineEntries
        .GroupBy(e => e.DateTime.Date)
        .OrderByDescending(g => g.Key)
        .ToList();
}

<!-- ══════════════════ HERO HEADER ══════════════════ -->
<header class="mh-hero">
    <div class="mh-hero-left">
        <div class="mh-hero-icon">
            <i class="fas fa-notes-medical"></i>
        </div>
        <div>
            <h1 class="mh-hero-title">Medical History</h1>
            <p class="mh-hero-sub">Your complete pregnancy journey and medical records</p>
        </div>
    </div>
</header>

<!-- ══════════════════ QUICK STATS ══════════════════ -->
<section class="mh-stats-grid">
    <div class="mh-stat-card mh-stat-lab">
        <div class="mh-stat-icon"><i class="fas fa-flask"></i></div>
        <div class="mh-stat-body">
            <span class="mh-stat-num">@Model.LabTestCount</span>
            <span class="mh-stat-lbl">Lab Tests</span>
        </div>
        <div class="mh-stat-bg-icon"><i class="fas fa-flask"></i></div>
    </div>
    <div class="mh-stat-card mh-stat-ultra">
        <div class="mh-stat-icon"><i class="fas fa-baby"></i></div>
        <div class="mh-stat-body">
            <span class="mh-stat-num">@Model.UltrasoundCount</span>
            <span class="mh-stat-lbl">Ultrasounds</span>
        </div>
        <div class="mh-stat-bg-icon"><i class="fas fa-baby"></i></div>
    </div>
    <div class="mh-stat-card mh-stat-appt">
        <div class="mh-stat-icon"><i class="fas fa-calendar-check"></i></div>
        <div class="mh-stat-body">
            <span class="mh-stat-num">@Model.AppointmentCount</span>
            <span class="mh-stat-lbl">Appointments</span>
        </div>
        <div class="mh-stat-bg-icon"><i class="fas fa-calendar-check"></i></div>
    </div>
    <div class="mh-stat-card mh-stat-bp">
        <div class="mh-stat-icon"><i class="fas fa-heartbeat"></i></div>
        <div class="mh-stat-body">
            <span class="mh-stat-num">@Model.BloodPressureCount</span>
            <span class="mh-stat-lbl">BP Readings</span>
        </div>
        <div class="mh-stat-bg-icon"><i class="fas fa-heartbeat"></i></div>
    </div>
    <div class="mh-stat-card mh-stat-alert">
        <div class="mh-stat-icon"><i class="fas fa-bell"></i></div>
        <div class="mh-stat-body">
            <span class="mh-stat-num">@Model.AlertCount</span>
            <span class="mh-stat-lbl">Alerts</span>
        </div>
        <div class="mh-stat-bg-icon"><i class="fas fa-bell"></i></div>
    </div>
</section>

<!-- ══════════════════ FILTERS ══════════════════ -->
<section class="mh-filters-wrap">
    <div class="mh-filters-card">
        <div class="mh-filters-row">
            <div class="mh-search-box">
                <i class="fas fa-search mh-search-icon"></i>
                <input type="text" placeholder="Search medical records…" id="historySearch" class="mh-search-input" />
            </div>
            <div class="mh-filter-group">
                <span class="mh-filter-label">Event Type</span>
                <select id="eventTypeFilter" class="mh-select">
                    <option value="all">All Events</option>
                    <option value="lab-test">Lab Tests</option>
                    <option value="ultrasound">Ultrasounds</option>
                    <option value="appointment">Appointments</option>
                    <option value="bp-reading">Blood Pressure</option>
                    <option value="blood-sugar">Blood Sugar</option>
                    <option value="alert">Alerts</option>
                    <option value="doctor-note">Doctor Notes</option>
                    <option value="medication">Medications</option>
                </select>
            </div>
            <div class="mh-filter-group">
                <span class="mh-filter-label">Status</span>
                <select id="statusFilter" class="mh-select">
                    <option value="all">All Status</option>
                    <option value="normal">Normal</option>
                    <option value="attention">Needs Attention</option>
                    <option value="critical">Critical</option>
                </select>
            </div>
            <button class="mh-btn mh-btn-ghost" id="clearFilters">
                <i class="fas fa-times"></i> Clear
            </button>
            <button class="mh-btn mh-btn-primary" id="exportHistory">
                <i class="fas fa-download"></i> Export
            </button>
        </div>
        <div class="mh-results-count" id="resultsCount"></div>
    </div>
</section>

<!-- ══════════════════ TIMELINE ══════════════════ -->
<section class="mh-timeline-section">
    @if (!Model.TimelineEntries.Any())
    {
        <div class="mh-empty-state">
            <div class="mh-empty-icon"><i class="fas fa-history"></i></div>
            <h3>No medical records yet</h3>
            <p>Records will appear here as you add health data.</p>
        </div>
    }
    else
    {
        <div class="mh-timeline" id="timelineContainer">
            @foreach (var group in groups)
            {
                string dayLabel;
                if (group.Key == DateTime.Today) dayLabel = "Today";
                else if (group.Key == DateTime.Today.AddDays(-1)) dayLabel = "Yesterday";
                else dayLabel = group.Key.ToString("ddd");

                <div class="mh-date-group timeline-date-group">
                    <div class="mh-date-header">
                        <span class="mh-day-badge @(group.Key == DateTime.Today ? "mh-day-today" : "")">@dayLabel</span>
                        <div class="mh-date-line"></div>
                        <span class="mh-date-full">@group.Key.ToString("MMMM dd, yyyy")</span>
                    </div>

                    @foreach (var entry in group.OrderByDescending(e => e.DateTime))
                    {
                        string markerClass = entry.EventType switch
                        {
                            "bp-reading"   => "bp",
                            "blood-sugar"  => "bs",
                            "lab-test"     => "lab",
                            "ultrasound"   => "ultrasound",
                            "appointment"  => "appointment",
                            "alert"        => "alert",
                            "doctor-note"  => "doctor",
                            "medication"   => "medication",
                            _              => "system"
                        };
                        string icon = entry.EventType switch
                        {
                            "bp-reading"   => "fas fa-heartbeat",
                            "blood-sugar"  => "fas fa-tint",
                            "lab-test"     => "fas fa-flask",
                            "ultrasound"   => "fas fa-baby",
                            "appointment"  => "fas fa-calendar-check",
                            "alert"        => "fas fa-exclamation-triangle",
                            "doctor-note"  => "fas fa-user-md",
                            "medication"   => "fas fa-pills",
                            _              => "fas fa-circle"
                        };
                        bool isWarning = entry.Status == "critical" || entry.Status == "attention";

                        <div class="mh-card @markerClass @(isWarning ? "mh-card-warning" : "") timeline-item"
                             data-type="@entry.EventType"
                             data-status="@entry.Status"
                             data-text="@(entry.Title + " " + entry.SubTitle + " " + entry.DoctorName)">

                            <!-- Card left accent bar is via CSS border-left on .mh-card.{type} -->

                            <div class="mh-card-marker @markerClass">
                                <i class="@icon"></i>
                            </div>

                            <div class="mh-card-body">
                                <!-- Card Header -->
                                <div class="mh-card-header">
                                    <div class="mh-card-title-row">
                                        <span class="mh-event-type-pill @markerClass">@(entry.EventType?.Replace("-", " ").ToUpper() ?? "RECORD")</span>
                                        <h4 class="mh-card-title">@entry.Title</h4>
                                    </div>
                                    <div class="mh-card-time">
                                        <i class="fas fa-clock"></i>
                                        @entry.DateTime.ToString("h:mm tt")
                                    </div>
                                </div>

                                <!-- Card Content -->
                                <div class="mh-card-content">

                                    @* ── Blood Pressure ── *@
                                    @if (entry.BloodPressure != null)
                                    {
                                        string bpBadge = entry.Status == "critical" ? "mh-badge-critical"
                                                       : entry.Status == "attention" ? "mh-badge-elevated"
                                                       : "mh-badge-normal";
                                        string bpText  = entry.Status == "critical" ? "Critical"
                                                       : entry.Status == "attention" ? "Elevated" : "Normal";
                                        <div class="mh-reading-row">
                                            <div class="mh-reading-block">
                                                <span class="mh-reading-val">@entry.BloodPressure.BloodPressure</span>
                                                <span class="mh-reading-unit">mmHg</span>
                                            </div>
                                            <span class="mh-badge @bpBadge"><i class="fas fa-circle"></i> @bpText</span>
                                        </div>
                                        @if (entry.BloodPressure.MeasurementTime != null)
                                        {
                                            <p class="mh-meta"><i class="fas fa-clock"></i> @entry.BloodPressure.MeasurementTime</p>
                                        }
                                    }

                                    @* ── Blood Sugar ── *@
                                    @if (entry.BloodSugar != null)
                                    {
                                        string bsBadge = entry.Status == "critical" ? "mh-badge-critical"
                                                       : entry.Status == "attention" ? "mh-badge-elevated"
                                                       : "mh-badge-normal";
                                        string bsText  = entry.Status == "critical" ? "Critical"
                                                       : entry.Status == "attention" ? "High" : "Normal";
                                        <div class="mh-reading-row">
                                            <div class="mh-reading-block">
                                                <span class="mh-reading-val">@entry.BloodSugar.BloodSugar</span>
                                                <span class="mh-reading-unit">mg/dL</span>
                                            </div>
                                            <span class="mh-badge @bsBadge"><i class="fas fa-circle"></i> @bsText</span>
                                        </div>
                                        @if (entry.BloodSugar.MeasurementTime != null)
                                        {
                                            <p class="mh-meta"><i class="fas fa-clock"></i> @entry.BloodSugar.MeasurementTime</p>
                                        }
                                    }

                                    @* ── Lab Test ── *@
                                    @if (entry.LabTest != null)
                                    {
                                        bool hasAI = !string.IsNullOrWhiteSpace(entry.LabTest.AI_AnalysisJSON);
                                        string labId = $"labReport_{entry.LabTest.LabTestID}";

                                        <div class="mh-lab-card">
                                            <!-- Coloured header band -->
                                            <div class="mh-lab-header-band">
                                                <div class="mh-lab-header-icon">
                                                    <i class="fas fa-flask"></i>
                                                </div>
                                                <div class="mh-lab-header-info">
                                                    <span class="mh-lab-test-type">@entry.LabTest.TestType</span>
                                                    <span class="mh-lab-sub">Laboratory Test Result</span>
                                                </div>
                                                @if (hasAI)
                                                {
                                                    <span class="mh-lab-ai-badge"><i class="fas fa-robot"></i> AI Analysed</span>
                                                }
                                            </div>

                                            <!-- Body: info chips + AI preview -->
                                            <div class="mh-lab-body">
                                                <div class="mh-lab-info-grid">
                                                    <div class="mh-lab-info-cell">
                                                        <div class="mh-lab-info-icon"><i class="fas fa-vial"></i></div>
                                                        <div>
                                                            <span class="mh-lab-info-label">Test Type</span>
                                                            <span class="mh-lab-info-value">@entry.LabTest.TestType</span>
                                                        </div>
                                                    </div>
                                                    <div class="mh-lab-info-cell">
                                                        <div class="mh-lab-info-icon"><i class="fas fa-calendar-alt"></i></div>
                                                        <div>
                                                            <span class="mh-lab-info-label">Uploaded</span>
                                                            <span class="mh-lab-info-value">@entry.LabTest.UploadDate.ToString("MMM dd, yyyy")</span>
                                                        </div>
                                                    </div>
                                                    @if (!string.IsNullOrWhiteSpace(entry.LabTest.ImagePath))
                                                    {
                                                        <div class="mh-lab-info-cell">
                                                            <div class="mh-lab-info-icon"><i class="fas fa-image"></i></div>
                                                            <div>
                                                                <span class="mh-lab-info-label">Image</span>
                                                                <span class="mh-lab-info-value">Available</span>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>

                                                @if (hasAI)
                                                {
                                                    <div class="mh-lab-ai-preview">
                                                        <div class="mh-lab-ai-preview-top">
                                                            <span class="mh-lab-ai-title"><i class="fas fa-robot"></i> AI Analysis Summary</span>
                                                            <span class="mh-lab-ai-dot mh-lab-ai-dot-active"></span>
                                                        </div>
                                                        <p class="mh-lab-ai-preview-text">AI analysis is available for this test. Open the full report to view detailed findings and parameter breakdown.</p>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="mh-lab-ai-preview mh-lab-ai-preview-pending">
                                                        <div class="mh-lab-ai-preview-top">
                                                            <span class="mh-lab-ai-title"><i class="fas fa-hourglass-half"></i> AI Analysis</span>
                                                        </div>
                                                        <p class="mh-lab-ai-preview-text">Analysis not yet available for this test.</p>
                                                    </div>
                                                }

                                                <!-- Action buttons -->
                                                <div class="mh-lab-actions">
                                                    <button class="mh-btn mh-btn-primary mh-lab-report-btn"
                                                            data-labid="@entry.LabTest.LabTestID"
                                                            data-testtype="@entry.LabTest.TestType"
                                                            data-uploaddate="@entry.LabTest.UploadDate.ToString("MMMM dd, yyyy")"
                                                            data-imagepath="@entry.LabTest.ImagePath"
                                                            data-hasai="@hasAI.ToString().ToLower()"
                                                            data-aijson="@(hasAI ? System.Web.HttpUtility.HtmlAttributeEncode(entry.LabTest.AI_AnalysisJSON) : "")">
                                                        <i class="fas fa-file-medical-alt"></i> View Full Report
                                                    </button>
                                                    @if (!string.IsNullOrWhiteSpace(entry.LabTest.ImagePath))
                                                    {
                                                        <a href="/@entry.LabTest.ImagePath.TrimStart('/')" target="_blank" class="mh-btn mh-btn-ghost mh-lab-img-btn">
                                                            <i class="fas fa-image"></i> View Image
                                                        </a>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }

                                    @* ── Ultrasound ── *@
                                    @if (entry.Ultrasound != null)
                                    {
                                        bool noAnomaly = string.IsNullOrWhiteSpace(entry.Ultrasound.DetectedAnomaly);
                                        <div class="mh-ai-box @(noAnomaly ? "mh-ai-box-success" : "mh-ai-box-warn")">
                                            <span class="mh-ai-label"><i class="fas fa-robot"></i> AI Analysis</span>
                                            <p>@(noAnomaly ? "No anomalies detected. Fetal development appears normal." : entry.Ultrasound.DetectedAnomaly)</p>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(entry.Ultrasound.DoctorComments))
                                        {
                                            <p class="mh-meta" style="margin-top:.5rem"><strong>Doctor note:</strong> @entry.Ultrasound.DoctorComments</p>
                                        }
                                    }

                                    @* ── Appointment ── *@
                                    @if (entry.Appointment != null)
                                    {
                                        bool isPast = entry.Appointment.Date < DateTime.Now;
                                        string apptStatusClass = isPast ? "mh-appt-status-completed" : "mh-appt-status-upcoming";
                                        string apptStatusIcon  = isPast ? "fa-check-circle" : "fa-hourglass-half";
                                        string apptStatusText  = isPast ? "Completed" : "Upcoming";
                                        string apptAccentClass = isPast ? "mh-appt-completed" : "mh-appt-upcoming";

                                        <div class="mh-appt-card @apptAccentClass">
                                            <!-- Header band -->
                                            <div class="mh-appt-header-band">
                                                <div class="mh-appt-doctor-avatar">
                                                    <i class="fas fa-user-md"></i>
                                                </div>
                                                <div class="mh-appt-header-info">
                                                    <span class="mh-appt-doctor-name">
                                                        @(string.IsNullOrWhiteSpace(entry.DoctorName) ? "Doctor" : entry.DoctorName)
                                                    </span>
                                                    <span class="mh-appt-specialty">General Practitioner</span>
                                                </div>
                                                <span class="mh-appt-status-pill @apptStatusClass">
                                                    <i class="fas @apptStatusIcon"></i>
                                                    @apptStatusText
                                                </span>
                                            </div>

                                            <!-- Body -->
                                            <div class="mh-appt-body">
                                                <div class="mh-appt-info-grid">
                                                    @if (!string.IsNullOrWhiteSpace(entry.ClinicName))
                                                    {
                                                        <div class="mh-appt-info-cell">
                                                            <div class="mh-appt-info-icon mh-appt-icon-clinic">
                                                                <i class="fas fa-hospital"></i>
                                                            </div>
                                                            <div>
                                                                <span class="mh-appt-info-label">Clinic</span>
                                                                <span class="mh-appt-info-value">@entry.ClinicName</span>
                                                            </div>
                                                        </div>
                                                    }
                                                    <div class="mh-appt-info-cell">
                                                        <div class="mh-appt-info-icon mh-appt-icon-time">
                                                            <i class="fas fa-clock"></i>
                                                        </div>
                                                        <div>
                                                            <span class="mh-appt-info-label">Time</span>
                                                            <span class="mh-appt-info-value">@entry.Appointment.Time.ToString(@"hh\:mm")</span>
                                                        </div>
                                                    </div>
                                                    <div class="mh-appt-info-cell">
                                                        <div class="mh-appt-info-icon mh-appt-icon-date">
                                                            <i class="fas fa-calendar-alt"></i>
                                                        </div>
                                                        <div>
                                                            <span class="mh-appt-info-label">Date</span>
                                                            <span class="mh-appt-info-value">@entry.Appointment.Date.ToString("MMM dd, yyyy")</span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }

                                    @* ── Alert ── *@
                                    @if (entry.Alert != null)
                                    {
                                        // Determine severity tier from AlertType
                                        string alertType    = (entry.Alert.AlertType ?? "info").ToLower();
                                        bool isAlertDanger  = alertType == "danger"  || alertType == "critical";
                                        bool isAlertWarning = alertType == "warning";
                                        bool isAlertSuccess = alertType == "success";

                                        string alertBoxClass  = isAlertDanger  ? "mh-alert-box-danger"
                                                              : isAlertWarning ? "mh-alert-box-warning"
                                                              : isAlertSuccess ? "mh-alert-box-success"
                                                              :                  "mh-alert-box-info";

                                        string alertIconClass = isAlertDanger  ? "fas fa-exclamation-circle"
                                                              : isAlertWarning ? "fas fa-exclamation-triangle"
                                                              : isAlertSuccess ? "fas fa-check-circle"
                                                              :                  "fas fa-info-circle";

                                        string severityLabel  = isAlertDanger  ? "Danger"
                                                              : isAlertWarning ? "Warning"
                                                              : isAlertSuccess ? "All Clear"
                                                              :                  "Info";

                                        <div class="mh-alert-card-inner @alertBoxClass">
                                            <div class="mh-alert-stripe"></div>
                                            <div class="mh-alert-card-body">
                                                <div class="mh-alert-top-row">
                                                    <span class="mh-alert-severity-pill @alertBoxClass">
                                                        <i class="@alertIconClass"></i> @severityLabel
                                                    </span>
                                                    @if (!entry.Alert.IsRead)
                                                    {
                                                        <span class="mh-alert-unread-dot" title="Unread"></span>
                                                    }
                                                </div>
                                                <p class="mh-alert-message-text">@entry.Alert.Message</p>
                                                <div class="mh-badge-row" style="margin-top:.55rem">
                                                    <span class="mh-badge @(entry.Alert.IsRead ? "mh-badge-completed" : "mh-badge-elevated")">
                                                        <i class="fas @(entry.Alert.IsRead ? "fa-envelope-open" : "fa-envelope")"></i>
                                                        @(entry.Alert.IsRead ? "Read" : "Unread")
                                                    </span>
                                                    <span class="mh-badge mh-badge-type">
                                                        <i class="fas fa-tag"></i> @entry.Alert.AlertType
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    }

                                    @* ── Doctor Note ── *@
                                    @if (entry.DoctorNote != null)
                                    {
                                        <div class="mh-note-box">
                                            <i class="fas fa-quote-left mh-note-quote"></i>
                                            <p class="mh-note-text">@entry.DoctorNote.Content</p>
                                        </div>
                                    }

                                    @* ── Medication / Prescription ── *@
                                    @if (entry.Prescription != null)
                                    {
                                        <div class="mh-meds-list">
                                            @if (entry.Prescription.Items != null && entry.Prescription.Items.Any())
                                            {
                                                foreach (var item in entry.Prescription.Items)
                                                {
                                                    <div class="mh-med-item">
                                                        <div class="mh-med-pill-icon"><i class="fas fa-capsules"></i></div>
                                                        <div class="mh-med-info">
                                                            <strong>@item.MedicineName</strong>
                                                            <span>@item.Dosage · @item.Frequency</span>
                                                            @if (!string.IsNullOrWhiteSpace(item.Instructions))
                                                            {
                                                                <em>@item.Instructions</em>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            }
                                            else if (!string.IsNullOrWhiteSpace(entry.Prescription.Notes))
                                            {
                                                <p class="mh-meta">@entry.Prescription.Notes</p>
                                            }
                                        </div>
                                    }

                                </div><!-- /.mh-card-content -->

                                <!-- Card Footer -->
                                <div class="mh-card-footer">
                                    @if (!string.IsNullOrWhiteSpace(entry.DoctorName) && entry.Appointment == null)
                                    {
                                        <span class="mh-recorded-by"><i class="fas fa-user-md"></i> @entry.DoctorName</span>
                                    }
                                    else if (entry.BloodPressure != null || entry.BloodSugar != null)
                                    {
                                        <span class="mh-recorded-by"><i class="fas fa-user"></i> Self-recorded</span>
                                    }
                                    else if (entry.Alert != null)
                                    {
                                        <span class="mh-recorded-by"><i class="fas fa-robot"></i> AI System</span>
                                    }
                                    else
                                    {
                                        <span></span>
                                    }
                                    <span class="mh-card-date-chip">@entry.DateTime.ToString("MMM dd, yyyy")</span>
                                </div>

                            </div><!-- /.mh-card-body -->
                        </div><!-- /.mh-card -->
                    }
                </div><!-- /.mh-date-group -->
            }
        </div>
    }
</section>

@section Scripts {
<script>
document.addEventListener("DOMContentLoaded", function () {
    const searchInput     = document.getElementById("historySearch");
    const eventTypeFilter = document.getElementById("eventTypeFilter");
    const statusFilter    = document.getElementById("statusFilter");
    const clearBtn        = document.getElementById("clearFilters");
    const exportBtn       = document.getElementById("exportHistory");
    const resultsCount    = document.getElementById("resultsCount");

    function getItems() { return document.querySelectorAll(".timeline-item"); }

    function filterTimeline() {
        const search    = (searchInput?.value ?? "").toLowerCase();
        const eventType = eventTypeFilter?.value ?? "all";
        const status    = statusFilter?.value    ?? "all";
        let visible = 0;
        getItems().forEach(item => {
            const t  = (item.dataset.type   ?? "").toLowerCase();
            const s  = (item.dataset.status ?? "").toLowerCase();
            const tx = (item.dataset.text   ?? "").toLowerCase();
            const show = (!search || tx.includes(search))
                      && (eventType === "all" || t === eventType)
                      && (status    === "all" || s === status);
            item.style.display = show ? "flex" : "none";
            if (show) visible++;
        });
        document.querySelectorAll(".timeline-date-group").forEach(g => {
            const hasVisible = Array.from(g.querySelectorAll(".timeline-item")).some(i => i.style.display !== "none");
            g.style.display = hasVisible ? "block" : "none";
        });
        if (resultsCount)
            resultsCount.textContent = `${visible} record${visible !== 1 ? "s" : ""} found`;
    }

    function debounce(fn, ms) { let t; return (...a) => { clearTimeout(t); t = setTimeout(() => fn(...a), ms); }; }

    searchInput?.addEventListener("input", debounce(filterTimeline, 250));
    eventTypeFilter?.addEventListener("change", filterTimeline);
    statusFilter?.addEventListener("change", filterTimeline);
    clearBtn?.addEventListener("click", () => {
        if (searchInput)     searchInput.value     = "";
        if (eventTypeFilter) eventTypeFilter.value = "all";
        if (statusFilter)    statusFilter.value    = "all";
        filterTimeline();
    });
    exportBtn?.addEventListener("click", showExportModal);
    filterTimeline();

    function showExportModal() {
        const modal = document.createElement("div");
        modal.className = "mh-modal-wrap";
        modal.innerHTML = `
            <div class="mh-modal-overlay"></div>
            <div class="mh-modal">
                <div class="mh-modal-header">
                    <h3><i class="fas fa-download"></i> Export Medical History</h3>
                    <button class="mh-modal-close"><i class="fas fa-times"></i></button>
                </div>
                <div class="mh-modal-body">
                    <p style="color:#64748b;margin-bottom:1rem">Choose format to export your records:</p>
                    <div class="mh-export-options">
                        <label class="mh-export-opt">
                            <input type="radio" name="exportFmt" value="pdf" checked>
                            <div class="mh-export-opt-inner">
                                <i class="fas fa-file-pdf"></i>
                                <div><span>PDF Document</span><small>Best for printing & sharing</small></div>
                            </div>
                        </label>
                        <label class="mh-export-opt">
                            <input type="radio" name="exportFmt" value="excel">
                            <div class="mh-export-opt-inner">
                                <i class="fas fa-file-excel"></i>
                                <div><span>Excel Spreadsheet</span><small>Best for data analysis</small></div>
                            </div>
                        </label>
                    </div>
                </div>
                <div class="mh-modal-footer">
                    <button class="mh-btn mh-btn-ghost mh-modal-cancel">Cancel</button>
                    <button class="mh-btn mh-btn-primary mh-modal-export"><i class="fas fa-download"></i> Export</button>
                </div>
            </div>`;
        document.body.appendChild(modal);
        modal.querySelector(".mh-modal-close").addEventListener("click", () => modal.remove());
        modal.querySelector(".mh-modal-cancel").addEventListener("click", () => modal.remove());
        modal.querySelector(".mh-modal-overlay").addEventListener("click", () => modal.remove());
        modal.querySelector(".mh-modal-export").addEventListener("click", function () {
            this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Exporting…';
            setTimeout(() => { modal.remove(); showNotif("Exported successfully!", "success"); }, 1500);
        });
    }

    function showNotif(msg, type = "info") {
        const n = document.createElement("div");
        n.className = `mh-notif mh-notif-${type}`;
        n.innerHTML = `<i class="fas fa-check-circle"></i><span>${msg}</span><button class="mh-notif-close"><i class="fas fa-times"></i></button>`;
        document.body.appendChild(n);
        n.querySelector(".mh-notif-close").addEventListener("click", () => n.remove());
        setTimeout(() => n.remove(), 4000);
    }
});
</script>

<style>
/* ─────────────────────────────────────────
   CSS VARIABLES
───────────────────────────────────────── */
:root {
