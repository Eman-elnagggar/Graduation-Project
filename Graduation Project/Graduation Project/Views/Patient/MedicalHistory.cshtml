}
.mh-ai-box-success {
    background: linear-gradient(135deg,#f0fdf4,#e8fdf0);
    border-color: #a7f3d0;
}
.mh-ai-box-warn {
    background: linear-gradient(135deg,#fffbeb,#fff5e0);
    border-color: #fcd34d;
}
.mh-ai-label {
    display: inline-flex; align-items: center; gap: .35rem;
    font-size: .77rem; font-weight: 700;
    color: #0284c7; margin-bottom: .3rem;
}
.mh-ai-box-success .mh-ai-label { color: #15803d; }
.mh-ai-box-warn    .mh-ai-label { color: #b45309; }
.mh-ai-box p { margin: 0; font-size: .86rem; color: #334155; line-height: 1.55; }

/* ─────────────────────────────────────────
   APPOINTMENT DETAILS
───────────────────────────────────────── */
.mh-appt-details { display: flex; flex-direction: column; gap: .4rem; }
.mh-appt-item {
    display: flex; align-items: center; gap: .6rem;
    font-size: .88rem; color: #475569;
}
.mh-appt-item-icon {
    width: 28px; height: 28px;
    background: var(--mh-light);
    border: 1px solid var(--mh-border);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: .75rem; color: var(--mh-primary); flex-shrink: 0;
