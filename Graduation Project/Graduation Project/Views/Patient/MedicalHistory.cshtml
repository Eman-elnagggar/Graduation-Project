}

/* ─────────────────────────────────────────
   FILTERS
───────────────────────────────────────── */
.mh-filters-wrap   { margin-bottom: 1.75rem; }
.mh-filters-card   {
    background: #fff;
    border-radius: var(--mh-radius);
