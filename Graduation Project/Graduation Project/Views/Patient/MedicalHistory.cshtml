.mh-badge-row       { display: flex; flex-wrap: wrap; gap: .4rem; }

/* ─────────────────────────────────────────
   INFO CHIPS (lab test)
───────────────────────────────────────── */
.mh-info-chips { display: flex; flex-wrap: wrap; gap: .6rem; margin-bottom: .5rem; }
.mh-info-chip  {
    display: flex; flex-direction: column;
    background: var(--mh-light);
    border: 1px solid var(--mh-border);
    border-radius: 10px;
    padding: .45rem .8rem;
    min-width: 100px;
}
.mh-chip-label { font-size: .7rem; color: #94a3b8; font-weight: 500; }
.mh-chip-value { font-size: .88rem; font-weight: 600; color: var(--mh-text); }

/* ─────────────────────────────────────────
   AI ANALYSIS BOX
───────────────────────────────────────── */
.mh-ai-box {
    background: linear-gradient(135deg,#f0f9ff,#e8f4fd);
    border: 1px solid #bae6fd;
    border-radius: 12px;
    padding: .7rem 1rem;
