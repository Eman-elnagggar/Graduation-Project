@model Graduation_Project.ViewModels.MedicalHistoryViewModel
@{
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    ViewData["Title"] = "Medical History";
    ViewData["PatientId"] = Model.Patient.PatientID;
    ViewData["ActivePage"] = "MedicalHistory";
    var groups = Model.TimelineEntries
        .GroupBy(e => e.DateTime.Date)
        .OrderByDescending(g => g.Key)
        .ToList();
}

<div class="mh-container">

    <!-- ══════════════════ HERO HEADER ══════════════════ -->
    <header class="mh-hero">
        <div class="mh-hero-content">
            <div class="mh-hero-left">
                <span class="mh-hero-eyebrow">
                    <i class="fas fa-heartbeat"></i> Medical Records
                </span>
                <h1 class="mh-hero-title">Health Timeline</h1>
                <p class="mh-hero-subtitle">Your complete pregnancy journey and medical records</p>
            </div>
            <div class="mh-hero-right">
                <button class="mh-action-btn mh-btn-secondary" id="printHistory">
                    <i class="fas fa-print"></i>
                    <span>Print</span>
                </button>
                <button class="mh-action-btn mh-btn-primary" id="exportHistory">
                    <i class="fas fa-download"></i>
                    <span>Export</span>
                </button>
            </div>
        </div>
    </header>

    <!-- ══════════════════ MAIN LAYOUT ══════════════════ -->
    <div class="mh-main-layout">

        <!-- LEFT SIDEBAR: STATS & FILTERS -->
        <aside class="mh-sidebar">

            <!-- Overview Card -->
            <div class="mh-sidebar-card mh-overview-card">
                <div class="mh-sidebar-header">
                    <div class="mh-sidebar-icon">
                        <i class="fas fa-chart-pie"></i>
                    </div>
                    <div>
                        <h3 class="mh-sidebar-title">Records Overview</h3>
                        <p class="mh-sidebar-subtitle">Summary statistics</p>
                    </div>
                </div>

                <div class="mh-stats-list">
                    <div class="mh-stat-item">
                        <div class="mh-stat-icon mh-stat-lab">
                            <i class="fas fa-flask"></i>
                        </div>
                        <div class="mh-stat-info">
                            <span class="mh-stat-value">@Model.LabTestCount</span>
                            <span class="mh-stat-label">Lab Tests</span>
                        </div>
                    </div>

                    <div class="mh-stat-item">
                        <div class="mh-stat-icon mh-stat-ultrasound">
                            <i class="fas fa-baby"></i>
                        </div>
                        <div class="mh-stat-info">
                            <span class="mh-stat-value">@Model.UltrasoundCount</span>
                            <span class="mh-stat-label">Ultrasounds</span>
                        </div>
                    </div>

                    <div class="mh-stat-item">
                        <div class="mh-stat-icon mh-stat-appointment">
                            <i class="fas fa-calendar-check"></i>
                        </div>
                        <div class="mh-stat-info">
                            <span class="mh-stat-value">@Model.AppointmentCount</span>
                            <span class="mh-stat-label">Appointments</span>
                        </div>
                    </div>

                    <div class="mh-stat-item">
                        <div class="mh-stat-icon mh-stat-vitals">
                            <i class="fas fa-heartbeat"></i>
                        </div>
                        <div class="mh-stat-info">
                            <span class="mh-stat-value">@Model.BloodPressureCount</span>
                            <span class="mh-stat-label">Vital Signs</span>
                        </div>
                    </div>

                    <div class="mh-stat-item">
                        <div class="mh-stat-icon mh-stat-alert">
                            <i class="fas fa-bell"></i>
                        </div>
                        <div class="mh-stat-info">
                            <span class="mh-stat-value">@Model.AlertCount</span>
                            <span class="mh-stat-label">Health Alerts</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Filters Card -->
            <div class="mh-sidebar-card mh-filter-card">
                <div class="mh-sidebar-header">
                    <div class="mh-sidebar-icon">
                        <i class="fas fa-filter"></i>
                    </div>
                    <div>
                        <h3 class="mh-sidebar-title">Filters</h3>
                        <p class="mh-sidebar-subtitle">Refine records</p>
                    </div>
                </div>

                <div class="mh-filter-section">
                    <label class="mh-filter-label">
                        <i class="fas fa-search"></i>
                        Search Records
                    </label>
                    <input type="text"
                           id="historySearch"
                           class="mh-filter-input"
                           placeholder="Search by keyword..." />
                </div>

                <div class="mh-filter-section">
                    <label class="mh-filter-label">
                        <i class="fas fa-layer-group"></i>
                        Event Type
                    </label>
                    <select id="eventTypeFilter" class="mh-filter-select">
                        <option value="all">All Events</option>
                        <option value="lab-test">Lab Tests</option>
                        <option value="ultrasound">Ultrasounds</option>
                        <option value="appointment">Appointments</option>
                        <option value="bp-reading">Blood Pressure</option>
                        <option value="blood-sugar">Blood Sugar</option>
                        <option value="alert">Alerts</option>
                        <option value="doctor-note">Doctor Notes</option>
                        <option value="medication">Medications</option>
                        <option value="pregnancy-started">Pregnancy Started</option>
                        <option value="pregnancy-ended">Pregnancy Updates</option>
                    </select>
                </div>

                <div class="mh-filter-section">
                    <label class="mh-filter-label">
                        <i class="fas fa-flag"></i>
                        Status
                    </label>
                    <select id="statusFilter" class="mh-filter-select">
                        <option value="all">All Status</option>
                        <option value="normal">Normal</option>
                        <option value="attention">Needs Attention</option>
                        <option value="critical">Critical</option>
                    </select>
                </div>

                <button class="mh-clear-filters-btn" id="clearFilters">
                    <i class="fas fa-redo"></i>
                    Clear All Filters
                </button>

                <div class="mh-results-summary" id="resultsCount"></div>
            </div>
        </aside>

        <!-- RIGHT CONTENT: TIMELINE -->
        <main class="mh-content">

            @if (!Model.TimelineEntries.Any())
            {
                <div class="mh-empty-state">
                    <div class="mh-empty-icon">
                        <i class="fas fa-clipboard-list"></i>
                    </div>
                    <h3 class="mh-empty-title">No Medical Records Yet</h3>
                    <p class="mh-empty-text">Your health records and timeline will appear here as you add data.</p>
                    <a href="/PatientDashboard/Dashboard/@Model.Patient.PatientID" class="mh-btn-primary">
                        <i class="fas fa-plus"></i>
                        Go to Dashboard
                    </a>
                </div>
            }
            else
            {
                <div class="mh-timeline" id="timelineContainer">
                    @foreach (var group in groups)
                    {
                        string dayLabel;
                        if (group.Key == DateTime.Today) dayLabel = "Today";
                        else if (group.Key == DateTime.Today.AddDays(-1)) dayLabel = "Yesterday";
                        else dayLabel = group.Key.ToString("dddd");

                        <div class="mh-timeline-group timeline-date-group">

                            <!-- Date Header -->
                            <div class="mh-timeline-date">
                                <div class="mh-date-badge @(group.Key == DateTime.Today ? "today" : "")">
                                    <span class="mh-date-day">@dayLabel</span>
                                    <span class="mh-date-full">@group.Key.ToString("MMM dd, yyyy")</span>
                                </div>
                            </div>

                            <!-- Timeline Items -->
                            <div class="mh-timeline-items">
                                @foreach (var entry in group.OrderByDescending(e => e.DateTime))
                                {
                                    string eventClass = entry.EventType switch
                                    {
                                        "bp-reading" => "bp",
                                        "blood-sugar" => "bs",
                                        "lab-test" => "lab",
                                        "ultrasound" => "ultrasound",
                                        "appointment" => "appointment",
                                        "alert" => "alert",
                                        "doctor-note" => "doctor",
                                        "medication" => "medication",
                                        "pregnancy-started" => "default",
                                        "pregnancy-ended" => "default",
                                        _ => "default"
                                    };

                                    string icon = entry.EventType switch
                                    {
                                        "bp-reading" => "fas fa-heartbeat",
                                        "blood-sugar" => "fas fa-tint",
                                        "lab-test" => "fas fa-flask",
                                        "ultrasound" => "fas fa-baby",
                                        "appointment" => "fas fa-calendar-check",
                                        "alert" => "fas fa-exclamation-triangle",
                                        "doctor-note" => "fas fa-user-md",
                                        "medication" => "fas fa-pills",
                                        "pregnancy-started" => "fas fa-play-circle",
                                        "pregnancy-ended" => "fas fa-flag-checkered",
                                        _ => "fas fa-circle"
                                    };

                                    bool isCritical = entry.Status == "critical" || entry.Status == "attention";

                                    <div class="mh-timeline-item timeline-item @eventClass @(isCritical ? "critical" : "")"
                                         data-type="@entry.EventType"
                                         data-status="@entry.Status"
                                         data-text="@(entry.Title + " " + entry.SubTitle + " " + entry.DoctorName)">

                                        <!-- Timeline Dot -->
                                        <div class="mh-timeline-dot">
                                            <i class="@icon"></i>
                                        </div>

                                        <!-- Timeline Card -->
                                        <div class="mh-timeline-card">

                                            <!-- Card Header -->
                                            <div class="mh-card-header">
                                                <div class="mh-card-header-left">
                                                    <span class="mh-event-badge @eventClass">
                                                        <i class="@icon"></i>
                                                        @(entry.EventType?.Replace("-", " ") ?? "Record")
                                                    </span>
                                                    <h4 class="mh-card-title">@entry.Title</h4>
                                                </div>
                                                <span class="mh-card-time">
                                                    <i class="fas fa-clock"></i>
                                                    @entry.DateTime.ToString("h:mm tt")
                                                </span>
                                            </div>

                                            <!-- Card Body -->
                                            <div class="mh-card-body">

                                                @* ── Blood Pressure ── *@
                                                @if (entry.BloodPressure != null)
                                                {
                                                    string statusClass = entry.Status == "critical" ? "critical" : entry.Status == "attention" ? "warning" : "normal";
                                                    string statusText = entry.Status == "critical" ? "Critical" : entry.Status == "attention" ? "Elevated" : "Normal";

                                                    <div class="mh-vitals-display">
                                                        <div class="mh-vitals-reading">
                                                            <span class="mh-vitals-value">@entry.BloodPressure.BloodPressure</span>
                                                            <span class="mh-vitals-unit">mmHg</span>
                                                        </div>
                                                        <span class="mh-status-badge @statusClass">
                                                            <i class="fas fa-circle"></i>
                                                            @statusText
                                                        </span>
                                                    </div>
                                                    @if (!string.IsNullOrWhiteSpace(entry.BloodPressure.MeasurementTime))
                                                    {
                                                        <p class="mh-card-meta">
                                                            <i class="fas fa-clock"></i>
                                                            Measured: @entry.BloodPressure.MeasurementTime
                                                        </p>
                                                    }
                                                }

                                                @* ── Blood Sugar ── *@
                                                @if (entry.BloodSugar != null)
                                                {
                                                    string statusClass = entry.Status == "critical" ? "critical" : entry.Status == "attention" ? "warning" : "normal";
                                                    string statusText = entry.Status == "critical" ? "Critical" : entry.Status == "attention" ? "High" : "Normal";

                                                    <div class="mh-vitals-display">
                                                        <div class="mh-vitals-reading">
                                                            <span class="mh-vitals-value">@entry.BloodSugar.BloodSugar</span>
                                                            <span class="mh-vitals-unit">mg/dL</span>
                                                        </div>
                                                        <span class="mh-status-badge @statusClass">
                                                            <i class="fas fa-circle"></i>
                                                            @statusText
                                                        </span>
                                                    </div>
                                                    @if (!string.IsNullOrWhiteSpace(entry.BloodSugar.MeasurementTime))
                                                    {
                                                        <p class="mh-card-meta">
                                                            <i class="fas fa-utensils"></i>
                                                            @entry.BloodSugar.MeasurementTime
                                                        </p>
                                                    }
                                                }

                                                @* ── Lab Test ── *@
                                                @if (entry.LabTest != null)
                                                {
                                                    bool hasAI = !string.IsNullOrWhiteSpace(entry.LabTest.AI_AnalysisJSON);

                                                    <div class="mh-lab-container">
                                                        <div class="mh-lab-details">
                                                            <div class="mh-lab-detail-item">
                                                                <i class="fas fa-vial"></i>
                                                                <div>
                                                                    <span class="mh-lab-detail-label">Test Type</span>
                                                                    <span class="mh-lab-detail-value">@entry.LabTest.TestType</span>
                                                                </div>
                                                            </div>
                                                            <div class="mh-lab-detail-item">
                                                                <i class="fas fa-calendar-alt"></i>
                                                                <div>
                                                                    <span class="mh-lab-detail-label">Date</span>
                                                                    <span class="mh-lab-detail-value">@entry.LabTest.UploadDate.ToString("MMM dd, yyyy")</span>
                                                                </div>
                                                            </div>
                                                            @if (hasAI)
                                                            {
                                                                <div class="mh-lab-detail-item">
                                                                    <i class="fas fa-robot"></i>
                                                                    <div>
                                                                        <span class="mh-lab-detail-label">Analysis</span>
                                                                        <span class="mh-lab-detail-value">AI Analyzed</span>
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>

                                                        <div class="mh-lab-actions">
                                                            <button class="mh-lab-btn mh-lab-btn-primary"
                                                                    data-labid="@entry.LabTest.LabTestID"
                                                                    data-testtype="@entry.LabTest.TestType"
                                                                    data-uploaddate="@entry.LabTest.UploadDate.ToString("MMMM dd, yyyy")"
                                                                    data-imagepath="@entry.LabTest.ImagePath"
                                                                    data-hasai="@hasAI.ToString().ToLower()"
                                                                    data-aijson="@(hasAI ? System.Net.WebUtility.HtmlEncode(entry.LabTest.AI_AnalysisJSON) : "")">
                                                                <i class="fas fa-file-medical-alt"></i>
                                                                View Full Report
                                                            </button>
                                                            @if (!string.IsNullOrWhiteSpace(entry.LabTest.ImagePath))
                                                            {
                                                                <a href="/@entry.LabTest.ImagePath.TrimStart('/')"
                                                                   target="_blank"
                                                                   class="mh-lab-btn mh-lab-btn-secondary">
                                                                    <i class="fas fa-image"></i>
                                                                    View Image
                                                                </a>
                                                            }
                                                        </div>
                                                    </div>
                                                }

                                                @* ── Ultrasound ── *@
                                                @if (entry.Ultrasound != null)
                                                {
                                                    bool noAnomaly = string.IsNullOrWhiteSpace(entry.Ultrasound.DetectedAnomaly);

                                                    <div class="mh-ai-analysis @(noAnomaly ? "success" : "warning")">
                                                        <div class="mh-ai-header">
                                                            <i class="fas fa-robot"></i>
                                                            <span>AI Analysis</span>
                                                        </div>
                                                        <p class="mh-ai-text">
                                                            @(noAnomaly ? "No anomalies detected. Fetal development appears normal." : entry.Ultrasound.DetectedAnomaly)
                                                        </p>
                                                    </div>

                                                    @if (!string.IsNullOrWhiteSpace(entry.Ultrasound.DoctorComments))
                                                    {
                                                        <div class="mh-doctor-comment">
                                                            <i class="fas fa-comment-medical"></i>
                                                            <div>
                                                                <strong>Doctor's Note:</strong>
                                                                <p>@entry.Ultrasound.DoctorComments</p>
                                                            </div>
                                                        </div>
                                                    }
                                                }

                                                @* ── Appointment ── *@
                                                @if (entry.Appointment != null)
                                                {
                                                    bool isPast = entry.Appointment.Date < DateTime.Now;
                                                    var appointmentDateTime = entry.Appointment.Date.Date.Add(entry.Appointment.Time);

                                                    <div class="mh-appointment-info">
                                                        <div class="mh-appt-status @(isPast ? "completed" : "upcoming")">
                                                            <i class="fas @(isPast ? "fa-check-circle" : "fa-clock")"></i>
                                                            <span>@(isPast ? "Completed" : "Upcoming")</span>
                                                        </div>

                                                        <div class="mh-appt-details">
                                                            @if (!string.IsNullOrWhiteSpace(entry.DoctorName))
                                                            {
                                                                <div class="mh-appt-detail">
                                                                    <i class="fas fa-user-md"></i>
                                                                    <span>@entry.DoctorName</span>
                                                                </div>
                                                            }
                                                            @if (!string.IsNullOrWhiteSpace(entry.ClinicName))
                                                            {
                                                                <div class="mh-appt-detail">
                                                                    <i class="fas fa-hospital"></i>
                                                                    <span>@entry.ClinicName</span>
                                                                </div>
                                                            }
                                                            <div class="mh-appt-detail">
                                                                <i class="fas fa-calendar"></i>
                                                                <span>@appointmentDateTime.ToString("MMM dd, yyyy 'at' h:mm tt")</span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }

                                                @* ── Alert ── *@
                                                @if (entry.Alert != null)
                                                {
                                                    string alertType = (entry.Alert.AlertType ?? "info").ToLower();
                                                    string alertClass = alertType == "danger" || alertType == "critical" ? "danger"
                                                                      : alertType == "warning" ? "warning"
                                                                      : alertType == "success" ? "success" : "info";

                                                    <div class="mh-alert-box @alertClass">
                                                        <div class="mh-alert-header">
                                                            <span class="mh-alert-severity @alertClass">
                                                                <i class="fas fa-exclamation-triangle"></i>
                                                                @entry.Alert.AlertType
                                                            </span>
                                                            @if (!entry.Alert.IsRead)
                                                            {
                                                                <span class="mh-alert-unread"></span>
                                                            }
                                                        </div>
                                                        <p class="mh-alert-message">@entry.Alert.Message</p>
                                                        <div class="mh-alert-footer">
                                                            <span class="mh-alert-status">
                                                                <i class="fas @(entry.Alert.IsRead ? "fa-envelope-open" : "fa-envelope")"></i>
                                                                @(entry.Alert.IsRead ? "Read" : "Unread")
                                                            </span>
                                                        </div>
                                                    </div>
                                                }

                                                @* ── Doctor Note ── *@
                                                @if (entry.DoctorNote != null)
                                                {
                                                    <div class="mh-note-box">
                                                        <i class="fas fa-quote-left"></i>
                                                        <p>@entry.DoctorNote.Content</p>
                                                    </div>
                                                }

                                                @* ── Medication ── *@
                                                @if (entry.Prescription != null)
                                                {
                                                    <div class="mh-medications">
                                                        @if (entry.Prescription.Items != null && entry.Prescription.Items.Any())
                                                        {
                                                            @foreach (var item in entry.Prescription.Items)
                                                            {
                                                                <div class="mh-med-item">
                                                                    <div class="mh-med-icon">
                                                                        <i class="fas fa-capsules"></i>
                                                                    </div>
                                                                    <div class="mh-med-info">
                                                                        <strong>@item.MedicineName</strong>
                                                                        <span>@item.Dosage · @item.Frequency</span>
                                                                        @if (!string.IsNullOrWhiteSpace(item.Instructions))
                                                                        {
                                                                            <em>@item.Instructions</em>
                                                                        }
                                                                    </div>
                                                                </div>
                                                            }
                                                        }
                                                        else if (!string.IsNullOrWhiteSpace(entry.Prescription.Notes))
                                                        {
                                                            <p class="mh-card-meta">@entry.Prescription.Notes</p>
                                                        }
                                                    </div>
                                                }

                                            </div>

                                            <!-- Card Footer -->
                                            <div class="mh-card-footer">
                                                @if (!string.IsNullOrWhiteSpace(entry.DoctorName) && entry.Appointment == null)
                                                {
                                                    <span class="mh-footer-info">
                                                        <i class="fas fa-user-md"></i>
                                                        Dr. @entry.DoctorName
                                                    </span>
                                                }
                                                else if (entry.BloodPressure != null || entry.BloodSugar != null)
                                                {
                                                    <span class="mh-footer-info">
                                                        <i class="fas fa-user"></i>
                                                        Self-recorded
                                                    </span>
                                                }
                                                else if (entry.Alert != null)
                                                {
                                                    <span class="mh-footer-info">
                                                        <i class="fas fa-robot"></i>
                                                        System Alert
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span></span>
                                                }

                                                <span class="mh-footer-date">
                                                    @entry.DateTime.ToString("MMM dd, yyyy")
                                                </span>
                                            </div>

                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

        </main>

    </div>

</div>

@section Scripts {
<script>
document.addEventListener("DOMContentLoaded", function () {
    const searchInput = document.getElementById("historySearch");
    const eventTypeFilter = document.getElementById("eventTypeFilter");
    const statusFilter = document.getElementById("statusFilter");
    const clearBtn = document.getElementById("clearFilters");
    const exportBtn = document.getElementById("exportHistory");
    const printBtn = document.getElementById("printHistory");
    const resultsCount = document.getElementById("resultsCount");

    function getItems() {
        return document.querySelectorAll(".timeline-item");
    }

    function filterTimeline() {
        const search = (searchInput?.value ?? "").toLowerCase();
        const eventType = eventTypeFilter?.value ?? "all";
        const status = statusFilter?.value ?? "all";
        let visible = 0;

        getItems().forEach(item => {
            const t = (item.dataset.type ?? "").toLowerCase();
            const s = (item.dataset.status ?? "").toLowerCase();
            const tx = (item.dataset.text ?? "").toLowerCase();

            const show = (!search || tx.includes(search))
                      && (eventType === "all" || t === eventType)
                      && (status === "all" || s === status);

            item.style.display = show ? "flex" : "none";
            if (show) visible++;
        });

        document.querySelectorAll(".timeline-date-group").forEach(g => {
            const hasVisible = Array.from(g.querySelectorAll(".timeline-item"))
                .some(i => i.style.display !== "none");
            g.style.display = hasVisible ? "block" : "none";
        });

        if (resultsCount) {
            resultsCount.innerHTML = `<i class="fas fa-check-circle"></i> ${visible} record${visible !== 1 ? 's' : ''} found`;
        }
    }

    function debounce(fn, ms) {
        let t;
        return (...a) => {
            clearTimeout(t);
            t = setTimeout(() => fn(...a), ms);
        };
    }

    searchInput?.addEventListener("input", debounce(filterTimeline, 250));
    eventTypeFilter?.addEventListener("change", filterTimeline);
    statusFilter?.addEventListener("change", filterTimeline);

    clearBtn?.addEventListener("click", () => {
        if (searchInput) searchInput.value = "";
        if (eventTypeFilter) eventTypeFilter.value = "all";
        if (statusFilter) statusFilter.value = "all";
        filterTimeline();
    });

    exportBtn?.addEventListener("click", showExportModal);
    printBtn?.addEventListener("click", () => window.print());

    filterTimeline();

    function showExportModal() {
        const modal = document.createElement("div");
        modal.className = "mh-modal-overlay";
        modal.innerHTML = `
            <div class="mh-modal">
                <div class="mh-modal-header">
                    <h3><i class="fas fa-download"></i> Export Medical History</h3>
                    <button class="mh-modal-close"><i class="fas fa-times"></i></button>
                </div>
                <div class="mh-modal-body">
                    <p class="mh-modal-desc">Select the format for exporting your medical records</p>
                    <div class="mh-export-options">
                        <label class="mh-export-option">
                            <input type="radio" name="exportFormat" value="pdf" checked>
                            <div class="mh-export-option-content">
                                <i class="fas fa-file-pdf"></i>
                                <div>
                                    <strong>PDF Document</strong>
                                    <span>Best for printing and sharing with healthcare providers</span>
                                </div>
                            </div>
                        </label>
                        <label class="mh-export-option">
                            <input type="radio" name="exportFormat" value="excel">
                            <div class="mh-export-option-content">
                                <i class="fas fa-file-excel"></i>
                                <div>
                                    <strong>Excel Spreadsheet</strong>
                                    <span>Best for data analysis and record keeping</span>
                                </div>
                            </div>
                        </label>
                    </div>
                </div>
                <div class="mh-modal-footer">
                    <button class="mh-modal-btn mh-modal-btn-cancel">Cancel</button>
                    <button class="mh-modal-btn mh-modal-btn-export">
                        <i class="fas fa-download"></i>
                        Export
                    </button>
                </div>
            </div>
        `;

        document.body.appendChild(modal);

        modal.querySelector(".mh-modal-close").addEventListener("click", () => modal.remove());
        modal.querySelector(".mh-modal-btn-cancel").addEventListener("click", () => modal.remove());
        modal.addEventListener("click", (e) => {
            if (e.target === modal) modal.remove();
        });

        modal.querySelector(".mh-modal-btn-export").addEventListener("click", function() {
            this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Exporting...';
            this.disabled = true;
            setTimeout(() => {
                modal.remove();
                showNotification("Medical history exported successfully!", "success");
            }, 1500);
        });
    }

    function showNotification(message, type = "success") {
        if (typeof window.showNotification === 'function') {
            window.showNotification(message, type);
        } else {
            const notification = document.createElement("div");
            notification.className = `mh-notification mh-notification-${type}`;
            notification.innerHTML = `
                <i class="fas fa-${type === 'success' ? 'check-circle' : 'info-circle'}"></i>
                <span>${message}</span>
                <button class="mh-notification-close"><i class="fas fa-times"></i></button>
            `;
            document.body.appendChild(notification);

            notification.querySelector(".mh-notification-close").addEventListener("click", () => {
                notification.remove();
            });

            setTimeout(() => notification.remove(), 4000);
        }
    }

    // Lab report button handlers
    document.addEventListener('click', function(e) {
        if (e.target.closest('.mh-lab-btn-primary')) {
            const btn = e.target.closest('.mh-lab-btn-primary');
            const labData = {
                labId: btn.dataset.labid,
                testType: btn.dataset.testtype,
                uploadDate: btn.dataset.uploaddate,
                imagePath: btn.dataset.imagepath,
                hasAI: btn.dataset.hasai === 'true',
                aiJSON: btn.dataset.aijson
            };

            console.log('Lab Report:', labData);
            showNotification("Lab report viewer coming soon!", "info");
        }
    });
});
</script>

