/* ─────────────────────────────────────────
   MODERN APPOINTMENT CARD
───────────────────────────────────────── */
.mh-appt-card {
    border-radius: 16px;
    overflow: hidden;
    border: 1.5px solid var(--mh-border);
    box-shadow: 0 4px 20px rgba(0,0,0,.07);
    transition: transform .22s, box-shadow .22s;
    margin-top: .1rem;
    background: #fff;
}
.mh-appt-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 32px rgba(0,0,0,.12);
}

/* ── Upcoming variant ── */
.mh-appt-upcoming { border-color: rgba(255,152,0,.35); }
.mh-appt-upcoming .mh-appt-header-band {
    background: linear-gradient(135deg, #ff9800, #fb8c00);
}
.mh-appt-upcoming .mh-appt-info-icon { background: rgba(255,152,0,.12); color: #e65100; }

/* ── Completed variant ── */
.mh-appt-completed { border-color: rgba(33,150,243,.3); }
.mh-appt-completed .mh-appt-header-band {
    background: linear-gradient(135deg, #2196f3, #1565c0);
}
.mh-appt-completed .mh-appt-info-icon { background: rgba(33,150,243,.12); color: #1565c0; }

/* Header band */
.mh-appt-header-band {
    display: flex;
    align-items: center;
    gap: .85rem;
    padding: .9rem 1.15rem;
    position: relative;
    overflow: hidden;
}
.mh-appt-header-band::after {
    content: '\f073';
    font-family: 'Font Awesome 5 Free';
    font-weight: 900;
    position: absolute;
    right: -10px; top: 50%;
    transform: translateY(-50%);
    font-size: 4.5rem;
    color: rgba(255,255,255,.08);
    pointer-events: none;
}

/* Doctor avatar */
.mh-appt-doctor-avatar {
    width: 42px; height: 42px;
    border-radius: 50%;
    background: rgba(255,255,255,.22);
    backdrop-filter: blur(4px);
    border: 2px solid rgba(255,255,255,.45);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 1rem;
    flex-shrink: 0;
    box-shadow: 0 2px 8px rgba(0,0,0,.18);
}

/* Doctor name & specialty */
.mh-appt-header-info {
    display: flex; flex-direction: column;
    flex: 1;
}
.mh-appt-doctor-name {
    font-size: .95rem; font-weight: 700;
    color: #fff; line-height: 1.2;
}
.mh-appt-specialty {
    font-size: .73rem;
    color: rgba(255,255,255,.78);
    margin-top: .08rem;
}

/* Status pill */
.mh-appt-status-pill {
    display: inline-flex; align-items: center; gap: .35rem;
    font-size: .7rem; font-weight: 700;
    padding: .28rem .75rem; border-radius: 20px;
    letter-spacing: .04em; white-space: nowrap;
    border: 1.5px solid rgba(255,255,255,.4);
    backdrop-filter: blur(4px);
}
.mh-appt-status-upcoming  { background: rgba(255,255,255,.22); color: #fff; }
.mh-appt-status-completed { background: rgba(255,255,255,.22); color: #fff; }

/* Body */
.mh-appt-body {
    padding: .9rem 1.15rem 1rem;
    background: #fff;
}

/* Info grid */
.mh-appt-info-grid {
    display: flex;
    flex-wrap: wrap;
    gap: .6rem;
}
.mh-appt-info-cell {
    display: flex;
    align-items: center;
    gap: .6rem;
    background: var(--mh-light);
    border: 1px solid var(--mh-border);
    border-radius: 12px;
    padding: .55rem .9rem;
    flex: 1;
    min-width: 130px;
    transition: border-color .2s, box-shadow .2s;
}
.mh-appt-info-cell:hover {
    border-color: var(--mh-primary);
    box-shadow: 0 0 0 3px rgba(27,174,190,.08);
}
.mh-appt-info-icon {
    width: 32px; height: 32px;
    border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    font-size: .8rem;
    flex-shrink: 0;
}
.mh-appt-info-label {
    display: block;
    font-size: .67rem;
    font-weight: 600;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: .04em;
    line-height: 1;
}
.mh-appt-info-value {
    display: block;
    font-size: .88rem;
    font-weight: 600;
    color: var(--mh-text);
    margin-top: .12rem;
    line-height: 1.2;
}

/* ─────────────────────────────────────────
   ALERT CARD INNER  (replaces old mh-alert-box)
───────────────────────────────────────── */
.mh-alert-card-inner {
    display: flex;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid transparent;
    margin-top: .1rem;
}

/* Severity variants */
.mh-alert-box-danger  { background: linear-gradient(135deg,#fff1f2,#ffe4e6); border-color: #fca5a5; }
.mh-alert-box-warning { background: linear-gradient(135deg,#fffbeb,#fef9c3); border-color: #fde68a; }
.mh-alert-box-info    { background: linear-gradient(135deg,#eff6ff,#dbeafe); border-color: #93c5fd; }
.mh-alert-box-success { background: linear-gradient(135deg,#f0fdf4,#dcfce7); border-color: #86efac; }

/* Left colour stripe */
.mh-alert-stripe {
    width: 5px;
    flex-shrink: 0;
    border-radius: 14px 0 0 14px;
}
.mh-alert-box-danger  .mh-alert-stripe { background: #ef4444; }
.mh-alert-box-warning .mh-alert-stripe { background: #f59e0b; }
.mh-alert-box-info    .mh-alert-stripe { background: #3b82f6; }
.mh-alert-box-success .mh-alert-stripe { background: #22c55e; }

.mh-alert-card-body {
    flex: 1;
    padding: .75rem 1rem;
}

/* Top row */
.mh-alert-top-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: .5rem;
}

/* Severity pill */
.mh-alert-severity-pill {
    display: inline-flex; align-items: center; gap: .35rem;
    font-size: .72rem; font-weight: 700;
    padding: .22rem .65rem; border-radius: 20px;
    text-transform: uppercase; letter-spacing: .04em;
    border: 1px solid transparent;
}
.mh-alert-box-danger  .mh-alert-severity-pill { background: #fee2e2; color: #b91c1c; border-color: #fca5a5; }
.mh-alert-box-warning .mh-alert-severity-pill { background: #fef3c7; color: #b45309; border-color: #fde68a; }
.mh-alert-box-info    .mh-alert-severity-pill { background: #dbeafe; color: #1d4ed8; border-color: #93c5fd; }
.mh-alert-box-success .mh-alert-severity-pill { background: #dcfce7; color: #15803d; border-color: #86efac; }

/* Pulsing unread dot */
.mh-alert-unread-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: #ef4444;
    box-shadow: 0 0 0 0 rgba(239,68,68,.4);
    animation: mhPulse 1.8s ease-in-out infinite;
    flex-shrink: 0;
}
@@keyframes mhPulse {
    0%   { box-shadow: 0 0 0 0 rgba(239,68,68,.5); }
    70%  { box-shadow: 0 0 0 8px rgba(239,68,68,0); }
    100% { box-shadow: 0 0 0 0 rgba(239,68,68,0); }
}

/* Alert message text */
.mh-alert-message-text {
    margin: 0;
    font-size: .88rem;
    color: #334155;
    line-height: 1.6;
}

/* Keep the old .mh-alert-box for any other use */
.mh-alert-box {
    display: flex; gap: .75rem; align-items: flex-start;
    background: linear-gradient(135deg,#fffbeb,#fff8f0);
    border: 1px solid #fcd34d;
    border-radius: 12px;
    padding: .75rem 1rem;
}
.mh-alert-icon {
    width: 32px; height: 32px;
    background: #fef3c7;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    color: #f59e0b; font-size: .95rem; flex-shrink: 0;
}
.mh-alert-msg { margin: 0; font-size: .88rem; color: #334155; line-height: 1.55; }

/* ─────────────────────────────────────────
   DOCTOR NOTE
───────────────────────────────────────── */
.mh-note-box {
    position: relative;
    background: linear-gradient(135deg,#f8fafc,#f1f5f9);
    border-left: 4px solid #6366f1;
    border-radius: 0 12px 12px 0;
    padding: .75rem 1rem .75rem 1.1rem;
}
.mh-note-quote { color: #818cf8; font-size: 1.1rem; margin-bottom: .3rem; display: block; }
.mh-note-text  { margin: 0; font-style: italic; color: #475569; line-height: 1.6; font-size: .9rem; }

/* ─────────────────────────────────────────
   MEDICATION LIST
───────────────────────────────────────── */
.mh-meds-list { display: flex; flex-direction: column; gap: .6rem; }
.mh-med-item  {
    display: flex; gap: .75rem; align-items: flex-start;
    background: var(--mh-light);
    border: 1px solid var(--mh-border);
    border-radius: 12px;
    padding: .65rem .9rem;
}
.mh-med-pill-icon {
    width: 36px; height: 36px;
    background: #e0f7fa; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    color: #00838f; font-size: .9rem; flex-shrink: 0;
}
.mh-med-info { display: flex; flex-direction: column; gap: .1rem; }
.mh-med-info strong { font-size: .9rem; color: var(--mh-text); }
.mh-med-info span   { font-size: .82rem; color: var(--mh-muted); }
.mh-med-info em     { font-size: .77rem; color: #94a3b8; }

/* ─────────────────────────────────────────
   META LINE
───────────────────────────────────────── */
.mh-meta {
    display: flex; align-items: center; gap: .35rem;
    font-size: .82rem; color: var(--mh-muted);
    margin: .3rem 0 0;
}

/* ─────────────────────────────────────────
   EMPTY STATE
───────────────────────────────────────── */
.mh-empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background: #fff;
    border-radius: var(--mh-radius);
    box-shadow: var(--mh-shadow);
    border: 1px solid var(--mh-border);
}
.mh-empty-icon {
    width: 72px; height: 72px;
    background: var(--mh-light);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem; color: #cbd5e1;
    margin: 0 auto 1.2rem;
}
.mh-empty-state h3 { color: #64748b; margin: 0 0 .5rem; }
.mh-empty-state p  { color: #94a3b8; margin: 0; }

/* ─────────────────────────────────────────
   EXPORT MODAL
───────────────────────────────────────── */
.mh-modal-wrap    { position: fixed; inset: 0; z-index: 9999; display: flex; align-items: center; justify-content: center; }
.mh-modal-overlay { position: absolute; inset: 0; background: rgba(15,23,42,.55); backdrop-filter: blur(3px); }
.mh-modal {
    position: relative; background: #fff;
    border-radius: 20px; max-width: 480px; width: 90%;
    overflow: hidden; box-shadow: 0 24px 60px rgba(0,0,0,.18);
    animation: mhModalIn .25s ease;
}
.mh-modal-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.2rem 1.5rem;
    border-bottom: 1px solid var(--mh-border);
    background: linear-gradient(135deg,#f8fafc,#f1f5f9);
}
.mh-modal-header h3 { margin: 0; font-size: 1rem; display: flex; align-items: center; gap: .55rem; color: var(--mh-text); }
.mh-modal-close { background: none; border: none; font-size: 1rem; cursor: pointer; color: var(--mh-muted); padding: 4px 8px; border-radius: 8px; }
.mh-modal-close:hover { background: var(--mh-light); }
.mh-modal-body   { padding: 1.5rem; }
.mh-modal-footer { display: flex; gap: .75rem; justify-content: flex-end; padding: 1rem 1.5rem; border-top: 1px solid var(--mh-border); background: var(--mh-light); }

.mh-export-options     { display: flex; flex-direction: column; gap: .75rem; }
.mh-export-opt         { cursor: pointer; }
.mh-export-opt input   { display: none; }
.mh-export-opt-inner   {
    display: flex; align-items: center; gap: 1rem;
    padding: .9rem 1.1rem;
    border: 2px solid var(--mh-border);
    border-radius: 12px;
    transition: border-color .2s, background .2s;
}
.mh-export-opt input:checked + .mh-export-opt-inner {
    border-color: var(--mh-primary);
    background: rgba(27,174,190,.05);
}
.mh-export-opt-inner i    { font-size: 1.5rem; color: var(--mh-primary); }
.mh-export-opt-inner span { font-weight: 600; display: block; color: var(--mh-text); }
.mh-export-opt-inner small{ display: block; font-size: .75rem; color: #94a3b8; }

/* ─────────────────────────────────────────
   NOTIFICATIONS
───────────────────────────────────────── */
.mh-notif {
    position: fixed; top: 1.5rem; right: 1.5rem;
    padding: .9rem 1.25rem; border-radius: 14px;
    display: flex; align-items: center; gap: .75rem;
    font-weight: 500; z-index: 9999;
    box-shadow: 0 8px 24px rgba(0,0,0,.14);
    animation: mhSlideIn .3s ease;
}
.mh-notif-success { background: #e8f5e9; color: #2e7d32; border: 1px solid #a5d6a7; }
.mh-notif-info    { background: #e3f2fd; color: #1565c0; border: 1px solid #90caf9; }
.mh-notif-close   { background: none; border: none; cursor: pointer; color: inherit; opacity: .6; padding: 2px 6px; }

/* ─────────────────────────────────────────
   ANIMATIONS
───────────────────────────────────────── */
@@keyframes mhModalIn  { from { opacity:0; transform:translateY(-20px) scale(.97); } to { opacity:1; transform:translateY(0) scale(1); } }
@@keyframes mhSlideIn  { from { opacity:0; transform:translateX(20px); } to { opacity:1; transform:translateX(0); } }
</style>
}

