@model Graduation_Project.ViewModels.PatientAppointmentsViewModel
@{
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    ViewData["Title"] = "My Appointments";
    ViewData["PatientId"] = Model.Patient.PatientID;
    ViewData["ActivePage"] = "Appointments";
    ViewData["UserName"] = Model.UserName;

    var nameParts = (Model.UserName ?? "Patient").Split(' ', StringSplitOptions.RemoveEmptyEntries);
    var firstName = nameParts.Length > 0 ? nameParts[0] : "Patient";
    ViewData["PageTitle"] = "Appointments";
    ViewData["PageTitleHtml"] = $"Appointments for <span class='topbar-accent'>{firstName}</span>";
    ViewData["PageSubtitle"] = "Manage upcoming and past visits";

    var patientId = Model.Patient.PatientID;
}
@section Head {
    @Html.AntiForgeryToken()
}

<header class="header pa-header pa-hero">
    <div class="header-left pa-hero-left">
        <div class="pa-hero-icon">
            <i class="fas fa-calendar-check"></i>
        </div>
        <div>
            <h1>My Appointments</h1>
            <p>View and manage your medical appointments</p>
        </div>
    </div>
    <div class="header-right pa-hero-right">
        <button class="btn btn-primary"
                onclick="window.location.href='@Url.Action("BookAppointment", "PatientAppointments", new { id = patientId })'">
            <i class="fas fa-plus-circle"></i> Book New Appointment
        </button>
    </div>
</header>

<div class="patient-appointments-page">

            <section class="pa-overview-grid">
                <div class="pa-overview-card">
                    <div class="pa-overview-icon"><i class="fas fa-clock"></i></div>
                    <div class="pa-overview-content">
                        <span class="pa-overview-label">Upcoming</span>
                        <strong>@Model.UpcomingAppointments.Count</strong>
                    </div>
                </div>
                <div class="pa-overview-card">
                    <div class="pa-overview-icon"><i class="fas fa-history"></i></div>
                    <div class="pa-overview-content">
                        <span class="pa-overview-label">Past Visits</span>
                        <strong>@Model.PastAppointments.Count</strong>
                    </div>
                </div>
                <div class="pa-overview-card">
                    <div class="pa-overview-icon"><i class="fas fa-user-md"></i></div>
                    <div class="pa-overview-content">
                        <span class="pa-overview-label">My Doctors</span>
                        <strong>@Model.MyDoctors.Count</strong>
                    </div>
                </div>
            </section>

            <!-- Primary Doctor Section -->
            <section class="primary-doctor-section">
                <div class="card primary-doctor-card">
                    <div class="card-header">
                        <h3><i class="fas fa-user-md"></i> Your Primary Doctor</h3>
                        <span class="primary-badge"><i class="fas fa-star"></i> Primary</span>
                    </div>
                    @if (Model.PrimaryDoctor?.Doctor != null)
                    {
                        var doc = Model.PrimaryDoctor.Doctor;
                        var docName = doc.User != null ? $"Dr. {doc.User.FirstName} {doc.User.LastName}".Trim() : "Doctor";
                        var clinicDoc = doc.ClinicDoctors?.FirstOrDefault();
                        var docApptCount = Model.UpcomingAppointments.Count(a => a.DoctorID == doc.DoctorID)
                                         + Model.PastAppointments.Count(a => a.DoctorID == doc.DoctorID);
                        <div class="primary-doctor-content">
                            <div class="primary-doctor-info">
                                <div class="primary-doctor-details">
                                    <div class="primary-doctor-avatar">
                                        <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(docName)&background=1BAEBE&color=fff&size=80"
                                             alt="@docName" />
                                        <span class="online-status"></span>
                                    </div>
                                    <div class="primary-info">
                                        <h4>@docName</h4>
                                        <p class="specialty"><i class="fas fa-stethoscope"></i> @doc.Specialization</p>
                                        <p class="location"><i class="fas fa-map-marker-alt"></i> @(clinicDoc?.Clinic?.Name ?? "Clinic")</p>
                                        <div class="quick-stats pa-quick-stats">
                                            <span>
                                                <i class="fas fa-calendar-check"></i>
                                                @docApptCount appointment@(docApptCount != 1 ? "s" : "")
                                            </span>
                                            <span><i class="fas fa-star"></i> Receives alerts</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="primary-doctor-actions">
                                    <button class="btn btn-primary"
                                            onclick="window.location.href='@Url.Action("BookAppointment", "PatientAppointments", new { id = patientId, doctorId = doc.DoctorID })'">
                                        <i class="fas fa-calendar-plus"></i> Book Appointment
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="primary-doctor-content">
                            <div class="no-primary-doctor">
                                <i class="fas fa-user-md"></i>
                                <h4>No Primary Doctor Set</h4>
                                <p>
                                    Select a doctor from the list below to set as your primary
                                    care provider
                                </p>
                                <button class="btn btn-primary"
                                        onclick="window.location.href='@Url.Action("BookAppointment", "PatientAppointments", new { id = patientId })'">
                                    <i class="fas fa-search"></i> Find &amp; Select Doctor
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <!-- My Doctors (Previously Visited) -->
            @if (Model.MyDoctors.Count > 0)
            {
                <section class="my-doctors-section">
                    <div class="card">
                        <div class="card-header">
                            <h3><i class="fas fa-history"></i> My Doctors</h3>
                            <span class="doctors-count" id="myDoctorsCount">
                                @Model.MyDoctors.Count doctor@(Model.MyDoctors.Count != 1 ? "s" : "")
                            </span>
                        </div>
                        <div class="my-doctors-grid">
                            @foreach (var pd in Model.MyDoctors)
                            {
                                var doc = pd.Doctor;
                                if (doc == null) { continue; }
                                var docName = doc.User != null ? $"Dr. {doc.User.FirstName} {doc.User.LastName}".Trim() : "Doctor";
                                var clinicDoc = doc.ClinicDoctors?.FirstOrDefault();
                                <div class="doctor-mini-card" data-doctor-id="@doc.DoctorID">
                                    <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(docName)&background=1BAEBE&color=fff&size=60"
                                         alt="@docName" />
                                    <div class="doctor-mini-info">
                                        <h5>
                                            @docName
                                            @if (pd.IsPrimary) { <span class="primary-tag">Primary</span> }
                                        </h5>
                                        <p>@doc.Specialization</p>
                                        <p>@(clinicDoc?.Clinic?.Name ?? "")</p>
                                    </div>
                                    <div class="doctor-mini-actions">
                                        <button class="btn btn-sm btn-outline"
                                                onclick="window.location.href='@Url.Action("BookAppointment", "PatientAppointments", new { id = patientId, doctorId = doc.DoctorID })'">
                                            Book
                                        </button>
                                        @if (!pd.IsPrimary)
                                        {
                                            <button class="btn btn-sm btn-outline set-primary-btn"
                                                    data-doctor-id="@doc.DoctorID"
                                                    data-patient-id="@patientId">
                                                Set Primary
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </section>
            }

            <!-- Upcoming Appointments -->
            <section class="upcoming-section">
                <div class="card">
                    <div class="card-header">
                        <h3><i class="fas fa-clock"></i> Upcoming Appointments</h3>
                        <span class="appointments-count" id="upcomingCount">
                            @Model.UpcomingAppointments.Count appointment@(Model.UpcomingAppointments.Count != 1 ? "s" : "")
                        </span>
                    </div>
                    <div class="appointments-list">
                        @if (!Model.UpcomingAppointments.Any())
                        {
                            <div class="appointment-empty-state">
                                <i class="fas fa-calendar-times"></i>
                                <p>No upcoming appointments.
                                    <a href="@Url.Action("BookAppointment", "PatientAppointments", new { id = patientId })">Book one now</a>
                                </p>
                            </div>
                        }
                        else
                        {
                            @foreach (var appt in Model.UpcomingAppointments)
                            {
                                var docName = appt.Doctor?.User != null
                                    ? $"Dr. {appt.Doctor.User.FirstName} {appt.Doctor.User.LastName}".Trim()
                                    : "Doctor";
                                var status = appt.Booking?.Status ?? "Confirmed";
                                var canCancel = string.Equals(status, "Confirmed", StringComparison.OrdinalIgnoreCase)
                                             || string.Equals(status, "Modified", StringComparison.OrdinalIgnoreCase);
                                var timeDisplay = DateTime.Today.Add(appt.Time).ToString("h:mm tt");
                                var reason = appt.Booking?.Reason;
                                if (string.IsNullOrWhiteSpace(reason)) reason = "Appointment";
                                <div class="appointment-card upcoming" id="appt-@appt.AppointmentID">
                                    <div class="appointment-date">
                                        <span class="day">@appt.Date.Day</span>
                                        <span class="month">@appt.Date.ToString("MMM")</span>
                                    </div>
                                    <div class="appointment-info">
                                        <h4>@reason</h4>
                                        <p class="doctor-name">
                                            <i class="fas fa-user-md"></i> @docName
                                        </p>
                                        <p class="appointment-time">
                                            <i class="fas fa-clock"></i> @timeDisplay
                                        </p>
                                        <p class="appointment-location">
                                            <i class="fas fa-map-marker-alt"></i> @(appt.Clinic?.Name ?? "Clinic")
                                        </p>
                                    </div>
                                    <div class="appointment-status">
                                        <span class="status-badge @status.ToLower()">@status</span>
                                    </div>
                                    <div class="appointment-actions">
                                        @if (canCancel)
                                        {
                                            <button class="btn btn-sm btn-outline danger cancel-btn"
                                                    data-appointment-id="@appt.AppointmentID"
                                                    data-patient-id="@patientId">
                                                <i class="fas fa-times"></i> Cancel
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </section>

            <!-- Past Appointments -->
            @if (Model.PastAppointments.Count > 0)
            {
                <section class="past-appointments" id="pastAppointmentsSection">
                    <div class="card">
                        <div class="card-header">
                            <h3><i class="fas fa-history"></i> Past Appointments</h3>
                            <button class="btn btn-sm btn-outline" id="openPastModalBtn" type="button">
                                <i class="fas fa-eye"></i> View All
                            </button>
                        </div>
                        <div class="pa-table-wrap">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Doctor</th>
                                        <th>Reason</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var appt in Model.PastAppointments.Take(3))
                                    {
                                        var docName = appt.Doctor?.User != null
                                            ? $"Dr. {appt.Doctor.User.FirstName} {appt.Doctor.User.LastName}".Trim()
                                            : "Doctor";
                                        var status = appt.Booking?.Status ?? "Completed";
                                        var normalizedStatus = status.Trim().ToLowerInvariant();
                                        var badgeClass = normalizedStatus switch
                                        {
                                            "cancelled" or "canceled" => "cancelled",
                                            "missed" => "cancelled",
                                            "modified" => "modified",
                                            "confirmed" => "confirmed",
                                            _ => "completed"
                                        };
                                        var badgeLabel = normalizedStatus switch
                                        {
                                            "cancelled" or "canceled" => "Cancelled",
                                            "missed" => "Missed",
                                            "modified" => "Modified",
                                            "confirmed" => "Confirmed",
                                            _ => "Completed"
                                        };
                                        var reason = appt.Booking?.Reason;
                                        if (string.IsNullOrWhiteSpace(reason)) reason = "Visit";
                                        <tr>
                                            <td>@appt.Date.ToString("MMM dd, yyyy")</td>
                                            <td>@docName</td>
                                            <td>@reason</td>
                                            <td><span class="status-badge @badgeClass">@badgeLabel</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="past-summary">
                            <i class="fas fa-calendar-check"></i>
                            <span>Showing last @(Math.Min(3, Model.PastAppointments.Count)) of @Model.PastAppointments.Count appointments.</span>
                        </div>
                    </div>
                </section>

                <div class="pa-modal-overlay" id="pastAppointmentsModal" aria-hidden="true">
                    <div class="pa-modal" role="dialog" aria-modal="true" aria-labelledby="pastAppointmentsModalTitle">
                        <div class="pa-modal-header">
                            <h3 id="pastAppointmentsModalTitle"><i class="fas fa-history"></i> All Past Appointments</h3>
                            <button class="pa-modal-close" id="closePastModalBtn" type="button" aria-label="Close">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                        <div class="pa-modal-body pa-table-wrap">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Doctor</th>
                                        <th>Reason</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var appt in Model.PastAppointments)
                                    {
                                        var docName = appt.Doctor?.User != null
                                            ? $"Dr. {appt.Doctor.User.FirstName} {appt.Doctor.User.LastName}".Trim()
                                            : "Doctor";
                                        var status = appt.Booking?.Status ?? "Completed";
                                        var normalizedStatus = status.Trim().ToLowerInvariant();
                                        var badgeClass = normalizedStatus switch
                                        {
                                            "cancelled" or "canceled" => "cancelled",
                                            "missed" => "cancelled",
                                            "modified" => "modified",
                                            "confirmed" => "confirmed",
                                            _ => "completed"
                                        };
                                        var badgeLabel = normalizedStatus switch
                                        {
                                            "cancelled" or "canceled" => "Cancelled",
                                            "missed" => "Missed",
                                            "modified" => "Modified",
                                            "confirmed" => "Confirmed",
                                            _ => "Completed"
                                        };
                                        var reason = appt.Booking?.Reason;
                                        if (string.IsNullOrWhiteSpace(reason)) reason = "Visit";
                                        <tr>
                                            <td>@appt.Date.ToString("MMM dd, yyyy")</td>
                                            <td>@docName</td>
                                            <td>@reason</td>
                                            <td><span class="status-badge @badgeClass">@badgeLabel</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
</div>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
          const pastModal = document.getElementById("pastAppointmentsModal");
          const openPastModalBtn = document.getElementById("openPastModalBtn");
          const closePastModalBtn = document.getElementById("closePastModalBtn");

          function openPastModal() {
            if (!pastModal) return;
            pastModal.classList.add("open");
            pastModal.setAttribute("aria-hidden", "false");
            document.body.style.overflow = "hidden";
          }

          function closePastModal() {
            if (!pastModal) return;
            pastModal.classList.remove("open");
            pastModal.setAttribute("aria-hidden", "true");
            document.body.style.overflow = "";
          }

          openPastModalBtn?.addEventListener("click", openPastModal);
          closePastModalBtn?.addEventListener("click", closePastModal);
          pastModal?.addEventListener("click", function (e) {
            if (e.target === pastModal) closePastModal();
          });

          document.addEventListener("keydown", function (e) {
            if (e.key === "Escape" && pastModal?.classList.contains("open")) {
              closePastModal();
            }
          });

          // ================================
          // Cancel Appointment
          // ================================
          const antiForgeryToken = document.querySelector(
            '[name="__RequestVerificationToken"]'
          )?.value ?? "";

          document.querySelectorAll(".cancel-btn").forEach(function (btn) {
            btn.addEventListener("click", async function () {
              if (!confirm("Are you sure you want to cancel this appointment?"))
                return;

              const appointmentId = parseInt(this.dataset.appointmentId);
              const patientId = parseInt(this.dataset.patientId);

              try {
                const response = await fetch("/PatientAppointments/CancelAppointment", {
                  method: "POST",
                  headers: {
                    "Content-Type": "application/x-www-form-urlencoded",
                  },
                  body: new URLSearchParams({
                    __RequestVerificationToken: antiForgeryToken,
                    patientId: patientId,
                    appointmentId: appointmentId,
                  }),
                });
                const result = await response.json();

                if (result.success) {
                  const card = document.getElementById("appt-" + appointmentId);
                  if (card) card.remove();
                  const remaining = document.querySelectorAll(
                    ".appointment-card.upcoming"
                  ).length;
                  const countEl = document.getElementById("upcomingCount");
                  if (countEl)
                    countEl.textContent =
                      remaining + " appointment" + (remaining !== 1 ? "s" : "");
                  window.showNotification?.("Appointment cancelled.", "success");
                } else {
                  window.showNotification?.(
                    result.message || "Failed to cancel.",
                    "error"
                  );
                }
              } catch {
                window.showNotification?.(
                  "Error cancelling appointment.",
                  "error"
                );
              }
            });
          });

          // ================================
          // Set Primary Doctor
          // ================================
          document.querySelectorAll(".set-primary-btn").forEach(function (btn) {
            btn.addEventListener("click", async function () {
              const doctorId = parseInt(this.dataset.doctorId);
              const patientId = parseInt(this.dataset.patientId);

              try {
                const response = await fetch("/PatientAppointments/SetPrimaryDoctor", {
                  method: "POST",
                  headers: {
                    "Content-Type": "application/x-www-form-urlencoded",
                  },
                  body: new URLSearchParams({
                    __RequestVerificationToken: antiForgeryToken,
                    patientId: patientId,
                    doctorId: doctorId,
                  }),
                });

                const result = await response.json();
                if (!result.success) {
                  window.showNotification?.(result.message || "Failed to set primary doctor.", "error");
                  return;
                }

                document.querySelectorAll(".doctor-mini-card").forEach((card) => {
                  card.querySelector(".primary-tag")?.remove();
                });

                document.querySelectorAll(".set-primary-btn").forEach((b) => {
                  b.style.display = "inline-flex";
                });

                const selectedCard = document.querySelector(`.doctor-mini-card[data-doctor-id='${doctorId}']`);
                if (selectedCard) {
                  const nameEl = selectedCard.querySelector(".doctor-mini-info h5");
                  if (nameEl && !nameEl.querySelector(".primary-tag")) {
                    nameEl.insertAdjacentHTML("beforeend", ' <span class="primary-tag">Primary</span>');
                  }

                  const selectedBtn = selectedCard.querySelector(".set-primary-btn");
                  if (selectedBtn) selectedBtn.style.display = "none";
                }

                window.showNotification?.("Primary doctor updated.", "success");
              } catch {
                window.showNotification?.("Error updating primary doctor.", "error");
              }
            });
          });

          // ================================
          // Global Notification
          // ================================
          window.showNotification = function (message, type = "info") {
            const existing = document.querySelector(".global-notification");
            if (existing) existing.remove();
            const notification = document.createElement("div");
            notification.className = "global-notification " + type;
            let icon = "fa-info-circle";
            if (type === "success") icon = "fa-check-circle";
            if (type === "error") icon = "fa-exclamation-circle";
            notification.innerHTML =
              '<i class="fas ' +
              icon +
              '"></i><span>' +
              message +
              '</span><button class="notification-close"><i class="fas fa-times"></i></button>';
            document.body.appendChild(notification);
            notification
              .querySelector(".notification-close")
              .addEventListener("click", () => notification.remove());
            setTimeout(() => {
              if (notification.parentNode) notification.remove();
            }, 4000);
          };
        });
    </script>
}
