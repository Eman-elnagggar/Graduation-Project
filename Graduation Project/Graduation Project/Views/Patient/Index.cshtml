    background:var(--db-light); border:1px solid var(--db-border);
}
.db-hist-date   { display:flex; flex-direction:column; align-items:center; min-width:32px; }
.db-hist-day    { font-size:1.1rem; font-weight:800; color:var(--db-text); line-height:1; }
.db-hist-mon    { font-size:.65rem; color:var(--db-muted); font-weight:500; text-transform:uppercase; }
.db-hist-reading{ flex:1; display:flex; flex-direction:column; }
.db-hist-val    { font-size:.9rem; font-weight:700; color:var(--db-text); }
.db-hist-time   { font-size:.75rem; color:#94a3b8; }
.db-hist-badge  {
    display:inline-flex; align-items:center; gap:.3rem;
    font-size:.72rem; font-weight:600;
    padding:.2rem .6rem; border-radius:20px; white-space:nowrap;
}
.db-hist-badge.normal   { background:#e8f5e9; color:#2e7d32; }
.db-hist-badge.elevated { background:#fff3e0; color:#e65100; }
.db-hist-badge.high     { background:#ffebee; color:#c62828; }
.db-hist-badge.low      { background:#e3f2fd; color:#1565c0; }
.db-no-data     { font-size:.85rem; color:#94a3b8; text-align:center; padding:1rem 0; margin:0; }
.db-view-all-link {
    display:inline-flex; align-items:center; gap:.35rem;
    font-size:.8rem; font-weight:600; color:var(--db-primary);
    text-decoration:none; margin-top:.65rem;
    transition:gap .2s;
}
.db-view-all-link:hover { gap:.55rem; }

/* chart card */
.db-chart-card  { display:flex; flex-direction:column; }
.db-chart-header {
    display:flex; justify-content:space-between; align-items:center;
    margin-bottom:1rem;
}
.db-chart-header h3 { margin:0; font-size:.95rem; font-weight:700; color:var(--db-text); display:flex; align-items:center; gap:.5rem; }
.db-chart-legend { display:flex; gap:.9rem; font-size:.75rem; color:var(--db-muted); }
.db-legend-dot  { display:inline-block; width:10px; height:10px; border-radius:3px; margin-right:.3rem; }
.db-legend-dot.systolic  { background:#2196f3; }
.db-legend-dot.diastolic { background:#90caf9; }

.db-chart-with-axis {
    display:flex;
    align-items:stretch;
    gap:.45rem;
    flex:1;
    min-height:300px;
    margin-bottom:1rem;
}

.db-y-axis {
    width:30px;
    height:100%;
    display:flex;
    flex-direction:column;
    justify-content:space-between;
    align-items:flex-end;
    padding:.4rem 0 .25rem;
    font-size:.65rem;
    color:#94a3b8;
    user-select:none;
}

.db-bar-chart {
    display:flex; align-items:flex-end; gap:.5rem;
    height:100%; padding:.5rem 0;
    border-bottom:1.5px solid var(--db-border);
    margin-bottom:0; flex:1;
}
.db-bar-group  { display:flex; flex-direction:column; align-items:center; gap:.35rem; flex:1; height:100%; justify-content:flex-end; }
.db-bar-pair   { display:flex; align-items:flex-end; justify-content:center; gap:4px; height:100%; width:100%; }
.db-bar        { width:12px; border-radius:4px 4px 0 0; transition:height .4s ease; min-height:4px; }
.db-bar-sys    { background:#2196f3; }
.db-bar-dia    { background:#90caf9; }
.db-bar-bs     { background:#e91e63; }
.db-bar-risk-low { background:#3b82f6 !important; }
.db-bar-risk-normal { background:#22c55e !important; }
.db-bar-risk-elevated { background:#f59e0b !important; }
.db-bar-risk-high { background:#ef4444 !important; }
.db-bar-elevated{ opacity:1 !important; }
.db-bar-elevated.db-bar-sys,
.db-bar-elevated.db-bar-bs { background:#ef4444; }
.db-bar-elevated.db-bar-dia { background:#ffcdd2; }
.db-bar-lbl    { font-size:.68rem; color:var(--db-muted); margin-top:.3rem; }

.db-summary-row  { display:flex; gap:.5rem; flex-wrap:wrap; }
.db-summary-item { flex:1; min-width:80px; background:var(--db-light); border-radius:10px; padding:.6rem .8rem; border:1px solid var(--db-border); }
.db-summary-lbl  { display:block; font-size:.7rem; color:#94a3b8; margin-bottom:.2rem; }
.db-summary-val  { display:block; font-size:.85rem; font-weight:700; color:var(--db-text); }
.db-val-warn     { color:#e65100; }

@@media(max-width:900px){
    .db-chart-with-axis { min-height:220px; }
}

/* ─────────────────────────────────────────
   TOAST
───────────────────────────────────────── */
.db-toast {
    position:fixed; top:1.5rem; right:1.5rem;
    padding:.9rem 1.25rem; border-radius:14px;
    display:flex; align-items:center; gap:.75rem;
    font-size:.9rem; font-weight:500; z-index:9999;
    box-shadow:0 8px 24px rgba(0,0,0,.14);
    animation:dbSlideIn .3s ease;
}
.db-toast-success { background:#e8f5e9; color:#2e7d32; border:1px solid #a5d6a7; }
.db-toast-error   { background:#ffebee; color:#c62828; border:1px solid #ef9a9a; }
.db-toast-warning { background:#fff3e0; color:#e65100; border:1px solid #ffcc80; }
.db-toast-info    { background:#e3f2fd; color:#1565c0; border:1px solid #90caf9; }
.db-toast-close   { background:none; border:none; cursor:pointer; color:inherit; opacity:.6; padding:2px 6px; margin-left:.25rem; }

@@keyframes dbSlideIn { from{ opacity:0; transform:translateX(30px); } to{ opacity:1; transform:translateX(0); } }
@@keyframes dbFadeIn  { from{ opacity:0; transform:translateY(8px);  } to{ opacity:1; transform:translateY(0); } }
</style>
}