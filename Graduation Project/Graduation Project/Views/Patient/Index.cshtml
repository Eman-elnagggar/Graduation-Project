@using System.Globalization
@using System.Linq
@model PatientDashboardViewModel
@{
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    ViewData["Title"] = "Dashboard";
    ViewData["PatientId"]  = Model.Patient.PatientID;
    ViewData["ActivePage"] = "Dashboard";
    ViewData["UserName"] = Model.UserName;

    var now = DateTime.Now;
    var greeting = now.Hour < 12 ? "Good morning" : now.Hour < 17 ? "Good afternoon" : "Good evening";
    var patientFirstName = (Model.UserName ?? "Patient").Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "Patient";
    ViewData["PageTitle"] = $"{greeting}, {patientFirstName} 👋";
    ViewData["PageTitleHtml"] = $"{greeting}, <span class='topbar-accent'>{patientFirstName}</span> 👋";
    ViewData["PageSubtitle"] = now.ToString("dddd, MMMM dd, yyyy", CultureInfo.InvariantCulture);
}

@section Head {
    <meta name="patient-id" content="@Model.Patient.PatientID" />
    @Html.AntiForgeryToken()
}

<!-- ══════════════════ PAGE HEADER ══════════════════ -->
<header class="db-header">
    <div class="db-header-left">
        <div class="db-title-wrap">
            <div class="db-title-icon">
                <i class="fas fa-home"></i>
            </div>
            <div>
                <h1 class="db-title">Welcome back, <span class="db-name">@Model.UserName</span> 👋</h1>
                <p class="db-subtitle">Here's your pregnancy journey overview for today</p>
            </div>
        </div>
    </div>
</header>

<!-- ══════════════════ PREGNANCY PROGRESS ══════════════════ -->
<section class="db-pregnancy-card">
    <div class="db-preg-left">
        <div class="db-preg-icon-col">
            <div class="db-preg-icon"><i class="fas fa-baby"></i></div>
        </div>
        <div class="db-preg-info">
            <div class="db-preg-week-row">
                <span class="db-preg-label">Pregnancy Progress</span>
                <span class="db-preg-trimester">@Model.Trimester</span>
            </div>
            <div class="db-preg-week-display">
                <span class="db-week-num">@Model.PregnancyWeek</span>
                <span class="db-week-of">&nbsp;/ 40 weeks</span>
            </div>
            <div class="db-preg-bar-wrap">
                <div class="db-preg-bar">
                    <div class="db-preg-bar-fill" style="width: @(Model.PregnancyProgressPercent)%"></div>
                    <div class="db-preg-bar-dot" style="left: calc(@(Model.PregnancyProgressPercent)% - 8px)"></div>
                </div>
                <div class="db-preg-bar-labels">
                    <span>Week 1</span><span>Week 13</span><span>Week 27</span><span>Week 40</span>
                </div>
            </div>
        </div>
    </div>
    <div class="db-preg-right">
        <div class="db-preg-stat">
            <div class="db-preg-stat-icon"><i class="fas fa-calendar-check"></i></div>
            <div>
                <span class="db-preg-stat-val">@Model.DueDate</span>
                <span class="db-preg-stat-lbl">Due Date</span>
            </div>
        </div>
        <div class="db-preg-divider"></div>
        <div class="db-preg-stat">
            <div class="db-preg-stat-icon"><i class="fas fa-heart"></i></div>
            <div>
                <span class="db-preg-stat-val">@(40 - Model.PregnancyWeek) weeks</span>
                <span class="db-preg-stat-lbl">Remaining</span>
            </div>
        </div>
        <div class="db-preg-divider"></div>
        <div class="db-preg-stat">
            <div class="db-preg-stat-icon"><i class="fas fa-percentage"></i></div>
            <div>
                <span class="db-preg-stat-val">@Model.PregnancyProgressPercent%</span>
                <span class="db-preg-stat-lbl">Complete</span>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════ STAT CARDS ══════════════════ -->
<section class="db-stats-grid">
    <!-- Weight -->
    <div class="db-stat-card db-stat-weight">
        <div class="db-stat-icon"><i class="fas fa-weight"></i></div>
        <div class="db-stat-body">
            <span class="db-stat-num">@Model.Patient.WeightKg</span>
            <span class="db-stat-lbl">Weight (kg)</span>
            <span class="db-stat-tag db-tag-normal"><i class="fas fa-arrow-up"></i> +2kg this month</span>
        </div>
        <div class="db-stat-bg"><i class="fas fa-weight"></i></div>
    </div>
    <!-- Blood Pressure -->
    <div class="db-stat-card db-stat-bp" style="cursor:pointer"
         onclick="document.querySelector('.db-tracker-section').scrollIntoView({behavior:'smooth'})">
        <div class="db-stat-icon"><i class="fas fa-heartbeat"></i></div>
        <div class="db-stat-body">
            <span class="db-stat-num" id="bpStatValue">@Model.LastBloodPressureValue</span>
            <span class="db-stat-lbl">Blood Pressure</span>
            <span class="db-stat-tag db-tag-normal" id="bpStatChange">Normal</span>
        </div>
        <div class="db-stat-bg"><i class="fas fa-heartbeat"></i></div>
    </div>
    <!-- Blood Sugar -->
    <div class="db-stat-card db-stat-bs" style="cursor:pointer"
         onclick="document.querySelector('.db-tracker-section').scrollIntoView({behavior:'smooth'})">
        <div class="db-stat-icon"><i class="fas fa-tint"></i></div>
        <div class="db-stat-body">
            <span class="db-stat-num" id="bsStatValue">@Model.LastBloodSugarValue</span>
            <span class="db-stat-lbl">Blood Sugar (mg/dL)</span>
            <span class="db-stat-tag db-tag-normal" id="bsStatChange">Normal</span>
        </div>
        <div class="db-stat-bg"><i class="fas fa-tint"></i></div>
    </div>
    <!-- Last Lab Test -->
    <div class="db-stat-card db-stat-lab">
        <div class="db-stat-icon"><i class="fas fa-flask"></i></div>
        <div class="db-stat-body">
            <span class="db-stat-num db-stat-num-sm">@(Model.LastLabTest?.TestType ?? "—")</span>
            <span class="db-stat-lbl">Last Lab Test</span>
            <span class="db-stat-tag db-tag-neutral">@(Model.LastLabTest?.UploadDate.ToString("MMM dd, yyyy") ?? "No tests yet")</span>
        </div>
        <div class="db-stat-bg"><i class="fas fa-flask"></i></div>
    </div>
    <!-- Next Appointment -->
    <div class="db-stat-card db-stat-appt">
        <div class="db-stat-icon"><i class="fas fa-calendar-alt"></i></div>
        <div class="db-stat-body">
            <span class="db-stat-num db-stat-num-sm">
                @if (Model.NextAppointment != null)
                {
                    @(Model.NextAppointment.Date.Date == DateTime.Today ? "Today" : Model.NextAppointment.Date.ToString("MMM dd"))
                }
                else
                {
                    @:—
                }
            </span>
            <span class="db-stat-lbl">Next Appointment</span>
            <span class="db-stat-tag db-tag-upcoming">
                @(Model.NextAppointment != null ? "Dr. " + Model.NextAppointment.Doctor?.User?.FirstName : "None scheduled")
            </span>
        </div>
        <div class="db-stat-bg"><i class="fas fa-calendar-alt"></i></div>
    </div>
</section>

<!-- ══════════════════ ACTIVITY & ALERTS GRID ══════════════════ -->
<section class="db-mid-grid">

    <!-- Recent Activity -->
    <div class="db-card db-activity-card">
        <div class="db-card-header">
            <div class="db-card-title">
                <div class="db-card-icon-wrap activity"><i class="fas fa-history"></i></div>
                <h3>Recent Activity</h3>
            </div>
            <a href="/PatientMedicalHistory/MedicalHistory/@Model.Patient.PatientID" class="db-view-all">
                View All <i class="fas fa-arrow-right"></i>
            </a>
        </div>
        <div class="db-activity-list">
            @if (Model.RecentActivities != null && Model.RecentActivities.Any())
            {
                @foreach (var activity in Model.RecentActivities)
                {
                    <div class="db-activity-item">
                        <div class="db-activity-icon" style="background:@activity.IconBgColor">
                            <i class="@activity.IconClass" style="color:@activity.IconColor"></i>
                        </div>
                        <div class="db-activity-info">
                            <h4>@activity.Title</h4>
                            <p>@activity.Description</p>
                        </div>
                        <span class="db-activity-time">@activity.RelativeTime</span>
                    </div>
                }
            }
            else
            {
                <div class="db-empty-feed">
                    <div class="db-empty-icon"><i class="fas fa-history"></i></div>
                    <p>No recent activity found.</p>
                </div>
            }
        </div>
    </div>

    <!-- Health Alerts -->
    <div class="db-card db-alerts-card">
        <div class="db-card-header">
            <div class="db-card-title">
                <div class="db-card-icon-wrap alerts"><i class="fas fa-bell"></i></div>
                <h3>Health Alerts</h3>
            </div>
            <a href="/PatientAlerts/Alerts/@Model.Patient.PatientID" class="db-view-all">
                View All <i class="fas fa-arrow-right"></i>
            </a>
        </div>
        <div class="db-alerts-list">
            @if (Model.HealthAlerts != null && Model.HealthAlerts.Any())
            {
                @foreach (var alert in Model.HealthAlerts)
                {
                    string alertType   = (alert.AlertType ?? "info").ToLower();
                    bool   isDanger    = alertType == "danger"  || alertType == "critical";
                    bool   isWarning   = alertType == "warning";
                    bool   isSuccess   = alertType == "success";
                    string cardCls     = isDanger ? "db-alert-item-danger" : isWarning ? "db-alert-item-warning" : isSuccess ? "db-alert-item-success" : "db-alert-item-info";
                    string iconCls     = isDanger ? "fas fa-exclamation-circle" : isWarning ? "fas fa-exclamation-triangle" : isSuccess ? "fas fa-check-circle" : "fas fa-info-circle";
                    <div class="db-alert-item @cardCls">
                        <div class="db-alert-stripe"></div>
                        <div class="db-alert-icon-col"><i class="@iconCls"></i></div>
                        <div class="db-alert-info">
                            <h4>@alert.Title</h4>
                            <p>@alert.Message</p>
                        </div>
                        @if (!alert.IsRead)
                        {
                            <span class="db-alert-unread-dot"></span>
                        }
                    </div>
                }
            }
            else
            {
                <div class="db-alert-item db-alert-item-success">
                    <div class="db-alert-stripe"></div>
                    <div class="db-alert-icon-col"><i class="fas fa-check-circle"></i></div>
                    <div class="db-alert-info">
                        <h4>All Clear!</h4>
                        <p>No critical alerts at this time. Keep up the great care!</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ══════════════════ HEALTH TRACKER ══════════════════ -->
<section class="db-tracker-section">
    <!-- Tab switcher -->
    <div class="db-tracker-tabs">
        <button class="db-tab active" data-tab="blood-pressure">
            <i class="fas fa-heartbeat"></i> Blood Pressure
        </button>
        <button class="db-tab" data-tab="blood-sugar">
            <i class="fas fa-tint"></i> Blood Sugar
        </button>
    </div>

    <!-- ─── Blood Pressure Tab ─── -->
    <div class="db-tab-content active" id="blood-pressure-tab">
        <div class="db-tracker-grid">

            <!-- Input card -->
            <div class="db-card db-tracker-input-card">
                <div class="db-tracker-header">
                    <div class="db-tracker-title">
                        <div class="db-tracker-icon bp"><i class="fas fa-heartbeat"></i></div>
                        <div>
                            <h3>Blood Pressure Tracker</h3>
                            <span class="db-tracker-date" id="bpTodayDate"></span>
                        </div>
                    </div>
                </div>

                <div class="db-bp-inputs">
                    <div class="db-input-group">
                        <label>Systolic <small>(Top)</small></label>
                        <div class="db-input-wrap">
                            <input type="number" id="systolic" class="db-input" placeholder="120" min="70" max="200" />
                            <span class="db-input-unit">mmHg</span>
                        </div>
                        <span class="db-input-hint">Normal: 90–120</span>
                    </div>
                    <div class="db-bp-divider"><span>/</span></div>
                    <div class="db-input-group">
                        <label>Diastolic <small>(Bottom)</small></label>
                        <div class="db-input-wrap">
                            <input type="number" id="diastolic" class="db-input" placeholder="80" min="40" max="130" />
                            <span class="db-input-unit">mmHg</span>
                        </div>
                        <span class="db-input-hint">Normal: 60–80</span>
                    </div>
                    <div class="db-input-group">
                        <label>Pulse <small>(Optional)</small></label>
                        <div class="db-input-wrap">
                            <input type="number" id="pulse" class="db-input" placeholder="72" min="40" max="200" />
                            <span class="db-input-unit">BPM</span>
                        </div>
                        <span class="db-input-hint">Normal: 60–100</span>
                    </div>
                    <div class="db-input-group db-input-group-full">
                        <label>When did you measure?</label>
                        <select id="bpMeasurementTime" class="db-select">
                            <option value="Morning">Morning</option>
                            <option value="Afternoon">Afternoon</option>
                            <option value="Evening">Evening</option>
                            <option value="Bedtime">Bedtime</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                </div>

                <button class="db-save-btn" id="saveBP">
                    <i class="fas fa-save"></i> Save Reading
                </button>

                <!-- Result banner -->
                <div class="db-result-banner" id="bpResult" style="display:none">
                    <div class="db-result-left">
                        <span class="db-result-value" id="bpValue">120/80</span>
                        <span class="db-result-unit">mmHg</span>
                    </div>
                    <div class="db-result-right">
                        <span class="db-result-status" id="bpStatus"><i class="fas fa-check-circle"></i> Normal</span>
                        <p class="db-result-msg" id="bpMessage"></p>
                    </div>
                </div>

                <!-- History -->
                <div class="db-history-section">
                    <h4 class="db-history-title"><i class="fas fa-history"></i> Recent Readings</h4>
                    <div class="db-history-list" id="bpHistoryList">
                        @if (Model.RecentBloodPressureReadings != null && Model.RecentBloodPressureReadings.Any())
                        {
                            @foreach (var bp in Model.RecentBloodPressureReadings)
                            {
                                var parts = bp.BloodPressure?.Split('/');
                                string cls = "normal", lbl = "Normal", ico = "fa-check-circle";
                                if (parts?.Length == 2 && int.TryParse(parts[0], out int s) && int.TryParse(parts[1], out int d))
                                {
                                    if (s < 90 || d < 60)        { cls = "low";      lbl = "Low";       ico = "fa-arrow-down"; }
                                    else if (s <= 120 && d <= 80) { cls = "normal";   lbl = "Normal";    ico = "fa-check-circle"; }
                                    else if (s <= 139 || d <= 89) { cls = "elevated"; lbl = "Elevated";  ico = "fa-exclamation-circle"; }
                                    else                           { cls = "high";     lbl = "High";      ico = "fa-exclamation-triangle"; }
                                }
                                <div class="db-history-item">
                                    <div class="db-hist-date">
                                        <span class="db-hist-day">@bp.DateTime.Day</span>
                                        <span class="db-hist-mon">@bp.DateTime.ToString("MMM")</span>
                                    </div>
                                    <div class="db-hist-reading">
                                        <span class="db-hist-val">@bp.BloodPressure</span>
                                        <span class="db-hist-time">
                                            @if (!string.IsNullOrWhiteSpace(bp.MeasurementTime)) { @(bp.MeasurementTime + " · ") }
                                            @bp.DateTime.ToString("h:mm tt")
                                        </span>
                                    </div>
                                    <span class="db-hist-badge @cls"><i class="fas @ico"></i> @lbl</span>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="db-no-data">No readings recorded yet.</p>
                        }
                    </div>
            <a href="/PatientMedicalHistory/MedicalHistory/@Model.Patient.PatientID" class="db-view-all-link">View Full History <i class="fas fa-arrow-right"></i></a>
                </div>
            </div>

            <!-- Chart card -->
            <div class="db-card db-chart-card">
                <div class="db-chart-header">
                    <h3><i class="fas fa-chart-bar"></i> Weekly Trend</h3>
                    <div class="db-chart-legend">
                        <span><span class="db-legend-dot systolic"></span> Systolic</span>
                        <span><span class="db-legend-dot diastolic"></span> Diastolic</span>
                    </div>
                </div>
                @{
                    var bpWeeklyPoints = (Model.WeeklyBloodPressureReadings ?? new List<PatientBloodPressure>())
                        .OrderByDescending(r => r.DateTime)
                        .Take(7)
                        .Select(r =>
                        {
                            var parts = (r.BloodPressure ?? string.Empty).Split('/');
                            int systolic = 0, diastolic = 0;
                            if (parts.Length == 2)
                            {
                                int.TryParse(parts[0], out systolic);
                                int.TryParse(parts[1], out diastolic);
                            }

                            return new
                            {
                                Date = r.DateTime,
                                Systolic = systolic,
                                Diastolic = diastolic
                            };
                        })
                        .Where(x => x.Systolic > 0 && x.Diastolic > 0)
                        .OrderBy(x => x.Date)
                        .ToList();

                    var bpAverageSys = bpWeeklyPoints.Any() ? (int)Math.Round(bpWeeklyPoints.Average(x => x.Systolic)) : 0;
                    var bpAverageDia = bpWeeklyPoints.Any() ? (int)Math.Round(bpWeeklyPoints.Average(x => x.Diastolic)) : 0;
                    var bpHighest = bpWeeklyPoints.OrderByDescending(x => x.Systolic).FirstOrDefault();
                    var bpLowest = bpWeeklyPoints.OrderBy(x => x.Systolic).FirstOrDefault();
                }
                <div class="db-chart-with-axis">
                    <div class="db-y-axis" aria-hidden="true">
                        <span>200</span>
                        <span>180</span>
                        <span>160</span>
                        <span>140</span>
                        <span>120</span>
                        <span>100</span>
                        <span>80</span>
                        <span>60</span>
                    </div>
                    <div class="db-bar-chart" id="bpChart">
                        @if (bpWeeklyPoints.Any())
                        {
                            @foreach (var point in bpWeeklyPoints)
                            {
                                var sysHeight = Math.Clamp((int)Math.Round((point.Systolic / 200.0) * 100), 8, 100);
                                var diaHeight = Math.Clamp((int)Math.Round((point.Diastolic / 130.0) * 100), 8, 100);
                                string bpRiskClass;
                                if (point.Systolic < 90 || point.Diastolic < 60) bpRiskClass = "db-bar-risk-low";
                                else if (point.Systolic <= 120 && point.Diastolic <= 80) bpRiskClass = "db-bar-risk-normal";
                                else if (point.Systolic <= 139 || point.Diastolic <= 89) bpRiskClass = "db-bar-risk-elevated";
                                else bpRiskClass = "db-bar-risk-high";
                                bool isToday = point.Date == DateTime.Today;
                                <div class="db-bar-group @(isToday ? "db-bar-today" : "")" data-systolic="@point.Systolic" data-diastolic="@point.Diastolic" data-date="@point.Date.ToString("MM/dd")">
                                    <div class="db-bar-pair" title="@($"{point.Systolic}/{point.Diastolic} mmHg")">
                                        <div class="db-bar db-bar-sys @bpRiskClass" style="height:@(sysHeight)%"></div>
                                        <div class="db-bar db-bar-dia @bpRiskClass" style="height:@(diaHeight)%"></div>
                                    </div>
                                    <span class="db-bar-lbl">@point.Date.ToString("MM/dd")</span>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="db-no-data" style="margin:auto;">No blood pressure readings found.</p>
                        }
                    </div>
                </div>
                <div class="db-summary-row">
                    <div class="db-summary-item">
                        <span class="db-summary-lbl">Average</span>
                        <span class="db-summary-val" id="bpSummaryAverage">@(bpWeeklyPoints.Any() ? $"{bpAverageSys}/{bpAverageDia} mmHg" : "—")</span>
                    </div>
                    <div class="db-summary-item">
                        <span class="db-summary-lbl">Highest</span>
                        <span class="db-summary-val db-val-warn" id="bpSummaryHighest">@(bpHighest != null ? $"{bpHighest.Systolic}/{bpHighest.Diastolic} mmHg" : "—")</span>
                    </div>
                    <div class="db-summary-item">
                        <span class="db-summary-lbl">Lowest</span>
                        <span class="db-summary-val" id="bpSummaryLowest">@(bpLowest != null ? $"{bpLowest.Systolic}/{bpLowest.Diastolic} mmHg" : "—")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- End BP Tab -->

    <!-- ─── Blood Sugar Tab ─── -->
    <div class="db-tab-content" id="blood-sugar-tab">
        <div class="db-tracker-grid">

            <!-- Input card -->
            <div class="db-card db-tracker-input-card">
                <div class="db-tracker-header">
                    <div class="db-tracker-title">
                        <div class="db-tracker-icon bs"><i class="fas fa-tint"></i></div>
                        <div>
                            <h3>Blood Sugar Tracker</h3>
                            <span class="db-tracker-date" id="bsTodayDate"></span>
                        </div>
                    </div>
                </div>

                <div class="db-bs-inputs">
                    <div class="db-input-group db-input-group-lg">
                        <label>Blood Sugar Level</label>
                        <div class="db-input-wrap">
                            <input type="number" id="bloodSugar" class="db-input" placeholder="95" min="40" max="400" />
                            <span class="db-input-unit">mg/dL</span>
                        </div>
                        <span class="db-input-hint">Fasting: 70–100 · After meals: &lt;140</span>
                    </div>
                    <div class="db-input-group db-input-group-lg">
                        <label>When did you measure?</label>
                        <select id="mealTime" class="db-select">
                            <option value="Fasting (Before breakfast)">Fasting (Before breakfast)</option>
                            <option value="After Breakfast (2 hours)">After Breakfast (2 hours)</option>
                            <option value="Before Lunch">Before Lunch</option>
                            <option value="After Lunch (2 hours)">After Lunch (2 hours)</option>
                            <option value="Before Dinner">Before Dinner</option>
                            <option value="After Dinner (2 hours)">After Dinner (2 hours)</option>
                            <option value="Bedtime">Bedtime</option>
                        </select>
                    </div>
                </div>

                <button class="db-save-btn db-save-btn-bs" id="saveBS">
                    <i class="fas fa-save"></i> Save Reading
                </button>

                <div class="db-result-banner" id="bsResult" style="display:none">
                    <div class="db-result-left">
                        <span class="db-result-value" id="bsValue">95</span>
                        <span class="db-result-unit">mg/dL</span>
                    </div>
                    <div class="db-result-right">
                        <span class="db-result-status" id="bsStatus"><i class="fas fa-check-circle"></i> Normal</span>
                        <p class="db-result-msg" id="bsMessage"></p>
                    </div>
                </div>

                <div class="db-history-section">
                    <h4 class="db-history-title"><i class="fas fa-history"></i> Recent Readings</h4>
                    <div class="db-history-list" id="bsHistoryList">
                        @if (Model.RecentBloodSugarReadings != null && Model.RecentBloodSugarReadings.Any())
                        {
                            @foreach (var bs in Model.RecentBloodSugarReadings)
                            {
                                bool isFast = bs.MeasurementTime != null && (bs.MeasurementTime.Contains("Fasting") || bs.MeasurementTime.Contains("Before Lunch") || bs.MeasurementTime.Contains("Before Dinner"));
                                string cls, lbl, ico;
                                if      (bs.BloodSugar < 70)  { cls="low";      lbl="Low";          ico="fa-arrow-down"; }
                                else if (isFast)
                                {
                                    if      (bs.BloodSugar <= 100) { cls="normal";   lbl="Normal";   ico="fa-check-circle"; }
                                    else if (bs.BloodSugar <= 125) { cls="elevated"; lbl="Elevated"; ico="fa-exclamation-circle"; }
                                    else                            { cls="high";     lbl="High";     ico="fa-exclamation-triangle"; }
                                }
                                else
                                {
                                    if      (bs.BloodSugar <= 140) { cls="normal";   lbl="Normal";        ico="fa-check-circle"; }
                                    else if (bs.BloodSugar <= 180) { cls="elevated"; lbl="Slightly High"; ico="fa-exclamation-circle"; }
                                    else                            { cls="high";     lbl="High";          ico="fa-exclamation-triangle"; }
                                }
                                <div class="db-history-item">
                                    <div class="db-hist-date">
                                        <span class="db-hist-day">@bs.DateTime.Day</span>
                                        <span class="db-hist-mon">@bs.DateTime.ToString("MMM")</span>
                                    </div>
                                    <div class="db-hist-reading">
                                        <span class="db-hist-val">@bs.BloodSugar mg/dL</span>
                                        <span class="db-hist-time">
                                            @if (!string.IsNullOrWhiteSpace(bs.MeasurementTime)) { @(bs.MeasurementTime + " · ") }
                                            @bs.DateTime.ToString("h:mm tt")
                                        </span>
                                    </div>
                                    <span class="db-hist-badge @cls"><i class="fas @ico"></i> @lbl</span>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="db-no-data">No readings recorded yet.</p>
                        }
                    </div>
            <a href="/PatientMedicalHistory/MedicalHistory/@Model.Patient.PatientID" class="db-view-all-link">View Full History <i class="fas fa-arrow-right"></i></a>
                </div>
            </div>

            <!-- Chart card -->
            <div class="db-card db-chart-card">
                <div class="db-chart-header">
                    <h3><i class="fas fa-chart-line"></i> Weekly Trend</h3>
                </div>
                @{
                    var bsWeeklyPoints = (Model.WeeklyBloodSugarReadings ?? new List<PatientBloodSugar>())
                        .OrderByDescending(r => r.DateTime)
                        .Take(7)
                        .Select(g => new
                        {
                            Date = g.DateTime,
                            Value = g.BloodSugar
                        })
                        .Where(x => x.Value > 0)
                        .OrderBy(x => x.Date)
                        .ToList();

                    var bsAverage = bsWeeklyPoints.Any() ? Math.Round(bsWeeklyPoints.Average(x => x.Value), 1) : 0;
                    var bsHighest = bsWeeklyPoints.OrderByDescending(x => x.Value).FirstOrDefault();
                    var bsLowest = bsWeeklyPoints.OrderBy(x => x.Value).FirstOrDefault();
                }
                <div class="db-chart-with-axis">
                    <div class="db-y-axis" aria-hidden="true">
                        <span>220</span>
                        <span>190</span>
                        <span>160</span>
                        <span>130</span>
                        <span>100</span>
                        <span>70</span>
                        <span>40</span>
                    </div>
                    <div class="db-bar-chart" id="bsChart">
                        @if (bsWeeklyPoints.Any())
                        {
                            @foreach (var point in bsWeeklyPoints)
                            {
                                var bsHeight = Math.Clamp((int)Math.Round((point.Value / 220.0) * 100), 8, 100);
                                string bsRiskClass;
                                if (point.Value < 70) bsRiskClass = "db-bar-risk-low";
                                else if (point.Value <= 140) bsRiskClass = "db-bar-risk-normal";
                                else if (point.Value <= 180) bsRiskClass = "db-bar-risk-elevated";
                                else bsRiskClass = "db-bar-risk-high";
                                bool isToday = point.Date == DateTime.Today;
                                <div class="db-bar-group @(isToday ? "db-bar-today" : "")" data-value="@point.Value" data-date="@point.Date.ToString("MM/dd")">
                                    <div class="db-bar-pair" title="@($"{point.Value} mg/dL")">
                                        <div class="db-bar db-bar-bs @bsRiskClass" style="height:@(bsHeight)%"></div>
                                    </div>
                                    <span class="db-bar-lbl">@point.Date.ToString("MM/dd")</span>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="db-no-data" style="margin:auto;">No blood sugar readings found.</p>
                        }
                    </div>
                </div>
                <div class="db-summary-row">
                    <div class="db-summary-item">
                        <span class="db-summary-lbl">Average</span>
                        <span class="db-summary-val" id="bsSummaryAverage">@(bsWeeklyPoints.Any() ? $"{bsAverage} mg/dL" : "—")</span>
                    </div>
                    <div class="db-summary-item">
                        <span class="db-summary-lbl">Highest</span>
                        <span class="db-summary-val" id="bsSummaryHighest">@(bsHighest != null ? $"{bsHighest.Value} mg/dL" : "—")</span>
                    </div>
                    <div class="db-summary-item">
                        <span class="db-summary-lbl">Lowest</span>
                        <span class="db-summary-val" id="bsSummaryLowest">@(bsLowest != null ? $"{bsLowest.Value} mg/dL" : "—")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- End BS Tab -->
</section>

@section Scripts {
<script>
// ── Shared helpers ──────────────────────────────────────────
const PATIENT_ID        = parseInt(document.querySelector('meta[name="patient-id"]').content, 10);
const ANTIFORGERY_TOKEN = document.querySelector('input[name="__RequestVerificationToken"]').value;

// Set today label
(function () {
    const opts  = { weekday:'long', year:'numeric', month:'long', day:'numeric' };
    const label = new Date().toLocaleDateString('en-US', opts);
    const el    = document.getElementById('dbTodayLabel');
    if (el) el.textContent = label;

    const bpDate = document.getElementById('bpTodayDate');
    const bsDate = document.getElementById('bsTodayDate');
    const short  = 'Today, ' + new Date().toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' });
    if (bpDate) bpDate.textContent = short;
    if (bsDate) bsDate.textContent = short;
})();

// Global toast
window.showNotification = function (message, type = "info") {
    document.querySelector('.db-toast')?.remove();
    const icons = { success:'fa-check-circle', error:'fa-times-circle', warning:'fa-exclamation-triangle', info:'fa-info-circle' };
    const n = document.createElement('div');
    n.className = `db-toast db-toast-${type}`;
    n.innerHTML = `<i class="fas ${icons[type]||icons.info}"></i><span>${message}</span><button class="db-toast-close"><i class="fas fa-times"></i></button>`;
    document.body.appendChild(n);
    n.querySelector('.db-toast-close').addEventListener('click', () => n.remove());
    setTimeout(() => n?.remove(), 4000);
};

document.addEventListener('DOMContentLoaded', function () {
    normalizeBPChartScale();
    normalizeBSChartScale();

    // ── Tab switching ──────────────────────────────────────
    document.querySelectorAll('.db-tab').forEach(btn => {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.db-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.db-tab-content').forEach(c => c.classList.remove('active'));
            this.classList.add('active');
            document.getElementById(this.dataset.tab + '-tab').classList.add('active');
        });
    });

    // ── Blood Pressure ──────────────────────────────────────
    const sysIn   = document.getElementById('systolic');
    const diaIn   = document.getElementById('diastolic');
    const pulseIn = document.getElementById('pulse');
    const bpTime  = document.getElementById('bpMeasurementTime');
    const bpRes   = document.getElementById('bpResult');

    [sysIn, diaIn, pulseIn].forEach(i => i?.addEventListener('input', () => { if (i) i.value = i.value.replace(/[^0-9]/g, ''); }));
    sysIn?.addEventListener('input',  () => { if (sysIn.value.length  >= 3) diaIn?.focus(); });
    diaIn?.addEventListener('input',  () => { if (diaIn.value.length  >= 2) pulseIn?.focus(); });

    // Input colour hints
    [sysIn, diaIn].forEach(inp => {
        if (!inp) return;
        inp.addEventListener('blur', function () {
            const v = parseInt(this.value), w = this.closest('.db-input-wrap');
            if (!w) return;
            w.classList.remove('hint-normal','hint-elevated','hint-high','hint-low');
            if (!v) return;
            if (this === sysIn) {
                if (v < 90) w.classList.add('hint-low'); else if (v <= 120) w.classList.add('hint-normal'); else if (v <= 139) w.classList.add('hint-elevated'); else w.classList.add('hint-high');
            } else {
                if (v < 60) w.classList.add('hint-low'); else if (v <= 80) w.classList.add('hint-normal'); else if (v <= 89) w.classList.add('hint-elevated'); else w.classList.add('hint-high');
            }
        });
    });

    document.getElementById('saveBP')?.addEventListener('click', async function () {
        const sys  = parseInt(sysIn.value);
        const dia  = parseInt(diaIn.value);
        const meas = bpTime?.value || '';
        if (!sys || !dia)             { window.showNotification('Please enter both values.', 'error'); return; }
        if (sys < 70  || sys > 200)   { window.showNotification('Systolic must be 70–200.',  'error'); return; }
        if (dia < 40  || dia > 130)   { window.showNotification('Diastolic must be 40–130.', 'error'); return; }

        const a = analyzeBP(sys, dia);
        document.getElementById('bpValue').textContent  = `${sys}/${dia}`;
        const bpSt = document.getElementById('bpStatus');
        bpSt.className = 'db-result-status ' + a.status;
        bpSt.innerHTML = `<i class="fas ${a.icon}"></i> ${a.label}`;
        document.getElementById('bpMessage').textContent = a.message;
        bpRes.style.display = 'block';

        document.getElementById('bpStatValue').textContent  = `${sys}/${dia}`;
        document.getElementById('bpStatChange').textContent = a.label;

        try {
            const fd = new FormData();
            fd.append('patientId', PATIENT_ID); fd.append('systolic', sys); fd.append('diastolic', dia);
            fd.append('measurementTime', meas); fd.append('__RequestVerificationToken', ANTIFORGERY_TOKEN);
            const r = await fetch('/Patient/SaveBloodPressure', { method:'POST', body:fd });
            if (!r.ok) throw new Error();
            const d = await r.json();
            if (d.success) {
                addBPRow(sys, dia, d.day, d.month, d.time, meas, a);
                addBPChartPoint(sys, dia, new Date());
                window.showNotification('Blood pressure saved!', 'success');
            }
        } catch { window.showNotification('Could not save. Please try again.', 'error'); }

        bpRes.scrollIntoView({ behavior:'smooth', block:'center' });
    });

    function analyzeBP(s, d) {
        if (s < 90 || d < 60)               return { status:'low',      label:'Low',            icon:'fa-arrow-down',           message:'Blood pressure is low. If you feel dizzy, consult your doctor.' };
        if (s <= 120 && d <= 80)             return { status:'normal',   label:'Normal',         icon:'fa-check-circle',         message:'Excellent! Your blood pressure is within the normal range.' };
        if (s <= 129 && d < 80)              return { status:'elevated', label:'Elevated',       icon:'fa-exclamation-circle',   message:'Slightly elevated. Consider reducing salt and increasing activity.' };
        if (s <= 139 || d <= 89)             return { status:'elevated', label:'High (Stage 1)', icon:'fa-exclamation-triangle', message:'High blood pressure. Monitor regularly and consult your provider.' };
        return                                      { status:'high',     label:'High (Stage 2)', icon:'fa-exclamation-triangle', message:'Significantly elevated. Please contact your doctor immediately.' };
    }

    function addBPRow(sys, dia, day, month, time, meas, a) {
        const list = document.getElementById('bpHistoryList');
        if (!list) return;
        list.querySelector('p.db-no-data')?.remove();
        const row = document.createElement('div');
        row.className = 'db-history-item'; row.style.animation = 'dbFadeIn .3s ease';
        row.innerHTML = `
            <div class="db-hist-date"><span class="db-hist-day">${day}</span><span class="db-hist-mon">${month}</span></div>
            <div class="db-hist-reading"><span class="db-hist-val">${sys}/${dia}</span><span class="db-hist-time">${meas ? meas+' · ' : ''}${time}</span></div>
            <span class="db-hist-badge ${a.status}"><i class="fas ${a.icon}"></i> ${a.label}</span>`;
        list.insertBefore(row, list.firstChild);
        const items = list.querySelectorAll('.db-history-item');
        if (items.length > 10) items[items.length-1].remove();
    }

    function formatChartDate(date) {
        const mm = String(date.getMonth() + 1).padStart(2, '0');
        const dd = String(date.getDate()).padStart(2, '0');
        return `${mm}/${dd}`;
    }

    function addBPChartPoint(sys, dia, date) {
        const chart = document.getElementById('bpChart');
        if (!chart) return;

        chart.querySelector('p.db-no-data')?.remove();

        const sysHeight = Math.max(8, Math.min(100, Math.round((sys / 200) * 100)));
        const diaHeight = Math.max(8, Math.min(100, Math.round((dia / 130) * 100)));
        let bpRiskClass = 'db-bar-risk-high';
        if (sys < 90 || dia < 60) bpRiskClass = 'db-bar-risk-low';
        else if (sys <= 120 && dia <= 80) bpRiskClass = 'db-bar-risk-normal';
        else if (sys <= 139 || dia <= 89) bpRiskClass = 'db-bar-risk-elevated';
        const label = formatChartDate(date);

        const group = document.createElement('div');
        group.className = 'db-bar-group';
        group.dataset.systolic = String(sys);
        group.dataset.diastolic = String(dia);
        group.dataset.date = label;
        group.innerHTML = `
            <div class="db-bar-pair" title="${sys}/${dia} mmHg">
                <div class="db-bar db-bar-sys ${bpRiskClass}" style="height:${sysHeight}%"></div>
                <div class="db-bar db-bar-dia ${bpRiskClass}" style="height:${diaHeight}%"></div>
            </div>
            <span class="db-bar-lbl">${label}</span>`;

        chart.appendChild(group);

        const groups = Array.from(chart.querySelectorAll('.db-bar-group'));
        while (groups.length > 7) {
            groups.shift()?.remove();
        }

        const todayLabel = formatChartDate(new Date());
        chart.querySelectorAll('.db-bar-group').forEach(g => {
            g.classList.toggle('db-bar-today', g.dataset.date === todayLabel);
        });

        normalizeBPChartScale();
        refreshBPSummary();
    }

    function buildAxisTicks(minValue, maxValue, targetTicks = 8) {
        const safeRange = Math.max(1, maxValue - minValue);
        const rawStep = safeRange / Math.max(1, targetTicks - 1);
        const magnitude = Math.pow(10, Math.floor(Math.log10(rawStep)));
        const normalized = rawStep / magnitude;

        let stepFactor = 10;
        if (normalized <= 1) stepFactor = 1;
        else if (normalized <= 2) stepFactor = 2;
        else if (normalized <= 2.5) stepFactor = 2.5;
        else if (normalized <= 5) stepFactor = 5;

        const step = stepFactor * magnitude;
        const axisMin = Math.floor(minValue / step) * step;
        const axisMax = Math.ceil(maxValue / step) * step;

        const ticks = [];
        for (let value = axisMax; value >= axisMin; value -= step) {
            ticks.push(Math.round(value));
        }

        return { ticks, axisMin, axisMax };
    }

    function normalizeBPChartScale() {
        const chart = document.getElementById('bpChart');
        if (!chart) return;
        const axis = chart.closest('.db-chart-with-axis')?.querySelector('.db-y-axis');

        const groups = Array.from(chart.querySelectorAll('.db-bar-group'));
        const points = groups
            .map(g => ({
                systolic: parseInt(g.dataset.systolic || '0', 10),
                diastolic: parseInt(g.dataset.diastolic || '0', 10)
            }))
            .filter(p => p.systolic > 0 && p.diastolic > 0);

        if (!points.length) return;

        const values = points.flatMap(p => [p.systolic, p.diastolic]);
        const paddedMin = Math.max(40, Math.min(...values) - 10);
        const paddedMax = Math.max(...values) + 10;
        const axisData = buildAxisTicks(paddedMin, paddedMax, 8);
        const range = Math.max(1, axisData.axisMax - axisData.axisMin);

        if (axis) {
            axis.innerHTML = axisData.ticks.map(t => `<span>${t}</span>`).join('');
        }

        groups.forEach((g, idx) => {
            const p = points[idx];
            if (!p) return;
            const sysEl = g.querySelector('.db-bar-sys');
            const diaEl = g.querySelector('.db-bar-dia');
            if (sysEl) {
                const h = Math.max(6, Math.min(100, Math.round(((p.systolic - axisData.axisMin) / range) * 100)));
                sysEl.style.height = `${h}%`;
            }
            if (diaEl) {
                const h = Math.max(6, Math.min(100, Math.round(((p.diastolic - axisData.axisMin) / range) * 100)));
                diaEl.style.height = `${h}%`;
            }
        });
    }

    function refreshBPSummary() {
        const groups = Array.from(document.querySelectorAll('#bpChart .db-bar-group'));
        const avgEl = document.getElementById('bpSummaryAverage');
        const highEl = document.getElementById('bpSummaryHighest');
        const lowEl = document.getElementById('bpSummaryLowest');

        const points = groups
            .map(g => ({
                systolic: parseInt(g.dataset.systolic || '0', 10),
                diastolic: parseInt(g.dataset.diastolic || '0', 10)
            }))
            .filter(p => p.systolic > 0 && p.diastolic > 0);

        if (!points.length) {
            if (avgEl) avgEl.textContent = '—';
            if (highEl) highEl.textContent = '—';
            if (lowEl) lowEl.textContent = '—';
            return;
        }

        const avgSys = Math.round(points.reduce((sum, p) => sum + p.systolic, 0) / points.length);
        const avgDia = Math.round(points.reduce((sum, p) => sum + p.diastolic, 0) / points.length);
        const highest = points.reduce((max, p) => p.systolic > max.systolic ? p : max, points[0]);
        const lowest = points.reduce((min, p) => p.systolic < min.systolic ? p : min, points[0]);

        if (avgEl) avgEl.textContent = `${avgSys}/${avgDia} mmHg`;
        if (highEl) highEl.textContent = `${highest.systolic}/${highest.diastolic} mmHg`;
        if (lowEl) lowEl.textContent = `${lowest.systolic}/${lowest.diastolic} mmHg`;
    }

    // ── Blood Sugar ─────────────────────────────────────────
    const bsIn   = document.getElementById('bloodSugar');
    const bsTime = document.getElementById('mealTime');
    const bsRes  = document.getElementById('bsResult');

    bsIn?.addEventListener('input', () => { bsIn.value = bsIn.value.replace(/[^0-9]/g, ''); });
    bsIn?.addEventListener('blur', function () {
        const v = parseInt(this.value), w = this.closest('.db-input-wrap');
        if (!w) return;
        w.classList.remove('hint-normal','hint-elevated','hint-high','hint-low');
        if (!v) return;
        if (v < 70) w.classList.add('hint-low'); else if (v <= 100) w.classList.add('hint-normal'); else if (v <= 140) w.classList.add('hint-elevated'); else w.classList.add('hint-high');
    });

    document.getElementById('saveBS')?.addEventListener('click', async function () {
        const val  = parseInt(bsIn.value);
        const meal = bsTime.value;
        if (!val)                      { window.showNotification('Please enter a blood sugar value.', 'error'); return; }
        if (val < 40 || val > 400)     { window.showNotification('Value must be 40–400 mg/dL.', 'error'); return; }

        const a = analyzeBS(val, meal);
        document.getElementById('bsValue').textContent   = val;
        const bsSt = document.getElementById('bsStatus');
        bsSt.className = 'db-result-status ' + a.status;
        bsSt.innerHTML = `<i class="fas ${a.icon}"></i> ${a.label}`;
        document.getElementById('bsMessage').textContent = a.message;
        bsRes.style.display = 'block';

        document.getElementById('bsStatValue').textContent  = val;
        document.getElementById('bsStatChange').textContent = a.label;

        try {
            const fd = new FormData();
            fd.append('patientId', PATIENT_ID); fd.append('bloodSugar', val);
            fd.append('measurementTime', meal); fd.append('__RequestVerificationToken', ANTIFORGERY_TOKEN);
            const r = await fetch('/Patient/SaveBloodSugar', { method:'POST', body:fd });
            if (!r.ok) throw new Error();
            const d = await r.json();
            if (d.success) {
                addBSRow(val, meal, d.day, d.month, d.time, a);
                addBSChartPoint(val, new Date());
                window.showNotification('Blood sugar saved!', 'success');
            }
        } catch { window.showNotification('Could not save. Please try again.', 'error'); }

        bsRes.scrollIntoView({ behavior:'smooth', block:'center' });
    });

    function analyzeBS(v, meal) {
        const isFast = meal.includes('Fasting') || meal.includes('Before Lunch') || meal.includes('Before Dinner');
        if (v < 70) return { status:'low', label:'Low', icon:'fa-arrow-down', message:'Blood sugar is low. Eat carbohydrates and monitor closely.' };
        if (isFast) {
            if (v <= 100) return { status:'normal',   label:'Normal',   icon:'fa-check-circle',         message:'Fasting blood sugar is in normal range. Great job!' };
            if (v <= 125) return { status:'elevated', label:'Elevated', icon:'fa-exclamation-circle',   message:'Slightly elevated fasting sugar. Monitor your diet.' };
            return              { status:'high',     label:'High',          icon:'fa-exclamation-triangle', message:'High fasting sugar. Please consult your provider.' };
        }
        if (v <= 140) return { status:'normal',   label:'Normal',       icon:'fa-check-circle',         message:'Post-meal blood sugar is within normal range.' };
        if (v <= 180) return { status:'elevated', label:'Slightly High', icon:'fa-exclamation-circle',   message:'Slightly high post-meal sugar. Reduce refined carbs.' };
        return              { status:'high',     label:'High',          icon:'fa-exclamation-triangle', message:'High post-meal sugar. Consult your healthcare provider.' };
    }

    function addBSRow(val, meal, day, month, time, a) {
        const list = document.getElementById('bsHistoryList');
        if (!list) return;
        list.querySelector('p.db-no-data')?.remove();
        const row = document.createElement('div');
        row.className = 'db-history-item'; row.style.animation = 'dbFadeIn .3s ease';
        row.innerHTML = `
            <div class="db-hist-date"><span class="db-hist-day">${day}</span><span class="db-hist-mon">${month}</span></div>
            <div class="db-hist-reading"><span class="db-hist-val">${val} mg/dL</span><span class="db-hist-time">${meal} · ${time}</span></div>
            <span class="db-hist-badge ${a.status}"><i class="fas ${a.icon}"></i> ${a.label}</span>`;
        list.insertBefore(row, list.firstChild);
        const items = list.querySelectorAll('.db-history-item');
        if (items.length > 10) items[items.length-1].remove();
    }

    function addBSChartPoint(value, date) {
        const chart = document.getElementById('bsChart');
        if (!chart) return;

        chart.querySelector('p.db-no-data')?.remove();

        const height = Math.max(8, Math.min(100, Math.round((value / 220) * 100)));
        let bsRiskClass = 'db-bar-risk-high';
        if (value < 70) bsRiskClass = 'db-bar-risk-low';
        else if (value <= 140) bsRiskClass = 'db-bar-risk-normal';
        else if (value <= 180) bsRiskClass = 'db-bar-risk-elevated';
        const label = formatChartDate(date);

        const group = document.createElement('div');
        group.className = 'db-bar-group';
        group.dataset.value = String(value);
        group.dataset.date = label;
        group.innerHTML = `
            <div class="db-bar-pair" title="${value} mg/dL">
                <div class="db-bar db-bar-bs ${bsRiskClass}" style="height:${height}%"></div>
            </div>
            <span class="db-bar-lbl">${label}</span>`;

        chart.appendChild(group);

        const groups = Array.from(chart.querySelectorAll('.db-bar-group'));
        while (groups.length > 7) {
            groups.shift()?.remove();
        }

        const todayLabel = formatChartDate(new Date());
        chart.querySelectorAll('.db-bar-group').forEach(g => {
            g.classList.toggle('db-bar-today', g.dataset.date === todayLabel);
        });

        normalizeBSChartScale();
        refreshBSSummary();
    }

    function normalizeBSChartScale() {
        const chart = document.getElementById('bsChart');
        if (!chart) return;
        const axis = chart.closest('.db-chart-with-axis')?.querySelector('.db-y-axis');

        const groups = Array.from(chart.querySelectorAll('.db-bar-group'));
        const values = groups
            .map(g => parseFloat(g.dataset.value || '0'))
            .filter(v => v > 0);

        if (!values.length) return;

        const paddedMin = Math.max(40, Math.min(...values) - 10);
        const paddedMax = Math.max(...values) + 15;
        const axisData = buildAxisTicks(paddedMin, paddedMax, 8);
        const range = Math.max(1, axisData.axisMax - axisData.axisMin);

        if (axis) {
            axis.innerHTML = axisData.ticks.map(t => `<span>${t}</span>`).join('');
        }

        groups.forEach((g, idx) => {
            const valueEl = g.querySelector('.db-bar-bs');
            const value = values[idx];
            if (!valueEl || value === undefined) return;
            const h = Math.max(6, Math.min(100, Math.round(((value - axisData.axisMin) / range) * 100)));
            valueEl.style.height = `${h}%`;
        });
    }

    function refreshBSSummary() {
        const groups = Array.from(document.querySelectorAll('#bsChart .db-bar-group'));
        const avgEl = document.getElementById('bsSummaryAverage');
        const highEl = document.getElementById('bsSummaryHighest');
        const lowEl = document.getElementById('bsSummaryLowest');

        const values = groups
            .map(g => parseFloat(g.dataset.value || '0'))
            .filter(v => v > 0);

        if (!values.length) {
            if (avgEl) avgEl.textContent = '—';
            if (highEl) highEl.textContent = '—';
            if (lowEl) lowEl.textContent = '—';
            return;
        }

        const avg = Math.round((values.reduce((sum, v) => sum + v, 0) / values.length) * 10) / 10;
        const highest = Math.max(...values);
        const lowest = Math.min(...values);

        if (avgEl) avgEl.textContent = `${avg} mg/dL`;
        if (highEl) highEl.textContent = `${highest} mg/dL`;
        if (lowEl) lowEl.textContent = `${lowest} mg/dL`;
    }
});
</script>

