@model Graduation_Project.ViewModels.PrescriptionsViewModel
@{
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    ViewData["Title"] = "My Prescriptions";
    ViewData["PatientId"]  = Model.Patient.PatientID;
    ViewData["ActivePage"] = "Prescriptions";
}

<!-- ?????????????????? PAGE HEADER ?????????????????? -->
<header class="rx-header">
    <div class="rx-header-left">
        <div class="rx-title-wrap">
            <div class="rx-title-icon">
                <i class="fas fa-prescription-bottle-alt"></i>
            </div>
            <div>
                <h1 class="rx-title">My Prescriptions</h1>
                <p class="rx-subtitle">View all prescriptions issued by your doctors</p>
            </div>
        </div>
    </div>
</header>

<!-- ?????????????????? STAT CARDS ?????????????????? -->
<section class="rx-stats-grid">
    <div class="rx-stat-card rx-stat-total">
        <div class="rx-stat-icon"><i class="fas fa-file-prescription"></i></div>
        <div class="rx-stat-body">
            <span class="rx-stat-num">@Model.TotalCount</span>
            <span class="rx-stat-lbl">Total Prescriptions</span>
        </div>
        <div class="rx-stat-bg-icon"><i class="fas fa-file-prescription"></i></div>
    </div>
    <div class="rx-stat-card rx-stat-latest">
        <div class="rx-stat-icon"><i class="fas fa-calendar-alt"></i></div>
        <div class="rx-stat-body">
            <span class="rx-stat-num" style="font-size:1.1rem;">
                @(Model.LatestDate.HasValue ? Model.LatestDate.Value.ToString("MMM dd") : "—")
            </span>
            <span class="rx-stat-lbl">Latest Prescription</span>
        </div>
        <div class="rx-stat-bg-icon"><i class="fas fa-calendar-alt"></i></div>
    </div>
</section>

<!-- ?????????????????? SEARCH / FILTER BAR ?????????????????? -->
<section class="rx-filter-bar-wrap">
    <div class="rx-filter-bar">
        <div class="rx-search-wrap">
            <i class="fas fa-search rx-search-icon"></i>
            <input type="text" id="rxSearch" class="rx-search-input"
                   placeholder="Search by medicine, doctor or date…" />
        </div>
        <div class="rx-filter-tabs">
            <button class="rx-tab active" data-filter="all">
                <i class="fas fa-list"></i> All
                <span class="rx-tab-count">@Model.TotalCount</span>
            </button>
            <button class="rx-tab" data-filter="recent">
                <i class="fas fa-clock"></i> Last 30 Days
            </button>
        </div>
    </div>
</section>

<!-- ?????????????????? PRESCRIPTIONS LIST ?????????????????? -->
<section class="rx-list-section" id="prescriptionsList">

    @if (!Model.Prescriptions.Any())
    {
        <div class="rx-empty-state">
            <div class="rx-empty-icon"><i class="fas fa-prescription-bottle"></i></div>
            <h3>No prescriptions yet</h3>
            <p>Your doctor-issued prescriptions will appear here.</p>
        </div>
    }
    else
    {
        @foreach (var rx in Model.Prescriptions)
        {
            var doctorName = rx.Doctor?.User != null
                ? $"Dr. {rx.Doctor.User.FirstName} {rx.Doctor.User.LastName}"
                : "Unknown Doctor";
            var specialization = rx.Doctor?.Specialization ?? "";
            var itemCount = rx.Items?.Count ?? 0;
            var isRecent = (DateTime.Today - rx.PrescriptionDate.Date).TotalDays <= 30;

            <div class="rx-card prescription-card"
                 data-date="@rx.PrescriptionDate.ToString("yyyy-MM-dd")"
                 data-doctor="@doctorName.ToLower()"
                 data-medicines="@string.Join(" ", rx.Items?.Select(i => i.MedicineName?.ToLower() ?? "") ?? Enumerable.Empty<string>())"
                 data-recent="@isRecent.ToString().ToLower()">

                <!-- Card Header -->
                <div class="rx-card-header">
                    <div class="rx-card-header-left">
                        <div class="rx-card-icon-wrap">
                            <i class="fas fa-prescription-bottle-alt"></i>
                        </div>
                        <div class="rx-card-info">
                            <h4 class="rx-card-title">Prescription #@rx.PrescriptionID</h4>
                            <div class="rx-card-meta">
                                <span class="rx-meta-chip rx-meta-date">
                                    <i class="fas fa-calendar-alt"></i>
                                    @rx.PrescriptionDate.ToString("MMMM dd, yyyy")
                                </span>
                                <span class="rx-meta-chip rx-meta-items">
                                    <i class="fas fa-pills"></i>
                                    @itemCount medication@(itemCount != 1 ? "s" : "")
                                </span>
                                @if (isRecent)
                                {
                                    <span class="rx-badge-recent">
                                        <i class="fas fa-star"></i> Recent
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                    <button class="rx-expand-btn" data-target="rx-body-@rx.PrescriptionID"
                            aria-expanded="false" title="Toggle details">
                        <i class="fas fa-chevron-down"></i>
                    </button>
                </div>

                <!-- Doctor Info Strip -->
                <div class="rx-doctor-strip">
                    <div class="rx-doctor-avatar">
                        <i class="fas fa-user-md"></i>
                    </div>
                    <div class="rx-doctor-details">
                        <span class="rx-doctor-name">@doctorName</span>
                        @if (!string.IsNullOrWhiteSpace(specialization))
                        {
                            <span class="rx-doctor-spec">@specialization</span>
                        }
                    </div>
                </div>

                <!-- Collapsible Body -->
                <div class="rx-card-body" id="rx-body-@rx.PrescriptionID">

                    @if (!string.IsNullOrWhiteSpace(rx.Notes))
                    {
                        <div class="rx-notes-block">
                            <div class="rx-notes-label"><i class="fas fa-sticky-note"></i> Doctor's Notes</div>
                            <p class="rx-notes-text">@rx.Notes</p>
                        </div>
                    }

                    @if (rx.Items != null && rx.Items.Any())
                    {
                        <div class="rx-meds-section">
                            <div class="rx-meds-header">
                                <span><i class="fas fa-pills"></i> Medications</span>
                                <span class="rx-meds-count">@itemCount item@(itemCount != 1 ? "s" : "")</span>
                            </div>
                            <div class="rx-meds-grid">
                                @foreach (var item in rx.Items)
                                {
                                    <div class="rx-med-card">
                                        <div class="rx-med-icon-wrap">
                                            <i class="fas fa-capsules"></i>
                                        </div>
                                        <div class="rx-med-info">
                                            <span class="rx-med-name">@item.MedicineName</span>
                                            <div class="rx-med-details">
                                                @if (!string.IsNullOrWhiteSpace(item.Dosage))
                                                {
                                                    <span class="rx-detail-chip rx-chip-dosage">
                                                        <i class="fas fa-weight"></i> @item.Dosage
                                                    </span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(item.Frequency))
                                                {
                                                    <span class="rx-detail-chip rx-chip-freq">
                                                        <i class="fas fa-redo"></i> @item.Frequency
                                                    </span>
                                                }
                                                @if (item.DurationDays > 0)
                                                {
                                                    <span class="rx-detail-chip rx-chip-duration">
                                                        <i class="fas fa-hourglass-half"></i> @item.DurationDays day@(item.DurationDays != 1 ? "s" : "")
                                                    </span>
                                                }
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(item.Instructions))
                                            {
                                                <div class="rx-med-instructions">
                                                    <i class="fas fa-info-circle"></i> @item.Instructions
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="rx-no-items"><i class="fas fa-info-circle"></i> No medication items recorded for this prescription.</p>
                    }

                </div><!-- /rx-card-body -->
            </div><!-- /rx-card -->
        }
    }
</section>

@section Scripts {
<script>
document.addEventListener("DOMContentLoaded", function () {

    // ?? Expand / Collapse cards ?????????????????????????????????????
    document.querySelectorAll(".rx-expand-btn").forEach(btn => {
        btn.addEventListener("click", function () {
            const targetId = this.dataset.target;
            const body     = document.getElementById(targetId);
            if (!body) return;
            const expanded = this.getAttribute("aria-expanded") === "true";
            if (expanded) {
                body.style.maxHeight = body.scrollHeight + "px";
                requestAnimationFrame(() => { body.style.maxHeight = "0"; });
                this.setAttribute("aria-expanded", "false");
                this.querySelector("i").style.transform = "rotate(0deg)";
            } else {
                body.style.maxHeight = body.scrollHeight + "px";
                this.setAttribute("aria-expanded", "true");
                this.querySelector("i").style.transform = "rotate(180deg)";
            }
        });
    });

    // ?? Filter tabs ?????????????????????????????????????????????????
    document.querySelectorAll(".rx-tab").forEach(tab => {
        tab.addEventListener("click", function () {
            document.querySelectorAll(".rx-tab").forEach(t => t.classList.remove("active"));
            this.classList.add("active");
            applyFilters();
        });
    });

    // ?? Search ??????????????????????????????????????????????????????
    document.getElementById("rxSearch").addEventListener("input", applyFilters);

    function applyFilters() {
        const query  = document.getElementById("rxSearch").value.toLowerCase().trim();
        const filter = document.querySelector(".rx-tab.active")?.dataset.filter ?? "all";

        document.querySelectorAll(".prescription-card").forEach(card => {
            const doctor    = card.dataset.doctor   ?? "";
            const medicines = card.dataset.medicines ?? "";
            const date      = card.dataset.date     ?? "";
            const isRecent  = card.dataset.recent   === "true";

            const matchesSearch = !query ||
                doctor.includes(query) ||
                medicines.includes(query) ||
                date.includes(query);

            const matchesFilter = filter === "all" ||
                (filter === "recent" && isRecent);

            card.style.display = (matchesSearch && matchesFilter) ? "block" : "none";
        });
    }
});
</script>

<style>
/* ?????????????????????????????????????????
   VARIABLES
????????????????????????????????????????? */
:root {
    --rx-primary:    #1BAEBE;
    --rx-primary-dk: #138fa0;
    --rx-text:       #1e293b;
    --rx-muted:      #64748b;
    --rx-light:      #f8fafc;
    --rx-border:     #e2e8f0;
    --rx-radius:     16px;
    --rx-shadow:     0 4px 24px rgba(0,0,0,.07);
    --rx-shadow-hov: 0 8px 32px rgba(0,0,0,.12);
    --rx-green:      #10b981;
    --rx-green-lt:   #ecfdf5;
    --rx-purple:     #8b5cf6;
    --rx-purple-lt:  #f5f3ff;
    --rx-orange:     #f59e0b;
    --rx-orange-lt:  #fffbeb;
    --rx-blue:       #3b82f6;
    --rx-blue-lt:    #eff6ff;
}

/* ?????????????????????????????????????????
   HEADER
????????????????????????????????????????? */
.rx-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 1.75rem; flex-wrap: wrap; gap: 1rem;
}
.rx-title-wrap {
    display: flex; align-items: center; gap: 1rem;
}
.rx-title-icon {
    width: 52px; height: 52px;
    background: linear-gradient(135deg, var(--rx-primary), var(--rx-primary-dk));
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 1.3rem;
    box-shadow: 0 4px 14px rgba(27,174,190,.35);
}
.rx-title    { margin: 0; font-size: 1.6rem; font-weight: 700; color: var(--rx-text); }
.rx-subtitle { margin: .15rem 0 0; font-size: .88rem; color: var(--rx-muted); }

.rx-profile-chip {
    display: flex; align-items: center; gap: .55rem;
    background: #fff; border-radius: 24px;
    padding: .45rem .9rem .45rem .6rem;
    box-shadow: 0 2px 8px rgba(0,0,0,.07);
    font-size: .88rem; font-weight: 500; color: var(--rx-text);
}
.rx-avatar {
    width: 30px; height: 30px;
    background: linear-gradient(135deg, var(--rx-primary), var(--rx-primary-dk));
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: .8rem;
}

/* ?????????????????????????????????????????
   STAT CARDS
????????????????????????????????????????? */
.rx-stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem; margin-bottom: 1.75rem;
}
@@media(max-width:900px) { .rx-stats-grid { grid-template-columns: repeat(2,1fr); } }
@@media(max-width:480px) { .rx-stats-grid { grid-template-columns: 1fr 1fr; } }

.rx-stat-card {
    position: relative; overflow: hidden;
    border-radius: var(--rx-radius);
    padding: 1.2rem 1.4rem;
    display: flex; align-items: center; gap: 1rem;
    box-shadow: var(--rx-shadow);
    transition: transform .22s, box-shadow .22s; cursor: default;
}
.rx-stat-card:hover { transform: translateY(-3px); box-shadow: var(--rx-shadow-hov); }

.rx-stat-total   { background: linear-gradient(135deg,#e0f7fa,#b2ebf2); border-top: 3px solid var(--rx-primary); }
.rx-stat-latest  { background: linear-gradient(135deg,#fffbeb,#fef9c3);  border-top: 3px solid var(--rx-orange);  }

.rx-stat-icon {
    width: 46px; height: 46px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.15rem; flex-shrink: 0;
    background: rgba(255,255,255,.65); backdrop-filter: blur(4px);
}
.rx-stat-total   .rx-stat-icon { color: var(--rx-primary-dk); }
.rx-stat-latest  .rx-stat-icon { color: #b45309; }

.rx-stat-body { display: flex; flex-direction: column; z-index: 1; }
.rx-stat-num  { font-size: 2rem; font-weight: 800; color: var(--rx-text); line-height: 1; }
.rx-stat-lbl  { font-size: .78rem; font-weight: 500; color: var(--rx-muted); margin-top: .2rem; }
.rx-stat-bg-icon {
    position: absolute; right: -8px; bottom: -8px;
    font-size: 4rem; opacity: .06; color: #000; pointer-events: none;
}

/* ?????????????????????????????????????????
   FILTER BAR
????????????????????????????????????????? */
.rx-filter-bar-wrap { margin-bottom: 1.75rem; }
.rx-filter-bar {
    background: #fff; border-radius: var(--rx-radius);
    padding: .9rem 1.25rem;
    box-shadow: var(--rx-shadow);
    border: 1px solid var(--rx-border);
    display: flex; align-items: center;
    justify-content: space-between;
    flex-wrap: wrap; gap: .75rem;
}
.rx-search-wrap {
    position: relative; flex: 1; min-width: 220px;
}
.rx-search-icon {
    position: absolute; left: .9rem; top: 50%; transform: translateY(-50%);
    color: var(--rx-muted); font-size: .85rem; pointer-events: none;
}
.rx-search-input {
    width: 100%; padding: .52rem 1rem .52rem 2.4rem;
    border: 1.5px solid var(--rx-border); border-radius: 10px;
    font-size: .88rem; color: var(--rx-text);
    background: var(--rx-light);
    outline: none; transition: border-color .2s, box-shadow .2s;
}
.rx-search-input:focus { border-color: var(--rx-primary); box-shadow: 0 0 0 3px rgba(27,174,190,.12); }

.rx-filter-tabs { display: flex; flex-wrap: wrap; gap: .5rem; }
.rx-tab {
    display: inline-flex; align-items: center; gap: .4rem;
    padding: .42rem 1rem; border-radius: 22px;
    border: 1.5px solid var(--rx-border);
    background: var(--rx-light);
    font-size: .82rem; font-weight: 600;
    color: var(--rx-muted); cursor: pointer; transition: all .2s;
}
.rx-tab:hover { background: #f1f5f9; color: var(--rx-text); }
.rx-tab.active {
    background: linear-gradient(135deg, var(--rx-primary), var(--rx-primary-dk));
    color: #fff; border-color: transparent;
    box-shadow: 0 3px 10px rgba(27,174,190,.3);
}
.rx-tab-count {
    background: rgba(0,0,0,.1); border-radius: 20px;
    padding: .05rem .45rem; font-size: .7rem;
    min-width: 18px; text-align: center;
}
.rx-tab.active .rx-tab-count { background: rgba(255,255,255,.28); }

/* ?????????????????????????????????????????
   PRESCRIPTION CARDS
????????????????????????????????????????? */
.rx-list-section { display: flex; flex-direction: column; gap: 1.25rem; }

.rx-card {
    background: #fff;
    border-radius: var(--rx-radius);
    box-shadow: var(--rx-shadow);
    border: 1px solid var(--rx-border);
    overflow: hidden;
    transition: box-shadow .22s, transform .22s;
}
.rx-card:hover { box-shadow: var(--rx-shadow-hov); transform: translateY(-2px); }

/* Card header */
.rx-card-header {
    display: flex; align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.4rem;
    background: linear-gradient(135deg, #f0fdfe, #e0f7fa);
    border-bottom: 1px solid #b2ebf2;
    cursor: pointer;
}
.rx-card-header-left { display: flex; align-items: center; gap: .9rem; }
.rx-card-icon-wrap {
    width: 48px; height: 48px; flex-shrink: 0;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--rx-primary), var(--rx-primary-dk));
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 1.2rem;
    box-shadow: 0 4px 12px rgba(27,174,190,.3);
}
.rx-card-title {
    margin: 0; font-size: 1.05rem; font-weight: 700; color: var(--rx-text);
}
.rx-card-meta {
    display: flex; flex-wrap: wrap; gap: .45rem; margin-top: .3rem; align-items: center;
}
.rx-meta-chip {
    display: inline-flex; align-items: center; gap: .3rem;
    font-size: .75rem; font-weight: 500; color: var(--rx-muted);
    background: rgba(255,255,255,.75); border: 1px solid var(--rx-border);
    border-radius: 20px; padding: .18rem .65rem;
}
.rx-badge-recent {
    display: inline-flex; align-items: center; gap: .3rem;
    font-size: .7rem; font-weight: 700;
    background: linear-gradient(135deg, #fbbf24, #f59e0b);
    color: #fff; border-radius: 20px; padding: .18rem .65rem;
    box-shadow: 0 2px 6px rgba(245,158,11,.3);
}

.rx-expand-btn {
    width: 36px; height: 36px; border-radius: 50%;
    border: 1.5px solid var(--rx-border);
    background: rgba(255,255,255,.8);
    display: flex; align-items: center; justify-content: center;
    color: var(--rx-muted); cursor: pointer;
    transition: background .2s, border-color .2s;
    flex-shrink: 0;
}
.rx-expand-btn:hover { background: #fff; border-color: var(--rx-primary); color: var(--rx-primary); }
.rx-expand-btn i { transition: transform .3s ease; }

/* Doctor strip */
.rx-doctor-strip {
    display: flex; align-items: center; gap: .85rem;
    padding: .8rem 1.4rem;
    background: #fafcfe;
    border-bottom: 1px solid var(--rx-border);
}
.rx-doctor-avatar {
    width: 40px; height: 40px; border-radius: 50%;
    background: linear-gradient(135deg, var(--rx-purple), #7c3aed);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: .95rem; flex-shrink: 0;
    box-shadow: 0 3px 10px rgba(139,92,246,.3);
}
.rx-doctor-details { display: flex; flex-direction: column; }
.rx-doctor-name {
    font-size: .95rem; font-weight: 700; color: var(--rx-text);
}
.rx-doctor-spec {
    font-size: .78rem; color: var(--rx-muted);
}

/* Collapsible body */
.rx-card-body {
    max-height: 0; overflow: hidden;
    transition: max-height .4s ease;
    padding: 0;
}

.rx-notes-block {
    margin: 1.25rem 1.4rem .5rem;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: 10px;
    padding: .85rem 1rem;
}
.rx-notes-label {
    font-size: .8rem; font-weight: 700; color: #b45309;
    margin-bottom: .4rem;
    display: flex; align-items: center; gap: .35rem;
}
.rx-notes-text {
    font-size: .9rem; color: #78350f; line-height: 1.6; margin: 0;
}

/* Meds section */
.rx-meds-section { padding: .75rem 1.4rem 1.25rem; }
.rx-meds-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: .85rem;
}
.rx-meds-header > span:first-child {
    font-size: .9rem; font-weight: 700; color: var(--rx-text);
    display: flex; align-items: center; gap: .4rem;
}
.rx-meds-count {
    font-size: .75rem; color: var(--rx-muted);
    background: var(--rx-light);
    border: 1px solid var(--rx-border);
    border-radius: 20px; padding: .15rem .6rem;
}

.rx-meds-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: .85rem;
}

.rx-med-card {
    display: flex; gap: .85rem;
    background: var(--rx-light);
    border: 1.5px solid var(--rx-border);
    border-radius: 12px;
    padding: .9rem 1rem;
    transition: border-color .2s, box-shadow .2s;
}
.rx-med-card:hover { border-color: var(--rx-primary); box-shadow: 0 2px 12px rgba(27,174,190,.12); }

.rx-med-icon-wrap {
    width: 38px; height: 38px; border-radius: 10px;
    background: linear-gradient(135deg, #e0f7fa, #b2ebf2);
    display: flex; align-items: center; justify-content: center;
    color: var(--rx-primary-dk); font-size: 1rem; flex-shrink: 0;
}
.rx-med-info { flex: 1; min-width: 0; }
.rx-med-name {
    font-size: .95rem; font-weight: 700; color: var(--rx-text);
    display: block; margin-bottom: .4rem;
}
.rx-med-details {
    display: flex; flex-wrap: wrap; gap: .35rem; margin-bottom: .4rem;
}
.rx-detail-chip {
    display: inline-flex; align-items: center; gap: .3rem;
    font-size: .72rem; font-weight: 600;
    border-radius: 20px; padding: .18rem .6rem; border: 1px solid transparent;
}
.rx-chip-dosage   { background: #eff6ff; color: #1d4ed8; border-color: #bfdbfe; }
.rx-chip-freq     { background: #ecfdf5; color: #059669; border-color: #6ee7b7; }
.rx-chip-duration { background: #f5f3ff; color: #7c3aed; border-color: #c4b5fd; }

.rx-med-instructions {
    font-size: .78rem; color: var(--rx-muted);
    line-height: 1.5; margin-top: .2rem;
    display: flex; align-items: flex-start; gap: .3rem;
}
.rx-med-instructions i { margin-top: .15rem; flex-shrink: 0; color: var(--rx-primary); }

.rx-no-items {
    margin: 1rem 1.4rem 1.25rem;
    font-size: .88rem; color: var(--rx-muted);
    display: flex; align-items: center; gap: .4rem;
}
.rx-no-items i { color: var(--rx-primary); }

/* ?????????????????????????????????????????
   EMPTY STATE
