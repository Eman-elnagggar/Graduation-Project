@{
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    ViewData["Title"] = "Product Safety";
    ViewData["ActivePage"] = "Products";
}

@Html.AntiForgeryToken()

<!-- Main Wrapper -->
<div class="ps-wrap">

    <!-- ══════════════════ HERO BANNER ══════════════════ -->
    <div class="hero">
        <div class="hero-top">
            <div class="hero-left">
                <span class="hero-eyebrow"><i class="fas fa-shield-alt"></i> Product Safety</span>
                <h2 class="hero-title">Product Safety <span>Checker</span> 🛡️</h2>
                <p class="hero-sub">
                    <i class="fas fa-circle"></i>
                    <span>Analyze ingredient labels for pregnancy safety · skincare, food &amp; household products</span>
                </p>
            </div>

            <div class="hero-right">
                <div class="hero-stat">
                    <div class="hero-stat-ico safe-ico"><i class="fas fa-check-circle"></i></div>
                    <div class="hero-stat-body">
                        <span class="hero-stat-lbl">Safe</span>
                    </div>
                </div>
                <div class="hero-stat">
                    <div class="hero-stat-ico caution-ico"><i class="fas fa-exclamation-circle"></i></div>
                    <div class="hero-stat-body">
                        <span class="hero-stat-lbl">Caution</span>
                    </div>
                </div>
                <div class="hero-stat">
                    <div class="hero-stat-ico avoid-ico"><i class="fas fa-times-circle"></i></div>
                    <div class="hero-stat-body">
                        <span class="hero-stat-lbl">Avoid</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ══════════════════ HOW IT WORKS ══════════════════ -->
    <div class="how-it-works">
        <div class="hw-step">
            <div class="hw-step-num">1</div>
            <div class="hw-step-body">
                <strong>Upload Photo</strong>
                <span>Take or upload an image of the product's ingredient label</span>
            </div>
        </div>
        <div class="hw-step-arrow"><i class="fas fa-chevron-right"></i></div>
        <div class="hw-step">
            <div class="hw-step-num">2</div>
            <div class="hw-step-body">
                <strong>OCR Analysis</strong>
                <span>Our AI reads and extracts all ingredients from the label</span>
            </div>
        </div>
        <div class="hw-step-arrow"><i class="fas fa-chevron-right"></i></div>
        <div class="hw-step">
            <div class="hw-step-num">3</div>
            <div class="hw-step-body">
                <strong>Safety Report</strong>
                <span>Get an instant pregnancy-safety verdict for each ingredient</span>
            </div>
        </div>
    </div>

    <!-- ══════════════════ MAIN GRID ══════════════════ -->
    <div class="main-grid">

        <!-- LEFT: SCANNER CARD -->
        <div class="card scan-card">
            <div class="card-header">
                <div class="card-header-left">
                    <div class="card-ico teal"><i class="fas fa-tag"></i></div>
                    <div>
                        <div class="card-title">Analyze Product Label</div>
                        <div class="card-sub">Upload an image or enter ingredients manually</div>
                    </div>
                </div>
            </div>

            <!-- Tab Switcher -->
            <div class="tab-wrap">
                <div class="tracker-tabs">
                    <button class="tracker-tab active" id="cameraOption" type="button">
                        <i class="fas fa-camera"></i> Capture Label
                    </button>
                    <button class="tracker-tab" id="manualOption" type="button">
                        <i class="fas fa-keyboard"></i> Enter Manually
                    </button>
                </div>
            </div>

            <!-- ── Upload Tab ── -->
            <div class="tracker-tab-content active" id="cameraScanner">
                <div class="upload-zone" id="psUploadZone">
                    <div class="upload-icon-wrap"><i class="fas fa-cloud-upload-alt"></i></div>
                    <p class="upload-title">Drop your image here</p>
                    <p class="upload-sub">or <span class="upload-link">click to browse</span></p>
                    <div class="upload-hint">
                        <i class="fas fa-info-circle"></i>
                        JPG · PNG · WebP &nbsp;·&nbsp; max 5 MB
                    </div>
                    <input type="file" id="imageFile" accept="image/jpeg,image/png,image/webp" style="display:none" />
                </div>

                <!-- Preview -->
                <div id="psPreviewWrap" style="display:none; position:relative;">
                    <div class="preview-frame">
                        <img id="psPreviewImg" src="" alt="Selected label" />
                        <div class="preview-overlay">
                            <button id="psRemoveFile" class="preview-remove" type="button">
                                <i class="fas fa-trash-alt"></i> Remove
                            </button>
                        </div>
                    </div>
                    <div class="preview-filename" id="psFileName"></div>
                </div>

                <!-- Loading -->
                <div id="psLoadingOverlay" class="loading-overlay" style="display:none;">
                    <div class="loading-spinner"><i class="fas fa-spinner fa-spin"></i></div>
                    <p class="loading-title">Analyzing ingredients…</p>
                    <p class="loading-sub">Reading label text via OCR · this may take a few seconds</p>
                    <div class="loading-bar"><div class="loading-bar-fill"></div></div>
                </div>

                <div class="scan-actions">
                    <button class="save-btn save-btn-bp" id="analyzeBtn" type="button">
                        <i class="fas fa-search"></i> Analyze Ingredients
                    </button>
                </div>
            </div>

            <!-- ── Manual Tab ── -->
            <div class="tracker-tab-content" id="manualEntry">
                <div class="inp-group inp-full">
                    <label for="productName">
                        <i class="fas fa-box"></i> Product Name <span class="optional-lbl">(Optional)</span>
                    </label>
                    <input type="text" id="productName" class="inp"
                           placeholder="e.g., Dove Body Lotion, Cereal Brand" />
                </div>
                <div class="inp-group inp-full">
                    <label for="ingredientsInput">
                        <i class="fas fa-list"></i> Ingredients / Components
                    </label>
                    <p class="inp-hint">Separate each ingredient by a comma or new line</p>
                    <textarea id="ingredientsInput" class="inp textarea-inp" rows="6"
                              placeholder="e.g., Water, Glycerin, Paraben, Retinol…"></textarea>
                </div>
                <button class="save-btn save-btn-bp" id="checkProduct" type="button">
                    <i class="fas fa-search"></i> Analyze Ingredients
                </button>
            </div>
        </div>

        <!-- RIGHT: RESULTS CARD -->
        <div class="card results-card" id="resultsCard">
            <div class="card-header">
                <div class="card-header-left">
                    <div class="card-ico purple"><i class="fas fa-shield-alt"></i></div>
                    <div>
                        <div class="card-title">Safety Analysis</div>
                        <div class="card-sub">Results will appear here after analysis</div>
                    </div>
                </div>
            </div>

            <div class="results-placeholder" id="resultsPlaceholder">
                <div class="placeholder-icon"><i class="fas fa-shield-alt"></i></div>
                <h4>Ready to Analyze</h4>
                <p>Upload a product label photo or enter ingredients manually to see a full pregnancy-safety breakdown.</p>
                <div class="placeholder-chips">
                    <span class="ph-chip safe"><i class="fas fa-check-circle"></i> Safe</span>
                    <span class="ph-chip caution"><i class="fas fa-exclamation-circle"></i> Caution</span>
                    <span class="ph-chip danger"><i class="fas fa-times-circle"></i> Avoid</span>
                </div>
            </div>

            <div id="dynamicResult" style="display:none;"></div>
        </div>

    </div>
    <!-- / MAIN GRID -->

    <!-- ══════════════════ QUICK REFERENCE ══════════════════ -->
    <div class="card reference-card">
        <div class="card-header">
            <div class="card-header-left">
                <div class="card-ico amber"><i class="fas fa-book-medical"></i></div>
                <div>
                    <div class="card-title">Quick Reference Guide</div>
                    <div class="card-sub">Common ingredients and their pregnancy safety classification</div>
                </div>
            </div>
            <span class="badge-info"><i class="fas fa-info-circle"></i> Always consult your doctor</span>
        </div>

        <div class="reference-grid">
            <!-- Avoid -->
            <div class="ref-card ref-danger">
                <div class="ref-card-header">
                    <div class="ref-icon-wrap danger"><i class="fas fa-ban"></i></div>
                    <div>
                        <h4>Avoid During Pregnancy</h4>
                        <span class="ref-count">6 ingredients</span>
                    </div>
                </div>
                <ul class="ref-list">
                    <li><i class="fas fa-times-circle"></i> Retinoids (Retinol, Tretinoin)</li>
                    <li><i class="fas fa-times-circle"></i> Salicylic Acid (high dose)</li>
                    <li><i class="fas fa-times-circle"></i> Parabens (high concentrations)</li>
                    <li><i class="fas fa-times-circle"></i> Formaldehyde &amp; Toluene</li>
                    <li><i class="fas fa-times-circle"></i> Hydroquinone</li>
                    <li><i class="fas fa-times-circle"></i> Phthalates</li>
                </ul>
            </div>

            <!-- Caution -->
            <div class="ref-card ref-warning">
                <div class="ref-card-header">
                    <div class="ref-icon-wrap warning"><i class="fas fa-exclamation-triangle"></i></div>
                    <div>
                        <h4>Use with Caution</h4>
                        <span class="ref-count">6 ingredients</span>
                    </div>
                </div>
                <ul class="ref-list">
                    <li><i class="fas fa-exclamation-circle"></i> Caffeine (limit 200 mg/day)</li>
                    <li><i class="fas fa-exclamation-circle"></i> Essential oils (concentrated)</li>
                    <li><i class="fas fa-exclamation-circle"></i> Artificial sweeteners</li>
                    <li><i class="fas fa-exclamation-circle"></i> Some fragrances</li>
                    <li><i class="fas fa-exclamation-circle"></i> Sodium Lauryl Sulfate (SLS)</li>
                    <li><i class="fas fa-exclamation-circle"></i> Chemical sunscreens</li>
                </ul>
            </div>

            <!-- Safe -->
            <div class="ref-card ref-safe">
                <div class="ref-card-header">
                    <div class="ref-icon-wrap safe"><i class="fas fa-check-circle"></i></div>
                    <div>
                        <h4>Generally Safe</h4>
                        <span class="ref-count">6 ingredients</span>
                    </div>
                </div>
                <ul class="ref-list">
                    <li><i class="fas fa-check-circle"></i> Vitamin C (topical)</li>
                    <li><i class="fas fa-check-circle"></i> Hyaluronic Acid</li>
                    <li><i class="fas fa-check-circle"></i> Glycerin &amp; Shea Butter</li>
                    <li><i class="fas fa-check-circle"></i> Mineral sunscreens (Zinc oxide)</li>
                    <li><i class="fas fa-check-circle"></i> Natural oils (Coconut, Jojoba)</li>
                    <li><i class="fas fa-check-circle"></i> Cocoa Butter</li>
                </ul>
            </div>
        </div>
    </div>

</div>
<!-- / ps-wrap -->

@section Styles {
<style>
/* ═══════════════════════════════════════════════════════════════
   PRODUCT SAFETY — using Patient Dashboard design system
═══════════════════════════════════════════════════════════════ */

.ps-wrap {
    --p:       #1BAEBE;
    --p-dk:    #138fa0;
    --p-mid:   #22c9db;
    --p-lt:    #e0f7fa;
    --p-xlt:   #f0fdfe;
    --pink:    #e91e63;
    --pink-lt: #fce4ec;
    --purple:  #9c27b0;
    --purp-lt: #f3e5f5;
    --green:   #4caf50;
    --grn-lt:  #e8f5e9;
    --amber:   #ff9800;
    --amb-lt:  #fff8e1;
    --blue:    #2196f3;
    --blue-lt: #e3f2fd;
    --navy:       #0b1f35;
    --navy-mid:   #152d47;
    --text:       #1e293b;
    --text-2:     #4a5568;
    --text-3:     #8896ab;
    --border:     #e4eaf2;
    --border-2:   #cdd6e3;
    --bg:         #f3f6fb;
    --white:      #fff;
    --danger:     #ef4444;
    --warning:    #f59e0b;
    --success:    #22c55e;
    --info:       #3b82f6;
    --r:          10px;
    --r-lg:       16px;
    --r-xl:       22px;
    --shadow-sm:  0 1px 4px rgba(15,28,46,.06);
    --shadow:     0 4px 16px rgba(15,28,46,.08);
    --shadow-md:  0 8px 28px rgba(15,28,46,.11);
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.ps-wrap .hero {
    background: linear-gradient(130deg, var(--navy) 0%, var(--navy-mid) 50%, #0d3d5c 100%);
    border-radius: var(--r-xl);
    padding: 24px 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    position: relative;
    overflow: hidden;
}
.ps-wrap .hero::before {
    content: ''; position: absolute; right: -40px; top: -40px;
    width: 200px; height: 200px; border-radius: 50%;
    background: radial-gradient(circle, rgba(27,174,190,.25) 0%, transparent 70%);
    pointer-events: none;
}
.ps-wrap .hero::after {
    content: ''; position: absolute; bottom: -60px; left: 20%;
    width: 260px; height: 260px; border-radius: 50%;
    background: radial-gradient(circle, rgba(0,180,216,.12) 0%, transparent 70%);
    pointer-events: none;
}
.ps-wrap .hero-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
    z-index: 1;
}
.ps-wrap .hero-left { display: flex; flex-direction: column; gap: 8px; }
.ps-wrap .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: .68rem; font-weight: 600; text-transform: uppercase; letter-spacing: .1em;
    color: var(--p-mid); background: rgba(27,174,190,.18);
    padding: 4px 10px; border-radius: 20px;
    border: 1px solid rgba(27,174,190,.25); width: fit-content;
}
.ps-wrap .hero-title { font-size: 1.85rem; font-weight: 700; color: #f1f5f9; line-height: 1.25; }
.ps-wrap .hero-title span { color: var(--p-mid); }
.ps-wrap .hero-sub { font-size: 1rem; color: #94a3b8; display: flex; align-items: center; gap: 7px; }
.ps-wrap .hero-sub i { font-size: .45rem; color: var(--p-mid); }
.ps-wrap .hero-right {
    display: flex; gap: 12px; align-items: center; justify-content: flex-end; flex-wrap: wrap; z-index: 1;
}
.ps-wrap .hero-stat {
    display: flex; align-items: center; gap: 10px;
    background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.12);
    border-radius: var(--r-lg); padding: 12px 16px; min-width: 100px;
}
.ps-wrap .hero-stat-ico {
    width: 38px; height: 38px; border-radius: 9px;
    display: flex; align-items: center; justify-content: center; font-size: 1rem;
}
.ps-wrap .hero-stat-ico.safe-ico { background: rgba(74,222,128,.25); color: #bbf7d0; }
.ps-wrap .hero-stat-ico.caution-ico { background: rgba(251,191,36,.25); color: #fde68a; }
.ps-wrap .hero-stat-ico.avoid-ico { background: rgba(252,165,165,.25); color: #fecaca; }
.ps-wrap .hero-stat-body { display: flex; flex-direction: column; }
.ps-wrap .hero-stat-lbl { font-size: .82rem; color: #e2e8f0; font-weight: 600; }

.ps-wrap .how-it-works {
    display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    background: var(--white); border-radius: var(--r-lg);
    border: 1px solid var(--border); padding: 16px 20px;
    box-shadow: var(--shadow-sm);
}
.ps-wrap .hw-step {
    display: flex; align-items: center; gap: 10px; flex: 1; min-width: 160px;
}
.ps-wrap .hw-step-num {
    width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0;
    background: linear-gradient(135deg, var(--p), var(--p-dk));
    color: #fff; font-size: .9rem; font-weight: 800;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 3px 10px rgba(27,174,190,.3);
}
.ps-wrap .hw-step-body { flex: 1; }
.ps-wrap .hw-step-body strong { display: block; font-size: .85rem; font-weight: 700; color: var(--text); }
.ps-wrap .hw-step-body span { font-size: .78rem; color: var(--text-3); line-height: 1.4; }
.ps-wrap .hw-step-arrow { color: var(--border-2); font-size: .85rem; flex-shrink: 0; }

.ps-wrap .main-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; align-items: start; }

.ps-wrap .card {
    background: var(--white); border-radius: var(--r-lg);
    border: 1px solid var(--border); box-shadow: var(--shadow-sm); overflow: hidden;
}
.ps-wrap .card-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 20px; border-bottom: 1px solid var(--border); gap: 10px;
}
.ps-wrap .card-header-left { display: flex; align-items: center; gap: 10px; }
.ps-wrap .card-ico {
    width: 32px; height: 32px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: .8rem; flex-shrink: 0;
}
.ps-wrap .card-ico.teal   { background: var(--p-lt);    color: var(--p); }
.ps-wrap .card-ico.purple { background: var(--purp-lt); color: var(--purple); }
.ps-wrap .card-ico.amber  { background: var(--amb-lt);  color: var(--amber); }
.ps-wrap .card-title { font-size: .88rem; font-weight: 700; color: var(--text); }
.ps-wrap .card-sub   { font-size: .71rem; color: var(--text-3); margin-top: 1px; }
.ps-wrap .badge-info {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 4px 10px; border-radius: 20px;
    background: var(--p-lt); color: var(--p);
    font-size: .72rem; font-weight: 600;
    border: 1px solid rgba(27,174,190,.25);
    white-space: nowrap; flex-shrink: 0;
}

.ps-wrap .tab-wrap { padding: 12px 16px 4px; }
.ps-wrap .tracker-tabs { display: flex; gap: 6px; flex-wrap: wrap; }
.ps-wrap .tracker-tab {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 6px 14px; border-radius: 20px;
    border: 1.5px solid var(--border); background: var(--bg);
    font-size: .8rem; font-weight: 600; color: var(--text-3);
    cursor: pointer; transition: all .18s;
}
.ps-wrap .tracker-tab:hover { background: var(--p-lt); color: var(--text); border-color: var(--p-lt); }
.ps-wrap .tracker-tab.active {
    background: linear-gradient(135deg, var(--p), var(--p-dk));
    color: #fff; border-color: transparent;
    box-shadow: 0 3px 10px rgba(27,174,190,.3);
}
.ps-wrap .tracker-tab-content { display: none; padding: 0 16px 16px; }
.ps-wrap .tracker-tab-content.active { display: block; }

.ps-wrap .upload-zone {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 8px; padding: 40px 24px;
    border: 2px dashed var(--border-2); border-radius: 14px;
    background: var(--bg); cursor: pointer;
    transition: border-color .2s, background .2s, box-shadow .2s;
    text-align: center; min-height: 210px; margin-bottom: 16px;
}
.ps-wrap .upload-zone:hover,
.ps-wrap .upload-zone.drag-over {
    border-color: var(--p);
    background: var(--p-xlt);
    box-shadow: 0 0 0 4px rgba(27,174,190,.08);
}
.ps-wrap .upload-icon-wrap {
    width: 64px; height: 64px; border-radius: 16px;
    background: var(--p-lt);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.7rem; color: var(--p);
    transition: transform .2s;
}
.ps-wrap .upload-zone:hover .upload-icon-wrap { transform: scale(1.08); }
.ps-wrap .upload-title { margin: 0; font-size: 1rem; font-weight: 700; color: var(--text); }
.ps-wrap .upload-sub   { margin: 0; font-size: .85rem; color: var(--text-3); }
.ps-wrap .upload-link  { color: var(--p); font-weight: 600; text-decoration: underline; text-decoration-style: dotted; cursor: pointer; }
.ps-wrap .upload-hint {
    display: inline-flex; align-items: center; gap: 5px;
    background: var(--white); border: 1px solid var(--border);
    border-radius: 20px; padding: 4px 12px;
    font-size: .75rem; color: var(--text-3); margin-top: 4px;
}

.ps-wrap .preview-frame {
    position: relative; border-radius: 14px; overflow: hidden;
    border: 2px solid var(--border); background: var(--bg);
    margin-bottom: 8px;
}
.ps-wrap .preview-frame img {
    width: 100%; max-height: 300px; object-fit: contain; display: block;
}
.ps-wrap .preview-overlay {
    position: absolute; inset: 0;
    background: rgba(15,23,42,0);
    display: flex; align-items: flex-start; justify-content: flex-end;
    padding: 12px; transition: background .2s;
}
.ps-wrap .preview-frame:hover .preview-overlay { background: rgba(15,23,42,.15); }
.ps-wrap .preview-remove {
    display: inline-flex; align-items: center; gap: 5px;
    background: rgba(239,68,68,.92); color: #fff; border: none; border-radius: 8px;
    padding: 6px 12px; font-size: .78rem; font-weight: 600; cursor: pointer;
    transition: background .2s;
}
.ps-wrap .preview-remove:hover { background: #dc2626; }
.ps-wrap .preview-filename {
    font-size: .78rem; color: var(--text-3); padding: 0 4px;
    display: flex; align-items: center; gap: 6px; margin-bottom: 12px;
}
.ps-wrap .preview-filename::before {
    content: '\f15b'; font-family: 'Font Awesome 6 Free';
    font-weight: 900; color: var(--p);
}

.ps-wrap .loading-overlay {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 12px; padding: 40px 24px;
    background: var(--p-xlt);
    border: 2px dashed var(--p);
    border-radius: 14px; text-align: center;
    margin-bottom: 16px;
}
.ps-wrap .loading-spinner {
    width: 62px; height: 62px; border-radius: 50%;
    background: var(--p-lt);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.6rem; color: var(--p);
}
.ps-wrap .loading-title { margin: 0; font-size: 1rem; font-weight: 700; color: var(--p); }
.ps-wrap .loading-sub   { margin: 0; font-size: .82rem; color: var(--text-3); }
.ps-wrap .loading-bar {
    width: 80%; max-width: 240px; height: 4px;
    background: var(--border); border-radius: 4px; overflow: hidden;
}
.ps-wrap .loading-bar-fill {
    height: 100%; width: 0%; border-radius: 4px;
    background: linear-gradient(90deg, var(--p), var(--p-dk));
    animation: psLoadBar 2s ease-in-out infinite;
}
@@keyframes psLoadBar {
    0%   { width: 0%;   margin-left: 0%; }
    50%  { width: 60%;  margin-left: 20%; }
    100% { width: 0%;   margin-left: 100%; }
}

.ps-wrap .scan-actions { margin-top: 12px; }
.ps-wrap .save-btn {
    display: inline-flex; align-items: center; gap: 6px;
    border: none; border-radius: var(--r); padding: 9px 18px;
    font-size: .86rem; font-weight: 700; cursor: pointer;
    transition: transform .18s, box-shadow .18s; width: 100%;
    justify-content: center;
}
