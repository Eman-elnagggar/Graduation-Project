@section Scripts {
<script>
(function () {
    'use strict';

    const TOKEN = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

    const cameraOption      = document.getElementById('cameraOption');
    const manualOption      = document.getElementById('manualOption');
    const cameraScanner     = document.getElementById('cameraScanner');
    const manualEntry       = document.getElementById('manualEntry');
    const psUploadZone      = document.getElementById('psUploadZone');
    const imageFileInput    = document.getElementById('imageFile');
    const psPreviewWrap     = document.getElementById('psPreviewWrap');
    const psPreviewImg      = document.getElementById('psPreviewImg');
    const psFileName        = document.getElementById('psFileName');
    const psRemoveFile      = document.getElementById('psRemoveFile');
    const psLoadingOverlay  = document.getElementById('psLoadingOverlay');
    const analyzeBtn        = document.getElementById('analyzeBtn');
    const checkProduct      = document.getElementById('checkProduct');
    const productNameInput  = document.getElementById('productName');
    const ingredientsInput  = document.getElementById('ingredientsInput');
    const resultsPlaceholder = document.getElementById('resultsPlaceholder');
    const dynamicResult      = document.getElementById('dynamicResult');

    cameraOption?.addEventListener('click', () => {
        cameraOption.classList.add('active');
        manualOption.classList.remove('active');
        cameraScanner.classList.add('active');
        manualEntry.classList.remove('active');
    });
    manualOption?.addEventListener('click', () => {
        manualOption.classList.add('active');
        cameraOption.classList.remove('active');
        manualEntry.classList.add('active');
        cameraScanner.classList.remove('active');
    });

    psUploadZone?.addEventListener('click', () => imageFileInput?.click());
    psUploadZone?.addEventListener('dragover', e => { e.preventDefault(); psUploadZone.classList.add('drag-over'); });
    psUploadZone?.addEventListener('dragleave', () => psUploadZone.classList.remove('drag-over'));
    psUploadZone?.addEventListener('drop', e => {
        e.preventDefault();
        psUploadZone.classList.remove('drag-over');
        const file = e.dataTransfer?.files?.[0];
        if (file) applyFile(file);
    });
    imageFileInput?.addEventListener('change', () => {
        if (imageFileInput.files?.length) applyFile(imageFileInput.files[0]);
    });

    function applyFile(file) {
        const allowed = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
        if (!allowed.includes(file.type)) { notify('Invalid file type. Please upload a JPG, PNG or WebP image.', 'error'); return; }
        if (file.size > 5 * 1024 * 1024)  { notify('File size exceeds 5 MB.', 'error'); return; }
        psPreviewImg.src = URL.createObjectURL(file);
        if (psFileName) psFileName.textContent = file.name + '  (' + (file.size / 1024).toFixed(1) + ' KB)';
        psUploadZone.style.display  = 'none';
        psPreviewWrap.style.display = 'block';
        if (!imageFileInput.files.length) {
            const dt = new DataTransfer(); dt.items.add(file); imageFileInput.files = dt.files;
        }
    }

    psRemoveFile?.addEventListener('click', () => {
        psPreviewImg.src = '';
        psPreviewWrap.style.display = 'none';
        psUploadZone.style.display  = 'flex';
        imageFileInput.value = '';
        if (psFileName) psFileName.textContent = '';
        clearResult();
    });

    analyzeBtn?.addEventListener('click', async () => {
        if (!imageFileInput?.files?.length) { notify('Please select an image first.', 'warning'); return; }
        showLoading(true);
        clearResult();
        try {
            const fd = new FormData();
            fd.append('image', imageFileInput.files[0]);
            const res  = await fetch('/ProductScan/AnalyzeImage', {
                method: 'POST',
                headers: { 'RequestVerificationToken': TOKEN },
                body: fd
            });
            const data = await res.json();
            if (!res.ok) { notify(data.error ?? 'Analysis failed. Please try again.', 'error'); return; }
            renderResult(data);
        } catch {
            notify('Network error. Please check your connection and try again.', 'error');
        } finally {
            showLoading(false);
        }
    });

    checkProduct?.addEventListener('click', async () => {
        const productName = (productNameInput?.value ?? '').trim();
        const ingredientsRaw = (ingredientsInput?.value ?? '').trim();

        if (!ingredientsRaw) {
            notify('Please enter ingredients before analyzing.', 'warning');
            ingredientsInput?.focus();
            return;
        }

        const normalizedIngredients = normalizeIngredients(ingredientsRaw);
        const payloadText = productName
            ? `Product Name: ${productName}\nIngredients: ${normalizedIngredients}`
            : normalizedIngredients;

        setButtonLoading(checkProduct, true, 'Analyzing...');
        clearResult();

        try {
            const body = new URLSearchParams();
            body.append('text', payloadText);

            const res = await fetch('/ProductScan/AnalyzeText', {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': TOKEN,
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
                },
                body
            });

            const data = await res.json();
            if (!res.ok) {
                notify(data.error ?? 'Analysis failed. Please try again.', 'error');
                return;
            }

            renderResult(data);
        } catch {
            notify('Network error. Please check your connection and try again.', 'error');
        } finally {
            setButtonLoading(checkProduct, false, 'Analyze Ingredients');
        }
    });

    function showLoading(on) {
        if (!psLoadingOverlay) return;
        if (on) { psUploadZone.style.display = 'none'; psPreviewWrap.style.display = 'none'; }
        else { if (imageFileInput?.files?.length) psPreviewWrap.style.display = 'block'; else psUploadZone.style.display = 'flex'; }
        psLoadingOverlay.style.display = on ? 'flex' : 'none';
    }

    function clearResult() {
        dynamicResult.style.display      = 'none';
        dynamicResult.innerHTML          = '';
        resultsPlaceholder.style.display = 'flex';
    }

    function renderResult(data) {
        const source = data?.results ?? data ?? {};
        const safe = Array.isArray(source.safe) ? source.safe.filter(Boolean) : [];
        const risky = Array.isArray(source.risky) ? source.risky.filter(Boolean) : [];
        const avoid = Array.isArray(source.avoid) ? source.avoid.filter(Boolean) : [];
        const status = source.status ?? data?.status;
        const total = safe.length + risky.length + avoid.length;
        const riskyIngredients = Array.from(new Set([...avoid, ...risky].flatMap(extractIngredientsFromBrackets)));
        let cls, icon, label, riskLevel;

        if (status === 'Unsafe' || avoid.length > 0) {
            cls = 'danger'; icon = 'fa-exclamation-triangle'; label = 'Avoid This Product'; riskLevel = 'High Risk';
        } else if (status === 'NeedsReview' || risky.length > 0) {
            cls = 'warning'; icon = 'fa-exclamation-circle'; label = 'Use With Caution'; riskLevel = 'Moderate Risk';
        } else {
            cls = 'safe'; icon = 'fa-check-circle'; label = 'Generally Safe'; riskLevel = 'Low Risk';
        }

        function buildGroup(items, itemCls, itemIcon, groupTitle, groupCls) {
            if (!items.length) return '';
            return `<div class="ps-ing-group">
                <div class="ps-ing-group-title ${groupCls}">
                    <i class="fas ${itemIcon}"></i> ${groupTitle}
                    <span style="font-weight:500;margin-left:.3rem;opacity:.7">(${items.length})</span>
                </div>
                <div class="ps-ing-list">
                    ${items.map(n => {
                        const foundIngredients = extractIngredientsFromBrackets(n);
                        return `<div class="ps-ing-item ${itemCls}">
                            <div class="ps-response-text"><i class="fas ${itemIcon}"></i> ${escHtml(n)}</div>
                            ${foundIngredients.length ? `<div class="ps-found-row">
                                <span class="ps-found-label">Found:</span>
                                ${foundIngredients.map(x => `<span class="ps-ing-chip ${itemCls}">${escHtml(x)}</span>`).join('')}
                            </div>` : ''}
                        </div>`;
                    }).join('')}
                </div>
            </div>`;
        }

        dynamicResult.innerHTML = `
            <div class="ps-result-wrap ${cls}">
                <div class="ps-result-header">
                    <div class="ps-result-info">
                        <div class="ps-result-kicker">Risk Level</div>
                        <h4>${label}</h4>
                        <p><i class="fas fa-tag"></i> ${riskyIngredients.length} risky ingredient${riskyIngredients.length !== 1 ? 's' : ''} found</p>
                    </div>
                    <div class="ps-verdict-badge ${cls}"><i class="fas ${icon}"></i> ${riskLevel}</div>
                </div>
                ${total > 0 ? `<div class="ps-ing-body">
                    ${buildGroup(avoid, 'danger',  'fa-times-circle',       'Avoid',            'danger')}
                    ${buildGroup(risky, 'warning', 'fa-exclamation-circle', 'Use with Caution', 'warning')}
                    ${buildGroup(safe,  'safe',    'fa-check-circle',       'Safe',             'safe')}
                    ${(!avoid.length && !risky.length) ? `<div class="ps-no-ingredients">No risky ingredients found.</div>` : ''}
                </div>` : `<div class="ps-no-ingredients">No ingredients were identified in the image.</div>`}
            </div>`;

        resultsPlaceholder.style.display = 'none';
        dynamicResult.style.display      = 'block';
        dynamicResult.closest('.results-card')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function notify(msg, type) {
        if (typeof window.showNotification === 'function') window.showNotification(msg, type);
        else console.warn(msg);
    }

    function normalizeIngredients(raw) {
        return raw
            .split(/[\n,]+/)
            .map(item => item.trim())
            .filter(Boolean)
            .join(', ');
    }

    function setButtonLoading(button, loading, loadingText) {
        if (!button) return;
        if (!button.dataset.originalHtml) button.dataset.originalHtml = button.innerHTML;

        button.disabled = loading;
        if (loading) {
            button.innerHTML = `<i class="fas fa-spinner fa-spin"></i> ${loadingText}`;
        } else {
            button.innerHTML = button.dataset.originalHtml;
        }
    }

    function escHtml(str) {
        return String(str ?? '')
            .replace(/&/g,'&amp;')
            .replace(/</g,'&lt;')
            .replace(/>/g,'&gt;')
            .replace(/"/g,'&quot;');
    }

    function extractIngredientsFromBrackets(text) {
        const matches = [...String(text ?? '').matchAll(/\[([^\]]+)\]/g)];
        if (!matches.length) return [];

        const tokens = matches
            .flatMap(m => m[1].split(','))
            .map(t => t.trim())
            .filter(Boolean)
            .filter(t => /[a-zA-Z]/.test(t));

        return Array.from(new Set(tokens));
    }
}());
</script>
}
