    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NABD - نبض - Smarter Pregnancy Care</title>
    <link rel="stylesheet" href="~/css/home-index.css" asp-append-version="true" />
</head>
<body>
    <!-- Navigation -->
