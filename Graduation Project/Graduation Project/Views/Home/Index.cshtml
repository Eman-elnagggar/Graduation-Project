                    <h3>AI-Supported Features</h3>
                    <p>Intelligent health analysis, risk detection alerts, and personalized care recommendations powered by AI.</p>
                    <div class="feature-bottom-border"></div>
                </div>
            </div>

            <h3 class="additional-title">Additional Capabilities</h3>
            <div class="additional-features">
                <div class="additional-card">
                    <div class="additional-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                            <polyline points="14 2 14 8 20 8" />
                        </svg>
                    </div>
                    <div>
                        <h4>Medical Records</h4>
                        <p>Secure digital storage of patient history</p>
                    </div>
                </div>

                <div class="additional-card">
                    <div class="additional-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                        </svg>
                    </div>
                    <div>
                        <h4>Real-time Alerts</h4>
                        <p>Instant notifications for critical updates</p>
                    </div>
                </div>

                <div class="additional-card">
                    <div class="additional-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                            <circle cx="9" cy="7" r="4" />
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" />
                        </svg>
                    </div>
                    <div>
                        <h4>Multi-user Support</h4>
                        <p>Patients, doctors, and clinic assistants</p>
                    </div>
                </div>

                <div class="additional-card">
                    <div class="additional-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                            <polyline points="9 22 9 12 15 12 15 22" />
                        </svg>
                    </div>
                    <div>
                        <h4>Prescription Management</h4>
                        <p>Digital prescriptions and medication tracking</p>
                    </div>
                </div>

                <div class="additional-card">
                    <div class="additional-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                        </svg>
                    </div>
                    <div>
                        <h4>Health Monitoring</h4>
                        <p>Track vital signs and health metrics</p>
                    </div>
                </div>

                <div class="additional-card">
                    <div class="additional-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
                        </svg>
                    </div>
                    <div>
                        <h4>Reports & Analytics</h4>
                        <p>Comprehensive health reports generation</p>
                    </div>
                </div>
            </div>
        </div>
