                        </svg>
                    </div>
                    <span class="logo-text">NABD - نبض</span>
                </div>

                <div class="nav-links">
                    <a href="#about" class="nav-link">About Us</a>
                    <a href="#features" class="nav-link">Features</a>
                    <a href="#how-it-works" class="nav-link">How It Works</a>
                    <a href="#faq" class="nav-link">FAQ</a>
                    <button class="btn-primary" onclick="window.location.href='@Url.Action("Login", "Account")'">Get Started</button>
                </div>

                <button class="mobile-menu-btn" id="mobileMenuBtn">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
        </div>

        <div class="mobile-menu" id="mobileMenu">
            <a href="#about" class="mobile-link">About Us</a>
            <a href="#features" class="mobile-link">Features</a>
            <a href="#how-it-works" class="mobile-link">How It Works</a>
            <a href="#faq" class="mobile-link">FAQ</a>
            <button class="btn-primary" onclick="window.location.href='@Url.Action("Login", "Account")'">Get Started</button>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-bg">
            <div class="blob blob-1"></div>
            <div class="blob blob-2"></div>
            <div class="particles" id="particles"></div>
        </div>

        <div class="container hero-content">
            <div class="badge fade-in">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" />
                </svg>
                <span>Graduation Project 2026</span>
            </div>

            <h1 class="hero-title fade-in-up">
                <span class="gradient-text animated-gradient">NABD - نبض</span>
            </h1>

            <p class="hero-subtitle fade-in-up">Smarter Pregnancy Care</p>

            <p class="hero-description fade-in-up">
                An intelligent pregnancy-care platform that connects patients, doctors,
                and clinic assistants through one smart, simple, and supportive system.
            </p>

            <div class="hero-buttons fade-in-up">
                <button class="btn-primary btn-large" onclick="scrollToSection('features')">
                    <span>Explore Features</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14M12 5l7 7-7 7" />
                    </svg>
                </button>
                <button class="btn-secondary btn-large" onclick="scrollToSection('how-it-works')">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polygon points="5 3 19 12 5 21 5 3" />
                    </svg>
                    <span>How It Works</span>
                </button>
            </div>

            <div class="trust-indicators fade-in-up">
                <div class="trust-item">
                    <span class="pulse-dot green"></span>
                    <span>AI-Powered Healthcare</span>
                </div>
                <div class="trust-item">
                    <span class="pulse-dot blue"></span>
                    <span>24/7 Monitoring</span>
                </div>
                <div class="trust-item">
                    <span class="pulse-dot purple"></span>
                    <span>Secure & Private</span>
                </div>
            </div>

            <div class="scroll-indicator">
                <div class="scroll-mouse">
                    <div class="scroll-wheel"></div>
                </div>
            </div>
        </div>
