    <!-- About Section -->
    <section id="about" class="about-section">
        <div class="container">
            <div class="section-header">
                <span class="section-badge pink">About Us</span>
                <h2 class="section-title">
                    Building the Future of
                    <span class="gradient-text">Maternal Care</span>
                </h2>
                <p class="section-description">
                    NABD - نبض is a healthcare-focused graduation project designed to improve prenatal follow-up.
                    Our goal is to reduce fragmented care by combining appointments, health tracking,
                    alerts, prescriptions, and medical records in one unified experience.
                </p>
            </div>

            <div class="about-cards">
                <div class="about-card pink-card">
                    <div class="card-blob"></div>
                    <div class="card-icon gradient-pink">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                            <circle cx="12" cy="12" r="10" />
                            <circle cx="12" cy="12" r="6" />
                            <circle cx="12" cy="12" r="2" />
                        </svg>
                    </div>
                    <h3>Our Mission</h3>
                    <p>Make maternal care safer and easier by enabling early risk detection, better communication, and continuous patient engagement.</p>
                    <div class="card-border"></div>
                </div>

                <div class="about-card blue-card">
                    <div class="card-blob"></div>
                    <div class="card-icon gradient-blue">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    </div>
                    <h3>Our Vision</h3>
                    <p>Build a digital care companion where every pregnant patient can receive timely guidance and every clinic team can work efficiently.</p>
                    <div class="card-border"></div>
                </div>
            </div>

            <div class="about-footer">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="#ec4899">
                    <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />
                </svg>
                <p>Dedicated to improving maternal healthcare through technology and innovation</p>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="features-section">
        <div class="container">
            <div class="section-header">
                <span class="section-badge purple">Features</span>
                <h2 class="section-title">
                    What We Are
                    <span class="gradient-text">Doing</span>
                </h2>
                <p class="section-description">
                    Comprehensive features designed to revolutionize maternal healthcare
                </p>
            </div>

            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-decoration"></div>
                    <div class="feature-icon gradient-pink">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                            <rect x="3" y="4" width="18" height="18" rx="2" />
