@model IEnumerable<Graduation_Project.Models.Place>

@{
    ViewData["Title"] = "My Places";
    ViewData["PageTitle"] = "My Places 📍";
    ViewData["PageSubtitle"] = "Manage your healthcare locations";
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    int patientId = (int)ViewBag.PatientId;
}

<!-- Header -->
<header class="header">
    <div class="header-left">
        <h1>My Places ??</h1>
        <p>Manage your healthcare locations</p>
    </div>
    <div class="header-right">
        <div class="notification">
            <i class="fas fa-bell"></i>
            <span class="badge">3</span>
        </div>
        <div class="profile">
            <img src="https://img.freepik.com/free-psd/portrait-woman-wearing-hijab_23-2150945115.jpg" alt="Profile" />
            <span>Sarah Ahmed</span>
        </div>
    </div>
</header>

<!-- Add New Place Form -->
<section class="add-place-section">
    <div class="card">
        <h3><i class="fas fa-plus-circle"></i> Add New Place</h3>
        <form asp-action="Create" asp-controller="Place" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="PatientID" value="@patientId" />

            <div class="form-row">
                <div class="form-group">
                    <label>Place Name *</label>
                    <input type="text" name="Name" class="form-input" placeholder="e.g., City Hospital" required />
                </div>
                <div class="form-group">
                    <label>Place Type *</label>
                    <select name="Type" class="form-select">
                        <option value="">Select Type</option>
                        <option value="hospital">Hospital</option>
                        <option value="clinic">Clinic</option>
                        <option value="lab">Laboratory</option>
                        <option value="pharmacy">Pharmacy</option>
                        <option value="imaging">Imaging Center</option>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Address *</label>
                    <input type="text" name="Address" class="form-input" placeholder="Full address" required />
                </div>
                <div class="form-group">
                    <label>Phone Number</label>
                    <input type="tel" name="Phone" class="form-input" placeholder="+20 xxx xxx xxxx" />
                </div>
            </div>

            <div class="form-group">
                <label>Image URL</label>
                <input type="text" name="ImageURL" class="form-input" placeholder="https://..." />
            </div>

            <div class="form-actions">
                <button type="reset" class="btn btn-secondary">Cancel</button>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Save Place
                </button>
            </div>
        </form>
    </div>
</section>

<!-- My Saved Places -->
<section class="places-list">
    <div class="card">
        <div class="card-header">
            <h3><i class="fas fa-list"></i> My Saved Places</h3>
        </div>

        <div class="places-grid">
            @foreach (var place in Model)
            {
                <div class="place-card">
                    <div class="place-image">
                        <img src="@(string.IsNullOrEmpty(place.ImageURL) ? "https://via.placeholder.com/300x200" : place.ImageURL)"
                             alt="@place.Name" />
                        <span class="place-type-badge @place.Type">@place.Type</span>
                    </div>
                    <div class="place-info">
                        <h4>@place.Name</h4>
                        <p class="place-address">
                            <i class="fas fa-map-marker-alt"></i> @place.Address
                        </p>
                        <p class="place-phone">
                            <i class="fas fa-phone"></i> @place.Phone
                        </p>
                    </div>
                    <div class="place-actions">
                        <form asp-action="Delete" asp-controller="Place" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@place.PlaceID" />
                            <input type="hidden" name="patientId" value="@place.PatientID" />
                            <button type="submit" class="btn btn-sm btn-outline danger"
                                    onclick="return confirm('Delete this place?')">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </form>
                    </div>
                </div>
            }

            @if (!Model.Any())
            {
                <p>No places added yet.</p>
            }
        </div>
    </div>
</section>