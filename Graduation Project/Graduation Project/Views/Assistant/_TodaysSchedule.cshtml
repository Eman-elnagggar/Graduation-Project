@model List<Graduation_Project.Models.Appointment>

@if (Model.Any())
{
    <div class="request-list request-list--modern">
        @foreach (var appt in Model)
        {
            var patientName = appt.Patient?.User != null
                ? $"{appt.Patient.User.FirstName} {appt.Patient.User.LastName}"
                : "Unknown";
            var doctorName = appt.Doctor?.User != null
                ? $"Dr. {appt.Doctor.User.FirstName} {appt.Doctor.User.LastName}"
                : "Doctor";
            var statusClass = appt.Booking != null
                ? (appt.Booking.Status?.ToLower() switch
                {
                    "confirmed" => "confirmed",
                    "cancelled" => "cancelled",
                    "modified" => "modified",
                    _ => "pending"
                })
                : (appt.isBooked ? "confirmed" : "pending");
            var statusText = appt.Booking?.Status ?? (appt.isBooked ? "Booked" : "Available");
            var appointmentTime = DateTime.Today.Add(appt.Time);

            <article class="request-card request-card--modern request-card--@statusClass">
                <div class="request-time">
                    <span class="request-time-main">@appointmentTime.ToString("h:mm")</span>
                    <span class="request-time-sub">@appointmentTime.ToString("tt")</span>
                </div>
                <div class="request-line request-line--@statusClass"></div>
                <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(patientName)&background=1baebe&color=fff&size=60"
                     alt="@patientName" class="patient-avatar" />
                <div class="request-info">
                    <h4>@patientName</h4>
                    <div class="meta">
                        <span class="meta-chip">
                            <i class="fas fa-hospital"></i>
                            @ViewBag.ClinicName
                        </span>
                        <span class="meta-chip">
                            <i class="fas fa-user-md"></i>
                            @doctorName
                        </span>
                    </div>
                    <div class="request-details">
                        <span class="detail-pill"><i class="fas fa-clock"></i> @appt.Time.ToString(@"hh\:mm")</span>
                        <span class="detail-pill"><i class="fas fa-calendar"></i> @appt.Date.ToString("MMM dd, yyyy")</span>
                        @if (appt.Booking != null && !string.IsNullOrEmpty(appt.Booking.Reason))
                        {
                            <span class="detail-pill"><i class="fas fa-notes-medical"></i> @appt.Booking.Reason</span>
                        }
                    </div>
                </div>
                <div class="request-actions">
                    <span class="appointment-status @statusClass">@statusText</span>
                </div>
            </article>
        }
    </div>
}
else
{
    <div class="privacy-notice privacy-notice-info">
        <i class="fas fa-info-circle text-info"></i>
        <p>
            @if (ViewBag.SelectedDoctorID != null)
            {
                @:No @ViewBag.SelectedStatusLabel entries for @ViewBag.SelectedDoctorName on @ViewBag.SelectedDateLabel.
            }
            else if (ViewBag.HasDoctors != null && !(bool)ViewBag.HasDoctors)
            {
                @:No doctors linked yet. Contact your clinic administrator.
            }
            else
            {
                @:No @ViewBag.SelectedStatusLabel entries for @ViewBag.SelectedDateLabel.
            }
        </p>
    </div>
}
