@model Graduation_Project.ViewModels.AssistantDashboardViewModel
@{
    Layout = "~/Views/Shared/_AssistantLayout.cshtml";
    ViewData["Title"] = "Dashboard";
    ViewData["AssistantId"] = Model.Assistant.AssistantID;
    ViewData["ActivePage"] = "Dashboard";
}

@section Head {
    <meta name="assistant-id" content="@Model.Assistant.AssistantID" />
}

<!-- Header -->
<header class="header">
    <div class="header-left">
        <h1>Welcome, @Model.AssistantName! 👋</h1>
        <p>Here's your assistant dashboard overview</p>
    </div>
    <div class="header-right">
        <div class="notification">
            <i class="fas fa-bell"></i>
            <span class="badge" id="alert-badge" style="display: none;"></span>
        </div>
        <div class="profile">
            <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.AssistantName)&background=7c3aed&color=fff&size=80"
                 alt="Profile" />
            <span>@Model.AssistantName</span>
        </div>
    </div>
</header>

<!-- Privacy Notice -->
<div class="privacy-notice">
    <i class="fas fa-shield-alt"></i>
    <p>
        <strong>Privacy Protected:</strong> As an assistant, you can manage
        appointments and schedules. Patient medical records, chat history,
        and clinical data are only accessible to doctors.
    </p>
</div>

<!-- Assistant Hero Section -->
<section class="pregnancy-progress">
    <div class="progress-card assistant-hero">
        <div class="progress-info">
            <h3>Today's Overview</h3>
            <p>
                <span class="week-number" id="todayDate">@DateTime.Today.ToString("MMMM dd, yyyy")</span>
            </p>
        </div>
        <div class="progress-details">
            <span>
                <i class="fas fa-calendar-check"></i>
                <span id="hero-appointment-count">--</span> Appointments Today
            </span>
            <span>
                <i class="fas fa-user-md"></i>
                <span>@Model.Doctors.Count</span> Linked Doctor(s)
            </span>
        </div>
    </div>
</section>

<!-- Doctor Filter Tabs -->
@if (Model.Doctors.Count > 1)
{
    <section class="card" style="margin-bottom: 1.5rem;">
        <div class="card-header">
            <h3><i class="fas fa-filter"></i> Filter by Doctor</h3>
        </div>
        <div class="doctor-filter-tabs" style="display: flex; flex-wrap: wrap; gap: 0.5rem; padding: 1rem;">
            <a href="@Url.Action("Index", new { id = Model.Assistant.AssistantID })"
               class="doctor-filter-tab @(Model.SelectedDoctorID == null ? "active" : "")"
               data-doctor-id=""
               style="padding: 0.5rem 1rem; border-radius: 20px; text-decoration: none;
                       background: @(Model.SelectedDoctorID == null ? "#7c3aed" : "#f3f4f6");
                       color: @(Model.SelectedDoctorID == null ? "#fff" : "#374151");
                       font-weight: 500; font-size: 0.9rem; transition: all 0.2s; cursor: pointer;">
                <i class="fas fa-users"></i> All Doctors
                <span id="all-doctors-tab-count"
                      style="background: @(Model.SelectedDoctorID == null ? "rgba(255,255,255,0.2)" : "#e5e7eb");
                             padding: 0.1rem 0.5rem; border-radius: 10px; margin-left: 0.3rem; font-size: 0.8rem;">
                    --
                </span>
            </a>
            @foreach (var doc in Model.Doctors)
            {
                var isSelected = Model.SelectedDoctorID == doc.DoctorID;
                <a href="@Url.Action("Index", new { id = Model.Assistant.AssistantID, doctorId = doc.DoctorID })"
                   class="doctor-filter-tab @(isSelected ? "active" : "")"
                   data-doctor-id="@doc.DoctorID"
                   style="padding: 0.5rem 1rem; border-radius: 20px; text-decoration: none;
                           background: @(isSelected ? "#1976d2" : "#f3f4f6");
                           color: @(isSelected ? "#fff" : "#374151");
                           font-weight: 500; font-size: 0.9rem; transition: all 0.2s; cursor: pointer;">
                    <i class="fas fa-user-md"></i> @doc.FullName
                    <span id="doctor-tab-count-@doc.DoctorID"
                          style="background: @(isSelected ? "rgba(255,255,255,0.2)" : "#e5e7eb");
                                 padding: 0.1rem 0.5rem; border-radius: 10px; margin-left: 0.3rem; font-size: 0.8rem;">
                        --
                    </span>
                </a>
            }
        </div>
    </section>
}

<!-- Quick Stats -->
<section class="quick-stats">
    <div class="quick-stat-card">
        <div class="stat-header">
            <div class="stat-icon" style="background: #e8f5e9">
                <i class="fas fa-calendar-check" style="color: #388e3c"></i>
            </div>
        </div>
        <div class="stat-value" id="stat-today-appointments">--</div>
        <div class="stat-label">Today's Appointments</div>
    </div>
    <div class="quick-stat-card">
        <div class="stat-header">
            <div class="stat-icon" style="background: #e3f2fd">
                <i class="fas fa-user-md" style="color: #1976d2"></i>
            </div>
        </div>
        <div class="stat-value">@Model.Doctors.Count</div>
        <div class="stat-label">Linked Doctors</div>
    </div>
    <div class="quick-stat-card">
        <div class="stat-header">
            <div class="stat-icon" style="background: #fff3e0">
                <i class="fas fa-users" style="color: #f57c00"></i>
            </div>
        </div>
        <div class="stat-value" id="stat-total-patients">--</div>
        <div class="stat-label">Clinic Patients</div>
    </div>
</section>

<!-- Dashboard Grid - Today's Schedule -->
<section class="dashboard-grid">
    <div class="card">
        <div class="card-header">
            <h3>
                <i class="fas fa-clock"></i> Today's Schedule
                <span id="schedule-doctor-label" style="font-size: 0.85rem; color: #6b7280; font-weight: 400;@(Model.SelectedDoctorID == null ? " display:none;" : "")">
                    &mdash; <span id="schedule-doctor-name">@Model.SelectedDoctorName</span>
                </span>
            </h3>
            <a href="#">View All</a>
        </div>
        <div id="schedule-container">
            <div style="text-align: center; padding: 2rem; color: #6b7280;">
                <i class="fas fa-spinner fa-spin" style="font-size: 1.5rem;"></i>
                <p style="margin-top: 0.5rem;">Loading schedule...</p>
            </div>
        </div>
    </div>
</section>

<!-- Linked Doctors -->
<section class="card">
    <div class="card-header">
        <h3><i class="fas fa-user-md"></i> Linked Doctors</h3>
        <a href="#">Manage</a>
    </div>
    @if (Model.Doctors.Any())
    {
        <div class="team-grid">
            @foreach (var doc in Model.Doctors)
            {
                <div class="team-card" style="cursor: pointer;"
                     data-doctor-id="@doc.DoctorID">
                    <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(doc.FullName)&background=1976d2&color=fff&size=88"
                         alt="@doc.FullName" class="avatar" />
                    <h4>@doc.FullName</h4>
                    <div class="role">@doc.Specialization</div>
                    <div style="display: flex; gap: 1rem; justify-content: center; margin-top: 0.5rem; font-size: 0.8rem; color: #6b7280;">
                        <span><i class="fas fa-calendar-check"></i> <span id="doctor-today-@doc.DoctorID">--</span> today</span>
                        <span><i class="fas fa-users"></i> <span id="doctor-patients-@doc.DoctorID">--</span> patients</span>
                    </div>
                    <span class="status-dot online">Active</span>
                </div>
            }
        </div>
    }
    else
    {
        <div class="privacy-notice" style="border-left-color: var(--warning);">
            <i class="fas fa-exclamation-triangle" style="color: var(--warning);"></i>
            <p>No doctors are currently linked to your account. Please contact your clinic administrator.</p>
        </div>
    }
</section>

<!-- Clinic Invitations (placeholder) -->
<section class="card" id="clinicInvitationsSection">
    <div class="card-header">
        <h3><i class="fas fa-envelope-open-text"></i> Clinic Invitations</h3>
        <a href="#">View All</a>
    </div>
    <div class="privacy-notice" style="border-left-color: var(--info);">
        <i class="fas fa-info-circle" style="color: var(--info);"></i>
        <p>No pending clinic invitations.</p>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            // Notifications panel toggle
            const notificationBtn = document.querySelector(".notification");
            const notificationsPanel = document.querySelector(".notifications-panel");
            const closeNotifications = document.querySelector(".close-notifications");

            if (notificationBtn && notificationsPanel) {
                notificationBtn.addEventListener("click", () => {
                    notificationsPanel.classList.toggle("open");
                });
                if (closeNotifications) {
                    closeNotifications.addEventListener("click", () => {
                        notificationsPanel.classList.remove("open");
                    });
                }
                document.addEventListener("click", (e) => {
                    if (!notificationsPanel.contains(e.target) && !notificationBtn.contains(e.target)) {
                        notificationsPanel.classList.remove("open");
                    }
                });
            }

            // Update today's date dynamically
            const todayDateEl = document.getElementById("todayDate");
            if (todayDateEl) {
                todayDateEl.textContent = new Date().toLocaleDateString("en-US", {
                    weekday: "long", year: "numeric", month: "long", day: "numeric"
                });
            }

            // --- Dashboard AJAX setup ---
            const assistantId = @Model.Assistant.AssistantID;
            let currentDoctorId = @(Model.SelectedDoctorID.HasValue ? Model.SelectedDoctorID.Value.ToString() : "null");
            const baseStatsUrl = '@Url.Action("GetDashboardStats", "Assistant")';
            const baseScheduleUrl = '@Url.Action("GetTodaysSchedule", "Assistant")';
            const baseIndexUrl = '@Url.Action("Index", "Assistant")';

            // Doctor name lookup for schedule header
            const doctorNames = {
                @foreach (var doc in Model.Doctors)
                {
                    @:[@doc.DoctorID]: '@Html.Raw(doc.FullName.Replace("'", "\\'"))',
                }
            };

            const setTxt = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };

            // --- Core: load dashboard data via AJAX ---
            function loadDashboardData(doctorId, pushState) {
                currentDoctorId = doctorId;

                // Update browser URL without reload
                if (pushState !== false) {
                    const newUrl = baseIndexUrl + '?id=' + assistantId + (doctorId !== null ? '&doctorId=' + doctorId : '');
                    history.pushState({ assistantId: assistantId, doctorId: doctorId }, '', newUrl);
                }

                // Update filter tab active states
                updateTabStyles(doctorId);

                // Update schedule header
                const label = document.getElementById('schedule-doctor-label');
                const nameSpan = document.getElementById('schedule-doctor-name');
                if (label && nameSpan) {
                    if (doctorId !== null && doctorNames[doctorId]) {
                        nameSpan.textContent = doctorNames[doctorId];
                        label.style.display = '';
                    } else {
                        label.style.display = 'none';
                    }
                }

                // Show loading spinner in schedule
                document.getElementById('schedule-container').innerHTML =
                    '<div style="text-align:center;padding:2rem;color:#6b7280;"><i class="fas fa-spinner fa-spin" style="font-size:1.5rem;"></i><p style="margin-top:0.5rem;">Loading schedule...</p></div>';

                // Fire both requests in parallel
                const qs = '?id=' + assistantId + (doctorId !== null ? '&doctorId=' + doctorId : '');

                fetch(baseStatsUrl + qs)
                    .then(r => { if (!r.ok) throw new Error(r.status); return r.json(); })
                    .then(data => {
                        setTxt('stat-today-appointments', data.todayAppointmentsCount);
                        setTxt('stat-total-patients', data.totalPatients);
                        setTxt('hero-appointment-count', data.todayAppointmentsCount);

                        const badge = document.getElementById('alert-badge');
                        if (badge) {
                            if (data.pendingAlertsCount > 0) {
                                badge.textContent = data.pendingAlertsCount;
                                badge.style.display = '';
                            } else {
                                badge.style.display = 'none';
                            }
                        }

                        let totalAppts = 0;
                        if (data.doctorCounts) {
                            data.doctorCounts.forEach(dc => {
                                totalAppts += dc.todayAppointments;
                                setTxt('doctor-tab-count-' + dc.doctorId, dc.todayAppointments);
                                setTxt('doctor-today-' + dc.doctorId, dc.todayAppointments);
                                setTxt('doctor-patients-' + dc.doctorId, dc.totalPatients);
                            });
                        }
                        setTxt('all-doctors-tab-count', totalAppts);
                    }).catch(err => {
                        console.error('Failed to load stats:', err);
                        ['stat-today-appointments', 'stat-total-patients', 'hero-appointment-count'].forEach(id => setTxt(id, '!'));
                    });

                fetch(baseScheduleUrl + qs)
                    .then(r => { if (!r.ok) throw new Error(r.status); return r.text(); })
                    .then(html => {
                        document.getElementById('schedule-container').innerHTML = html;
                    }).catch(err => {
                        console.error('Failed to load schedule:', err);
                        document.getElementById('schedule-container').innerHTML =
                            '<div class="privacy-notice" style="border-left-color:var(--danger)"><i class="fas fa-exclamation-circle" style="color:var(--danger)"></i><p>Failed to load schedule. Please refresh the page.</p></div>';
                    });
            }

            // --- Update filter tab visual states ---
            function updateTabStyles(activeDoctorId) {
                document.querySelectorAll('.doctor-filter-tab').forEach(tab => {
                    const tabId = tab.dataset.doctorId;
                    const isAllTab = tabId === '' || tabId === undefined;
                    const isActive = isAllTab ? (activeDoctorId === null) : (parseInt(tabId) === activeDoctorId);

                    tab.classList.toggle('active', isActive);
                    const activeColor = isAllTab ? '#7c3aed' : '#1976d2';
                    tab.style.background = isActive ? activeColor : '#f3f4f6';
                    tab.style.color = isActive ? '#fff' : '#374151';

                    const countSpan = tab.querySelector('span[id]');
                    if (countSpan) {
                        countSpan.style.background = isActive ? 'rgba(255,255,255,0.2)' : '#e5e7eb';
                    }
                });
            }

            // --- Click handlers: filter tabs (event delegation) ---
            const tabContainer = document.querySelector('.doctor-filter-tabs');
            if (tabContainer) {
                tabContainer.addEventListener('click', e => {
                    const tab = e.target.closest('.doctor-filter-tab');
                    if (!tab) return;
                    e.preventDefault();
                    const tabId = tab.dataset.doctorId;
                    const newDoctorId = (tabId === '' || tabId === undefined) ? null : parseInt(tabId);
                    if (newDoctorId === currentDoctorId) return;
                    loadDashboardData(newDoctorId);
                });

                // Hover effects (event delegation — auto-skips active tabs)
                tabContainer.addEventListener('mouseenter', e => {
                    const tab = e.target.closest('.doctor-filter-tab:not(.active)');
                    if (tab) tab.style.background = '#e5e7eb';
                }, true);
                tabContainer.addEventListener('mouseleave', e => {
                    const tab = e.target.closest('.doctor-filter-tab:not(.active)');
                    if (tab) tab.style.background = '#f3f4f6';
                }, true);
            }

            // --- Click handlers: doctor cards ---
            document.querySelectorAll('.team-card[data-doctor-id]').forEach(card => {
                card.addEventListener('click', () => {
                    const docId = parseInt(card.dataset.doctorId);
                    if (docId !== currentDoctorId) loadDashboardData(docId);
                });
            });

            // --- Browser back/forward support ---
            window.addEventListener('popstate', e => {
                if (e.state && e.state.assistantId) {
                    loadDashboardData(e.state.doctorId, false);
                }
            });

            // --- Replace initial history entry (so popstate works from the start) ---
            history.replaceState({ assistantId: assistantId, doctorId: currentDoctorId }, '', location.href);

            // --- Initial load ---
            loadDashboardData(currentDoctorId, false);
        })();
    </script>
}
