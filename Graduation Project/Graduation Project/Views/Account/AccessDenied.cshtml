@{
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    ViewData["Title"] = "Access Denied";
    ViewData["ActivePage"] = "";

    string requiredRole = ViewBag.RequiredRole as string ?? null;
    string attemptedUrl = ViewBag.AttemptedUrl as string ?? null;
    string userRole = ViewBag.UserRole as string ?? null;
}

<div class="ua-page">
    <div class="ua-ring ua-ring-1"></div>
    <div class="ua-ring ua-ring-2"></div>
    <div class="ua-ring ua-ring-3"></div>

    <div class="ua-card">
        <div class="ua-icon-wrap">
            <div class="ua-icon-outer">
                <div class="ua-icon-inner">
                    <i class="fas fa-shield-alt"></i>
                </div>
            </div>
            <div class="ua-error-code">403</div>
        </div>

        <h1 class="ua-title">Access Denied</h1>
        <p class="ua-desc">
            You don't have permission to view this page.
            This area is restricted to authorised roles only.
        </p>

        @if (requiredRole != null || userRole != null || attemptedUrl != null)
        {
            <div class="ua-context">
                @if (userRole != null)
                {
                    <div class="ua-context-row">
                        <span class="ua-context-label">
                            <i class="fas fa-user-circle"></i> Your role
                        </span>
                        <span class="ua-chip ua-chip-current">@userRole</span>
                    </div>
                }
                @if (requiredRole != null)
                {
                    <div class="ua-context-row">
                        <span class="ua-context-label">
                            <i class="fas fa-key"></i> Required role
                        </span>
                        <span class="ua-chip ua-chip-required">@requiredRole</span>
                    </div>
                }
                @if (attemptedUrl != null)
                {
                    <div class="ua-context-row">
                        <span class="ua-context-label">
                            <i class="fas fa-link"></i> Attempted page
                        </span>
                        <code class="ua-code">@attemptedUrl</code>
                    </div>
                }
            </div>
        }

        <div class="ua-divider">
            <span>What would you like to do?</span>
        </div>

        <div class="ua-actions">
            <a href="javascript:history.back()" class="ua-btn ua-btn-ghost">
                <i class="fas fa-arrow-left"></i>
                Go back
            </a>
            <a href="@Url.Action("Index", "Home")" class="ua-btn ua-btn-primary">
                <i class="fas fa-home"></i>
                Dashboard
            </a>
        </div>

        <div class="ua-hint">
            <i class="fas fa-info-circle"></i>
            <span>
                Wrong account?
                <a href="@Url.Action("Login", "Account")" class="ua-link">Sign in with a different account</a>
                or <a href="@Url.Action("LogoutGet", "Account")" class="ua-link">log out</a>.
            </span>
        </div>
    </div>

    <div class="ua-roles-guide">
        <p class="ua-roles-title">MamaCare access levels</p>
        <div class="ua-roles-grid">
            <div class="ua-role-card @(userRole == "Patient" ? "ua-role-current" : "")">
                <div class="ua-role-icon ua-role-icon-patient">
                    <i class="fas fa-baby"></i>
                </div>
                <div class="ua-role-name">Patient</div>
                <ul class="ua-role-perms">
                    <li><i class="fas fa-check"></i> Dashboard &amp; profile</li>
                    <li><i class="fas fa-check"></i> Upload &amp; view tests</li>
                    <li><i class="fas fa-check"></i> Appointments</li>
                    <li><i class="fas fa-check"></i> Product safety</li>
                    <li><i class="fas fa-check"></i> Community &amp; chatbot</li>
                    <li><i class="fas fa-times"></i> Doctor panel</li>
                    <li><i class="fas fa-times"></i> Admin controls</li>
                </ul>
            </div>

            <div class="ua-role-card @(userRole == "Doctor" ? "ua-role-current" : "")">
                <div class="ua-role-icon ua-role-icon-doctor">
                    <i class="fas fa-user-md"></i>
                </div>
                <div class="ua-role-name">Doctor</div>
                <ul class="ua-role-perms">
                    <li><i class="fas fa-check"></i> Patient management</li>
                    <li><i class="fas fa-check"></i> Review test results</li>
                    <li><i class="fas fa-check"></i> Write prescriptions</li>
                    <li><i class="fas fa-check"></i> Appointment calendar</li>
                    <li><i class="fas fa-check"></i> Alerts &amp; notifications</li>
                    <li><i class="fas fa-times"></i> Admin controls</li>
                    <li><i class="fas fa-times"></i> System configuration</li>
                </ul>
            </div>

            <div class="ua-role-card @(userRole == "Assistant" ? "ua-role-current" : "")">
                <div class="ua-role-icon ua-role-icon-assistant">
                    <i class="fas fa-user-nurse"></i>
                </div>
                <div class="ua-role-name">Assistant</div>
                <ul class="ua-role-perms">
                    <li><i class="fas fa-check"></i> View patient list</li>
                    <li><i class="fas fa-check"></i> Manage appointments</li>
                    <li><i class="fas fa-check"></i> Send notifications</li>
                    <li><i class="fas fa-times"></i> Edit medical records</li>
                    <li><i class="fas fa-times"></i> Write prescriptions</li>
                    <li><i class="fas fa-times"></i> Admin controls</li>
                    <li><i class="fas fa-times"></i> System configuration</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Styles {
<style>
.ua-page { min-height: calc(100vh - 80px); display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2.5rem 1.25rem 3rem; position: relative; overflow: hidden; }
.ua-ring { position: absolute; border-radius: 50%; pointer-events: none; z-index: 0; }
.ua-ring-1 { width: 500px; height: 500px; top: -180px; right: -140px; background: radial-gradient(circle, rgba(27,174,190,.08) 0%, transparent 65%); animation: uaRingPulse 6s ease-in-out infinite; }
.ua-ring-2 { width: 380px; height: 380px; bottom: -100px; left: -100px; background: radial-gradient(circle, rgba(239,68,68,.06) 0%, transparent 65%); animation: uaRingPulse 8s ease-in-out infinite reverse; }
.ua-ring-3 { width: 260px; height: 260px; top: 40%; left: 40%; background: radial-gradient(circle, rgba(27,174,190,.05) 0%, transparent 65%); animation: uaRingPulse 10s ease-in-out infinite; }
.ua-card { background: #fff; border-radius: 20px; border: 1px solid #e2e8f0; box-shadow: 0 8px 40px rgba(0,0,0,.09); padding: 3rem 2.8rem 2.4rem; max-width: 700px; width: 100%; text-align: center; position: relative; z-index: 1; animation: uaCardIn .5s cubic-bezier(.22,.68,0,1.2) both; }
.ua-icon-wrap { display: flex; flex-direction: column; align-items: center; margin-bottom: 1.5rem; position: relative; }
.ua-icon-outer { width: 100px; height: 100px; border-radius: 50%; background: linear-gradient(135deg, rgba(239,68,68,.1), rgba(239,68,68,.05)); border: 2px solid rgba(239,68,68,.15); display: flex; align-items: center; justify-content: center; animation: uaShieldPulse 3s ease-in-out infinite; margin-bottom: .6rem; }
.ua-icon-inner { width: 72px; height: 72px; border-radius: 50%; background: linear-gradient(135deg, #fef2f2, #fff5f5); border: 1.5px solid rgba(239,68,68,.2); display: flex; align-items: center; justify-content: center; font-size: 1.9rem; color: #ef4444; }
.ua-error-code { font-size: .72rem; font-weight: 800; letter-spacing: .18em; color: #ef4444; text-transform: uppercase; background: #fef2f2; border: 1px solid #fecaca; padding: .22rem .75rem; border-radius: 20px; }
.ua-title { font-size: 1.65rem; font-weight: 700; color: #1e293b; margin-bottom: .55rem; letter-spacing: -.3px; }
.ua-desc { font-size: .9rem; color: #64748b; line-height: 1.65; max-width: 360px; margin: 0 auto 1.5rem; }
.ua-context { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: .9rem 1.1rem; margin-bottom: 1.5rem; text-align: left; display: flex; flex-direction: column; gap: .6rem; }
.ua-context-row { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: .5rem; }
.ua-context-label { font-size: .78rem; font-weight: 600; color: #64748b; display: flex; align-items: center; gap: .4rem; }
.ua-context-label i { color: #1BAEBE; font-size: .73rem; }
.ua-chip { font-size: .73rem; font-weight: 700; padding: .22rem .75rem; border-radius: 20px; white-space: nowrap; }
.ua-chip-current { background: rgba(27,174,190,.1); color: #138fa0; border: 1px solid rgba(27,174,190,.25); }
.ua-chip-required { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
.ua-code { font-family: 'Courier New', monospace; font-size: .75rem; background: #f1f5f9; color: #475569; padding: .2rem .6rem; border-radius: 5px; border: 1px solid #e2e8f0; word-break: break-all; }
.ua-divider { display: flex; align-items: center; gap: .75rem; margin: 0 0 1.25rem; }
.ua-divider::before, .ua-divider::after { content: ''; flex: 1; height: 1px; background: #e2e8f0; }
.ua-divider span { font-size: .75rem; color: #94a3b8; white-space: nowrap; }
.ua-actions { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; margin-bottom: 1.25rem; }
.ua-btn { display: inline-flex; align-items: center; justify-content: center; gap: .5rem; padding: .65rem 1.25rem; border-radius: 10px; font-size: .88rem; font-weight: 600; cursor: pointer; text-decoration: none; transition: all .2s; border: none; font-family: inherit; }
.ua-btn:hover { transform: translateY(-2px); }
.ua-btn-primary { background: linear-gradient(135deg, #1BAEBE, #138fa0); color: #fff; box-shadow: 0 4px 14px rgba(27,174,190,.3); }
.ua-btn-primary:hover { box-shadow: 0 6px 20px rgba(27,174,190,.45); color: #fff; text-decoration: none; }
.ua-btn-ghost { background: #f8fafc; color: #475569; border: 1.5px solid #e2e8f0; }
.ua-btn-ghost:hover { background: #f1f5f9; border-color: #cbd5e1; color: #1e293b; text-decoration: none; }
.ua-hint { display: flex; align-items: flex-start; gap: .45rem; font-size: .78rem; color: #94a3b8; line-height: 1.55; }
.ua-hint i { color: #1BAEBE; flex-shrink: 0; margin-top: .15rem; font-size: .75rem; }
.ua-link { color: #1BAEBE; font-weight: 600; text-decoration: none; }
.ua-link:hover { text-decoration: underline; }
.ua-roles-guide { margin-top: 2rem; max-width: 820px; width: 100%; z-index: 1; }
.ua-roles-title { font-size: .78rem; font-weight: 700; color: #94a3b8; text-align: center; text-transform: uppercase; letter-spacing: .1em; margin-bottom: .9rem; }
.ua-roles-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: .85rem; }
@@media (max-width: 700px) { .ua-roles-grid { grid-template-columns: 1fr; } }
@@media (max-width: 960px) and (min-width: 701px) { .ua-roles-grid { grid-template-columns: 1fr 1fr; } }
.ua-role-card { background: #fff; border: 1.5px solid #e2e8f0; border-radius: 14px; padding: 1.1rem 1rem; transition: box-shadow .2s, transform .2s, border-color .2s; animation: uaCardIn .5s cubic-bezier(.22,.68,0,1.2) both; }
.ua-role-card:nth-child(1) { animation-delay: .07s; }
.ua-role-card:nth-child(2) { animation-delay: .14s; }
.ua-role-card:nth-child(3) { animation-delay: .21s; }
.ua-role-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,.09); transform: translateY(-3px); }
.ua-role-card.ua-role-current { border-color: rgba(27,174,190,.4); box-shadow: 0 0 0 3px rgba(27,174,190,.08); background: linear-gradient(160deg, #f0fdfe, #fff); }
.ua-role-card.ua-role-current::before { content: 'Your role'; display: block; font-size: .65rem; font-weight: 800; text-transform: uppercase; letter-spacing: .1em; color: #1BAEBE; background: rgba(27,174,190,.1); border: 1px solid rgba(27,174,190,.2); padding: .18rem .6rem; border-radius: 20px; margin-bottom: .6rem; width: fit-content; }
.ua-role-icon { width: 40px; height: 40px; border-radius: 11px; display: flex; align-items: center; justify-content: center; font-size: 1rem; margin-bottom: .55rem; }
.ua-role-icon-patient { background: rgba(27,174,190,.12); color: #1BAEBE; }
.ua-role-icon-doctor { background: rgba(99,102,241,.12); color: #6366f1; }
.ua-role-icon-assistant { background: rgba(139,92,246,.12); color: #8b5cf6; }
.ua-role-name { font-size: .9rem; font-weight: 700; color: #1e293b; margin-bottom: .55rem; }
.ua-role-perms { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: .32rem; }
.ua-role-perms li { display: flex; align-items: center; gap: .42rem; font-size: .77rem; color: #475569; line-height: 1.4; }
.ua-role-perms li i.fa-check { color: #22c55e; font-size: .68rem; flex-shrink: 0; }
.ua-role-perms li i.fa-times { color: #e2e8f0; font-size: .68rem; flex-shrink: 0; }
@@keyframes uaCardIn { from { opacity: 0; transform: translateY(18px) scale(.97); } to { opacity: 1; transform: translateY(0) scale(1); } }
@@keyframes uaRingPulse { 0%,100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.06); opacity: .6; } }
@@keyframes uaShieldPulse { 0%,100% { box-shadow: 0 0 0 0px rgba(239,68,68,.15); } 50% { box-shadow: 0 0 0 12px rgba(239,68,68,.0); } }
</style>
}