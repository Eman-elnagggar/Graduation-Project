@{
    Layout = null;
    ViewData["Title"] = "Register as Assistant — NABD - نبض";
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"]</title>
  <link rel="icon" type="image/png" href="~/images/logo.png" asp-append-version="true" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body>

<div class="auth-shell">
  <aside class="auth-panel">
    <div class="panel-brand">
      <div class="panel-brand-icon"><img src="~/images/logo.png" alt="NABD Logo" asp-append-version="true" /></div>
      <div>
        <div class="panel-brand-name">NABD - نبض</div>
        <div class="panel-brand-badge">Assistant Portal</div>
      </div>
    </div>

    <div class="panel-content">
      <h2 class="panel-headline">Support the<br><span>care team</span></h2>
      <p class="panel-desc">As a NABD - نبض assistant, you'll help coordinate patient care, manage appointments, and keep everything running smoothly.</p>
    </div>

    <div class="panel-features">
      <div class="panel-feature">
        <div class="panel-feature-ico"><i class="fas fa-calendar-alt"></i></div>
        <div class="panel-feature-text">Appointment coordination &amp; scheduling</div>
      </div>
      <div class="panel-feature">
        <div class="panel-feature-ico"><i class="fas fa-bell"></i></div>
        <div class="panel-feature-text">Patient notification management</div>
      </div>
      <div class="panel-feature">
        <div class="panel-feature-ico"><i class="fas fa-tasks"></i></div>
        <div class="panel-feature-text">Administrative task management</div>
      </div>
    </div>
  </aside>

  <main class="auth-form-area">
    <div class="auth-form-wrap">

      <div class="mobile-brand">
        <div class="mobile-brand-icon"><img src="~/images/logo.png" alt="NABD Logo" asp-append-version="true" /></div>
        <div class="mobile-brand-name">NABD - نبض</div>
      </div>

      <div class="auth-card">
        <div class="auth-card-header">
          <div style="display:flex; align-items:center; gap:.65rem;">
            <div style="width:38px;height:38px;border-radius:10px;background:rgba(139,92,246,.1);color:#7c3aed;display:flex;align-items:center;justify-content:center;">
              <i class="fas fa-user-nurse"></i>
            </div>
            <div>
              <div class="auth-card-title">Assistant Registration</div>
              <div class="auth-card-sub">Create your assistant account on NABD - نبض</div>
            </div>
          </div>
        </div>

        <div class="auth-card-body">
          @if (TempData["AuthError"] is string authError)
          {
            <div class="mc-warning-box" style="display:flex; margin-bottom:.9rem;">
              <i class="fas fa-exclamation-circle"></i>
              <p>@authError</p>
            </div>
          }

          @using (Html.BeginForm("RegisterAssistant", "Account", FormMethod.Post,
                  new { id = "assistantForm", novalidate = "novalidate" }))
          {
            @Html.AntiForgeryToken()

            <div class="mc-row">
              <div class="mc-form-group">
                <label class="mc-label" for="FirstName">
                  <i class="fas fa-user"></i> First Name <span class="req">*</span>
                </label>
                <input type="text" id="FirstName" name="FirstName" class="mc-input"
                       placeholder="Nour" required autocomplete="given-name" />
              </div>
              <div class="mc-form-group">
                <label class="mc-label" for="LastName">
                  <i class="fas fa-user"></i> Last Name <span class="req">*</span>
                </label>
                <input type="text" id="LastName" name="LastName" class="mc-input"
                       placeholder="Ibrahim" required autocomplete="family-name" />
              </div>
            </div>

            <div class="mc-form-group">
              <label class="mc-label" for="Email">
                <i class="fas fa-envelope"></i> Email Address <span class="req">*</span>
              </label>
              <div class="mc-input-wrap">
                <input type="email" id="Email" name="Email" class="mc-input has-icon"
                       placeholder="you@example.com" required autocomplete="email" />
                <i class="mc-input-icon fas fa-envelope"></i>
              </div>
            </div>

            <div class="mc-form-group">
              <label class="mc-label" for="PhoneNumber">
                <i class="fas fa-phone"></i> Phone Number <span class="req">*</span>
              </label>
              <div class="mc-input-wrap">
                <input type="tel" id="PhoneNumber" name="PhoneNumber" class="mc-input has-icon"
                       placeholder="+20 xxx xxx xxxx" required autocomplete="tel" />
                <i class="mc-input-icon fas fa-phone"></i>
              </div>
            </div>

            <div class="mc-row">
              <div class="mc-form-group">
                <label class="mc-label" for="Password">
                  <i class="fas fa-lock"></i> Password <span class="req">*</span>
                </label>
                <div class="mc-input-wrap">
                  <input type="password" id="Password" name="Password" class="mc-input has-eye"
                         placeholder="Min. 8 characters" required data-min-length="8"
                         autocomplete="new-password" />
                  <button type="button" class="mc-input-eye"><i class="fas fa-eye"></i></button>
                </div>
                <div class="mc-pwd-strength">
                  <div class="mc-pwd-strength-bar"><div class="mc-pwd-strength-fill" id="pwdBar"></div></div>
                  <div class="mc-pwd-strength-label" id="pwdLabel"></div>
                </div>
              </div>
              <div class="mc-form-group">
                <label class="mc-label" for="ConfirmPassword">
                  <i class="fas fa-lock"></i> Confirm Password <span class="req">*</span>
                </label>
                <div class="mc-input-wrap">
                  <input type="password" id="ConfirmPassword" name="ConfirmPassword" class="mc-input has-eye"
                         placeholder="Repeat password" required data-match="Password"
                         autocomplete="new-password" />
                  <button type="button" class="mc-input-eye"><i class="fas fa-eye"></i></button>
                </div>
              </div>
            </div>

            <div class="mc-form-group">
              <label class="mc-check-group">
                <input type="checkbox" id="AgreeTerms" name="AgreeTerms" class="mc-check"
                       value="true" required />
                <span class="mc-check-label">
                  I agree to the
                  <a href="#" class="mc-link">Terms of Service</a>
                  and
                  <a href="#" class="mc-link">Privacy Policy</a>
                </span>
              </label>
            </div>

            <button type="submit" class="mc-btn mc-btn-primary mt-2">
              <i class="fas fa-paper-plane"></i> Create Account
            </button>
          }
        </div>

        <div class="auth-card-footer">
          Already have an account?
          <a href="@Url.Action("Login", "Account")" class="mc-link">Sign in</a>
          &nbsp;·&nbsp;
          Register as
          <a href="@Url.Action("RegisterPatient", "Account")" class="mc-link">Patient</a> or
          <a href="@Url.Action("RegisterDoctor", "Account")" class="mc-link">Doctor</a>
        </div>
      </div>

    </div>
  </main>
</div>

<script src="~/js/auth.js"></script>
<script>
(function () {
  'use strict';
  initLiveValidation('assistantForm');
  initPasswordStrength('Password', 'pwdBar', 'pwdLabel');

  document.getElementById('assistantForm').addEventListener('submit', function (e) {
    if (!validateForm('assistantForm')) {
      e.preventDefault();
      showToast('Please fix the errors before submitting.', 'error');
      return;
    }
    const terms = document.getElementById('AgreeTerms');
    if (!terms.checked) {
      e.preventDefault();
      setFieldState(terms, 'You must agree to the Terms of Service.');
      showToast('Please agree to the Terms of Service.', 'error');
    }
  });
}());
</script>
</body>
</html>
