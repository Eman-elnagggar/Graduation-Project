## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.wsuo

# Visual Studio folders at any level
.vs/
**/.vs/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache files
*.vsidx
*.vspscc
.builds
*.pidb
*.svclog
*.scc
*.db
*.sqlite
*.backup.json

# Files built by Visual Studio
*.dbmdl
*.jfm
*.pfx
*.publishsettings
